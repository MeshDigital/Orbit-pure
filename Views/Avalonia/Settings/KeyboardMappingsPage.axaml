<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SLSKDONET.ViewModels.Settings"
             x:Class="SLSKDONET.Views.Avalonia.Settings.KeyboardMappingsPage"
             x:DataType="vm:KeyboardMappingsViewModel"
             Background="Transparent">

  <UserControl.Styles>
    <Style Selector="Button.settingsAction">
      <Setter Property="Background" Value="#1A3399FF"/>
      <Setter Property="Foreground" Value="#88BBFF"/>
      <Setter Property="BorderBrush" Value="#33AADDFF"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="4"/>
      <Setter Property="Padding" Value="10,4"/>
      <Setter Property="FontSize" Value="12"/>
    </Style>
    <Style Selector="Button.settingsDanger">
      <Setter Property="Background" Value="#1AFF4444"/>
      <Setter Property="Foreground" Value="#FFAA88"/>
      <Setter Property="BorderBrush" Value="#33FF6666"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="4"/>
      <Setter Property="Padding" Value="10,4"/>
      <Setter Property="FontSize" Value="12"/>
    </Style>
    <!-- Binding chip: default -->
    <Style Selector="Border.binding-chip">
      <Setter Property="Background" Value="#1AFFFFFF"/>
    </Style>
    <!-- Binding chip: conflict -->
    <Style Selector="Border.binding-chip.conflict">
      <Setter Property="Background" Value="#33FF4444"/>
    </Style>
    <!-- Binding chip text: default -->
    <Style Selector="Border.binding-chip TextBlock">
      <Setter Property="Foreground" Value="#AAFFFFFF"/>
      <Setter Property="FontFamily" Value="Consolas,Courier New,monospace"/>
    </Style>
    <!-- Binding chip text: conflict -->
    <Style Selector="Border.binding-chip.conflict TextBlock">
      <Setter Property="Foreground" Value="#FF8888"/>
      <Setter Property="FontFamily" Value="Consolas,Courier New,monospace"/>
    </Style>
  </UserControl.Styles>

  <Panel>

    <!-- ── Main content ─────────────────────────────────────────────────────── -->
    <ScrollViewer IsVisible="{Binding !IsCapturingKey}">
      <StackPanel Spacing="14" Margin="0,0,0,16">

        <!-- Header / profile name -->
        <StackPanel Spacing="4">
          <TextBlock Text="Keyboard Mappings"
                     FontSize="16" FontWeight="SemiBold" Foreground="#CCFFFFFF"/>
          <TextBlock Text="{Binding ActiveProfileName, StringFormat='Active profile: {0}'}"
                     FontSize="12" Foreground="#888"/>
        </StackPanel>

        <!-- Preset buttons -->
        <WrapPanel>
          <TextBlock Text="Preset:" VerticalAlignment="Center"
                     FontSize="12" Foreground="#888" Margin="0,0,8,0"/>
          <Button Content="Orbit Default"
                  Command="{Binding LoadPresetOrbitCommand}"
                  Classes="settingsAction" Margin="0,0,6,0"/>
          <Button Content="Rekordbox"
                  Command="{Binding LoadPresetRekordboxCommand}"
                  Classes="settingsAction" Margin="0,0,6,0"/>
          <Button Content="DJ.Studio"
                  Command="{Binding LoadPresetDjStudioCommand}"
                  Classes="settingsAction" Margin="0,0,6,0"/>
          <Button Content="Rekordbox 4-Deck"
                  Command="{Binding LoadPresetRekordbox4DeckCommand}"
                  AutomationProperties.Name="Load Rekordbox 4-channel performance keyboard preset"
                  Classes="settingsAction" Margin="0,0,6,0"/>
        </WrapPanel>

        <!-- Import / Export -->
        <WrapPanel>
          <Button Content="Import profile…"
                  Command="{Binding ImportProfileCommand}"
                  AutomationProperties.Name="Import keyboard profile from file"
                  Classes="settingsAction" Margin="0,0,6,0"/>
          <Button Content="Export profile…"
                  Command="{Binding ExportProfileCommand}"
                  AutomationProperties.Name="Export keyboard profile to file"
                  Classes="settingsAction" Margin="0,0,6,0"/>
          <Button Content="Reset to default"
                  Command="{Binding ResetToDefaultCommand}"
                  AutomationProperties.Name="Reset keyboard mappings to Orbit Default"
                  Classes="settingsDanger"/>
        </WrapPanel>

        <!-- Import error message -->
        <Border IsVisible="{Binding ImportError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                Background="#22FF4444" CornerRadius="4" Padding="10,6">
          <TextBlock Text="{Binding ImportError}"
                     Foreground="#FF8888" FontSize="12"
                     TextWrapping="Wrap"/>
        </Border>

        <!-- "Your most used actions" — populated when keyboard telemetry is enabled -->
        <StackPanel IsVisible="{Binding TopActions.Count}" Spacing="4">
          <TextBlock Text="Your most used actions"
                     FontSize="11" FontWeight="SemiBold"
                     Foreground="#888"/>
          <ItemsControl ItemsSource="{Binding TopActions}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <WrapPanel/>
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:KeyboardStatRow">
                <Border Background="#1A3366CC" CornerRadius="4"
                        Padding="8,3" Margin="0,2,6,2">
                  <TextBlock Text="{Binding Label}"
                             FontSize="11"
                             FontFamily="Consolas,Courier New,monospace"
                             Foreground="#88BBFF"/>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>

        <!-- Conflict warnings (only shown when there are conflicts) -->
        <ItemsControl ItemsSource="{Binding Conflicts}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border Background="#22FF4444" CornerRadius="4"
                      Padding="8,4" Margin="0,2">
                <TextBlock Text="{Binding}" Foreground="#FF8888" FontSize="11"/>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Column headers -->
        <Grid ColumnDefinitions="110,*,160,52" Margin="2,4,2,0">
          <TextBlock Grid.Column="0" Text="Category"
                     FontSize="10" Foreground="#555" FontWeight="SemiBold"/>
          <TextBlock Grid.Column="1" Text="Action"
                     FontSize="10" Foreground="#555" FontWeight="SemiBold"/>
          <TextBlock Grid.Column="2" Text="Key Binding"
                     FontSize="10" Foreground="#555" FontWeight="SemiBold"/>
        </Grid>

        <Rectangle Height="1" Fill="#1AFFFFFF"/>

        <!-- Binding rows -->
        <ItemsControl ItemsSource="{Binding Bindings}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:BindingRowViewModel">
              <Grid ColumnDefinitions="110,*,160,52"
                    Margin="2,1">

                <!-- Category badge -->
                <Border Grid.Column="0"
                        CornerRadius="3" Padding="5,2"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center">
                  <Border.Background>
                    <SolidColorBrush Color="#18448866"/>
                  </Border.Background>
                  <TextBlock Text="{Binding CategoryLabel}"
                             FontSize="10" Foreground="#5588AA"/>
                </Border>

                <!-- Action name -->
                <TextBlock Grid.Column="1"
                           Text="{Binding ActionLabel}"
                           FontSize="12" Foreground="#BBFFFFFF"
                           VerticalAlignment="Center"
                           Margin="6,0"/>

                <!-- Key binding pill - class driven styling -->
                <Border Grid.Column="2"
                        Classes="binding-chip"
                        Classes.conflict="{Binding HasConflict}"
                        CornerRadius="4" Padding="8,3"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Margin="4,0">
                  <TextBlock Text="{Binding BindingLabel}" FontSize="11"/>
                </Border>

                <!-- Set button -->
                <Button Grid.Column="3"
                        Content="Set"
                        FontSize="10"
                        Padding="6,2"
                        VerticalAlignment="Center"
                        AutomationProperties.Name="{Binding ActionLabel, StringFormat='Set key binding for {0}'}"
                        Command="{Binding $parent[ItemsControl].((vm:KeyboardMappingsViewModel)DataContext).StartCaptureCommand}"
                        CommandParameter="{Binding}"
                        Classes="settingsAction"/>
              </Grid>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

      </StackPanel>
    </ScrollViewer>

    <!-- ── Key capture overlay ──────────────────────────────────────────────── -->
    <Border IsVisible="{Binding IsCapturingKey}"
            Background="#EE0A0A14"
            CornerRadius="10"
            x:Name="CaptureOverlay"
            Focusable="True">
      <StackPanel VerticalAlignment="Center"
                  HorizontalAlignment="Center"
                  Spacing="16">
        <TextBlock Text="{Binding CaptureHint}"
                   FontSize="18" FontWeight="SemiBold"
                   Foreground="#FFFFFF"
                   TextAlignment="Center"/>
        <!-- Live key combo preview: updates as modifier keys are held -->
        <Border MinWidth="200" Padding="16,10"
                Background="#22FFFFFF" CornerRadius="8"
                HorizontalAlignment="Center">
          <TextBlock Text="{Binding LiveKeyCombo}"
                     FontSize="28" FontWeight="Bold"
                     FontFamily="Consolas,Courier New,monospace"
                     Foreground="#FFFFFFFF"
                     TextAlignment="Center"
                     MinHeight="40"/>
        </Border>
        <TextBlock Text="Delete/Backspace = clear binding   ·   Esc = cancel"
                   FontSize="12" Foreground="#777"
                   TextAlignment="Center"/>
        <Button Content="Cancel"
                Command="{Binding CancelCaptureCommand}"
                AutomationProperties.Name="Cancel key binding capture"
                HorizontalAlignment="Center"
                Classes="settingsAction"/>
      </StackPanel>
    </Border>

  </Panel>

</UserControl>
