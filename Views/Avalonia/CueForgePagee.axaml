<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:SLSKDONET.ViewModels"
             xmlns:ctrl="clr-namespace:SLSKDONET.Views.Avalonia.Controls"
             mc:Ignorable="d" d:DesignWidth="1400" d:DesignHeight="900"
             x:Class="SLSKDONET.Views.Avalonia.CueForgePagee"
             x:DataType="vm:CueForgeViewModel"
             Background="#0A0E27"
             Focusable="True">

    <UserControl.Styles>
        <Style Selector="Button.cmd-primary">
            <Setter Property="Background" Value="#1B5E20"/>
            <Setter Property="Foreground" Value="#E8F5E9"/>
            <Setter Property="BorderBrush" Value="#2E7D32"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style Selector="Button.cmd-primary:pointerover">
            <Setter Property="Background" Value="#2E7D32"/>
        </Style>
        <Style Selector="Button.cmd-primary:disabled">
            <Setter Property="Background" Value="#1A2A1A"/>
            <Setter Property="Foreground" Value="#446644"/>
        </Style>
        <Style Selector="Button.cmd-secondary">
            <Setter Property="Background" Value="#252530"/>
            <Setter Property="Foreground" Value="#B0BEC5"/>
            <Setter Property="BorderBrush" Value="#404055"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style Selector="Button.cmd-secondary:pointerover">
            <Setter Property="Background" Value="#333345"/>
        </Style>
        <Style Selector="Button.cmd-danger">
            <Setter Property="Background" Value="#3E1A1A"/>
            <Setter Property="Foreground" Value="#FF6B6B"/>
            <Setter Property="BorderBrush" Value="#6E2A2A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style Selector="ToggleButton.cmd-toggle">
            <Setter Property="Background" Value="#252530"/>
            <Setter Property="Foreground" Value="#888899"/>
            <Setter Property="BorderBrush" Value="#404055"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="7,3"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="FontSize" Value="10"/>
        </Style>
        <Style Selector="ToggleButton.cmd-toggle:checked">
            <Setter Property="Background" Value="#1A3A6A"/>
            <Setter Property="Foreground" Value="#7DB8FF"/>
            <Setter Property="BorderBrush" Value="#2255AA"/>
        </Style>
        <Style Selector="TextBlock.commit-feedback">
            <Setter Property="Foreground" Value="#44AA66"/>
        </Style>
        <Style Selector="TextBlock.commit-feedback.commit-error">
            <Setter Property="Foreground" Value="#FF6B6B"/>
        </Style>
        <!-- Hot cue pad styles -->
        <Style Selector="Button.hotcue-pad">
            <Setter Property="Width" Value="52"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,Auto,200,Auto,*,Auto,Auto">

        <!-- Row 0: Track Title Bar -->
        <Border Grid.Row="0" Background="#111118" BorderBrush="#1E1E2E" BorderThickness="0,0,0,1" Padding="16,6">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <TextBlock Grid.Column="0" Text="🎯 CUE FORGE" Foreground="#444466" FontSize="10"
                           FontWeight="Bold" LetterSpacing="2" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="{Binding TrackTitle}" Foreground="#C0C0D8"
                           FontSize="12" FontWeight="SemiBold" Margin="16,0"
                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Bpm, StringFormat='{}{0} BPM'}" Foreground="#5577AA" FontSize="11"/>
                    <TextBlock Text="{Binding TrackDuration, StringFormat='{}{0:F0}s'}" Foreground="#445566" FontSize="11"/>
                    <Border Background="#1A1A30" BorderBrush="#33335A" BorderThickness="1" CornerRadius="3"
                            Padding="7,3" IsVisible="{Binding TrackEnergyScore, Converter={x:Static ObjectConverters.IsNotNull}}"
                            ToolTip.Tip="MIK-compatible energy score (1–10)">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="E" Foreground="#555577" FontSize="9" FontWeight="Bold"
                                       LetterSpacing="1" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding TrackEnergyScore}" Foreground="#FFD700"
                                       FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Row 1: Command Bar -->
        <Border Grid.Row="1" Background="#16161E" BorderBrush="#1E1E2E" BorderThickness="0,0,0,1" Padding="12,7">
            <Grid ColumnDefinitions="Auto,8,Auto,12,Auto,12,Auto,*,Auto,8,Auto">

                <!-- Transport: cue navigation + embedded play/pause + live time display -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <Button Classes="cmd-secondary" Padding="8,4" Content="⏮" FontSize="11"
                            ToolTip.Tip="Previous cue (← arrow)" Command="{Binding PreviousCueCommand}"/>
                    <Button Classes="cmd-secondary" Command="{Binding PlaybackToggleCommand}" Padding="10,4"
                            ToolTip.Tip="Play / Pause (Space)">
                        <Panel>
                            <TextBlock Text="▶" FontSize="12" IsVisible="{Binding !Player.IsPlaying}"/>
                            <TextBlock Text="⏸" FontSize="12" IsVisible="{Binding Player.IsPlaying}"/>
                        </Panel>
                    </Button>
                    <Button Classes="cmd-secondary" Padding="8,4" Content="⏭" FontSize="11"
                            ToolTip.Tip="Next cue (→ arrow)" Command="{Binding NextCueCommand}"/>
                    <TextBlock Text="{Binding Player.CurrentTimeStr}" Foreground="#5577AA" FontSize="10"
                               VerticalAlignment="Center" Margin="6,0,0,0"/>
                    <TextBlock Text="/" Foreground="#333355" FontSize="10" VerticalAlignment="Center" Margin="2,0"/>
                    <TextBlock Text="{Binding TrackDurationDisplay}" Foreground="#335566" FontSize="10"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Auto-Generate -->
                <Button Grid.Column="2" Classes="cmd-primary"
                        Command="{Binding AutoGenerateCuesCommand}"
                        IsEnabled="{Binding !IsGenerating}"
                        Content="⚡ Auto-Generate"
                        ToolTip.Tip="Re-run the full analysis engine to generate 8 structural DJ cues"/>

                <!-- Snap & Quantize -->
                <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <ToggleButton Classes="cmd-toggle" IsChecked="{Binding SnapToGrid}" Content="⊞ Snap"/>
                    <ComboBox SelectedItem="{Binding QuantizeBeats}"
                              Background="#252530" Foreground="#9090AA" BorderBrush="#404055"
                              FontSize="10" Width="120" Padding="6,3">
                        <!--
                            Items must be plain strings, not ComboBoxItem wrappers: SelectedItem binds
                            to CueForgeViewModel.QuantizeBeats (a string), and Avalonia's ComboBox never
                            matches a bound string against a ComboBoxItem wrapper, so the box rendered
                            with no visible selection even though a valid value was bound underneath.
                        -->
                        <x:String>Off</x:String>
                        <x:String>1 beat</x:String>
                        <x:String>2 beats</x:String>
                        <x:String>4 beats</x:String>
                        <x:String>8 beats</x:String>
                        <x:String>16 beats</x:String>
                        <x:String>32 beats</x:String>
                        <x:String>64 beats (16 bars)</x:String>
                        <x:String>128 beats (32 bars)</x:String>
                    </ComboBox>
                </StackPanel>

                <!-- Undo / Redo -->
                <StackPanel Grid.Column="6" Orientation="Horizontal" Spacing="3" VerticalAlignment="Center">
                    <Button Classes="cmd-secondary" Command="{Binding UndoCommand}" IsEnabled="{Binding CanUndo}"
                            Content="↶" FontSize="13" Padding="7,3" ToolTip.Tip="Undo"/>
                    <Button Classes="cmd-secondary" Command="{Binding RedoCommand}" IsEnabled="{Binding CanRedo}"
                            Content="↷" FontSize="13" Padding="7,3" ToolTip.Tip="Redo"/>
                </StackPanel>

                <!-- Spacer -->
                <Rectangle Grid.Column="7" Fill="Transparent"/>

                <!-- Key + Vocal Indicator -->
                <StackPanel Grid.Column="8" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <Border Background="#1A1A30" BorderBrush="#33336A" BorderThickness="1" CornerRadius="3" Padding="8,4">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="KEY" Foreground="#555577" FontSize="9" FontWeight="Bold"
                                       LetterSpacing="1" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding CurrentCamelotKey}" Foreground="#FFD700"
                                       FontSize="14" FontWeight="Bold" VerticalAlignment="Center"
                                       ToolTip.Tip="{Binding CompatibleCamelotKeys, StringFormat='Mix with: {0}'}"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#2A1010" BorderBrush="#6A2222" BorderThickness="1" CornerRadius="3"
                            Padding="8,4" IsVisible="{Binding IsInVocalRegion}"
                            ToolTip.Tip="Vocal region — avoid placing drop cues here">
                        <TextBlock Text="🎤 VOCAL" Foreground="#FF7070" FontSize="9" FontWeight="Bold" LetterSpacing="1"/>
                    </Border>
                </StackPanel>

                <!-- Commit / Discard -->
                <StackPanel Grid.Column="10" Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                    <Button Classes="cmd-primary" Command="{Binding CommitChangesCommand}"
                            IsVisible="{Binding HasUncommittedChanges}" Content="✓ Commit"/>
                    <Button Classes="cmd-danger" Command="{Binding DiscardChangesCommand}"
                            IsVisible="{Binding HasUncommittedChanges}" Content="✕ Discard"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Row 2: Full-width waveform strip (fixed 200px height) -->
        <Border Grid.Row="2" Background="#0A0E27" BorderBrush="#1E1E2E" BorderThickness="0,0,0,1">
            <ctrl:CueForgeWaveformControl
                Cues="{Binding WorkingCues}"
                PhraseSegments="{Binding PhraseSegments}"
                CurrentPlayPosition="{Binding CurrentPlayPosition}"
                Bpm="{Binding Bpm}"
                TrackDuration="{Binding TrackDuration}"
                SnapToGrid="{Binding SnapToGrid}"
                QuantizeBeatString="{Binding QuantizeBeats}"
                WaveformLow="{Binding WaveformLow}"
                WaveformMid="{Binding WaveformMid}"
                WaveformHigh="{Binding WaveformHigh}"
                EnergyCurve="{Binding EnergyCurveData}"
                VocalDensityCurve="{Binding VocalDensityCurveData}"
                OnsetDensityCurve="{Binding OnsetDensityCurveData}"
                ZoomLevel="{Binding WaveformZoom, Mode=TwoWay}"
                ScrollOffset="{Binding WaveformScroll, Mode=TwoWay}"
                SeekCommand="{Binding SeekPlayheadCommand}"/>
        </Border>

        <!-- Row 3: Waveform navigation bar (zoom + scroll) -->
        <Border Grid.Row="3" Background="#0F0F18" BorderBrush="#1E1E2E" BorderThickness="0,0,0,1" Padding="10,4">
            <Grid ColumnDefinitions="Auto,4,Auto,4,Auto,10,*,10,Auto,4,Auto">
                <Button Grid.Column="0" Classes="cmd-secondary" Command="{Binding ZoomOutCommand}"
                        Content="−" Padding="9,3" FontSize="13" ToolTip.Tip="Zoom out (Ctrl+scroll)"/>
                <TextBlock Grid.Column="2"
                           Text="{Binding ZoomDisplay}"
                           Foreground="#555577" FontSize="10" Width="34"
                           TextAlignment="Center" VerticalAlignment="Center"/>
                <Button Grid.Column="4" Classes="cmd-secondary" Command="{Binding ZoomInCommand}"
                        Content="+" Padding="9,3" FontSize="13" ToolTip.Tip="Zoom in (Ctrl+scroll)"/>
                <Slider Grid.Column="6"
                        Value="{Binding WaveformScroll}"
                        Minimum="0" Maximum="{Binding WaveformScrollMaximum}"
                        SmallChange="0.01" LargeChange="0.1"
                        VerticalAlignment="Center"
                        ToolTip.Tip="Scroll position — or scroll with mouse wheel on the waveform"/>
                <Button Grid.Column="8" Classes="cmd-secondary" Command="{Binding ScrollLeftCommand}"
                        Content="◀" Padding="8,3" FontSize="10" ToolTip.Tip="Scroll left"/>
                <Button Grid.Column="10" Classes="cmd-secondary" Command="{Binding ScrollRightCommand}"
                        Content="▶" Padding="8,3" FontSize="10" ToolTip.Tip="Scroll right"/>
            </Grid>
        </Border>

        <!-- Row 4: Browser + Inspector -->
        <Grid Grid.Row="4" ColumnDefinitions="200,*,300">

            <!-- Track Browser -->
            <Border Grid.Column="0" Background="#0E0E16" BorderBrush="#1A1A2A" BorderThickness="0,0,1,0">
                <Grid RowDefinitions="Auto,Auto,*">

                    <!-- Playlist selector -->
                    <Border Grid.Row="0" Background="#111118" BorderBrush="#1E1E2E"
                            BorderThickness="0,0,0,1" Padding="8,6">
                        <StackPanel Spacing="4">
                            <TextBlock Text="PLAYLIST" Foreground="#333355" FontSize="8"
                                       FontWeight="Bold" LetterSpacing="2"/>
                            <ComboBox ItemsSource="{Binding Playlists}"
                                      SelectedItem="{Binding SelectedPlaylist}"
                                      HorizontalAlignment="Stretch"
                                      Background="#0A0A12" Foreground="#B0B0CC"
                                      BorderBrush="#2A2A40" BorderThickness="1"
                                      Padding="6,4" FontSize="11" MaxDropDownHeight="300">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding SourceTitle}"
                                                   TextTrimming="CharacterEllipsis" FontSize="11"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                    </Border>

                    <!-- Search within playlist -->
                    <Border Grid.Row="1" Background="#0E0E16" BorderBrush="#1A1A2A"
                            BorderThickness="0,0,0,1" Padding="8,5">
                        <TextBox Text="{Binding BrowserQuery}"
                                 Watermark="Filter tracks..."
                                 Background="#0A0A12" Foreground="#A0A0C0"
                                 BorderBrush="#2A2A40" BorderThickness="1"
                                 CornerRadius="3" Padding="6,3" FontSize="10"
                                 CaretBrush="#7777AA"/>
                    </Border>

                    <!-- Downloaded track list -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding BrowserTracks}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding $parent[UserControl].DataContext.LoadFromBrowserCommand}"
                                            CommandParameter="{Binding}"
                                            Background="Transparent" BorderThickness="0"
                                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                            Padding="8,5" Cursor="Hand">
                                        <Button.Styles>
                                            <Style Selector="Button:pointerover /template/ ContentPresenter">
                                                <Setter Property="Background" Value="#181828"/>
                                            </Style>
                                        </Button.Styles>
                                        <StackPanel Spacing="1">
                                            <TextBlock Text="{Binding Title}" Foreground="#C0C0D8"
                                                       FontSize="11" FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Artist}" Foreground="#505070"
                                                       FontSize="10" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Center: Cue Detail Editor -->
            <Border Grid.Column="1" Background="#0A0A12" BorderBrush="#1A1A2A" BorderThickness="1,0,1,0">
                <Grid RowDefinitions="Auto,*">
                    <Border Grid.Row="0" Background="#111118" BorderBrush="#1E1E2E" BorderThickness="0,0,0,1" Padding="12,7">
                        <TextBlock Text="CUE DETAIL" Foreground="#444455" FontSize="9" FontWeight="Bold" LetterSpacing="2"/>
                    </Border>

                    <TextBlock Grid.Row="1" Text="Select a cue in the list or on the waveform to edit its name, role, color, or hot cue slot."
                               Foreground="#5A5A7A" FontSize="11" TextWrapping="Wrap" TextAlignment="Center"
                               HorizontalAlignment="Center" VerticalAlignment="Center" Margin="24"
                               IsVisible="{Binding SelectedCue, Converter={x:Static ObjectConverters.IsNull}}"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                  IsVisible="{Binding SelectedCue, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <StackPanel Margin="16" Spacing="16">

                            <!-- Name -->
                            <StackPanel Spacing="4">
                                <TextBlock Text="NAME" Foreground="#333355" FontSize="8" FontWeight="Bold" LetterSpacing="2"/>
                                <TextBox Text="{Binding SelectedCue.Name}" LostFocus="OnCueFieldLostFocus"
                                         Background="#12121E" Foreground="#D0D0E0" BorderBrush="#2A2A40" BorderThickness="1"
                                         CornerRadius="3" Padding="8,5" FontSize="12" CaretBrush="#7777AA"/>
                            </StackPanel>

                            <!-- Timestamp + seek/nudge -->
                            <StackPanel Spacing="4">
                                <TextBlock Text="TIMESTAMP" Foreground="#333355" FontSize="8" FontWeight="Bold" LetterSpacing="2"/>
                                <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                                    <TextBlock Grid.Column="0" Text="{Binding SelectedCue.TimestampDisplay}"
                                               Foreground="#B0B0CC" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <Button Grid.Column="1" Classes="cmd-secondary" Content="− beat" FontSize="10" Padding="8,4"
                                            Command="{Binding NudgeCueCommand}" CommandParameter="-1"
                                            ToolTip.Tip="Nudge back 1 beat (Shift+←)"/>
                                    <Button Grid.Column="2" Classes="cmd-secondary" Content="+ beat" FontSize="10" Padding="8,4" Margin="4,0,0,0"
                                            Command="{Binding NudgeCueCommand}" CommandParameter="1"
                                            ToolTip.Tip="Nudge forward 1 beat (Shift+→)"/>
                                    <Button Grid.Column="3" Classes="cmd-primary" Content="▶ Seek" FontSize="10" Padding="8,4" Margin="4,0,0,0"
                                            Command="{Binding SeekPlayheadCommand}" CommandParameter="{Binding SelectedCue.Timestamp}"/>
                                </Grid>
                            </StackPanel>

                            <!-- Role -->
                            <StackPanel Spacing="4">
                                <TextBlock Text="ROLE" Foreground="#333355" FontSize="8" FontWeight="Bold" LetterSpacing="2"/>
                                <ItemsControl ItemsSource="{Binding CueRoleOptions}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Classes="cmd-secondary" Content="{Binding}" FontSize="10" Padding="8,4" Margin="0,0,4,4"
                                                    Command="{Binding $parent[UserControl].DataContext.SetSelectedCueRoleCommand}"
                                                    CommandParameter="{Binding}"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <!-- Color -->
                            <StackPanel Spacing="4">
                                <TextBlock Text="COLOR" Foreground="#333355" FontSize="8" FontWeight="Bold" LetterSpacing="2"/>
                                <ItemsControl ItemsSource="{Binding CueColorSwatches}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Width="26" Height="26" Margin="0,0,4,4" CornerRadius="4" Padding="0"
                                                    Background="{Binding}" BorderThickness="1" BorderBrush="#33334A" Cursor="Hand"
                                                    Command="{Binding $parent[UserControl].DataContext.SetSelectedCueColorCommand}"
                                                    CommandParameter="{Binding}"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <!-- Hot cue slot -->
                            <StackPanel Spacing="4" IsVisible="{Binding !SelectedCue.IsLoop}">
                                <TextBlock Text="HOT CUE SLOT" Foreground="#333355" FontSize="8" FontWeight="Bold" LetterSpacing="2"/>
                                <ItemsControl ItemsSource="{Binding CueSlotOptions}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Content="{Binding Label}" FontSize="10" Padding="10,4" Margin="0,0,4,4"
                                                    Classes="cmd-secondary"
                                                    Command="{Binding $parent[UserControl].DataContext.SetSelectedCueSlotCommand}"
                                                    CommandParameter="{Binding Value}"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <TextBlock Text="{Binding SelectedCue.WhyHereTooltip}"
                                       Foreground="#555577" FontSize="10" TextWrapping="Wrap"/>

                            <Button Classes="cmd-danger" Content="✕ Delete Cue" HorizontalAlignment="Left"
                                    Command="{Binding DeleteCueCommand}" CommandParameter="{Binding SelectedCue}"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Inspector Panel -->
            <Border Grid.Column="2" Background="#111118">
                <Grid RowDefinitions="Auto,Auto,*">

                    <!-- Inspector header -->
                    <Border Grid.Row="0" Background="#16161E" BorderBrush="#1E1E2E" BorderThickness="0,0,0,1" Padding="12,7">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="CUE INSPECTOR" Foreground="#444455" FontSize="9"
                                       FontWeight="Bold" LetterSpacing="2" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Classes="cmd-primary"
                                    Command="{Binding AddCueAtPlayheadCommand}"
                                    Content="+ Add Cue" Padding="8,3" FontSize="10"/>
                        </Grid>
                    </Border>

                    <!-- Hot Cue Pad Bank -->
                    <Border Grid.Row="1" Background="#0E0E1A" BorderBrush="#1E1E2E" BorderThickness="0,0,0,1" Padding="8,8">
                        <StackPanel>
                            <TextBlock Text="HOT CUES" Foreground="#333355" FontSize="8"
                                       FontWeight="Bold" LetterSpacing="2" Margin="0,0,0,6"/>
                            <ItemsControl ItemsSource="{Binding HotCuePads}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Rows="2" Columns="4"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Classes="hotcue-pad" Margin="2"
                                                Background="{Binding Background}"
                                                BorderBrush="{Binding BorderColor}"
                                                Foreground="{Binding Foreground}"
                                                ToolTip.Tip="{Binding CueName}"
                                                Command="{Binding $parent[UserControl].DataContext.JumpToCueCommand}"
                                                CommandParameter="{Binding}">
                                            <StackPanel HorizontalAlignment="Center"
                                                        VerticalAlignment="Center" Spacing="1">
                                                <TextBlock Text="{Binding PadLabel}"
                                                           FontSize="11" FontWeight="Bold"
                                                           HorizontalAlignment="Center"/>
                                                <TextBlock Text="{Binding TimestampDisplay}"
                                                           FontSize="7" HorizontalAlignment="Center"
                                                           IsVisible="{Binding IsAssigned}"/>
                                            </StackPanel>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Cue List -->
                    <ScrollViewer Grid.Row="2" Background="#0A0A12" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding WorkingCues}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#1A1A28" BorderThickness="0,0,0,1"
                                            Background="#0A0A12"
                                            Padding="8,6"
                                            PointerPressed="OnCueRowPointerPressed">
                                        <Border.Styles>
                                            <Style Selector="Border:pointerover">
                                                <Setter Property="Background" Value="#12121E"/>
                                            </Style>
                                        </Border.Styles>
                                        <Grid ColumnDefinitions="4,8,*,Auto,Auto">
                                            <!-- Color bar -->
                                            <Border Grid.Column="0" Background="{Binding Color}" CornerRadius="2"/>
                                            <!-- Cue info -->
                                            <StackPanel Grid.Column="2" Spacing="2">
                                                <TextBox Text="{Binding Name}"
                                                         Background="Transparent" BorderThickness="0"
                                                         Foreground="#D0D0E0" FontSize="11" FontWeight="SemiBold"
                                                         Padding="0" CaretBrush="#7777AA"
                                                         LostFocus="OnCueFieldLostFocus"/>
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <TextBlock Text="{Binding TimestampDisplay}"
                                                               Foreground="#555577" FontSize="9"/>
                                                    <TextBlock Text="{Binding Role}" Foreground="#444466" FontSize="9"/>
                                                    <TextBlock Text="{Binding SlotLabel}"
                                                               Foreground="#5577AA" FontSize="9" FontWeight="Bold"
                                                               IsVisible="{Binding HasSlot}"/>
                                                    <!-- Confidence dot -->
                                                    <Border Width="7" Height="7" CornerRadius="4"
                                                            Background="{Binding ConfidenceColor}"
                                                            VerticalAlignment="Center"
                                                            ToolTip.Tip="{Binding WhyHereTooltip}"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <!-- Audition (▶ with pre-roll) -->
                                            <Button Grid.Column="3" Content="▶" Padding="4,2"
                                                    FontSize="9" Foreground="#5577AA"
                                                    Background="Transparent" BorderThickness="0"
                                                    VerticalAlignment="Center" Cursor="Hand"
                                                    ToolTip.Tip="Audition — plays 4 beats before this cue (Enter)"
                                                    Command="{Binding $parent[UserControl].DataContext.AuditionCueCommand}"
                                                    CommandParameter="{Binding}"/>
                                            <!-- Delete -->
                                            <Button Grid.Column="4" Content="✕" Padding="4,2"
                                                    FontSize="10" Foreground="#663333"
                                                    Background="Transparent" BorderThickness="0"
                                                    VerticalAlignment="Center" Cursor="Hand"
                                                    Command="{Binding $parent[UserControl].DataContext.DeleteCueCommand}"
                                                    CommandParameter="{Binding}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- Row 5: Loop Controls -->
        <Border Grid.Row="5" Background="#13131C" BorderBrush="#1E1E2E" BorderThickness="0,1,0,1" Padding="12,7">
            <Grid ColumnDefinitions="Auto,12,Auto,12,Auto,12,Auto,*,Auto">
                <TextBlock Grid.Column="0" Text="LOOP" Foreground="#333355" FontSize="9"
                           FontWeight="Bold" LetterSpacing="2" VerticalAlignment="Center"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <Button Classes="cmd-secondary" Command="{Binding SetLoopInCommand}"
                            Content="IN" FontSize="11" FontWeight="Bold" Foreground="#88CC88" Padding="10,4"/>
                    <Button Classes="cmd-secondary" Command="{Binding SetLoopOutCommand}"
                            Content="OUT" FontSize="11" FontWeight="Bold" Foreground="#88CC88" Padding="10,4"/>
                </StackPanel>

                <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <Button Classes="cmd-secondary" Command="{Binding LoopHalfCommand}"
                            Content="÷2" FontSize="11" Padding="8,4" ToolTip.Tip="Halve loop length"/>
                    <Button Classes="cmd-secondary" Command="{Binding LoopDoubleCommand}"
                            Content="×2" FontSize="11" Padding="8,4" ToolTip.Tip="Double loop length"/>
                </StackPanel>

                <StackPanel Grid.Column="6" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <TextBlock Text="Quick:" Foreground="#444455" FontSize="10" VerticalAlignment="Center"/>
                    <Button Classes="cmd-secondary" Content="1 bar" FontSize="10" Padding="6,3"
                            Command="{Binding SetQuickLoopCommand}" CommandParameter="1"/>
                    <Button Classes="cmd-secondary" Content="2 bar" FontSize="10" Padding="6,3"
                            Command="{Binding SetQuickLoopCommand}" CommandParameter="2"/>
                    <Button Classes="cmd-secondary" Content="4 bar" FontSize="10" Padding="6,3"
                            Command="{Binding SetQuickLoopCommand}" CommandParameter="4"/>
                    <Button Classes="cmd-secondary" Content="8 bar" FontSize="10" Padding="6,3"
                            Command="{Binding SetQuickLoopCommand}" CommandParameter="8"/>
                    <Button Classes="cmd-secondary" Content="16 bar" FontSize="10" Padding="6,3"
                            Command="{Binding SetQuickLoopCommand}" CommandParameter="16"/>
                </StackPanel>

                <Rectangle Grid.Column="7" Fill="Transparent"/>

                <StackPanel Grid.Column="8" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <ToggleButton Classes="cmd-toggle"
                                  IsChecked="{Binding IsAuditioningLoop, Mode=TwoWay}"
                                  IsEnabled="{Binding HasStagedLoop}"
                                  Content="🔁 Preview" FontSize="10" Padding="8,3"
                                  ToolTip.Tip="Loop playback between IN and OUT to audition before committing"/>
                    <TextBlock Text="{Binding LoopInDisplay}"
                               Foreground="#447744" FontSize="10" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding LoopOutDisplay}"
                               Foreground="#447744" FontSize="10" VerticalAlignment="Center"/>
                    <Button Classes="cmd-secondary" Command="{Binding PinLoopStartAsCueCommand}"
                            Content="→ Cue" FontSize="10" Padding="8,3"
                            ToolTip.Tip="Pin loop IN point as a hot cue marker"/>
                    <Button Classes="cmd-danger" Command="{Binding ClearLoopCommand}" Content="Clear Loop"
                            FontSize="10" Padding="8,3"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Row 6: Status Bar -->
        <Border Grid.Row="6" Background="#0E0E16" BorderBrush="#1A1A2A" BorderThickness="0,1,0,0" Padding="12,5">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                    <TextBlock Text="{Binding CurrentPlayPositionDisplay}"
                               Foreground="#444466" FontSize="10"/>
                    <TextBlock Text="{Binding WorkingCues.Count, StringFormat='Cues: {0}'}"
                               Foreground="#444466" FontSize="10"/>
                    <Border Background="#2A1A00" BorderBrush="#5A3A00" BorderThickness="1"
                            CornerRadius="2" Padding="6,2" IsVisible="{Binding HasUncommittedChanges}">
                        <TextBlock Text="● UNSAVED CHANGES" Foreground="#FF9800" FontSize="9"
                                   FontWeight="Bold" LetterSpacing="1"/>
                    </Border>
                    <Border Background="#0A2A0A" BorderBrush="#1A5A1A" BorderThickness="1"
                            CornerRadius="2" Padding="6,2" IsVisible="{Binding IsGenerating}">
                        <TextBlock Text="⚙ GENERATING..." Foreground="#60D060" FontSize="9"
                                   FontWeight="Bold" LetterSpacing="1"/>
                    </Border>
                    <Border Background="#0A1A0A" BorderBrush="#1A5A2A" BorderThickness="1"
                            CornerRadius="2" Padding="6,2" IsVisible="{Binding IsExportReady}"
                            ToolTip.Tip="Track has Intro, Drop, and Outro cues — ready to export">
                        <TextBlock Text="✓ EXPORT READY" Foreground="#44DD88" FontSize="9"
                                   FontWeight="Bold" LetterSpacing="1"/>
                    </Border>
                    <!-- Commit feedback -->
                    <TextBlock Text="{Binding LastCommitMessage}" FontSize="10"
                               VerticalAlignment="Center"
                               Classes="commit-feedback"
                               Classes.commit-error="{Binding HasCommitError}"
                               IsVisible="{Binding LastCommitMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                </StackPanel>
                <!-- Keyboard hint (hash in tooltip for debug) -->
                <TextBlock Grid.Column="1"
                           Text="← → jump  Shift+← → nudge  Enter audition  A add  Del remove  Ctrl+Z undo"
                           Foreground="#2A2A44" FontSize="9" VerticalAlignment="Center"
                           ToolTip.Tip="{Binding TrackHash}"/>
            </Grid>
        </Border>
    </Grid>

</UserControl>
