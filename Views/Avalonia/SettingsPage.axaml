<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:conv="clr-namespace:SLSKDONET.Views.Avalonia.Converters"
             xmlns:controls="clr-namespace:SLSKDONET.Views.Avalonia.Controls"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
             x:Class="SLSKDONET.Views.Avalonia.SettingsPage"
             Background="#1E1E1E" Foreground="White">

    <UserControl.Resources>
        <conv:RankColorConverter x:Key="RankColorConverter"/>
        <conv:BoolToTextConverter x:Key="BoolToTextConverter"/>
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="ToggleButton.profileChip">
            <Setter Property="Background" Value="#242424"/>
            <Setter Property="BorderBrush" Value="#3A3A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Foreground" Value="#D8D8D8"/>
            <Setter Property="MinWidth" Value="130"/>
        </Style>
        <Style Selector="ToggleButton.profileChip:pointerover">
            <Setter Property="Background" Value="#303030"/>
            <Setter Property="BorderBrush" Value="#4A4A4A"/>
        </Style>
        <Style Selector="ToggleButton.profileChip:checked">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>
        <Style Selector="ToggleButton.profileChip.nonStrict:checked">
            <Setter Property="Background" Value="#20322A"/>
            <Setter Property="BorderBrush" Value="#4CAF50"/>
        </Style>
        <Style Selector="ToggleButton.profileChip.strict:checked">
            <Setter Property="Background" Value="#112A3A"/>
            <Setter Property="BorderBrush" Value="#00BFFF"/>
        </Style>
        <Style Selector="ToggleButton.profileChip.stricter:checked">
            <Setter Property="Background" Value="#3A2D11"/>
            <Setter Property="BorderBrush" Value="#FFB300"/>
        </Style>
    </UserControl.Styles>
    
    <ScrollViewer>
        <StackPanel Margin="24" Spacing="24" MaxWidth="800">
            
            <!-- Header -->
            <StackPanel Spacing="8">
                <TextBlock Text="Settings" FontSize="28" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="Configure your download preferences and Soulseek settings" 
                           FontSize="13" Foreground="#A0A0A0"/>
            </StackPanel>

            <!-- Download Settings -->
            <Border Background="#252526" CornerRadius="8" Padding="20" BorderBrush="#3E3E3E" BorderThickness="1">
                <StackPanel Spacing="16">
                    <TextBlock Text="Download Settings" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                    
                    <!-- Download Folder -->
                    <Grid ColumnDefinitions="180,*,Auto">
                        <TextBlock Grid.Column="0" Text="Download Folder:" VerticalAlignment="Center" Foreground="#DDD"/>
                        <TextBox Grid.Column="1" 
                                 Text="{Binding DownloadPath, Mode=TwoWay}" 
                                 IsReadOnly="True"
                                 Background="#1E1E1E"
                                 Margin="0,0,8,0"/>
                        <Button Grid.Column="2" 
                                Command="{Binding BrowseDownloadPathCommand}"
                                Background="#0078D4"
                                Foreground="White"
                                Padding="12,8">
                            <TextBlock Text="Browse..."/>
                        </Button>
                    </Grid>
                    
                    <!-- File Name Format -->
                    <Grid ColumnDefinitions="180,*">
                        <TextBlock Grid.Column="0" Text="File Name Format:" VerticalAlignment="Center" Foreground="#DDD"/>
                        <TextBox Grid.Column="1" 
                                 Text="{Binding FileNameFormat, Mode=TwoWay}"
                                 Background="#1E1E1E"/>
                    </Grid>
                    <TextBlock Text="Placeholders: {{artist}}, {{title}}, {{album}}, {{filename}}, {{bitrate}}, {{format}}, {{length}}, {{user}}" 
                               Foreground="#666" 
                               FontSize="11"
                               Margin="180,0,0,0"/>
                    
                    <!-- Duplicate Prevention -->
                    <Grid ColumnDefinitions="180,*">
                        <TextBlock Grid.Column="0" Text="Prevent Duplicate Downloads:" VerticalAlignment="Center" Foreground="#DDD"/>
                        <CheckBox Grid.Column="1" 
                                  IsChecked="{Binding CheckForDuplicates, Mode=TwoWay}"
                                  Content="Skip tracks that already exist in library"
                                  Foreground="#AAA"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Library Sharing -->
            <Border Background="#0D1117" CornerRadius="8" Padding="20" BorderBrush="#1DB954" BorderThickness="1">
                <StackPanel Spacing="16">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="4">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="📤" FontSize="20" VerticalAlignment="Center"/>
                                <TextBlock Text="Library Sharing" FontSize="16" FontWeight="SemiBold" Foreground="#1DB954"/>
                            </StackPanel>
                            <TextBlock Text="Share files back to the Soulseek network. Your share count directly affects your reputation and download priority from quality peers."
                                       Foreground="#666" FontSize="12" TextWrapping="Wrap"/>
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1"
                                      IsChecked="{Binding EnableLibrarySharing, Mode=TwoWay}"
                                      OnContent="On" OffContent="Off"
                                      VerticalAlignment="Top"/>
                    </Grid>

                    <Separator Background="#1A2F1A" Height="1"/>

                    <!-- Folder picker – only enabled when sharing is on -->
                    <Grid ColumnDefinitions="130,*,Auto" IsEnabled="{Binding EnableLibrarySharing}">
                        <TextBlock Grid.Column="0" Text="Shared Folder:" VerticalAlignment="Center" Foreground="#DDD"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding SharedFolderPath, Mode=TwoWay}"
                                 IsReadOnly="True"
                                 Background="#1E1E1E"
                                 Margin="0,0,8,0"/>
                        <Button Grid.Column="2"
                                Command="{Binding BrowseSharedFolderCommand}"
                                Background="#0078D4"
                                Foreground="White"
                                Padding="12,8">
                            <TextBlock Text="Browse..."/>
                        </Button>
                    </Grid>

                    <!-- Live share status pill -->
                    <Border Background="#111" BorderBrush="#2A3A2A" BorderThickness="1" CornerRadius="6" Padding="12,10">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Ellipse Grid.Column="0"
                                     Width="9" Height="9"
                                     Fill="{Binding ShareStatusColor}"
                                     VerticalAlignment="Center"
                                     Margin="0,0,10,0"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding ShareStatusSummary}"
                                       Foreground="#AAA" FontSize="11"
                                       VerticalAlignment="Center"
                                       TextWrapping="Wrap"/>
                            <Button Grid.Column="2"
                                    Command="{Binding RefreshShareNowCommand}"
                                    Background="Transparent"
                                    BorderBrush="#2A3A2A"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="10,4"
                                    VerticalAlignment="Center"
                                    Margin="12,0,0,0">
                                <TextBlock Text="↻ Refresh" Foreground="#888" FontSize="10"/>
                            </Button>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Library Folders -->
            <Border Background="#252526" CornerRadius="8" Padding="20" BorderBrush="#3E3E3E" BorderThickness="1">
                <StackPanel Spacing="16">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="4">
                             <TextBlock Text="Library Folders" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                             <TextBlock Text="Manage additional folders to scan for music." Foreground="#AAA" FontSize="12"/>
                        </StackPanel>
                        <Button Grid.Column="1" Command="{Binding AddLibraryFolderCommand}" Background="#1DB954" Foreground="White" Padding="12,6">
                             <StackPanel Orientation="Horizontal" Spacing="6">
                                 <TextBlock Text="+" FontWeight="Bold"/>
                                 <TextBlock Text="Add Folder"/>
                             </StackPanel>
                        </Button>
                    </Grid>
                    
                    <ListBox ItemsSource="{Binding LibraryFolders}" 
                             SelectedItem="{Binding SelectedLibraryFolder}"
                             Background="#1E1E1E" 
                             BorderThickness="1" 
                             BorderBrush="#333" 
                             Height="150">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="Auto,*,Auto">
                                    <PathIcon Grid.Column="0" Data="{StaticResource folder_regular}" Width="16" Height="16" Foreground="#DDD" Margin="0,0,12,0"/>
                                    <TextBlock Grid.Column="1" Text="{Binding FolderPath}" VerticalAlignment="Center" Foreground="#DDD"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Button Command="{Binding RemoveLibraryFolderCommand}" 
                            IsEnabled="{Binding SelectedLibraryFolder, Converter={x:Static ObjectConverters.IsNotNull}}"
                            Background="#2D2D2D" 
                            BorderBrush="#FF5555" 
                            BorderThickness="1" 
                            HorizontalAlignment="Right">
                        <TextBlock Text="Remove Selected" Foreground="#FF5555" Padding="12,4"/>
                    </Button>

                </StackPanel>
            </Border>

            <!-- Library Navigation Behavior -->
            <Border Background="#252526" CornerRadius="8" Padding="20" BorderBrush="#3E3E3E" BorderThickness="1">
                <StackPanel Spacing="16">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Library Navigation" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                        <TextBlock Text="Control whether the library playlist panel reacts to mouse hover." Foreground="#AAA" FontSize="12"/>
                    </StackPanel>

                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="Enable Hover Auto-Hide" FontWeight="SemiBold" Foreground="#DDD"/>
                            <TextBlock Text="When off, the playlist panel only opens/closes when you click the arrow." Foreground="#666" FontSize="11" TextWrapping="Wrap"/>
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1"
                                      IsChecked="{Binding LibraryNavigationAutoHideEnabled, Mode=TwoWay}"
                                      VerticalAlignment="Center"
                                      OffContent="Off"
                                      OnContent="On"/>
                    </Grid>

                    <Grid ColumnDefinitions="*,120"
                          IsEnabled="{Binding LibraryNavigationAutoHideEnabled}">
                        <StackPanel Grid.Column="0" Spacing="2" Margin="0,0,12,0">
                            <TextBlock Text="Activation Clicks" FontWeight="SemiBold" Foreground="#DDD"/>
                            <TextBlock Text="Hover behavior activates only after you manually collapse the panel this many times." Foreground="#666" FontSize="11" TextWrapping="Wrap"/>
                        </StackPanel>
                        <NumericUpDown Grid.Column="1"
                                       Value="{Binding LibraryNavigationAutoHideActivationToggleCount, Mode=TwoWay}"
                                       Minimum="2"
                                       Maximum="10"
                                       Increment="1"
                                       Background="#1E1E1E"
                                       Foreground="White"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Search Filter Defaults -->
            <Border Background="#252526" CornerRadius="8" Padding="20" BorderBrush="#3E3E3E" BorderThickness="1">
                <StackPanel Spacing="16">
                    <TextBlock Text="Default Search Filters" FontSize="16" FontWeight="SemiBold" Foreground="White"/>

                    <Border Background="#1E1E1E" BorderBrush="#333" BorderThickness="1" CornerRadius="8" Padding="12">
                        <StackPanel Spacing="8">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Search Profile Overwrite" FontWeight="SemiBold" Foreground="#DDD"/>
                                <TextBlock Text="Apply one of the shared runtime profiles used by Download Center." Foreground="#888" FontSize="11" TextWrapping="Wrap"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <ToggleButton Classes="profileChip nonStrict" IsChecked="{Binding SearchProfileNonStrict, Mode=TwoWay}">
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="Non-Strict" FontSize="11" FontWeight="SemiBold"/>
                                        <TextBlock Text="FLAC + MP3" FontSize="10" Opacity="0.8"/>
                                    </StackPanel>
                                </ToggleButton>
                                <ToggleButton Classes="profileChip strict" IsChecked="{Binding SearchProfileStrict, Mode=TwoWay}">
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="Strict" FontSize="11" FontWeight="SemiBold"/>
                                        <TextBlock Text="Lossless Focus" FontSize="10" Opacity="0.8"/>
                                    </StackPanel>
                                </ToggleButton>
                                <ToggleButton Classes="profileChip stricter" IsChecked="{Binding SearchProfileStricter, Mode=TwoWay}">
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="Stricter" FontSize="11" FontWeight="SemiBold"/>
                                        <TextBlock Text="FLAC Only" FontSize="10" Opacity="0.8"/>
                                    </StackPanel>
                                </ToggleButton>
                            </StackPanel>
                            <TextBlock Text="{Binding SearchProfileModeText}" Foreground="#9AA3AD" FontSize="11" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Min Bitrate (minimum 320 kbps enforced) -->
                    <Grid ColumnDefinitions="180,120,*">
                        <TextBlock Grid.Column="0" Text="Min Bitrate:" VerticalAlignment="Center" Foreground="#DDD"/>
                        <NumericUpDown Grid.Column="1" 
                                       Value="{Binding MinBitrate, Mode=TwoWay}"
                                       Minimum="320"
                                       Maximum="1000"
                                       Increment="32"
                                       Background="#1E1E1E"
                                       Foreground="White"/>
                        <TextBlock Grid.Column="2" 
                                   Text="kbps" 
                                   VerticalAlignment="Center" 
                                   Foreground="#666"
                                   Margin="12,0,0,0"/>
                    </Grid>
                    
                    <!-- Max Bitrate -->
                    <Grid ColumnDefinitions="180,120,*">
                        <TextBlock Grid.Column="0" Text="Max Bitrate:" VerticalAlignment="Center" Foreground="#DDD"/>
                        <NumericUpDown Grid.Column="1" 
                                       Value="{Binding MaxBitrate, Mode=TwoWay}"
                                       Minimum="0"
                                       Maximum="1000"
                                       Increment="32"
                                       Background="#1E1E1E"
                                       Foreground="White"/>
                        <TextBlock Grid.Column="2" 
                                   Text="kbps" 
                                   VerticalAlignment="Center" 
                                   Foreground="#666"
                                   Margin="12,0,0,0"/>
                    </Grid>
                    
                    <!-- Preferred Formats -->
                    <Grid ColumnDefinitions="180,*">
                        <TextBlock Grid.Column="0" Text="Preferred Formats:" VerticalAlignment="Center" Foreground="#DDD"/>
                        <TextBox Grid.Column="1" 
                                 Text="{Binding PreferredFormats, Mode=TwoWay}"
                                 Background="#1E1E1E"
                                 Watermark="mp3,flac,aac"/>
                    </Grid>
                    <TextBlock Text="Comma-separated list of preferred audio formats" 
                               Foreground="#666" 
                               FontSize="11"
                               Margin="180,0,0,0"/>
                </StackPanel>
            </Border>

            <!-- Brain 2.0 & Quality Guard -->
            <Border Background="#252526" CornerRadius="8" Padding="20" BorderBrush="#3E3E3E" BorderThickness="1">
                <StackPanel Spacing="16">
                    <StackPanel Spacing="4">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="🧠" FontSize="20" VerticalAlignment="Center"/>
                            <TextBlock Text="Smart Features &amp; Integrity" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                        </StackPanel>
                        <TextBlock Text="Sonic intelligence for adaptive search and upscale protection" 
                                   Foreground="#AAA" FontSize="12"/>
                    </StackPanel>

                    <Separator Background="#333" Height="1"/>

                    <!-- Fuzzy Normalization -->
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="Fuzzy Normalization" FontWeight="SemiBold" Foreground="#DDD"/>
                            <TextBlock Text="Auto-corrects titles, strips special characters, and handles 'feat.' variants." 
                                       Foreground="#666" FontSize="11" TextWrapping="Wrap"/>
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsChecked="{Binding EnableFuzzyNormalization}" OnContent="On" OffContent="Off"/>
                    </Grid>

                    <!-- VBR Fraud Detection -->
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="VBR Fraud Detection (Upscale Guard)" FontWeight="SemiBold" Foreground="#DDD"/>
                            <TextBlock Text="Detects and flags fake 320kbps/FLAC files that were upscaled from low-quality sources." 
                                       Foreground="#666" FontSize="11" TextWrapping="Wrap"/>
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsChecked="{Binding EnableVbrFraudDetection}" OnContent="On" OffContent="Off"/>
                    </Grid>

                    <Separator Background="#333" Height="1"/>

                    <!-- Relaxation Strategy -->
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="Adaptive Relaxation Strategy" FontWeight="SemiBold" Foreground="#DDD"/>
                            <TextBlock Text="If no perfect quality match is found after a timeout, progressively widens search filters." 
                                       Foreground="#666" FontSize="11" TextWrapping="Wrap"/>
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsChecked="{Binding EnableRelaxationStrategy}" OnContent="On" OffContent="Off"/>
                    </Grid>

                    <!-- Relaxation Timeout -->
                    <Grid ColumnDefinitions="180,120,*" IsEnabled="{Binding EnableRelaxationStrategy}">
                        <TextBlock Grid.Column="0" Text="Relaxation Timeout:" VerticalAlignment="Center" Foreground="#DDD"/>
                        <NumericUpDown Grid.Column="1" 
                                       Value="{Binding RelaxationTimeoutSeconds}"
                                       Minimum="5"
                                       Maximum="120"
                                       Increment="5"
                                       Background="#1E1E1E"
                                       Foreground="White"/>
                        <TextBlock Grid.Column="2" 
                                   Text="seconds before widening search" 
                                   VerticalAlignment="Center" 
                                   Foreground="#666"
                                   FontSize="11"
                                   Margin="12,0,0,0"/>
                    </Grid>

                    <Separator Background="#333" Height="1"/>

                    <!-- Automation & Retries -->
                    <StackPanel Spacing="12">
                        <TextBlock Text="Automation &amp; Retries" FontWeight="SemiBold" Foreground="#DDD"/>
                        
                        <!-- Auto Retry Toggle -->
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Spacing="2">
                                <TextBlock Text="Auto-Retry Failed Downloads" FontWeight="SemiBold" Foreground="#DDD"/>
                                <TextBlock Text="Automatically requeue failed tracks or searches with exponential backoff." 
                                           Foreground="#666" FontSize="11" TextWrapping="Wrap"/>
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1" IsChecked="{Binding AutoRetryFailedDownloads}" OnContent="On" OffContent="Off"/>
                        </Grid>

                        <!-- Max Retries Numeric -->
                        <Grid ColumnDefinitions="180,120,*" IsEnabled="{Binding AutoRetryFailedDownloads}">
                            <TextBlock Grid.Column="0" Text="Max Retry Attempts:" VerticalAlignment="Center" Foreground="#DDD"/>
                            <NumericUpDown Grid.Column="1" 
                                           Value="{Binding MaxDownloadRetries}"
                                           Minimum="1"
                                           Maximum="20"
                                           Increment="1"
                                           Background="#1E1E1E"
                                           Foreground="White"/>
                            <TextBlock Grid.Column="2" 
                                       Text="attempts" 
                                       VerticalAlignment="Center" 
                                       Foreground="#666"
                                       FontSize="11"
                                       Margin="12,0,0,0"/>
                        </Grid>
                    </StackPanel>

                    <Separator Background="#333" Height="1"/>

                    <!-- Spotify Track Identification &amp; Album Art Toggle -->
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="Spotify Track &amp; Album Art" FontWeight="SemiBold" Foreground="#DDD"/>
                            <TextBlock Text="Fetch track metadata (Title, Artist, Album Art, Duration, ISRC) from Spotify. Uses Search API - works even in Developer Mode." 
                                       Foreground="#666" FontSize="11" TextWrapping="Wrap"/>
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsChecked="{Binding SpotifyUseApi}" OnContent="On" OffContent="Off"/>
                    </Grid>

                </StackPanel>
            </Border>

            <!-- NEW REFACORTED SPOTIFY INTEGRATION -->
            <Border Background="#252526" CornerRadius="8" Padding="20" BorderBrush="#3E3E3E" BorderThickness="1">
                <StackPanel Spacing="16">
                    <Grid ColumnDefinitions="*,Auto">
                         <StackPanel Grid.Column="0" Spacing="4">
                             <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Data="{StaticResource icons_spotify}" Width="20" Height="20" Foreground="#1DB954"/>
                                <TextBlock Text="Spotify Integration" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                             </StackPanel>
                             <TextBlock Text="Connect to import playlists and improve matching" Foreground="#AAA" FontSize="12"/>
                             <StackPanel Orientation="Horizontal" Spacing="10">
                                 <TextBlock Text="{Binding SpotifyState, StringFormat='State: {0}'}" Foreground="Cyan"/>
                                 <TextBlock Text="{Binding IsSpotifyDisconnected, StringFormat='Disc: {0}'}" Foreground="Yellow"/>
                                 <TextBlock Text="{Binding IsSpotifyConnecting, StringFormat='Conn: {0}'}" Foreground="Orange"/>
                                 <TextBlock Text="{Binding IsSpotifyConnected, StringFormat='Cned: {0}'}" Foreground="Lime"/>
                             </StackPanel>
                         </StackPanel>
                         
                         <!-- Status Badge -->
                         <Border Grid.Column="1" CornerRadius="12" Padding="12,4" Background="{Binding SpotifyStatusColor}" VerticalAlignment="Top">
                             <TextBlock Text="{Binding SpotifyDisplayName}" FontSize="12" FontWeight="SemiBold" Foreground="White"/>
                         </Border>
                    </Grid>

                    <Separator Background="#333" Height="1"/>

                    <!-- Panel 1: Disconnected State -->
                    <StackPanel IsVisible="{Binding IsSpotifyDisconnected}" Spacing="12">
                        <TextBlock Text="Unlock the full power of ORBIT by connecting your Spotify account." 
                                   TextWrapping="Wrap" Foreground="#CCC"/>
                        
                        <Button Command="{Binding ConnectSpotifyCommand}"
                                Background="#1DB954"
                                HorizontalAlignment="Left"
                                Padding="24,10"
                                CornerRadius="20">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Connect with Spotify" FontWeight="Bold" Foreground="White"/>
                                <PathIcon Data="{StaticResource icons_spotify}" Width="16" Height="16" Foreground="White"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Panel 2: Connecting State -->
                    <StackPanel IsVisible="{Binding IsSpotifyConnecting}" Spacing="16" HorizontalAlignment="Center">
                        <TextBlock Text="Connecting to Spotify..." FontSize="16" FontWeight="SemiBold"/>
                        <ProgressBar IsIndeterminate="True" Width="200" Height="4" Foreground="#1DB954"/>
                        <TextBlock Text="Please complete the login in your browser window." Foreground="#AAA"/>
                        
                        <Button Command="{Binding RestartSpotifyAuthCommand}"
                                Content="Restart / Cancel"
                                Background="Transparent"
                                BorderBrush="#444"
                                BorderThickness="1"
                                CornerRadius="16"
                                Foreground="#AAA"
                                Margin="0,8,0,0"/>
                    </StackPanel>

                    <!-- Panel 3: Connected State -->
                    <StackPanel IsVisible="{Binding IsSpotifyConnected}" Spacing="12">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <!-- Avatar placeholder could go here -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="You are connected." Foreground="#DDD"/>
                                <TextBlock Text="Private playlists and liked songs are available for import." Foreground="#888" FontSize="11"/>
                            </StackPanel>
                            
                            <Button Grid.Column="2" 
                                    Command="{Binding DisconnectSpotifyCommand}"
                                    Background="#2D2D2D"
                                    BorderBrush="#FF5555"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="12,6">
                                <TextBlock Text="Disconnect" Foreground="#FF5555"/>
                            </Button>
                        </Grid>
                    </StackPanel>

                     <!-- Advanced / Troubleshooting (Always available at bottom) -->
                     <Expander Header="Troubleshooting &amp; Advanced" 
                               HorizontalAlignment="Stretch" 
                               Background="Transparent"
                               BorderBrush="#333"
                               BorderThickness="1"
                               CornerRadius="4"
                               Margin="0,8,0,0">
                        <StackPanel Spacing="12" Margin="0,12,0,0">
                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto">
                                <!-- Test Connection -->
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Test Connection Status" VerticalAlignment="Center" Foreground="#DDD"/>
                                <Button Grid.Row="0" Grid.Column="1" Command="{Binding TestSpotifyConnectionCommand}" Content="Run Test" Background="#333"/>
                                
                                <!-- Clear Cache -->
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Clear Metadata Cache" VerticalAlignment="Center" Foreground="#DDD" Margin="0,12,0,0"/>
                                <Button Grid.Row="1" Grid.Column="1" Command="{Binding ClearSpotifyCacheCommand}" Content="Clear Cache" Background="#333" Margin="0,12,0,0"/>
                                
                                <!-- Revoke -->
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Revoke &amp; Re-authenticate (Full Reset)" VerticalAlignment="Center" Foreground="#FF8888" Margin="0,12,0,0"/>
                                <Button Grid.Row="2" Grid.Column="1" Command="{Binding RevokeAndReAuthCommand}" Content="Revoke All" Background="#552222" Foreground="#FF8888" Margin="0,12,0,0"/>
                            </Grid>
                            
                            <Separator Background="#333" Height="1" Margin="0,8"/>
                            
                            <!-- Client ID Override -->
                            <Grid ColumnDefinitions="120,*">
                                <TextBlock Grid.Column="0" Text="Client ID:" VerticalAlignment="Center" Foreground="#666"/>
                                <TextBox Grid.Column="1" Text="{Binding SpotifyClientId}" Watermark="Default (QMUSICSLSK)" Background="#111" BorderThickness="0"/>
                            </Grid>
                        </StackPanel>
                     </Expander>
                </StackPanel>
            </Border>

            <!-- Phase 8: Self-Healing Library (Upgrade Scout) -->
            <Border Background="#252526" CornerRadius="8" Padding="20" BorderBrush="#3E3E3E" BorderThickness="1">
                <StackPanel Spacing="16">
                    <TextBlock Text="Library Self-Healing (Upgrade Scout)" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                    
                    <TextBlock TextWrapping="Wrap" Foreground="#AAA" FontSize="12">
                        Automatically scan your library for low-quality or faked tracks and search for high-fidelity replacements.
                    </TextBlock>

                    <Grid ColumnDefinitions="180,*">
                        <TextBlock Grid.Column="0" Text="Enable Upgrade Scout:" VerticalAlignment="Center" Foreground="#DDD"/>
                        <ToggleSwitch Grid.Column="1" 
                                      IsChecked="{Binding UpgradeScoutEnabled, Mode=TwoWay}"
                                      OnContent="Active" OffContent="Disabled"/>
                    </Grid>

                    <Grid ColumnDefinitions="180,120,*">
                        <TextBlock Grid.Column="0" Text="Min Bitrate Threshold:" VerticalAlignment="Center" Foreground="#DDD"/>
                        <NumericUpDown Grid.Column="1" 
                                       Value="{Binding UpgradeMinBitrateThreshold, Mode=TwoWay}"
                                       Minimum="128"
                                       Maximum="320"
                                       Increment="32"
                                       IsEnabled="{Binding UpgradeScoutEnabled}"
                                       Background="#1E1E1E"/>
                        <TextBlock Grid.Column="2" Text="Upgrade everything below this bitrate" 
                                   VerticalAlignment="Center" Foreground="#666" FontSize="11" Margin="12,0,0,0"/>
                    </Grid>

                    <Grid ColumnDefinitions="180,120,*">
                        <TextBlock Grid.Column="0" Text="Min Quality Gain:" VerticalAlignment="Center" Foreground="#DDD"/>
                        <NumericUpDown Grid.Column="1" 
                                       Value="{Binding UpgradeMinGainKbps, Mode=TwoWay}"
                                       Minimum="0"
                                       Maximum="320"
                                       Increment="32"
                                       IsEnabled="{Binding UpgradeScoutEnabled}"
                                       Background="#1E1E1E"/>
                        <TextBlock Grid.Column="2" Text="Only upgrade if bitrate gain >= this value" 
                                   VerticalAlignment="Center" Foreground="#666" FontSize="11" Margin="12,0,0,0"/>
                    </Grid>

                    <Grid ColumnDefinitions="180,*">
                        <TextBlock Grid.Column="0" Text="Auto-Queue Upgrades:" VerticalAlignment="Center" Foreground="#DDD"/>
                        <CheckBox Grid.Column="1" 
                                  IsChecked="{Binding UpgradeAutoQueueEnabled, Mode=TwoWay}"
                                  IsEnabled="{Binding UpgradeScoutEnabled}"
                                  Content="Automatically queue found upgrades for download"
                                  Foreground="#AAA"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Phase 8: Dependencies (FFmpeg Validation) -->
            <Border Background="#252526" CornerRadius="8" Padding="20" BorderBrush="#3E3E3E" BorderThickness="1">
                <StackPanel Spacing="16">
                    <TextBlock Text="Dependencies" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                    
                    <TextBlock TextWrapping="Wrap" Foreground="#AAA" FontSize="12">
                        Smart features require external dependencies. Ensure these are installed for full functionality.
                    </TextBlock>

                    <!-- FFmpeg Status Card -->
                    <Border Background="#2D2D2D" 
                            CornerRadius="8" 
                            Padding="16" 
                            BorderBrush="{Binding FfmpegBorderColor}" 
                            BorderThickness="2">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="FFmpeg" 
                                           FontWeight="SemiBold" 
                                           FontSize="14"
                                           Foreground="White"/>
                                <TextBlock Text="{Binding FfmpegStatus}" 
                                           FontSize="12" 
                                           Foreground="#AAA"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="2" 
                                        Orientation="Horizontal" 
                                        Spacing="8">
                                <Button Command="{Binding CheckFfmpegCommand}" 
                                        Content="Check"
                                        Background="#0078D4"
                                        Foreground="White"
                                        Padding="16,6"/>
                                
                                <Button Content="Download FFmpeg"
                                        Name="DownloadFfmpegButton"
                                        IsVisible="{Binding !IsFfmpegInstalled}"
                                        Background="#1DB954"
                                        Foreground="White"
                                        Padding="16,6"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Warning message if not installed -->
                    <Border Background="#332200" 
                            CornerRadius="4" 
                            Padding="12"
                            IsVisible="{Binding !IsFfmpegInstalled}"
                            BorderBrush="#FFA500"
                            BorderThickness="1">
                        <StackPanel Spacing="8">
                            <TextBlock Text="⚠️ FFmpeg is required for:" 
                                       FontSize="12" 
                                       Foreground="#FFA500"
                                       FontWeight="SemiBold"/>
                            <StackPanel Margin="16,0,0,0" Spacing="4">
                                <TextBlock Text="• Sonic Integrity Analysis (fake FLAC detection)" FontSize="11" Foreground="#DDD"/>
                                <TextBlock Text="• Quality Guard (spectral frequency analysis)" FontSize="11" Foreground="#DDD"/>
                                <TextBlock Text="• Spectral Hash de-duplication" FontSize="11" Foreground="#DDD"/>
                            </StackPanel>
                            
                            <Separator Background="#FFA500" Height="1" Margin="0,4"/>
                            
                            <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#CCC">
                                <Bold>Windows:</Bold> Download from gyan.dev (full builds)
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#CCC">
                                <Bold>macOS:</Bold> Run: <Span Foreground="#0078D4">brew install ffmpeg</Span>
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#CCC">
                                <Bold>Linux:</Bold> Run: <Span Foreground="#0078D4">sudo apt install ffmpeg</Span>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>


            <!-- Database & Maintenance -->
            <Border Background="#252526" CornerRadius="8" Padding="20" BorderBrush="#3E3E3E" BorderThickness="1">
                <StackPanel Spacing="16">
                    <StackPanel Spacing="4">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="🛠️" FontSize="20" VerticalAlignment="Center"/>
                            <TextBlock Text="Database &amp; Maintenance" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                        </StackPanel>
                        <TextBlock Text="Manage your local library data and system health." 
                                   Foreground="#AAA" FontSize="12"/>
                    </StackPanel>

                    <Separator Background="#333" Height="1"/>

                    <!-- Reset/Update Database Schema -->
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="Refresh Database Schema" FontWeight="SemiBold" Foreground="#FF8888"/>
                            <TextBlock Text="Safely resets the database file and restores your data from backup. Use this to enable new features (like AI columns) on an existing library." 
                                       Foreground="#666" FontSize="11" TextWrapping="Wrap"/>
                        </StackPanel>
                        <Button Grid.Column="1" 
                                Command="{Binding ResetDatabaseCommand}"
                                Content="Update Schema" 
                                Background="#552222" 
                                Foreground="#FF8888"
                                Padding="16,8"
                                VerticalAlignment="Center"/>
                    </Grid>
                    
                    <Separator Background="#333" Height="1"/>
                    
                    <!-- Manual Scan -->
                    <StackPanel Spacing="10">
                        <TextBlock Text="Library Scan" FontWeight="SemiBold" FontSize="16" Foreground="{DynamicResource TextBrush}"/>
                        <TextBlock Text="Manually scan the configured download folder for new files." 
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" TextWrapping="Wrap"/>
                        
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Button Command="{Binding ScanLibraryCommand}" 
                                    IsEnabled="{Binding !IsScanning}"
                                    Classes="AccentBtn" HorizontalAlignment="Left"
                                    Padding="16,8" Background="#0078D4">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <PathIcon Data="{StaticResource search_regular}" Width="16" Height="16"/>
                                    <TextBlock Text="{Binding IsScanning, Converter={StaticResource BoolToTextConverter}, ConverterParameter='Scanning...|Scan Library'}" VerticalAlignment="Center" Foreground="White"/>
                                </StackPanel>
                            </Button>
                            
                            <TextBlock Text="{Binding ScanStatus}" VerticalAlignment="Center" 
                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                        </StackPanel>

                        <Border Background="#1D1F22" BorderBrush="#333" BorderThickness="1" CornerRadius="6" Padding="12">
                            <StackPanel Spacing="10">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Column="0" Spacing="2">
                                        <TextBlock Text="Removal Candidates" FontWeight="SemiBold" Foreground="White"/>
                                        <TextBlock Text="Review lower-quality files that were replaced by better matches during scan consolidation."
                                                   Foreground="#AAA" FontSize="11" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Command="{Binding RefreshRemovalCandidatesCommand}"
                                            Padding="10,6"
                                            Margin="8,0,0,0"
                                            VerticalAlignment="Top"
                                            Background="#2F3136"
                                            Foreground="#D0D0D0"
                                            Content="Refresh"/>
                                </Grid>

                                <TextBlock Text="{Binding RemovalCandidatesStatus}" Foreground="#B0B0B0" FontSize="11"/>

                                <TextBlock Text="No candidates to review yet."
                                           Foreground="#7A7A7A"
                                           FontStyle="Italic"
                                           FontSize="11"
                                           IsVisible="{Binding !HasRemovalCandidates}"/>

                                <ScrollViewer MaxHeight="220"
                                              VerticalScrollBarVisibility="Auto"
                                              IsVisible="{Binding HasRemovalCandidates}">
                                    <ItemsControl ItemsSource="{Binding RemovalCandidates}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#23262B" BorderBrush="#343840" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,8">
                                                    <StackPanel Spacing="6">
                                                        <Grid ColumnDefinitions="*,Auto">
                                                            <TextBlock Grid.Column="0" Text="{Binding TrackLabel}" Foreground="#EAEAEA" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding TimestampLabel}" Foreground="#8FA3B8" FontSize="10"/>
                                                        </Grid>

                                                        <TextBlock Text="Candidate (lower quality):" Foreground="#C3CDD8" FontSize="10"/>
                                                        <Grid ColumnDefinitions="*,Auto">
                                                            <TextBlock Grid.Column="0" Text="{Binding SourceFileName}" Foreground="#F2A3A3" TextTrimming="CharacterEllipsis"/>
                                                            <Button Grid.Column="1" Content="Open"
                                                                    Command="{Binding OpenCandidateCommand}"
                                                                    Padding="8,3"
                                                                    Margin="8,0,0,0"
                                                                    Background="#3A2A2A"
                                                                    Foreground="#F2A3A3"/>
                                                        </Grid>

                                                        <TextBlock Text="Preferred (kept):" Foreground="#C3CDD8" FontSize="10"/>
                                                        <Grid ColumnDefinitions="*,Auto">
                                                            <TextBlock Grid.Column="0" Text="{Binding PreferredFileName}" Foreground="#9ED6A8" TextTrimming="CharacterEllipsis"/>
                                                            <Button Grid.Column="1" Content="Open"
                                                                    Command="{Binding OpenPreferredCommand}"
                                                                    Padding="8,3"
                                                                    Margin="8,0,0,0"
                                                                    Background="#243829"
                                                                    Foreground="#9ED6A8"/>
                                                        </Grid>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Phase 6: Security Transparency Panel -->
            <Border Background="#0D1117" CornerRadius="8" Padding="20" BorderBrush="#30C97A" BorderThickness="1">
                <StackPanel Spacing="16">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="4">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="🛡️" FontSize="20" VerticalAlignment="Center"/>
                                <TextBlock Text="Security Transparency" FontSize="16" FontWeight="SemiBold" Foreground="#30C97A"/>
                            </StackPanel>
                            <TextBlock Text="Live audit trail of every guardrail decision made by the Shield, Gate, Forensic Lab, and Blacklist."
                                       Foreground="#666" FontSize="12" TextWrapping="Wrap"/>
                        </StackPanel>
                        <Button Grid.Column="1"
                                Command="{Binding ClearSecurityAuditCommand}"
                                Background="Transparent"
                                BorderBrush="#333"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="10,4"
                                VerticalAlignment="Top">
                            <TextBlock Text="Clear" Foreground="#666" FontSize="11"/>
                        </Button>
                    </Grid>

                    <Separator Background="#1A2633" Height="1"/>

                    <!-- Feed (shown only when there are entries) -->
                    <TextBlock Text="No security events recorded yet. Events will appear here once a search is running."
                               Foreground="#444" FontSize="11" FontStyle="Italic"
                               IsVisible="{Binding !SecurityAuditFeed.Count}"/>

                    <ScrollViewer MaxHeight="240"
                                  IsVisible="{Binding SecurityAuditFeed.Count}"
                                  VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding SecurityAuditFeed}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <!-- Each audit row -->
                                    <Border Background="#111319" CornerRadius="4" Padding="10,6" Margin="0,2">
                                        <Grid ColumnDefinitions="Auto,Auto,*,Auto">
                                            <!-- Timestamp -->
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding TimeLabel}"
                                                       Foreground="#555" FontSize="10"
                                                       FontFamily="Consolas,Courier New,monospace"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,10,0"/>
                                            <!-- Category icon -->
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding CategoryIcon}"
                                                       FontSize="14" VerticalAlignment="Center"
                                                       Margin="0,0,8,0"/>
                                            <!-- Summary + detail -->
                                            <StackPanel Grid.Column="2" Spacing="2">
                                                <TextBlock Text="{Binding Summary}"
                                                           Foreground="#DDD" FontSize="12" FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding Detail}"
                                                           Foreground="#666" FontSize="10"
                                                           TextWrapping="NoWrap"
                                                           TextTrimming="CharacterEllipsis"
                                                           IsVisible="{Binding Detail, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                            </StackPanel>
                                            <!-- Severity badge -->
                                            <Border Grid.Column="3"
                                                    CornerRadius="3" Padding="6,2"
                                                    Background="{Binding SeverityColor}"
                                                    Opacity="0.9"
                                                    VerticalAlignment="Center"
                                                    Margin="8,0,0,0">
                                                <TextBlock Text="{Binding SeverityLabel}"
                                                           Foreground="White"
                                                           FontSize="9" FontWeight="Bold"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </Border>

            <!-- Diagnostics & Telemetry -->
            <Border Background="#0D1B2A" CornerRadius="8" Padding="20" BorderBrush="#00D4FF" BorderThickness="1">
                <StackPanel Spacing="16">
                    <StackPanel Spacing="4">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="🔬" FontSize="20" VerticalAlignment="Center"/>
                            <TextBlock Text="Diagnostics &amp; Telemetry" FontSize="16" FontWeight="SemiBold" Foreground="#00D4FF"/>
                        </StackPanel>
                        <TextBlock Text="Performance validation and system health monitoring for soundcheck sessions." 
                                   Foreground="#778DA9" FontSize="12"/>
                    </StackPanel>

                    <Separator Background="#1B263B" Height="1"/>

                    <StackPanel Spacing="8">
                        <TextBlock Text="Adaptive Lane Decisions"
                                   FontWeight="SemiBold"
                                   Foreground="#E0E1DD"/>
                        <TextBlock Text="Last 10 automatic lane tuning decisions (newest first)."
                                   Foreground="#778DA9"
                                   FontSize="11"/>

                        <TextBlock Text="No lane decisions recorded yet."
                                   Foreground="#516A86"
                                   FontSize="11"
                                   FontStyle="Italic"
                                   IsVisible="{Binding !AdaptiveLaneDecisionHistory.Count}"/>

                        <ScrollViewer MaxHeight="170"
                                      VerticalScrollBarVisibility="Auto"
                                      IsVisible="{Binding AdaptiveLaneDecisionHistory.Count}">
                            <ItemsControl ItemsSource="{Binding AdaptiveLaneDecisionHistory}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#111F2F"
                                                BorderBrush="#22364C"
                                                BorderThickness="1"
                                                CornerRadius="4"
                                                Padding="8,6"
                                                Margin="0,2">
                                            <Grid ColumnDefinitions="Auto,Auto,*">
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding TimeLabel}"
                                                           Foreground="#6C87A6"
                                                           FontSize="10"
                                                           FontFamily="Consolas,Courier New,monospace"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,10,0"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding LaneLabel}"
                                                           Foreground="#A7D8FF"
                                                           FontSize="10"
                                                           FontWeight="SemiBold"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,10,0"/>
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding Reason}"
                                                           Foreground="#C7D4E2"
                                                           FontSize="10"
                                                           TextTrimming="CharacterEllipsis"
                                                           TextWrapping="NoWrap"
                                                           VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>

                    <!-- Phase E3: Copy diagnostics snapshot -->
                    <Separator Background="#1B263B" Height="1"/>

                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="System Snapshot" FontWeight="SemiBold" Foreground="#E0E1DD"/>
                            <TextBlock Text="Copy current pressure level, lane decisions, share health and FFmpeg status to clipboard."
                                       Foreground="#778DA9" FontSize="11" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding DiagnosticsSnapshotStatus}"
                                       Foreground="#D7BA7D"
                                       FontSize="11"
                                       FontFamily="Consolas,Courier New,monospace"
                                       IsVisible="{Binding HasDiagnosticsSnapshotStatus}"/>
                        </StackPanel>
                        <Button Grid.Column="1"
                                Command="{Binding CopyDiagnosticsSnapshotCommand}"
                                Background="#1B263B"
                                Foreground="#D7BA7D"
                                BorderBrush="#D7BA7D"
                                BorderThickness="1"
                                FontWeight="SemiBold"
                                Padding="14,8"
                                CornerRadius="6"
                                VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="📋"/>
                                <TextBlock Text="Copy Snapshot"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <Separator Background="#1B263B" Height="1"/>

                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="Redline Performance Test" FontWeight="SemiBold" Foreground="#E0E1DD"/>
                            <TextBlock Text="4-phase stress test: Dual Deck → Chaos Blend → 4-Deck Saturation → Vector Sweep" 
                                       Foreground="#778DA9" FontSize="11" TextWrapping="Wrap"/>
                        </StackPanel>
                        <Button Grid.Column="1" 
                                Name="OpenDiagnosticsPanelButton"
                                Background="#00D4FF" 
                                Foreground="#0D1B2A"
                                FontWeight="Bold"
                                Padding="16,8"
                                CornerRadius="6"
                                VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="🚀"/>
                                <TextBlock Text="Open Diagnostics"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Strategy Command Center -->
            <Border Background="#252526" CornerRadius="8" Padding="20" BorderBrush="#3E3E3E" BorderThickness="1">
                <StackPanel Spacing="16">
                    <StackPanel Spacing="4">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="🎯" FontSize="20" VerticalAlignment="Center"/>
                            <TextBlock Text="Search Strategy" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                        </StackPanel>
                        <TextBlock Text="Choose how ORBIT prioritizes search results. This replaces the old slider system." 
                                   Foreground="#AAA" FontSize="12"/>
                    </StackPanel>

                    <ItemsControl ItemsSource="{Binding Strategies}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Spacing="12"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.SelectStrategyCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="0"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch">
                                    <controls:StrategyCard Title="{Binding Title}"
                                                           Description="{Binding Description}"
                                                           Icon="{Binding Icon}"
                                                           IsSelected="{Binding IsSelected}"
                                                           HorizontalAlignment="Stretch"/>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Safety Gates ─────────────────────────────────── -->
                    <Separator Background="#3E3E3E" Height="1"/>
                    <StackPanel Spacing="4">
                        <TextBlock Text="Safety Gates" FontSize="13" FontWeight="SemiBold" Foreground="#DDD"/>
                        <TextBlock Text="Strict rules applied before ranking — candidates failing any enabled gate are rejected."
                                   Foreground="#888" FontSize="11" TextWrapping="Wrap"/>
                    </StackPanel>
                    <Grid ColumnDefinitions="*,Auto" Margin="0,2">
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="File Integrity" Foreground="#DDD" FontSize="12"/>
                            <TextBlock Text="Reject fake FLAC / upscaled MP3 files" Foreground="#888" FontSize="10"/>
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsChecked="{Binding EnforceFileIntegrity, Mode=TwoWay}" VerticalAlignment="Center"/>
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto" Margin="0,2">
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="Strict Title Match" Foreground="#DDD" FontSize="12"/>
                            <TextBlock Text="Reject if filename doesn't contain all query tokens" Foreground="#888" FontSize="10"/>
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsChecked="{Binding EnforceStrictTitleMatch, Mode=TwoWay}" VerticalAlignment="Center"/>
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto" Margin="0,2">
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="Duration Match" Foreground="#DDD" FontSize="12"/>
                            <TextBlock Text="Reject if track duration differs significantly from target" Foreground="#888" FontSize="10"/>
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsChecked="{Binding EnforceDurationMatch, Mode=TwoWay}" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Soulseek Connection -->
            <Border Background="#0D1117" CornerRadius="8" Padding="20" BorderBrush="#0078D4" BorderThickness="1">
                <StackPanel Spacing="16">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="4">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="🌐" FontSize="20" VerticalAlignment="Center"/>
                                <TextBlock Text="Soulseek Connection" FontSize="16" FontWeight="SemiBold" Foreground="#0078D4"/>
                            </StackPanel>
                            <TextBlock Text="Manage your connection to the Soulseek peer-to-peer network for music sharing and downloads."
                                       Foreground="#666" FontSize="12" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>

                    <Separator Background="#1A2F3A" Height="1"/>

                    <!-- Username -->
                    <Grid ColumnDefinitions="140,*">
                        <TextBlock Grid.Column="0" Text="Username:" VerticalAlignment="Center" Foreground="#DDD"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding SoulseekUsername, Mode=TwoWay}"
                                 Watermark="Your Soulseek username"
                                 Background="#1E1E1E"/>
                    </Grid>

                    <!-- Connection Options -->
                    <StackPanel Spacing="8">
                        <CheckBox Content="Auto-connect on startup"
                                  IsChecked="{Binding SoulseekAutoConnectEnabled, Mode=TwoWay}"
                                  Foreground="#AAA"/>
                        <CheckBox Content="Remember password"
                                  IsChecked="{Binding SoulseekRememberPassword, Mode=TwoWay}"
                                  Foreground="#AAA"/>
                    </StackPanel>

                    <!-- Connection Buttons -->
                    <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Left">
                        <Button Command="{Binding SoulseekConnectCommand}"
                                Background="#0078D4"
                                Foreground="White"
                                Padding="16,8"
                                IsEnabled="{Binding SoulseekIsDisconnected}">
                            <TextBlock Text="Connect" FontSize="12" FontWeight="SemiBold"/>
                        </Button>

                        <Button Command="{Binding SoulseekDisconnectCommand}"
                                Background="#2D2D2D"
                                Foreground="#FF5555"
                                BorderBrush="#FF5555"
                                BorderThickness="1"
                                Padding="16,8"
                                IsEnabled="{Binding SoulseekIsConnected}">
                            <TextBlock Text="Disconnect" FontSize="12" FontWeight="SemiBold"/>
                        </Button>

                        <Button Command="{Binding SoulseekReconnectCommand}"
                                Background="#FFA500"
                                Foreground="White"
                                Padding="16,8"
                                IsEnabled="{Binding SoulseekIsConnected}">
                            <TextBlock Text="Reconnect" FontSize="12" FontWeight="SemiBold"/>
                        </Button>
                    </StackPanel>

                    <!-- Connection status feedback -->
                    <TextBlock Text="{Binding SoulseekConnectionStatusText}"
                               Foreground="#FFB347"
                               FontSize="12"
                               TextWrapping="Wrap"
                               IsVisible="{Binding SoulseekConnectionStatusText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                </StackPanel>
            </Border>

            <!-- Save Button -->
            <Button Command="{Binding SaveSettingsCommand}"
                    Classes="primary"
                    HorizontalAlignment="Left"
                    Padding="24,12">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="💾" FontSize="16"/>
                    <TextBlock Text="Save Settings" FontSize="14" FontWeight="SemiBold"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </ScrollViewer>
</UserControl>
