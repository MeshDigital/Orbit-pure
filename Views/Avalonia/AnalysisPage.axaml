<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:SLSKDONET.ViewModels"
             xmlns:models="clr-namespace:SLSKDONET.Models"
             xmlns:controls="clr-namespace:SLSKDONET.Views.Avalonia.Controls"
             xmlns:avConverters="clr-namespace:SLSKDONET.Views.Avalonia.Converters"
             mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="800"
             x:Class="SLSKDONET.Views.Avalonia.AnalysisPage"
             x:DataType="vm:AnalysisPageViewModel"
             Background="#1A1A1A" Foreground="White">

    <UserControl.Styles>

        <!-- ── Chip / badge ─────────────────────────────────────────────────── -->
        <Style Selector="Border.chip">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="Margin" Value="3,2"/>
        </Style>

        <!-- ── Queue / library row ──────────────────────────────────────────── -->
        <Style Selector="Border.trackRow">
            <Setter Property="Background" Value="#242424"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>
        <Style Selector="Border.trackRow:pointerover">
            <Setter Property="Background" Value="#2E2E2E"/>
        </Style>

        <!-- ── Primary action button ────────────────────────────────────────── -->
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="#1DB954"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="16,8"/>
        </Style>
        <Style Selector="Button.primary:pointerover">
            <Setter Property="Background" Value="#1ED760"/>
        </Style>
        <Style Selector="Button.primary:disabled">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="#666666"/>
        </Style>

        <!-- ── Secondary action button ──────────────────────────────────────── -->
        <Style Selector="Button.secondary">
            <Setter Property="Background" Value="#252525"/>
            <Setter Property="Foreground" Value="#1DB954"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="BorderBrush" Value="#1DB954"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="Button.secondary:pointerover">
            <Setter Property="Background" Value="#1A2A1A"/>
        </Style>
        <Style Selector="Button.secondary:disabled">
            <Setter Property="Background" Value="#1C1C1C"/>
            <Setter Property="Foreground" Value="#444444"/>
            <Setter Property="BorderBrush" Value="#333333"/>
        </Style>

        <!-- ── Danger / remove button ───────────────────────────────────────── -->
        <Style Selector="Button.removeBtn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#FF4444"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="Button.removeBtn:pointerover">
            <Setter Property="Foreground" Value="#FF6666"/>
        </Style>

        <!-- ── Add button ───────────────────────────────────────────────────── -->
        <Style Selector="Button.addBtn">
            <Setter Property="Background" Value="#1DB954"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.addBtn:disabled">
            <Setter Property="Background" Value="#1A2A1A"/>
            <Setter Property="Foreground" Value="#1DB954"/>
            <Setter Property="Opacity" Value="0.7"/>
        </Style>

    </UserControl.Styles>

    <!-- ═══════════════════════════════════════════════════════════════════════
         Root layout: header + two-pane body
    ════════════════════════════════════════════════════════════════════════ -->
    <Grid RowDefinitions="Auto,Auto,*">

        <!-- ── Page Header ────────────────────────────────────────────────── -->
        <Border Grid.Row="0"
                Background="#161616"
                BorderBrush="#2A2A2A"
                BorderThickness="0,0,0,1"
                Padding="20,14">
            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <TextBlock Text="🔬" FontSize="22" VerticalAlignment="Center"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Audio Analysis Pipeline"
                               FontSize="18" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Queue tracks for ML analysis · Inspect results"
                               FontSize="12" Foreground="#888888"/>
                </StackPanel>

                <!-- Processing state label -->
                <Border CornerRadius="10" Padding="10,4" Margin="16,0,0,0"
                        Background="#252525">
                    <TextBlock Text="{Binding ProcessingState}"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="#1DB954"/>
                </Border>

                <!-- Queue runtime metrics (avg time · throughput · elapsed) -->
                <StackPanel Orientation="Horizontal" Spacing="20" Margin="16,0,0,0"
                            IsVisible="{Binding HasQueueMetrics}"
                            VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="AVG TIME" FontSize="9" Foreground="#555" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding AvgAnalysisTimeDisplay}" FontSize="12" Foreground="#1DB954" FontWeight="SemiBold"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="THROUGHPUT" FontSize="9" Foreground="#555" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding ThroughputDisplay}" FontSize="12" Foreground="#1DB954" FontWeight="SemiBold"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="ELAPSED" FontSize="9" Foreground="#555" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding ElapsedTimeDisplay}" FontSize="12" Foreground="#1DB954" FontWeight="SemiBold"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Margin="16,12,16,0"
                Background="#141414"
                BorderBrush="#262626"
                BorderThickness="1"
                CornerRadius="12"
                Padding="12">
            <Grid ColumnDefinitions="*,*,*,*,*">
                <Border Grid.Column="0" Background="#191919" CornerRadius="10" Padding="12,10">
                    <StackPanel Spacing="2">
                        <TextBlock Text="TRACKS" FontSize="10" Foreground="#777777" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding TotalTrackCount}" FontSize="22" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Library indexed" FontSize="11" Foreground="#8A8A8A"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Background="#132217" CornerRadius="10" Padding="12,10">
                    <StackPanel Spacing="2">
                        <TextBlock Text="ANALYZED" FontSize="10" Foreground="#7BCB95" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding AnalyzedTrackCount}" FontSize="22" FontWeight="Bold" Foreground="#D8FFE5"/>
                        <TextBlock Text="{Binding CompletionRateDisplay, StringFormat='{}{0} complete'}" FontSize="11" Foreground="#9CC9A9"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Background="#201A12" CornerRadius="10" Padding="12,10">
                    <StackPanel Spacing="2">
                        <TextBlock Text="PENDING" FontSize="10" Foreground="#D6A96F" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding PendingTrackCount}" FontSize="22" FontWeight="Bold" Foreground="#FFEAD2"/>
                        <TextBlock Text="Awaiting analysis" FontSize="11" Foreground="#C2A485"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="3" Background="#181D28" CornerRadius="10" Padding="12,10">
                    <StackPanel Spacing="2">
                        <TextBlock Text="QUEUE" FontSize="10" Foreground="#86AFFF" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding QueueTrackCount}" FontSize="22" FontWeight="Bold" Foreground="#E0E9FF"/>
                        <TextBlock Text="Ready for next run" FontSize="11" Foreground="#94A7CE"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="4" Background="#211726" CornerRadius="10" Padding="12,10">
                    <StackPanel Spacing="2">
                        <TextBlock Text="AUTOMIX" FontSize="10" Foreground="#D38BFF" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding PlaylistTrackCount}" FontSize="22" FontWeight="Bold" Foreground="#F2DEFF"/>
                        <TextBlock Text="{Binding StemsReadyCount, StringFormat='{}{0} stem-ready'}" FontSize="11" Foreground="#BE9FD1"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ── Two-pane body ─────────────────────────────────────────────── -->
        <Grid Grid.Row="2" ColumnDefinitions="1*,Auto,1*">

            <!-- ════════════════════════════════════════════════════════════
                 LEFT PANE — Track Library
            ════════════════════════════════════════════════════════════ -->
            <DockPanel Grid.Column="0" Margin="16,16,8,16" LastChildFill="True">

                <!-- Pane header -->
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10" Spacing="8">

                    <!-- Title row with "Queue All Unanalyzed" bulk-action button -->
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0"
                                   Text="📚  Track Library"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="#C0C0C0"
                                   VerticalAlignment="Center"/>
                        <Button Grid.Column="1"
                                Classes="secondary"
                                Content="＋ Queue All Unanalyzed"
                                Command="{Binding QueueAllUnanalyzedCommand}"
                                ToolTip.Tip="Add all unanalyzed visible tracks to the analysis queue"/>
                    </Grid>

                    <!-- Search bar -->
                    <TextBox Text="{Binding SearchText, Mode=TwoWay}"
                             Watermark="Search by title or artist…"
                             Background="#242424"
                             BorderBrush="#3A3A3A"
                             BorderThickness="1"
                             CornerRadius="6"
                             Padding="10,6"
                             Foreground="White"
                             CaretBrush="White"
                             FontSize="12"/>
                </StackPanel>

                <!-- Track list (scrollable) -->
                <ScrollViewer DockPanel.Dock="Top" VerticalScrollBarVisibility="Auto">
                    <Panel>
                        <!-- Empty state: shown when search returns no results -->
                        <Border IsVisible="{Binding IsLibraryEmpty}"
                                Padding="24,40"
                                HorizontalAlignment="Stretch">
                            <StackPanel HorizontalAlignment="Center" Spacing="8">
                                <TextBlock Text="🔍" FontSize="32"
                                           HorizontalAlignment="Center" Opacity="0.4"/>
                                <TextBlock Text="No tracks match your search"
                                           FontSize="13" Foreground="#555555"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Try a different title or artist name"
                                           FontSize="11" Foreground="#444444"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Track list -->
                        <ItemsControl ItemsSource="{Binding FilteredLibraryTracks}"
                                      IsVisible="{Binding !IsLibraryEmpty}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VirtualizingStackPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Classes="trackRow">
                                        <Grid ColumnDefinitions="*,Auto">

                                            <!-- Track metadata -->
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2">
                                                <TextBlock Text="{Binding Title}"
                                                           FontSize="13" FontWeight="SemiBold"
                                                           Foreground="White"/>
                                                <TextBlock Text="{Binding Artist}"
                                                           FontSize="11" Foreground="#888888"/>
                                                <!-- BPM / Key / Analysed badges -->
                                                <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,3,0,0">
                                                    <Border Classes="chip"
                                                            Background="{Binding Bpm, Converter={StaticResource BpmBackgroundConverter}}"
                                                            IsVisible="{Binding Bpm, Converter={x:Static ObjectConverters.IsNotNull}}">
                                                        <TextBlock FontSize="10"
                                                                   Foreground="{Binding Bpm, Converter={StaticResource BpmForegroundConverter}}">
                                                            <Run Text="{Binding Bpm, StringFormat='{}{0:F0} BPM'}"/>
                                                        </TextBlock>
                                                    </Border>
                                                    <Border Classes="chip" Background="#1A2233"
                                                            IsVisible="{Binding MusicalKey, Converter={x:Static ObjectConverters.IsNotNull}}">
                                                        <TextBlock Text="{Binding MusicalKey}"
                                                                   FontSize="10" Foreground="#64B5F6"/>
                                                    </Border>
                                                    <Border Classes="chip" Background="#1A2A1A"
                                                            IsVisible="{Binding HasAnalysis}">
                                                        <TextBlock Text="✓ Analysed"
                                                                   FontSize="10" Foreground="#66BB6A"/>
                                                    </Border>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- Add to Queue button: shows ✓ and is disabled when already queued -->
                                            <Button Grid.Column="1"
                                                    Classes="addBtn"
                                                    Content="{Binding IsInQueue, Converter={StaticResource BoolToStringConverter}, ConverterParameter='✓|＋'}"
                                                    IsEnabled="{Binding !IsInQueue}"
                                                    VerticalAlignment="Center"
                                                    ToolTip.Tip="{Binding IsInQueue, Converter={StaticResource BoolToStringConverter}, ConverterParameter='Already queued|Add to analysis queue'}"
                                                    Command="{Binding $parent[UserControl].DataContext.AddToQueueCommand}"
                                                    CommandParameter="{Binding}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Panel>
                </ScrollViewer>
            </DockPanel>

            <!-- ── Divider ────────────────────────────────────────────────── -->
            <Rectangle Grid.Column="1" Width="1"
                       Fill="#2A2A2A"
                       VerticalAlignment="Stretch"
                       Margin="0,16"/>

            <!-- ════════════════════════════════════════════════════════════
                 RIGHT PANE — Analysis Queue
            ════════════════════════════════════════════════════════════ -->
            <DockPanel Grid.Column="2" Margin="8,16,16,16" LastChildFill="True">

                <!-- Pane header + Start button -->
                <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto,Auto" Margin="0,0,0,6">
                    <StackPanel Grid.Column="0" Spacing="2">
                        <TextBlock Text="🧪  Analysis Queue"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="#C0C0C0"
                                   VerticalAlignment="Center"/>
                        <!-- Queue metrics summary -->
                        <TextBlock Text="{Binding QueueMetricsSummary}"
                                   FontSize="11" Foreground="#666"
                                   IsVisible="{Binding QueueMetricsSummary,
                                       Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Classes="primary"
                            Content="▶  Start Analysis"
                            IsEnabled="{Binding CanStartAnalysis}"
                            Command="{Binding StartAnalysisCommand}"
                            ToolTip.Tip="Start processing all queued tracks"
                            Margin="0,0,8,0"/>

                    <Button Grid.Column="2"
                            Classes="secondary"
                            Content="✨ Build Automix"
                            IsEnabled="{Binding CanCreateAutomix}"
                            Command="{Binding CreateAutomixCommand}"
                            ToolTip.Tip="Build a staged BPM-ordered automix from analyzed tracks"/>
                </Grid>

                <!-- Processing indicator banner -->
                <Border DockPanel.Dock="Top"
                        Background="#0D2A1A"
                        BorderBrush="#1DB954"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12,8"
                        Margin="0,0,0,8"
                        IsVisible="{Binding IsProcessing}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="⏳" FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock Text="Processing tracks…"
                                   FontSize="12" Foreground="#1DB954"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border DockPanel.Dock="Top"
                        Background="#161A22"
                        BorderBrush="#293042"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12,9"
                        Margin="0,0,0,8">
                    <StackPanel Spacing="4">
                        <TextBlock Text="🎛  Automix staging"
                                   FontSize="12" FontWeight="SemiBold" Foreground="#D9E4FF"/>
                        <TextBlock Text="{Binding AutomixSelectionSummary}"
                                   FontSize="11" Foreground="#93A2C2"/>
                        <TextBlock Text="{Binding AutomixStatusMessage}"
                                   FontSize="11" Foreground="#1DB954"
                                   IsVisible="{Binding AutomixStatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                    </StackPanel>
                </Border>

                <!-- Queue items -->
                <ScrollViewer DockPanel.Dock="Top" VerticalScrollBarVisibility="Auto">
                    <Panel>

                        <!-- Empty state: shown when nothing has been staged yet -->
                        <Border IsVisible="{Binding IsQueueEmpty}"
                                Padding="24,40"
                                HorizontalAlignment="Stretch">
                            <StackPanel HorizontalAlignment="Center" Spacing="8">
                                <TextBlock Text="🧪" FontSize="32"
                                           HorizontalAlignment="Center" Opacity="0.4"/>
                                <TextBlock Text="Your analysis queue is empty"
                                           FontSize="13" Foreground="#555555"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text='Click ＋ on a track or use "Queue All Unanalyzed"'
                                           FontSize="11" Foreground="#444444"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <ItemsControl ItemsSource="{Binding AnalysisQueue}"
                                      IsVisible="{Binding !IsQueueEmpty}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VirtualizingStackPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Classes="trackRow">
                                        <StackPanel Spacing="6">

                                            <!-- Track info row -->
                                            <Grid ColumnDefinitions="*,Auto">
                                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Title}"
                                                               FontSize="13" FontWeight="SemiBold"
                                                               Foreground="White"/>
                                                    <TextBlock Text="{Binding Artist}"
                                                               FontSize="11" Foreground="#888888"/>
                                                </StackPanel>

                                                <!-- Status icon + remove button -->
                                                <StackPanel Grid.Column="1"
                                                            Orientation="Horizontal"
                                                            Spacing="6"
                                                            VerticalAlignment="Center">
                                                    <!-- Queued -->
                                                    <TextBlock Text="⏸"
                                                               FontSize="14"
                                                               VerticalAlignment="Center"
                                                               IsVisible="{Binding AnalysisStatus,
                                                                   Converter={x:Static ObjectConverters.IsNotNull}}"/>

                                                    <!-- Completed checkmark -->
                                                    <TextBlock Text="✓"
                                                               FontSize="14"
                                                               Foreground="#1DB954"
                                                               VerticalAlignment="Center"
                                                               IsVisible="{Binding IsCompleted}"/>

                                                    <Button Classes="removeBtn"
                                                            Content="✕"
                                                            IsVisible="{Binding !IsProcessing}"
                                                            Command="{Binding $parent[UserControl].DataContext.RemoveFromQueueCommand}"
                                                            CommandParameter="{Binding}"
                                                            ToolTip.Tip="Remove from queue"/>
                                                </StackPanel>
                                            </Grid>

                                            <!-- Progress bar (visible while processing) -->
                                            <StackPanel IsVisible="{Binding IsProcessing}" Spacing="3">
                                                <ProgressBar Value="{Binding ProgressPercent}"
                                                             Minimum="0" Maximum="100"
                                                             Height="4"
                                                             Foreground="#1DB954"
                                                             Background="#2A2A2A"/>
                                                <TextBlock Text="{Binding CurrentStep}"
                                                           FontSize="10"
                                                           Foreground="#888888"/>
                                            </StackPanel>

                                            <!-- ── Completed track: enriched card ── -->
                                            <StackPanel IsVisible="{Binding IsCompleted}" Spacing="6">

                                                <!-- Waveform strip (tri-band, 60px) -->
                                                <controls:WaveformControl
                                                    LowBand="{Binding WaveformLow}"
                                                    MidBand="{Binding WaveformMid}"
                                                    HighBand="{Binding WaveformHigh}"
                                                    Height="60"
                                                    IsVisible="{Binding HasWaveform}"
                                                    Margin="0,2,0,4"/>

                                                <!-- Row 1: Cue count badge + BPM confidence + Key confidence + action buttons -->
                                                <Grid ColumnDefinitions="Auto,*,*,Auto,Auto,Auto" Margin="0,0,0,4">
                                                    <!-- Cue count badge -->
                                                    <Border Grid.Column="0" Classes="chip"
                                                            Background="#1A1A2E" CornerRadius="10"
                                                            IsVisible="{Binding CueCount, Converter={x:Static avConverters:NumericConverters.IsNotZero}}"
                                                            VerticalAlignment="Center">
                                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                                            <TextBlock Text="🎯" FontSize="10"/>
                                                            <TextBlock FontSize="10" Foreground="#BB86FC">
                                                                <Run Text="{Binding CueCount}"/>
                                                                <Run Text="cues"/>
                                                            </TextBlock>
                                                        </StackPanel>
                                                    </Border>

                                                    <!-- BPM confidence bar -->
                                                    <StackPanel Grid.Column="1" Margin="8,0,4,0" VerticalAlignment="Center"
                                                                IsVisible="{Binding HasConfidenceData}">
                                                        <TextBlock Text="Tonal confidence" FontSize="9" Foreground="#555"/>
                                                        <ProgressBar Value="{Binding BpmConfidence}"
                                                                     Minimum="0" Maximum="1" Height="4"
                                                                     Foreground="#1DB954" Background="#2A2A2A"
                                                                     Margin="0,2,0,0"/>
                                                    </StackPanel>

                                                    <!-- Key confidence bar -->
                                                    <StackPanel Grid.Column="2" Margin="4,0,8,0" VerticalAlignment="Center"
                                                                IsVisible="{Binding HasConfidenceData}">
                                                        <TextBlock Text="Key confidence" FontSize="9" Foreground="#555"/>
                                                        <ProgressBar Value="{Binding KeyConfidence}"
                                                                     Minimum="0" Maximum="1" Height="4"
                                                                     Foreground="#64B5F6" Background="#2A2A2A"
                                                                     Margin="0,2,0,0"/>
                                                    </StackPanel>

                                                    <!-- Re-analyze button -->
                                                    <Button Grid.Column="3"
                                                            Classes="secondary"
                                                            Content="↺ Re-analyze"
                                                            FontSize="10" Padding="6,3"
                                                            Command="{Binding $parent[UserControl].DataContext.ReanalyzeCommand}"
                                                            CommandParameter="{Binding}"
                                                            ToolTip.Tip="Clear results and re-run analysis"
                                                            Margin="4,0,0,0"/>

                                                    <Button Grid.Column="4"
                                                            Classes="secondary"
                                                            Content="{Binding PlaylistActionLabel}"
                                                            FontSize="10" Padding="6,3"
                                                            Command="{Binding $parent[UserControl].DataContext.TogglePlaylistCommand}"
                                                            CommandParameter="{Binding}"
                                                            ToolTip.Tip="Stage or remove this track for automix"
                                                            Margin="4,0,0,0"/>

                                                    <!-- Copy JSON (developer mode only) -->
                                                    <Button Grid.Column="5"
                                                            Classes="secondary"
                                                            Content="{}{} JSON"
                                                            FontSize="10" Padding="6,3"
                                                            Command="{Binding $parent[UserControl].DataContext.CopyAnalysisJsonCommand}"
                                                            CommandParameter="{Binding}"
                                                            ToolTip.Tip="Copy full analysis JSON to clipboard"
                                                            IsVisible="{Binding $parent[UserControl].DataContext.IsDeveloperMode}"
                                                            Margin="4,0,0,0"/>
                                                </Grid>

                                                <!-- Mood bars -->
                                                <TextBlock Text="Mood Profile"
                                                           FontSize="10" Foreground="#666666"
                                                           FontWeight="SemiBold"/>
                                                <Grid ColumnDefinitions="65,*"
                                                      RowDefinitions="Auto,Auto,Auto">
                                                    <TextBlock Grid.Row="0" Grid.Column="0"
                                                               Text="😊 Happy" FontSize="10"
                                                               Foreground="#888888" VerticalAlignment="Center"/>
                                                    <ProgressBar Grid.Row="0" Grid.Column="1"
                                                                 Value="{Binding AnalysisData.Moods.Happy}"
                                                                 Minimum="0" Maximum="100" Height="5"
                                                                 Foreground="#FFD700" Background="#2A2A2A"
                                                                 Margin="0,2"/>

                                                    <TextBlock Grid.Row="1" Grid.Column="0"
                                                               Text="😤 Aggressive" FontSize="10"
                                                               Foreground="#888888" VerticalAlignment="Center"/>
                                                    <ProgressBar Grid.Row="1" Grid.Column="1"
                                                                 Value="{Binding AnalysisData.Moods.Aggressive}"
                                                                 Minimum="0" Maximum="100" Height="5"
                                                                 Foreground="#FF5252" Background="#2A2A2A"
                                                                 Margin="0,2"/>

                                                    <TextBlock Grid.Row="2" Grid.Column="0"
                                                               Text="😌 Relaxed" FontSize="10"
                                                               Foreground="#888888" VerticalAlignment="Center"/>
                                                    <ProgressBar Grid.Row="2" Grid.Column="1"
                                                                 Value="{Binding AnalysisData.Moods.Relaxed}"
                                                                 Minimum="0" Maximum="100" Height="5"
                                                                 Foreground="#64B5F6" Background="#2A2A2A"
                                                                 Margin="0,2"/>
                                                </Grid>

                                                <!-- Affective: Arousal / Valence -->
                                                <StackPanel Orientation="Horizontal" Spacing="12">
                                                    <TextBlock FontSize="10" Foreground="#888888">
                                                        <Run Text="Arousal "/>
                                                        <Run Text="{Binding AnalysisData.Affective.Arousal, StringFormat='{}{0:+0.00;-0.00}'}"
                                                             Foreground="#BB86FC"/>
                                                    </TextBlock>
                                                    <TextBlock FontSize="10" Foreground="#888888">
                                                        <Run Text="Valence "/>
                                                        <Run Text="{Binding AnalysisData.Affective.Valence, StringFormat='{}{0:+0.00;-0.00}'}"
                                                             Foreground="#BB86FC"/>
                                                    </TextBlock>
                                                </StackPanel>

                                                <!-- Genre chips -->
                                                <ItemsControl ItemsSource="{Binding AnalysisData.Genres}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <WrapPanel Orientation="Horizontal"/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Classes="chip" Background="#1A1A2E">
                                                                <TextBlock Text="{Binding Label}"
                                                                           FontSize="10"
                                                                           Foreground="#BB86FC"/>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                                <!-- Last analyzed / model version -->
                                                <TextBlock FontSize="10" Foreground="#444"
                                                           ToolTip.Tip="{Binding ModelVersion}">
                                                    <Run Text="Analyzed: "/>
                                                    <Run Text="{Binding LastAnalyzedDisplay}" Foreground="#555"/>
                                                </TextBlock>

                                            </StackPanel>

                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Panel>
                </ScrollViewer>

            </DockPanel>
        </Grid>
    </Grid>
</UserControl>
