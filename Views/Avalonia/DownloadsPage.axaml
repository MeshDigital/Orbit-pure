<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:SLSKDONET.ViewModels.Downloads"
             xmlns:m="clr-namespace:SLSKDONET.Models"
             xmlns:c="clr-namespace:SLSKDONET.Views.Avalonia.Controls"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
             x:Class="SLSKDONET.Views.Avalonia.DownloadsPage"
             x:DataType="vm:DownloadCenterViewModel"
             Background="#1E1E1E" Foreground="White">
    
    <UserControl.Styles>
        <Style Selector="Border.express">
             <Setter Property="BorderBrush" Value="#FFD700"/>
             <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="ToggleButton.profileChip">
            <Setter Property="Background" Value="#242424"/>
            <Setter Property="BorderBrush" Value="#3A3A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Foreground" Value="#D8D8D8"/>
            <Setter Property="MinWidth" Value="112"/>
        </Style>
        <Style Selector="ToggleButton.profileChip:pointerover">
            <Setter Property="Background" Value="#303030"/>
            <Setter Property="BorderBrush" Value="#4A4A4A"/>
        </Style>
        <Style Selector="ToggleButton.profileChip:checked">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>
        <Style Selector="ToggleButton.profileChip.nonStrict:checked">
            <Setter Property="Background" Value="#20322A"/>
            <Setter Property="BorderBrush" Value="#4CAF50"/>
        </Style>
        <Style Selector="ToggleButton.profileChip.strict:checked">
            <Setter Property="Background" Value="#112A3A"/>
            <Setter Property="BorderBrush" Value="#00BFFF"/>
        </Style>
        <Style Selector="ToggleButton.profileChip.stricter:checked">
            <Setter Property="Background" Value="#3A2D11"/>
            <Setter Property="BorderBrush" Value="#FFB300"/>
        </Style>
        <Style Selector="ToggleButton.sessionChip">
            <Setter Property="Background" Value="#1B1B1C"/>
            <Setter Property="BorderBrush" Value="#343436"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="999"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Foreground" Value="#AEB7BF"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style Selector="ToggleButton.sessionChip:pointerover">
            <Setter Property="Background" Value="#24282C"/>
            <Setter Property="BorderBrush" Value="#45515B"/>
        </Style>
        <Style Selector="ToggleButton.sessionChip:checked">
            <Setter Property="Background" Value="#112A3A"/>
            <Setter Property="BorderBrush" Value="#00BFFF"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </UserControl.Styles>

    <UserControl.Resources>
        <!-- Golden Row Template -->
        <DataTemplate x:Key="DownloadItemTemplate" DataType="vm:UnifiedTrackViewModel">
            <Border Background="Transparent" Margin="0,0,0,8">
                <Border.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Play" Command="{Binding PlayCommand}" IsVisible="{Binding IsCompleted}"><MenuItem.Icon><PathIcon Data="{StaticResource play_circle_regular}" Width="16" Height="16"/></MenuItem.Icon></MenuItem>
                        <MenuItem Header="Show in Explorer" Command="{Binding RevealFileCommand}" IsVisible="{Binding IsCompleted}"><MenuItem.Icon><PathIcon Data="{StaticResource folder_open_regular}" Width="16" Height="16"/></MenuItem.Icon></MenuItem>
                        <MenuItem Header="Add to Project" Command="{Binding AddToProjectCommand}" IsVisible="{Binding IsCompleted}"><MenuItem.Icon><PathIcon Data="{StaticResource add_circle_regular}" Width="16" Height="16"/></MenuItem.Icon></MenuItem>
                        <Separator/>
                        <MenuItem Header="Retry Download" Command="{Binding RetryCommand}" IsVisible="{Binding IsFailed}"><MenuItem.Icon><PathIcon Data="{StaticResource arrow_counterclockwise_regular}" Width="16" Height="16"/></MenuItem.Icon></MenuItem>
                        <MenuItem Header="Force Download (Ignore Quality Guards)" Command="{Binding ForceDownloadIgnoreGuardsCommand}" IsVisible="{Binding IsFailed}" Foreground="#00BFFF"><MenuItem.Icon><PathIcon Data="{StaticResource rocket_regular}" Width="16" Height="16" Foreground="#00BFFF"/></MenuItem.Icon></MenuItem>
                        <MenuItem Header="Remove from History" Command="{Binding CleanCommand}"><MenuItem.Icon><PathIcon Data="{StaticResource delete_regular}" Width="16" Height="16"/></MenuItem.Icon></MenuItem>
                    </ContextMenu>
                </Border.ContextMenu>

                <StackPanel Spacing="0">
                    <c:StandardTrackRow Classes="card" MinimalBadges="True"/>

                    <!-- Unified log strip: single collapsible section, visible only when there is log data -->
                    <Expander IsExpanded="{Binding IsConsoleOpen, Mode=TwoWay}"
                              IsVisible="{Binding HasIncomingResults}"
                              Margin="12,0,12,8"
                              Background="#0A0F14"
                              BorderBrush="{Binding LatestIncomingStateColor}"
                              BorderThickness="1"
                              CornerRadius="4">
                        <Expander.Header>
                            <!-- Compact single-line summary when collapsed -->
                            <Grid ColumnDefinitions="Auto,*,Auto,Auto" Margin="4,0">
                                <TextBlock Grid.Column="0"
                                           Text="{Binding SearchKnowledgeSummary}"
                                           Foreground="#7FA8C0"
                                           FontSize="10"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,0"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding LatestIncomingMessage}"
                                           Foreground="#B0C8D8"
                                           FontSize="10"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center"/>
                                <Border Grid.Column="2"
                                        Background="#1D2228"
                                        BorderBrush="{Binding LatestIncomingStateColor}"
                                        BorderThickness="1"
                                        CornerRadius="3"
                                        Padding="5,1"
                                        Margin="8,0,0,0"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{Binding LatestIncomingStateLabel}"
                                               FontSize="9" FontWeight="Bold"
                                               Foreground="{Binding LatestIncomingStateColor}"/>
                                </Border>
                                <TextBlock Grid.Column="3"
                                           Text="{Binding LatestIncomingTimeDisplay}"
                                           Foreground="#555"
                                           FontSize="9"
                                           FontFamily="Consolas,Courier New,monospace"
                                           VerticalAlignment="Center"
                                           Margin="8,0,6,0"/>
                            </Grid>
                        </Expander.Header>

                        <StackPanel Spacing="6" Margin="8,4,8,8">
                            <!-- Telemetry row — only visible inside the expanded section -->
                            <Border Background="#111820"
                                    BorderBrush="#1E2C38"
                                    BorderThickness="1"
                                    CornerRadius="3"
                                    Padding="8,5"
                                    IsVisible="{Binding HasSearchTelemetry}">
                                <WrapPanel Orientation="Horizontal">
                                    <TextBlock Text="Duration:" FontSize="10" Foreground="#5A7080" Margin="0,0,4,0"/>
                                    <TextBlock Text="{Binding SearchDurationDisplay}" FontSize="10" Foreground="#C0CDD5" FontWeight="SemiBold" Margin="0,0,14,0"/>
                                    <TextBlock Text="Time Left:" FontSize="10" Foreground="#5A7080" Margin="0,0,4,0"/>
                                    <TextBlock Text="{Binding SearchCountdownDisplay}" FontSize="10" Foreground="#8BD2FF" FontWeight="SemiBold" Margin="0,0,14,0"/>
                                    <TextBlock Text="Outcome:" FontSize="10" Foreground="#5A7080" Margin="0,0,4,0"/>
                                    <TextBlock Text="{Binding SearchOutcomeLabel}" FontSize="10" Foreground="{Binding SearchOutcomeColor}" FontWeight="Bold" Margin="0,0,14,0"/>
                                    <TextBlock Text="Results:" FontSize="10" Foreground="#5A7080" Margin="0,0,4,0"/>
                                    <TextBlock Text="{Binding SearchResultBreakdown}" FontSize="10" Foreground="#A8BAC3" Margin="0,0,14,0"/>
                                    <TextBlock Text="Path:" FontSize="10" Foreground="#5A7080" Margin="0,0,4,0"/>
                                    <TextBlock Text="{Binding SearchPathSummary}" FontSize="10" Foreground="#A8BAC3"/>
                                </WrapPanel>
                            </Border>

                            <!-- Log entries -->
                            <ItemsControl ItemsSource="{Binding IncomingResults}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#0D1318" BorderBrush="#1A2530" BorderThickness="1" CornerRadius="3" Padding="6,4" Margin="0,0,0,3">
                                            <Grid ColumnDefinitions="70,70,90,*">
                                                <TextBlock Grid.Column="0" Text="{Binding TimeDisplay}" Foreground="#8899A6" FontFamily="Consolas,Courier New,monospace" FontSize="9"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Username}" Foreground="#AFC1CC" FontSize="10" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Grid.Column="2" Text="{Binding StateLabel}" Foreground="{Binding StateColor}" FontSize="10" FontWeight="Bold"/>
                                                <TextBlock Grid.Column="3" Text="{Binding Detail}" Foreground="#C8D8E0" FontSize="10" TextWrapping="Wrap"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Expander>
                </StackPanel>
            </Border>
        </DataTemplate>
        <!-- Failed Row Template -->
        <DataTemplate x:Key="FailedDownloadItemTemplate" DataType="vm:UnifiedTrackViewModel">
             <Border Background="Transparent" Margin="0,0,0,8">
                 <Border.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Retry Download (Standard)" Command="{Binding RetryCommand}"><MenuItem.Icon><PathIcon Data="{StaticResource arrow_counterclockwise_regular}" Width="16" Height="16"/></MenuItem.Icon></MenuItem>
                        <MenuItem Header="Force Download (Ignore Quality Guards)" Command="{Binding ForceDownloadIgnoreGuardsCommand}" Foreground="#00BFFF"><MenuItem.Icon><PathIcon Data="{StaticResource rocket_regular}" Width="16" Height="16" Foreground="#00BFFF"/></MenuItem.Icon></MenuItem>
                        <MenuItem Header="View All Search Results" Command="{Binding ViewAllSearchResultsCommand}"><MenuItem.Icon><PathIcon Data="{StaticResource search_regular}" Width="16" Height="16"/></MenuItem.Icon></MenuItem>
                        <MenuItem Header="Remove from History" Command="{Binding CleanCommand}"><MenuItem.Icon><PathIcon Data="{StaticResource delete_regular}" Width="16" Height="16"/></MenuItem.Icon></MenuItem>
                        <Separator/>
                        <MenuItem Header="Copy Failure Log" Command="{Binding CopyLogCommand}"><MenuItem.Icon><PathIcon Data="{StaticResource copy_regular}" Width="16" Height="16"/></MenuItem.Icon></MenuItem>
                    </ContextMenu>
                </Border.ContextMenu>
                
                <Border Background="#252526" CornerRadius="6" Padding="12" BorderBrush="#333" BorderThickness="1">
                    <Grid ColumnDefinitions="*, Auto">
                        <StackPanel Grid.Column="0" Spacing="4">
                            <!-- Header -->
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{Binding TrackTitle}" FontWeight="Bold" Foreground="White" />
                                <TextBlock Text="•" Foreground="#444"/>
                                <TextBlock Text="{Binding ArtistName}" Foreground="#AAA" />
                            </StackPanel>
                            
                            <!-- Diagnostics -->
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                <!-- Error Badge -->
                                <Border Background="#2C1F1F" CornerRadius="4" Padding="8,4" BorderBrush="#501B1B" BorderThickness="1">
                                     <StackPanel Orientation="Horizontal" Spacing="6">
                                         <TextBlock Text="⚠️" FontSize="10" VerticalAlignment="Center"/>
                                         <TextBlock Text="{Binding FailureDisplayMessage}" Foreground="#FF5252" FontSize="11" FontWeight="SemiBold"/>
                                     </StackPanel>
                                </Border>
                                
                                <!-- Suggestion -->
                                <TextBlock Text="{Binding FailureActionSuggestion}" 
                                           Foreground="#888" 
                                           FontSize="11" 
                                           VerticalAlignment="Center"
                                           FontStyle="Italic"/>
 
                                <!-- Synergy Badge -->
                                <Border Background="#1A1F2C" CornerRadius="4" Padding="6,2" BorderBrush="#00BFFF" BorderThickness="1" IsVisible="{Binding HasCrossProjectReference}">
                                     <StackPanel Orientation="Horizontal" Spacing="6">
                                         <TextBlock Text="🔗" FontSize="10" VerticalAlignment="Center"/>
                                         <TextBlock Text="FOUND IN:" FontSize="9" Foreground="#00BFFF" FontWeight="Black" VerticalAlignment="Center"/>
                                         <TextBlock Text="{Binding CrossProjectReference}" FontSize="10" Foreground="#00BFFF" FontWeight="Bold" VerticalAlignment="Center" MaxWidth="150" TextTrimming="CharacterEllipsis"/>
                                         <Button Command="{Binding AddToProjectCommand}" Background="#00BFFF" Foreground="Black" Padding="8,2" CornerRadius="3">
                                             <TextBlock Text="ADD TO CURRENT" FontSize="9" FontWeight="Black"/>
                                         </Button>
                                     </StackPanel>
                                </Border>
 
                                <TextBlock Text="•" Foreground="#333" VerticalAlignment="Center" IsVisible="{Binding !HasCrossProjectReference}"/>
 
                                <!-- Forensic Summary -->
                                <TextBlock Text="{Binding RejectionSummary}" 
                                           Foreground="#00BFFF" 
                                           FontSize="10" 
                                           VerticalAlignment="Center"
                                           Opacity="0.8"/>
                            </StackPanel>

                            <!-- Per-track log: single collapsible strip, only when log data exists -->
                            <Expander IsExpanded="{Binding IsConsoleOpen, Mode=TwoWay}"
                                      IsVisible="{Binding HasIncomingResults}"
                                      Margin="0,6,0,0"
                                      Background="#0A0F14"
                                      BorderBrush="{Binding LatestIncomingStateColor}"
                                      BorderThickness="1"
                                      CornerRadius="4">
                                <Expander.Header>
                                    <Grid ColumnDefinitions="Auto,*,Auto,Auto" Margin="4,0">
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding SearchKnowledgeSummary}"
                                                   Foreground="#7FA8C0"
                                                   FontSize="10"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,10,0"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding LatestIncomingMessage}"
                                                   Foreground="#B0C8D8"
                                                   FontSize="10"
                                                   TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center"/>
                                        <Border Grid.Column="2"
                                                Background="#1D2228"
                                                BorderBrush="{Binding LatestIncomingStateColor}"
                                                BorderThickness="1"
                                                CornerRadius="3"
                                                Padding="5,1"
                                                Margin="8,0,0,0"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding LatestIncomingStateLabel}"
                                                       FontSize="9" FontWeight="Bold"
                                                       Foreground="{Binding LatestIncomingStateColor}"/>
                                        </Border>
                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding LatestIncomingTimeDisplay}"
                                                   Foreground="#555"
                                                   FontSize="9"
                                                   FontFamily="Consolas,Courier New,monospace"
                                                   VerticalAlignment="Center"
                                                   Margin="8,0,6,0"/>
                                    </Grid>
                                </Expander.Header>
                                <StackPanel Spacing="6" Margin="8,4,8,8">
                                    <Border Background="#111820" BorderBrush="#1E2C38" BorderThickness="1" CornerRadius="3" Padding="8,5" IsVisible="{Binding HasSearchTelemetry}">
                                        <WrapPanel Orientation="Horizontal">
                                            <TextBlock Text="Duration:" FontSize="10" Foreground="#5A7080" Margin="0,0,4,0"/>
                                            <TextBlock Text="{Binding SearchDurationDisplay}" FontSize="10" Foreground="#C0CDD5" FontWeight="SemiBold" Margin="0,0,14,0"/>
                                            <TextBlock Text="Time Left:" FontSize="10" Foreground="#5A7080" Margin="0,0,4,0"/>
                                            <TextBlock Text="{Binding SearchCountdownDisplay}" FontSize="10" Foreground="#8BD2FF" FontWeight="SemiBold" Margin="0,0,14,0"/>
                                            <TextBlock Text="Outcome:" FontSize="10" Foreground="#5A7080" Margin="0,0,4,0"/>
                                            <TextBlock Text="{Binding SearchOutcomeLabel}" FontSize="10" Foreground="{Binding SearchOutcomeColor}" FontWeight="Bold" Margin="0,0,14,0"/>
                                            <TextBlock Text="Results:" FontSize="10" Foreground="#5A7080" Margin="0,0,4,0"/>
                                            <TextBlock Text="{Binding SearchResultBreakdown}" FontSize="10" Foreground="#A8BAC3" Margin="0,0,14,0"/>
                                            <TextBlock Text="Path:" FontSize="10" Foreground="#5A7080" Margin="0,0,4,0"/>
                                            <TextBlock Text="{Binding SearchPathSummary}" FontSize="10" Foreground="#A8BAC3"/>
                                        </WrapPanel>
                                    </Border>
                                    <ItemsControl ItemsSource="{Binding IncomingResults}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#0D1318" BorderBrush="#1A2530" BorderThickness="1" CornerRadius="3" Padding="6,4" Margin="0,0,0,3">
                                                    <Grid ColumnDefinitions="70,70,90,*">
                                                        <TextBlock Grid.Column="0" Text="{Binding TimeDisplay}" Foreground="#8899A6" FontFamily="Consolas,Courier New,monospace" FontSize="9"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding Username}" Foreground="#AFC1CC" FontSize="10" TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding StateLabel}" Foreground="{Binding StateColor}" FontSize="10" FontWeight="Bold"/>
                                                        <TextBlock Grid.Column="3" Text="{Binding Detail}" Foreground="#C8D8E0" FontSize="10" TextWrapping="Wrap"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Expander>

                            <TextBlock Text="{Binding DetailedStatusText}"
                                       Foreground="#8FA0AA"
                                       FontSize="10"
                                       Margin="0,4,0,0"
                                       TextWrapping="Wrap"
                                       IsVisible="{Binding !HasIncomingResults}"/>
 
                            <!-- Phase 0.5: Detailed Rejection Reasons -->
                            <StackPanel IsVisible="{Binding HasRejectionDetails}" Margin="0,8,0,0">
                                 <TextBlock Text="Top Rejection Reasons:" FontSize="10" Foreground="#666" Margin="0,0,0,2"/>
                                 <ItemsControl ItemsSource="{Binding RejectionDetails}">
                                     <ItemsControl.ItemTemplate>
                                         <DataTemplate>
                                             <Grid ColumnDefinitions="20, *" RowDefinitions="Auto, Auto" Margin="0,3">
                                                 <!-- Rank -->
                                                 <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding Rank, StringFormat='{}#{0}'}" Foreground="#555" FontSize="11" VerticalAlignment="Top" Margin="0,1,0,0"/>
                                                 
                                                 <!-- Top Row: Reason + Score + Tech Stats -->
                                                 <Grid Grid.Row="0" Grid.Column="1" ColumnDefinitions="*, Auto, Auto">
                                                     <TextBlock Grid.Column="0" Text="{Binding ShortReason}" Foreground="{Binding ReasonColor}" FontSize="11" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                                     
                                                     <!-- Phase 1.0: Search Score Indicator -->
                                                     <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" Margin="8,0" VerticalAlignment="Center">
                                                         <Border Background="#222" CornerRadius="3" Width="60" Height="6" VerticalAlignment="Center">
                                                             <Border Background="{Binding ScoreColor}" CornerRadius="3" HorizontalAlignment="Left"
                                                                     Width="{Binding SearchScore, Converter={StaticResource PercentToWidthConverter}, ConverterParameter=60}"/>
                                                         </Border>
                                                         <TextBlock Text="{Binding SearchScore, StringFormat='{}{0:0}%'}" Foreground="#AAA" FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                                                     </StackPanel>
                                                     
                                                     <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" Margin="8,0,0,0">
                                                          <TextBlock Text="{Binding Bitrate, StringFormat='{}{0}kbps'}" Foreground="#888" FontSize="11"/>
                                                          <TextBlock Text="{Binding Artist}" FontWeight="SemiBold" Foreground="#1DB954" FontSize="11"/>
                                                          <TextBlock Text=" - " Foreground="#444" FontSize="11"/>
                                                          <TextBlock Text="{Binding Title}" Foreground="#EEE" FontSize="11"/>
                                                          <TextBlock Text="{Binding Username, StringFormat='{}@{0}'}" Foreground="#555" FontSize="11"/>
                                                     </StackPanel>
                                                  </Grid>
 
                                                  <!-- Bottom Row: Filename (Subtle) -->
                                                  <TextBlock Grid.Row="1" Grid.Column="1" 
                                                             Text="{Binding Filename}" 
                                                             Foreground="#444" FontStyle="Italic" FontSize="9" 
                                                             TextTrimming="CharacterEllipsis" Margin="0,1,0,0"
                                                             ToolTip.Tip="{Binding Filename}"/>
                                             </Grid>
                                         </DataTemplate>
                                     </ItemsControl.ItemTemplate>
                                 </ItemsControl>
                            </StackPanel>
                        </StackPanel>
                        
                        <!-- Action -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <!-- View Log Button (Micro) -->
                            <Button Command="{Binding ViewLogCommand}" 
                                    Background="Transparent" 
                                    BorderThickness="0"
                                    ToolTip.Tip="View Diagnostic Log"
                                    IsVisible="{Binding HasRejectionDetails}">
                                <PathIcon Data="{StaticResource document_text_regular}" Width="14" Height="14" Foreground="#666"/>
                            </Button>
                            
                            <Button Command="{Binding RetryCommand}" 
                                    Background="Transparent" 
                                    BorderThickness="1" BorderBrush="#2E7D32" 
                                    Foreground="#4CAF50"
                                    Padding="12,6" 
                                    CornerRadius="4">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <PathIcon Data="{StaticResource arrow_counterclockwise_regular}" Width="14" Height="14" Foreground="#4CAF50"/>
                                    <TextBlock Text="Retry" FontSize="12" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
            </Border>
        </DataTemplate>
    </UserControl.Resources>
    
    <Grid RowDefinitions="Auto,*">
        
        <!-- Header: Control Center Dashboard -->
        <Border Grid.Row="0" Background="#1E1E1E" BorderBrush="#3E3E3E" BorderThickness="0,0,0,1">
            <StackPanel>
                <!-- Master Status Bar (Ultra Slim) -->
                <Border Height="2" Background="{Binding EngineStatusColor}" Opacity="0.6">
                    <Border.Styles>
                        <Style Selector="Border">
                             <Style.Animations>
                                 <Animation Duration="0:0:3" IterationCount="Infinite">
                                     <KeyFrame KeyTime="0:0:0"><Setter Property="Opacity" Value="0.2"/></KeyFrame>
                                     <KeyFrame KeyTime="0:0:1.5"><Setter Property="Opacity" Value="0.8"/></KeyFrame>
                                     <KeyFrame KeyTime="0:0:3"><Setter Property="Opacity" Value="0.2"/></KeyFrame>
                                 </Animation>
                             </Style.Animations>
                        </Style>
                    </Border.Styles>
                </Border>

                <Border Padding="16,8">
                    <Grid ColumnDefinitions="*, Auto">
                    <StackPanel Spacing="6">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="DOWNLOAD CENTER" FontSize="11" FontWeight="Black" Foreground="#666" LetterSpacing="2" VerticalAlignment="Center"/>
                            <Border Background="{Binding EngineStatusColor}" CornerRadius="12" Padding="8,2" BorderBrush="#333" BorderThickness="1">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="{Binding EngineStatusIcon}" FontSize="10" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding EngineStatusText}" FontSize="10" FontWeight="Bold" Foreground="Black" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            
                            <!-- Phase 2: Live Engine Telemetry -->
                            <StackPanel Orientation="Horizontal" Spacing="10" Margin="4,0,0,0">
                                <TextBlock Text="|" Foreground="#252526" VerticalAlignment="Center"/>
                                
                                <!-- SoulSeek Pulse -->
                                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                    <Ellipse Width="6" Height="6" Fill="{Binding IsSoulseekConnected, Converter={StaticResource BoolToColorConverter}}" VerticalAlignment="Center"/>
                                    <TextBlock Text="SoulSeek:" FontSize="10" Foreground="#555" VerticalAlignment="Center"/>
                                    <Panel VerticalAlignment="Center">
                                        <TextBlock Text="CONNECTED" FontSize="10" FontWeight="Black" Foreground="#4CAF50" IsVisible="{Binding IsSoulseekConnected}"/>
                                        <TextBlock Text="OFFLINE" FontSize="10" FontWeight="Black" Foreground="#FF5252" IsVisible="{Binding !IsSoulseekConnected}"/>
                                    </Panel>
                                    
                                    <!-- Backoff Countdown -->
                                    <Border Background="#3D2600" CornerRadius="4" Padding="6,2" BorderBrush="#664400" BorderThickness="1" IsVisible="{Binding IsBackingOff}">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <TextBlock Text="RETRY IN" FontSize="9" Foreground="#FFA500" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding BackoffSeconds}" FontSize="10" FontWeight="Black" Foreground="#FFA500" VerticalAlignment="Center"/>
                                            <TextBlock Text="s" FontSize="9" Foreground="#FFA500" VerticalAlignment="Center" Margin="-2,0,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                            </StackPanel>
                        </StackPanel>
                    
                    <StackPanel Orientation="Horizontal" Spacing="18">
                            <!-- Global Metrics -->
                            <StackPanel Spacing="2">
                                <TextBlock Text="THROUGHPUT" FontSize="9" FontWeight="Bold" Foreground="#555"/>
                                <TextBlock Text="{Binding GlobalSpeed}" FontSize="16" FontWeight="SemiBold" Foreground="#00BCD4"/>
                            </StackPanel>

                            <StackPanel Spacing="2">
                                <TextBlock Text="ACTIVE SESSIONS" FontSize="9" FontWeight="Bold" Foreground="#555"/>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="{Binding DownloadingCount}" FontSize="16" FontWeight="Bold" Foreground="White"/>
                                    <TextBlock Text="/" FontSize="12" Foreground="#444" VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                                    <TextBlock Text="{Binding MaxConcurrentDownloads}" FontSize="12" Foreground="#888" VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Spacing="2">
                                <TextBlock Text="SEARCHING" FontSize="9" FontWeight="Bold" Foreground="#555"/>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                     <TextBlock Text="{Binding SearchingCount}" FontSize="16" FontWeight="Bold" Foreground="#4EC9B0"/>
                                     <PathIcon Data="{StaticResource search_regular}" Width="12" Height="12" Foreground="#4EC9B0" VerticalAlignment="Center" Margin="0,3,0,0" Opacity="0.5"/>
                                </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Control Deck -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="6">
                        <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right">
                             <!-- Start/Stop/Pause -->
                             <Button Command="{Binding StartEngineCommand}" IsVisible="{Binding !IsEngineRunning}"
                                     Background="#4CAF50" Foreground="White" Padding="12,6" CornerRadius="6">
                                 <StackPanel Orientation="Horizontal" Spacing="8">
                                     <PathIcon Data="{StaticResource play_regular}" Width="14" Height="14"/>
                                     <TextBlock Text="START ENGINE" FontWeight="Bold" FontSize="11"/>
                                 </StackPanel>
                             </Button>

                             <Button Command="{Binding ToggleEnginePauseCommand}" IsVisible="{Binding IsEngineRunning}"
                                     Background="#333" BorderBrush="#FFA500" BorderThickness="1" Foreground="#FFA500" Padding="10,6" CornerRadius="6">
                                 <TextBlock Text="{Binding IsEnginePaused, Converter={StaticResource BoolToTextConverter}, ConverterParameter='RESUME|PAUSE'}" 
                                            FontWeight="Bold" FontSize="11"/>
                             </Button>

                             <Button Command="{Binding StopEngineCommand}" IsVisible="{Binding IsEngineRunning}"
                                     Background="#2D2D2D" Foreground="#FF5252" Padding="10,6" CornerRadius="6">
                                 <PathIcon Data="{StaticResource dismiss_regular}" Width="14" Height="14"/>
                             </Button>

                             <ToggleButton IsChecked="{Binding ShowEngineLogs}" 
                                           Background="#2D2D2D" BorderBrush="#444" BorderThickness="1" Padding="10,6" CornerRadius="6">
                                 <PathIcon Data="{StaticResource document_text_regular}" Width="14" Height="14" Foreground="#888"/>
                             </ToggleButton>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                             <TextBlock Text="CONCURRENCY" FontSize="9" Foreground="#555" VerticalAlignment="Center"/>
                             <Slider Width="108" Minimum="1" Maximum="20" Value="{Binding MaxConcurrentDownloads}" TickFrequency="1" IsSnapToTickEnabled="True"/>
                             <TextBlock Text="{Binding MaxConcurrentDownloads}" FontSize="11" FontWeight="Bold" Foreground="#00BFFF" Width="18" TextAlignment="Center"/>

                            <TextBlock Text="PROFILE" FontSize="9" Foreground="#555" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right">
                                <ToggleButton Classes="profileChip nonStrict" IsChecked="{Binding DownloadProfileNonStrict, Mode=TwoWay}" ToolTip.Tip="Non-Strict: FLAC + MP3">
                                    <TextBlock Text="Non-Strict" FontSize="10" FontWeight="SemiBold"/>
                                </ToggleButton>
                                <ToggleButton Classes="profileChip strict" IsChecked="{Binding DownloadProfileStrict, Mode=TwoWay}" ToolTip.Tip="Strict: Lossless Focus">
                                    <TextBlock Text="Strict" FontSize="10" FontWeight="SemiBold"/>
                                </ToggleButton>
                                <ToggleButton Classes="profileChip stricter" IsChecked="{Binding DownloadProfileStricter, Mode=TwoWay}" ToolTip.Tip="Stricter: FLAC Only">
                                    <TextBlock Text="Stricter" FontSize="10" FontWeight="SemiBold"/>
                                </ToggleButton>
                            </StackPanel>
                        </StackPanel>
                        <TextBlock Text="{Binding DownloadProfileModeText}" FontSize="10" Foreground="#768592" HorizontalAlignment="Right"/>
                </StackPanel>
                </Grid>
            </Border>
        </StackPanel>
    </Border>

        <!-- Phase 12.3: Bulk Selection Action Bar (Overlay) -->
        <Border Grid.Row="0" Background="#007ACC" Padding="24,20" BorderBrush="#005A9E" BorderThickness="0,0,0,1" IsVisible="{Binding HasSelection}">
            <Grid ColumnDefinitions="Auto, *, Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="16">
                    <TextBlock Text="{Binding SelectedItems.Count}" FontSize="28" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                    <TextBlock Text="selected" FontSize="18" Foreground="#E0E0E0" VerticalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="12">
                    <Button Command="{Binding VipStartSelectedCommand}"
                            Background="White"
                            Foreground="#007ACC"
                            Padding="16,8"
                            CornerRadius="6"
                            FontWeight="Bold">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="🚀" FontSize="16"/>
                            <TextBlock Text="VIP Start" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    
                    <Button Command="{Binding ResumeSelectedCommand}"
                            Background="#4CAF50"
                            Foreground="White"
                            Padding="16,8"
                            CornerRadius="6"
                            FontWeight="Bold">
                         <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="▶" FontSize="14"/>
                            <TextBlock Text="Resume" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    
                    <Button Command="{Binding PauseSelectedCommand}"
                            Background="#FFB74D"
                            Foreground="#4E342E" 
                            Padding="16,8"
                            CornerRadius="6"
                            FontWeight="Bold">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="⏸" FontSize="14"/>
                            <TextBlock Text="Pause" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding CancelSelectedCommand}"
                            Background="#D32F2F"
                            Foreground="White"
                            Padding="16,8"
                            CornerRadius="6"
                            FontWeight="Bold">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="✖" FontSize="14"/>
                            <TextBlock Text="Cancel" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Tab Control -->
        <TabControl Grid.Row="1" Background="Transparent" Padding="0">
            <TabControl.Styles>
                <Style Selector="TabItem">
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="Padding" Value="16,12"/>
                </Style>
                <Style Selector="TabItem:selected">
                    <Setter Property="Foreground" Value="#4CAF50"/>
                </Style>
            </TabControl.Styles>

            <!-- Current Session Tab -->
            <TabItem Header="Current Session">
                <Grid RowDefinitions="Auto,*">
                    <!-- Global Status Indicator (Info) -->
                    <Border Grid.Row="0"
                            IsVisible="{Binding IsGlobalStatusInfoVisible}"
                            Background="#112236"
                            Opacity="0.92"
                            Margin="16,16,16,0"
                            Padding="16,10"
                            CornerRadius="8"
                            BorderThickness="1"
                            BorderBrush="#2C5D8A">
                        <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Stretch">
                            <TextBlock Text="ℹ️" FontSize="15" VerticalAlignment="Center" MinHeight="0"/>
                            <TextBlock Text="{Binding GlobalStatusMessage}"
                                       Foreground="#D9ECFF"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       TextWrapping="Wrap"
                                       HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Border>

                    <!-- Global Status Indicator (Error) -->
                    <Border Grid.Row="0"
                            IsVisible="{Binding IsGlobalStatusErrorVisible}"
                            Background="#3A1C1C"
                            Opacity="0.92"
                            Margin="16,16,16,0"
                            Padding="16,10"
                            CornerRadius="8"
                            BorderThickness="1"
                            BorderBrush="#B14646">
                        <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Stretch">
                            <TextBlock Text="⚠️" FontSize="16" VerticalAlignment="Top" Margin="0,2,0,0" MinHeight="0"/>
                            <TextBlock Text="{Binding GlobalStatusMessage}"
                                       Foreground="White"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Top"
                                       TextWrapping="Wrap"
                                       HorizontalAlignment="Left"/>
                            <ProgressBar IsIndeterminate="True"
                                         Width="100"
                                         Height="2"
                                         VerticalAlignment="Center"
                                         Margin="12,0,0,0"/>
                        </StackPanel>
                    </Border>

                        <!-- Beta 2026: Network Parent Health Warning -->
                        <Border Grid.Row="0"
                                IsVisible="{Binding ShowNetworkHealthWarning}"
                                Background="#2A1500"
                                Margin="16,8,16,0"
                                Padding="14,10"
                                CornerRadius="8"
                                BorderThickness="1"
                                BorderBrush="#664400">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <TextBlock Text="🔍" FontSize="14" VerticalAlignment="Center"/>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="NETWORK HEALTH ALERT" FontSize="9" FontWeight="Black" Foreground="#FFA500" LetterSpacing="1"/>
                                    <TextBlock Text="{Binding NetworkHealthMessage}" Foreground="#FFB74D" FontSize="11" FontStyle="Italic"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                    <!-- Empty State -->
                    <Border Grid.Row="1" 
                            IsVisible="{Binding !HasAnyActiveOrQueued}"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center">
                        <StackPanel Spacing="16" HorizontalAlignment="Center">
                             <Panel Width="80" Height="80">
                                 <Ellipse Fill="#252526" Width="80" Height="80"/>
                                 <PathIcon Data="{StaticResource cloud_download_regular}" Width="32" Height="32" Foreground="#444"/>
                             </Panel>
                            <TextBlock Text="The In-Box is Empty" 
                                       FontSize="20" FontWeight="SemiBold"
                                       Foreground="#808080"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Fire up a search or import a playlist to get started." 
                                       FontSize="13" 
                                       Foreground="#606060"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Unified Session Ledger -->
                    <Grid Grid.Row="1" RowDefinitions="Auto, *" IsVisible="{Binding HasAnyActiveOrQueued}">

                        <!-- Session toolbar: search + chips + compact actions -->
                        <StackPanel Grid.Row="0" Spacing="10" Margin="20,10,20,0">
                            <Grid ColumnDefinitions="Auto,Auto,*,Auto">
                                <Button Grid.Column="0"
                                        Command="{Binding ClearCompletedCommand}"
                                        Background="#0D1DB954" BorderBrush="#2A4D35" BorderThickness="1"
                                        CornerRadius="6" Padding="10,5" Foreground="#4CAF50" FontSize="11"
                                        ToolTip.Tip="Remove completed tracks from this session view">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="🧹" FontSize="11" VerticalAlignment="Center"/>
                                        <TextBlock Text="Clear Completed" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="1"
                                        Command="{Binding ClearFailedCommand}"
                                        Background="#1A2C1F1F" BorderBrush="#501B1B" BorderThickness="1"
                                        CornerRadius="6" Padding="10,5" Foreground="#FF5252" FontSize="11"
                                        Margin="8,0,0,0"
                                        ToolTip.Tip="Remove failed tracks from this session view">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="🗑️" FontSize="11" VerticalAlignment="Center"/>
                                        <TextBlock Text="Clear Failed" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <TextBox Grid.Column="3"
                                         Width="260"
                                         Text="{Binding SearchText, Mode=TwoWay}"
                                         Watermark="Filter current session..."
                                         Background="#202124"
                                         BorderBrush="#343436"
                                         BorderThickness="1"
                                         CornerRadius="6">
                                    <TextBox.InnerLeftContent>
                                        <PathIcon Data="{StaticResource search_regular}" Width="13" Height="13" Margin="10,0,0,0" Opacity="0.5"/>
                                    </TextBox.InnerLeftContent>
                                </TextBox>
                            </Grid>

                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                                    <ToggleButton Classes="sessionChip" IsChecked="{Binding SessionFilterAll, Mode=TwoWay}">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="All"/>
                                            <TextBlock Text="{Binding SessionLedgerCount}" Foreground="#6E8798"/>
                                        </StackPanel>
                                    </ToggleButton>
                                    <ToggleButton Classes="sessionChip" IsChecked="{Binding SessionFilterLive, Mode=TwoWay}">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="Live"/>
                                            <TextBlock Text="{Binding DownloadingCount}" Foreground="#6E8798"/>
                                        </StackPanel>
                                    </ToggleButton>
                                    <ToggleButton Classes="sessionChip" IsChecked="{Binding SessionFilterQueued, Mode=TwoWay}">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="Queued"/>
                                            <TextBlock Text="{Binding QueuedCount}" Foreground="#6E8798"/>
                                        </StackPanel>
                                    </ToggleButton>
                                    <ToggleButton Classes="sessionChip" IsChecked="{Binding SessionFilterDone, Mode=TwoWay}">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="Done"/>
                                            <TextBlock Text="{Binding CompletedTodayCount}" Foreground="#6E8798"/>
                                        </StackPanel>
                                    </ToggleButton>
                                    <ToggleButton Classes="sessionChip" IsChecked="{Binding SessionFilterFailed, Mode=TwoWay}">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="Failed"/>
                                            <TextBlock Text="{Binding FailedCount}" Foreground="#6E8798"/>
                                        </StackPanel>
                                    </ToggleButton>
                                </StackPanel>

                                <TextBlock Grid.Column="1"
                                           Text="{Binding VisibleSessionTrackCount, StringFormat='{}{0} visible'}"
                                           FontSize="11"
                                           Foreground="#68737D"
                                           Margin="12,0,0,0"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel Spacing="32" Margin="24,16">
                                <!-- CURRENT SESSION: all non-cleared tracks morph in-place -->
                                <StackPanel Spacing="12">
                                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,0,0,8">
                                        <TextBlock Text="CURRENT SESSION" FontSize="10" FontWeight="Black" Foreground="#00BCD4" LetterSpacing="1"/>
                                        <Border Background="#00BCD4" Width="40" Height="2" VerticalAlignment="Center" Opacity="0.3"/>
                                    </StackPanel>
                                    
                                    <ItemsRepeater ItemsSource="{Binding SessionTracks}">
                                        <ItemsRepeater.Layout>
                                            <StackLayout Spacing="4"/>
                                        </ItemsRepeater.Layout>
                                        <ItemsRepeater.ItemTemplate>
                                            <StaticResource ResourceKey="DownloadItemTemplate"/>
                                        </ItemsRepeater.ItemTemplate>
                                    </ItemsRepeater>

                                    <!-- If no active tracks but engine is running, show a 'Scanning' hint -->
                                    <Border IsVisible="{Binding !SessionTracks.Count}" Background="#1A1A1A" CornerRadius="8" Padding="16" BorderBrush="#333" BorderThickness="1">
                                         <StackPanel Orientation="Horizontal" Spacing="12">
                                             <ProgressBar IsIndeterminate="True" Width="20" Height="20" Theme="{StaticResource FluentProgressBarRingTheme}"/>
                                             <TextBlock Text="No session tracks match the current filters." Foreground="#666" FontSize="13" VerticalAlignment="Center"/>
                                         </StackPanel>
                                    </Border>
                                </StackPanel>

                                    <!-- Beta 2026: PEER LANE DASHBOARD — Group active transfers by peer -->
                                    <Expander IsVisible="{Binding ByPeerGroups.Count}"
                                              IsExpanded="False"
                                              Background="#161617"
                                              BorderBrush="#2B2B2E"
                                              BorderThickness="1"
                                              CornerRadius="8">
                                        <Expander.Header>
                                            <StackPanel Orientation="Horizontal" Spacing="12" Margin="8,4">
                                                <TextBlock Text="PEER LANES" FontSize="10" FontWeight="Black" Foreground="#FFA500" LetterSpacing="1"/>
                                                <Border Background="#FFA500" Width="40" Height="2" VerticalAlignment="Center" Opacity="0.3"/>
                                                <TextBlock Text="active contributors" FontSize="9" Foreground="#666" VerticalAlignment="Center" FontStyle="Italic"/>
                                            </StackPanel>
                                        </Expander.Header>
                                        <ScrollViewer Margin="12,0,12,12" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Height="150">
                                            <ItemsRepeater ItemsSource="{Binding ByPeerGroups}">
                                                <ItemsRepeater.Layout>
                                                    <StackLayout Orientation="Horizontal" Spacing="8"/>
                                                </ItemsRepeater.Layout>
                                                <ItemsRepeater.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="#1C1C1E" CornerRadius="8" Padding="14,10" Width="190"
                                                                BorderBrush="{Binding LaneAccentColor}" BorderThickness="1">
                                                            <StackPanel Spacing="6">
                                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                                    <TextBlock Text="👤" FontSize="10" VerticalAlignment="Center"/>
                                                                    <TextBlock Text="{Binding PeerName}"
                                                                               FontSize="11" FontWeight="SemiBold" Foreground="White"
                                                                               MaxWidth="144" TextTrimming="CharacterEllipsis"
                                                                               VerticalAlignment="Center"/>
                                                                </StackPanel>
                                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                                    <Border Background="#252526" CornerRadius="4" Padding="6,2">
                                                                        <TextBlock Text="{Binding SpeedDisplay}"
                                                                                   FontSize="10" FontWeight="Bold"
                                                                                   Foreground="{Binding LaneAccentColor}"/>
                                                                    </Border>
                                                                    <Border Background="#252526" CornerRadius="4" Padding="6,2">
                                                                        <TextBlock Text="{Binding TrackCountDisplay}" FontSize="10" Foreground="#888"/>
                                                                    </Border>
                                                                </StackPanel>
                                                                <ItemsRepeater ItemsSource="{Binding Tracks}">
                                                                    <ItemsRepeater.Layout>
                                                                        <StackLayout Spacing="2"/>
                                                                    </ItemsRepeater.Layout>
                                                                    <ItemsRepeater.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <TextBlock Text="{Binding TrackTitle}"
                                                                                       FontSize="9" Foreground="#666"
                                                                                       TextTrimming="CharacterEllipsis" MaxWidth="162"/>
                                                                        </DataTemplate>
                                                                    </ItemsRepeater.ItemTemplate>
                                                                </ItemsRepeater>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsRepeater.ItemTemplate>
                                            </ItemsRepeater>
                                        </ScrollViewer>
                                    </Expander>

                                <!-- SECTION 2: THE QUEUE (Groups & Bulk) -->
                                <Expander IsVisible="{Binding ActiveGroups.Count}"
                                          IsExpanded="False"
                                          Background="#161617"
                                          BorderBrush="#2B2B2E"
                                          BorderThickness="1"
                                          CornerRadius="8">
                                    <Expander.Header>
                                        <StackPanel Orientation="Horizontal" Spacing="12" Margin="8,4">
                                            <TextBlock Text="ON DECK" FontSize="10" FontWeight="Black" Foreground="#8A8A8A" LetterSpacing="1"/>
                                            <Border Background="#333" Width="40" Height="1" VerticalAlignment="Center"/>
                                            <TextBlock Text="queued and stalled groups" FontSize="9" Foreground="#666" VerticalAlignment="Center" FontStyle="Italic"/>
                                        </StackPanel>
                                    </Expander.Header>

                                    <ItemsRepeater Margin="12,0,12,12" ItemsSource="{Binding ActiveGroups}">
                                        <ItemsRepeater.Layout>
                                            <StackLayout Spacing="4"/>
                                        </ItemsRepeater.Layout>
                                        <ItemsRepeater.ItemTemplate>
                                            <DataTemplate>
                                                <c:DownloadGroupRow/>
                                            </DataTemplate>
                                        </ItemsRepeater.ItemTemplate>
                                    </ItemsRepeater>
                                </Expander>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </TabItem>


            <!-- Completed Downloads Tab -->
            <TabItem Header="Completed History">
                <Grid RowDefinitions="Auto,*">
                    <!-- Actions Bar (Search + Clear) -->
                    <Border Grid.Row="0" Background="#1E1E1E" Padding="16,12" BorderBrush="#3E3E3E" BorderThickness="0,0,0,1">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBox Grid.Column="0" 
                                     Text="{Binding SearchText, Mode=TwoWay}"
                                     Watermark="Search completed tracks..."
                                     Width="300"
                                     HorizontalAlignment="Left"
                                     Background="#252526"
                                     BorderThickness="1"
                                     CornerRadius="6">
                                <TextBox.InnerLeftContent>
                                    <PathIcon Data="{StaticResource search_regular}" Width="14" Height="14" Margin="10,0,0,0" Opacity="0.5"/>
                                </TextBox.InnerLeftContent>
                            </TextBox>
                            
                            <Button Grid.Column="1" Command="{Binding ClearCompletedCommand}"
                                    HorizontalAlignment="Right"
                                    Background="#333"
                                    Foreground="White"
                                    Padding="12,8"
                                    CornerRadius="6">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="🗑️" FontSize="12"/>
                                    <TextBlock Text="Clear All" FontSize="13"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Empty State -->
                    <Border Grid.Row="1" 
                            IsVisible="{Binding !CompletedDownloads.Count}"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center">
                        <StackPanel Spacing="12" HorizontalAlignment="Center">
                            <TextBlock Text="✅" FontSize="48" HorizontalAlignment="Center" Opacity="0.3"/>
                            <TextBlock Text="No completed downloads" 
                                       FontSize="18" 
                                       Foreground="#808080"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Completed List -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsRepeater Margin="16,12" ItemsSource="{Binding CompletedDownloads}">
                            <ItemsRepeater.Layout>
                                <StackLayout Spacing="0"/>
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <StaticResource ResourceKey="DownloadItemTemplate"/>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- Failed Downloads Tab -->
            <TabItem Header="Failed History">
                <Grid RowDefinitions="Auto,*">
                    <!-- Actions Bar (Search + Actions) -->
                    <Border Grid.Row="0" Background="#1E1E1E" Padding="16,12" BorderBrush="#3E3E3E" BorderThickness="0,0,0,1">
                        <Grid ColumnDefinitions="*,Auto">
                             <TextBox Grid.Column="0" 
                                     Text="{Binding SearchText, Mode=TwoWay}"
                                     Watermark="Search failed tracks..."
                                     Width="300"
                                     HorizontalAlignment="Left"
                                     Background="#252526"
                                     BorderThickness="1"
                                     CornerRadius="6">
                                <TextBox.InnerLeftContent>
                                    <PathIcon Data="{StaticResource search_regular}" Width="14" Height="14" Margin="10,0,0,0" Opacity="0.5"/>
                                </TextBox.InnerLeftContent>
                            </TextBox>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                                <Button Command="{Binding RetryAllFailedCommand}"
                                        Background="#2E7D32"
                                        Foreground="White"
                                        Padding="12,8"
                                        CornerRadius="6">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="🔄" FontSize="12"/>
                                        <TextBlock Text="Retry All" FontSize="13"/>
                                    </StackPanel>
                                </Button>
    
                                <Button Command="{Binding ClearFailedCommand}"
                                        Background="#333"
                                        Foreground="White"
                                        Padding="12,8"
                                        CornerRadius="6">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="🗑️" FontSize="12"/>
                                        <TextBlock Text="Clear All" FontSize="13"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Empty State -->
                    <Border Grid.Row="1" 
                            IsVisible="{Binding !FailedDownloads.Count}"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center">
                        <StackPanel Spacing="12" HorizontalAlignment="Center">
                            <TextBlock Text="💯" FontSize="48" HorizontalAlignment="Center" Opacity="0.3"/>
                            <TextBlock Text="No failed downloads" 
                                       FontSize="18" 
                                       Foreground="#808080"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Failed List -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsRepeater Margin="16,12" ItemsSource="{Binding FailedDownloads}">
                            <ItemsRepeater.Layout>
                                <StackLayout Spacing="0"/>
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <StaticResource ResourceKey="FailedDownloadItemTemplate"/>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- Phase 6: Security & Quality Audit Log Tab -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="🛡" FontSize="12" VerticalAlignment="Center"/>
                        <TextBlock Text="Security &amp; Quality" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <Grid RowDefinitions="Auto,*">
                    <!-- Header bar -->
                    <Border Grid.Row="0" Background="#0D1117" Padding="16,12" BorderBrush="#30C97A" BorderThickness="0,0,0,1">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                <TextBlock Text="Live audit trail of guardrail decisions"
                                           Foreground="#30C97A" FontSize="12" FontWeight="SemiBold"/>
                                <TextBlock Text="Shield · Gate · ForensicLab · Blacklist events — newest first, capped at 200"
                                           Foreground="#666" FontSize="10"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Command="{Binding ClearSecurityQualityLogsCommand}"
                                    Background="Transparent"
                                    BorderBrush="#333"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="10,4"
                                    VerticalAlignment="Center">
                                <TextBlock Text="Clear" Foreground="#666" FontSize="11"/>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Empty state -->
                    <Border Grid.Row="1"
                            IsVisible="{Binding !SecurityQualityLogs.Count}"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center">
                        <StackPanel Spacing="12" HorizontalAlignment="Center">
                            <TextBlock Text="🛡️" FontSize="48" HorizontalAlignment="Center" Opacity="0.2"/>
                            <TextBlock Text="No security events yet"
                                       FontSize="16" Foreground="#505050"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Events will appear here once a search or download is running."
                                       FontSize="11" Foreground="#404040" FontStyle="Italic"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Audit feed -->
                    <ScrollViewer Grid.Row="1"
                                  IsVisible="{Binding SecurityQualityLogs.Count}"
                                  VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding SecurityQualityLogs}" Margin="0,4">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#111319" CornerRadius="4" Padding="10,6" Margin="8,2">
                                        <Grid ColumnDefinitions="Auto,Auto,*,Auto">
                                            <!-- Timestamp -->
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding TimeLabel}"
                                                       Foreground="#555" FontSize="10"
                                                       FontFamily="Consolas,Courier New,monospace"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,10,0"/>
                                            <!-- Category icon -->
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding CategoryIcon}"
                                                       FontSize="14" VerticalAlignment="Center"
                                                       Margin="0,0,8,0"/>
                                            <!-- Summary + detail -->
                                            <StackPanel Grid.Column="2" Spacing="2">
                                                <TextBlock Text="{Binding Summary}"
                                                           Foreground="#DDD" FontSize="12" FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding Detail}"
                                                           Foreground="#666" FontSize="10"
                                                           TextWrapping="NoWrap"
                                                           TextTrimming="CharacterEllipsis"
                                                           IsVisible="{Binding Detail, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                            </StackPanel>
                                            <!-- Severity badge -->
                                            <Border Grid.Column="3"
                                                    CornerRadius="3" Padding="6,2"
                                                    Background="{Binding SeverityColor}"
                                                    Opacity="0.9"
                                                    VerticalAlignment="Center"
                                                    Margin="8,0,0,0">
                                                <TextBlock Text="{Binding SeverityLabel}"
                                                           Foreground="White"
                                                           FontSize="9" FontWeight="Bold"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Phase 2: Live Engine Feed (Collapsible Overlay) -->
        <Border Grid.Row="1" 
                VerticalAlignment="Bottom" 
                Background="#161617" 
                BorderBrush="#2D2D2D" 
                BorderThickness="0,2,0,0" 
                Height="220" 
                IsVisible="{Binding ShowEngineLogs}"
                BoxShadow="0 -10 20 0 #A0000000">
            <Grid RowDefinitions="Auto, *">
                <Border Grid.Row="0" Background="#1E1E1E" Padding="16,8" BorderBrush="#2D2D2D" BorderThickness="0,0,0,1">
                    <Grid ColumnDefinitions="*, Auto">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <PathIcon Data="{StaticResource document_text_regular}" Width="14" Height="14" Foreground="#4EC9B0"/>
                            <TextBlock Text="LIVE ENGINE FEED" FontSize="11" FontWeight="Black" Foreground="#EEE" LetterSpacing="2" VerticalAlignment="Center"/>
                            <TextBlock Text="•" Foreground="#444" VerticalAlignment="Center"/>
                            <TextBlock Text="Real-time Search &amp; Forensic Diagnostics" FontSize="11" Foreground="#666" VerticalAlignment="Center"/>
                        </StackPanel>
                        
                        <Button Grid.Column="1" Command="{Binding ToggleLogsCommand}" Background="Transparent" Padding="4">
                             <PathIcon Data="{StaticResource dismiss_regular}" Width="16" Height="16" Foreground="#666"/>
                        </Button>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" Padding="16">
                    <ItemsControl ItemsSource="{Binding EngineLogs}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="80, 80, 80, *" Margin="0,0,0,4">
                                     <TextBlock Grid.Column="0" Text="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss}'}" Foreground="#555" FontSize="11" FontFamily="Consolas"/>
                                     <Border Grid.Column="1" HorizontalAlignment="Left" Padding="6,1" CornerRadius="3" Background="#222">
                                         <TextBlock Text="{Binding Level}" Foreground="{Binding Level, Converter={StaticResource LogLevelColorConverter}}" FontSize="10" FontWeight="Bold" FontFamily="Consolas"/>
                                     </Border>
                                     <TextBlock Grid.Column="2" Text="{Binding Stage}" Foreground="#666" FontSize="11" Opacity="0.7" FontFamily="Consolas"/>
                                     <TextBlock Grid.Column="3" Text="{Binding Message}" Foreground="#DCDCDC" FontSize="11" FontFamily="Consolas" TextWrapping="Wrap"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>

