<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:views="clr-namespace:SLSKDONET.Views.Avalonia"
             xmlns:vm="clr-namespace:SLSKDONET.ViewModels"
             mc:Ignorable="d" d:DesignWidth="280" d:DesignHeight="60"
             x:Class="SLSKDONET.Views.Avalonia.Controls.CompactPlaylistTemplate"
             x:DataType="vm:LibraryPlaylistCardViewModel">
    
    <Grid ColumnDefinitions="Auto, *, Auto" RowDefinitions="Auto,Auto" Margin="4" MinHeight="66">
        <Grid.Styles>
            <Style Selector="Grid:pointerover">
                <Setter Property="Background" Value="{DynamicResource GlassThinBrush}"/>
            </Style>
        </Grid.Styles>
        <Grid.ContextMenu>
            <ContextMenu>
                <MenuItem Header="Export to Rekordbox" 
                          Command="{Binding $parent[views:LibraryPage].DataContext.Projects.ExportProjectCommand}"
                          CommandParameter="{Binding Model}">
                    <MenuItem.Icon>
                        <TextBlock Text="📀"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Generate Auto-Cues" 
                          Command="{Binding $parent[views:LibraryPage].DataContext.Projects.GenerateCuesCommand}"
                          CommandParameter="{Binding Model}">
                    <MenuItem.Icon>
                        <TextBlock Text="🎯"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Download Album (All Tracks)" 
                          Command="{Binding $parent[views:LibraryPage].DataContext.DownloadAlbumCommand}"
                          CommandParameter="{Binding Model}">
                    <MenuItem.Icon>
                        <TextBlock Text="⬇️"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Download Missing" 
                          Command="{Binding $parent[views:LibraryPage].DataContext.DownloadMissingCommand}"
                          CommandParameter="{Binding Model}">
                    <MenuItem.Icon>
                        <TextBlock Text="🔍"/>
                    </MenuItem.Icon>
                </MenuItem>
            </ContextMenu>
        </Grid.ContextMenu>
        
        <!-- Art with Source Symbol Overlay -->
        <Panel Grid.Column="0" Grid.RowSpan="2" Width="56" Height="56" Margin="2">
            <Border CornerRadius="4" ClipToBounds="True" Background="{DynamicResource TertiaryBackgroundBrush}"
                    BoxShadow="{DynamicResource ShadowSm}">
                <Image Source="{Binding CoverBitmap}" Stretch="UniformToFill"/>
            </Border>
            
        </Panel>

        <!-- Text Info -->
        <StackPanel Grid.Column="1" Grid.Row="0" VerticalAlignment="Top" Margin="12,2,0,0" Spacing="4">
            <TextBlock Text="{Binding Name}" 
                       FontWeight="SemiBold" FontSize="14" TextTrimming="CharacterEllipsis"/>

            <StackPanel Orientation="Horizontal" Spacing="6">
                <Border Background="{DynamicResource GlassThinBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="6,1">
                    <TextBlock Text="{Binding Model.SourceType}" FontSize="10" Foreground="{DynamicResource BrushInfo}"/>
                </Border>
                <TextBlock Text="{Binding Model.CreatedAt, StringFormat='Added {0:dd MMM}'}"
                           FontSize="10"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
            </StackPanel>
            
            <!-- Stats Row -->
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,1,0,0">
                <TextBlock Text="{Binding Model.TotalTracks, StringFormat='{}Tracks: {0}'}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" ToolTip.Tip="Total tracks"/>
                <TextBlock Text="{Binding Model.SuccessfulCount, StringFormat='{}Done: {0}'}" FontSize="11" Foreground="{DynamicResource BrushSuccess}" ToolTip.Tip="Downloaded"/>
                <TextBlock Text="{Binding Model.MissingCount, StringFormat='{}Pending: {0}'}" FontSize="11" Foreground="{DynamicResource BrushWarning}" ToolTip.Tip="Pending"/>
                <TextBlock Text="{Binding Model.ActiveDownloadsCount, StringFormat='{}Live: {0}'}" FontSize="11" Foreground="{DynamicResource BrushInfo}" ToolTip.Tip="Downloading" IsVisible="{Binding Model.HasActiveDownloads}"/>
            </StackPanel>
        </StackPanel>
        
        <!-- Progress Bar & Downloading Info (Premium Refinement) -->
        <Panel Grid.Column="1" Grid.Row="1" Margin="12,4,8,4">
            <!-- Thinner Progress Line -->
            <ProgressBar Height="2" VerticalAlignment="Top" Minimum="0" Maximum="100" 
                         Value="{Binding Model.ProgressPercentage}" Foreground="{StaticResource AccentBrush}" Background="{StaticResource GlassThinBrush}"
                         IsVisible="True"/>

            <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,6,0,0">
                <!-- Downloading Label in subtle glass -->
                <Border Background="{StaticResource GlassBrush}" CornerRadius="4" Padding="6,2"
                        IsVisible="{Binding Model.CurrentDownloadingTrack, Converter={x:Static ObjectConverters.IsNotNull}}">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="↓" FontSize="10" Foreground="{StaticResource AccentBrush}"/>
                        <TextBlock Text="{Binding Model.CurrentDownloadingTrack}" 
                                   FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" MaxWidth="120" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Border>
                
                <!-- Stats in subtle glass -->
                <Border Background="{StaticResource GlassThinBrush}" CornerRadius="4" Padding="6,2">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="{Binding Model.SuccessfulCount, StringFormat='{}Done {0}'}" FontSize="9" Foreground="{DynamicResource BrushSuccess}"/>
                        <TextBlock Text="{Binding Model.FailedCount, StringFormat='{}Failed {0}'}" FontSize="9" Foreground="{DynamicResource BrushError}"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Panel>

        <!-- Controls (Refined) -->
        <StackPanel Grid.Column="2" Grid.Row="0" Grid.RowSpan="2" Orientation="Horizontal" VerticalAlignment="Center" Spacing="0" Margin="4,0,0,0">
            <Button Classes="icon-btn" ToolTip.Tip="Play" Padding="6" Background="Transparent"
                    Opacity="0.6"
                    Command="{Binding $parent[views:LibraryPage].DataContext.PlayAlbumCommand}"
                    CommandParameter="{Binding Model}">
                 <TextBlock Text="▶️" FontSize="14"/>
                 <Button.Styles><Style Selector="Button:pointerover"><Setter Property="Opacity" Value="1"/></Style></Button.Styles>
            </Button>
                <Button Classes="icon-btn" ToolTip.Tip="Download Album" Padding="6" Background="Transparent"
                    Opacity="0.6"
                    Command="{Binding $parent[views:LibraryPage].DataContext.DownloadAlbumCommand}"
                    CommandParameter="{Binding Model}">
                 <TextBlock Text="⬇️" FontSize="14"/>
                 <Button.Styles><Style Selector="Button:pointerover"><Setter Property="Opacity" Value="1"/></Style></Button.Styles>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
