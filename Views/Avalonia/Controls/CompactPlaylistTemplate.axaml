<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:views="clr-namespace:SLSKDONET.Views.Avalonia"
             xmlns:vm="clr-namespace:SLSKDONET.ViewModels"
             mc:Ignorable="d" d:DesignWidth="280" d:DesignHeight="60"
             x:Class="SLSKDONET.Views.Avalonia.Controls.CompactPlaylistTemplate"
             x:DataType="vm:LibraryPlaylistCardViewModel">
    
    <Grid ColumnDefinitions="Auto, *, Auto" Margin="4" Height="56">
        <Grid.Styles>
            <Style Selector="Grid:pointerover">
                <Setter Property="Background" Value="{DynamicResource GlassThinBrush}"/>
            </Style>
            <Style Selector="StackPanel.actions-panel">
                <Setter Property="Opacity" Value="0"/>
                <Setter Property="Transitions">
                    <Transitions>
                        <DoubleTransition Property="Opacity" Duration="0:0:0.15"/>
                    </Transitions>
                </Setter>
            </Style>
            <Style Selector="Grid:pointerover StackPanel.actions-panel">
                <Setter Property="Opacity" Value="1"/>
            </Style>
        </Grid.Styles>
        
        <Grid.ContextMenu>
            <ContextMenu>
                <MenuItem Header="Export to Rekordbox" 
                           Command="{Binding $parent[views:LibraryPage].DataContext.Projects.ExportProjectCommand}"
                           CommandParameter="{Binding Model}">
                    <MenuItem.Icon>
                        <TextBlock Text="📀"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Generate Auto-Cues" 
                           Command="{Binding $parent[views:LibraryPage].DataContext.Projects.GenerateCuesCommand}"
                           CommandParameter="{Binding Model}">
                    <MenuItem.Icon>
                        <TextBlock Text="🎯"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Download Playlist" 
                           Command="{Binding $parent[views:LibraryPage].DataContext.DownloadAlbumCommand}"
                           CommandParameter="{Binding Model}">
                    <MenuItem.Icon>
                        <TextBlock Text="⬇️"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Force Re-download" 
                           Command="{Binding $parent[views:LibraryPage].DataContext.ForceRedownloadCommand}"
                           CommandParameter="{Binding Model}">
                    <MenuItem.Icon>
                        <TextBlock Text="🔥"/>
                    </MenuItem.Icon>
                </MenuItem>
            </ContextMenu>
        </Grid.ContextMenu>
        
        <!-- Column 0: Cover Art (Refined to 44x44 for compactness) -->
        <Panel Grid.Column="0" Width="44" Height="44" Margin="2" VerticalAlignment="Center">
            <Border CornerRadius="4" ClipToBounds="True" Background="{DynamicResource TertiaryBackgroundBrush}"
                    BoxShadow="{DynamicResource ShadowSm}">
                <Image Source="{Binding CoverBitmap}" Stretch="UniformToFill"/>
            </Border>
        </Panel>
        
        <!-- Column 1: Text & Status Info -->
        <Grid Grid.Column="1" RowDefinitions="Auto,Auto" VerticalAlignment="Center" Margin="10,0,6,0">
            <!-- Row 0: Name & Source -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                <TextBlock Text="{Binding Name}" 
                           FontWeight="SemiBold" 
                           FontSize="12" 
                           Foreground="White"
                           MaxWidth="140"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center"/>
                <Border Background="#252528" CornerRadius="4" Padding="4,1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Model.SourceType}" FontSize="8" Foreground="#8FA7C0" FontWeight="SemiBold"/>
                </Border>
            </StackPanel>

            <!-- Row 1: Subtitle/Stats/Sync Progress -->
            <Panel Grid.Row="1" Margin="0,3,0,0">
                <!-- Standard Stats (visible when not syncing) -->
                <StackPanel Orientation="Horizontal" Spacing="6" IsVisible="{Binding !Model.HasActiveDownloads}">
                    <TextBlock Text="{Binding TrackCountText}" FontSize="10" Foreground="#888"/>
                    <TextBlock Text="•" FontSize="10" Foreground="#555"/>
                    <TextBlock Text="{Binding DownloadedCount, StringFormat='{}{0} done'}" FontSize="10" Foreground="#29D391"/>
                    
                    <!-- Failures display (visible only when there are failures) -->
                    <StackPanel Orientation="Horizontal" Spacing="6" IsVisible="{Binding HasFailures}">
                        <TextBlock Text="•" FontSize="10" Foreground="#555"/>
                        <TextBlock Text="{Binding FailedCount, StringFormat='{}{0} failed'}" FontSize="10" Foreground="#E56767"/>
                    </StackPanel>
                </StackPanel>

                <!-- Syncing Progress (visible when syncing) -->
                <StackPanel Spacing="3" IsVisible="{Binding Model.HasActiveDownloads}">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="🔄 Syncing..." FontSize="9" Foreground="#2DB5FF" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding Model.CurrentDownloadingTrack}" 
                                   FontSize="9" Foreground="#888" MaxWidth="110" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                    <ProgressBar Height="2" Minimum="0" Maximum="100" 
                                 Value="{Binding Model.ProgressPercentage}" 
                                 Foreground="#2DB5FF" Background="#252528"/>
                </StackPanel>
            </Panel>
        </Grid>

        <!-- Column 2: Controls (Hover Revealed actions) -->
        <StackPanel Grid.Column="2" Classes="actions-panel" Orientation="Horizontal" VerticalAlignment="Center" Spacing="2" Margin="0,0,4,0">
            <Button Classes="icon-btn" ToolTip.Tip="Play" Padding="4" Background="Transparent" BorderThickness="0"
                    Command="{Binding $parent[views:LibraryPage].DataContext.PlayAlbumCommand}"
                    CommandParameter="{Binding Model}">
                 <TextBlock Text="▶️" FontSize="12"/>
            </Button>
            <Button Classes="icon-btn" ToolTip.Tip="Download Playlist" Padding="4" Background="Transparent" BorderThickness="0"
                    Command="{Binding $parent[views:LibraryPage].DataContext.DownloadAlbumCommand}"
                    CommandParameter="{Binding Model}">
                 <TextBlock Text="⬇️" FontSize="12"/>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
