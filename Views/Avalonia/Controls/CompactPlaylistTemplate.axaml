<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:views="clr-namespace:SLSKDONET.Views.Avalonia"
             xmlns:models="clr-namespace:SLSKDONET.Models"
             mc:Ignorable="d" d:DesignWidth="280" d:DesignHeight="60"
             x:Class="SLSKDONET.Views.Avalonia.Controls.CompactPlaylistTemplate"
             x:DataType="models:PlaylistJob">
    
    <Grid ColumnDefinitions="Auto, *, Auto" RowDefinitions="Auto,Auto" Margin="4" MinHeight="66">
        <Grid.Styles>
            <Style Selector="Grid:pointerover">
                <Setter Property="Background" Value="#11FFFFFF"/>
            </Style>
        </Grid.Styles>
        <Grid.ContextMenu>
            <ContextMenu>
                <MenuItem Header="Export to Rekordbox" 
                          Command="{Binding $parent[views:LibraryPage].DataContext.Projects.ExportProjectCommand}"
                          CommandParameter="{Binding}">
                    <MenuItem.Icon>
                        <TextBlock Text="📀"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Generate Auto-Cues" 
                          Command="{Binding $parent[views:LibraryPage].DataContext.Projects.GenerateCuesCommand}"
                          CommandParameter="{Binding}">
                    <MenuItem.Icon>
                        <TextBlock Text="🎯"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Download Album (All Tracks)" 
                          Command="{Binding $parent[views:LibraryPage].DataContext.DownloadAlbumCommand}"
                          CommandParameter="{Binding}">
                    <MenuItem.Icon>
                        <TextBlock Text="⬇️"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Download Missing" 
                          Command="{Binding $parent[views:LibraryPage].DataContext.DownloadMissingCommand}"
                          CommandParameter="{Binding}">
                    <MenuItem.Icon>
                        <TextBlock Text="🔍"/>
                    </MenuItem.Icon>
                </MenuItem>
            </ContextMenu>
        </Grid.ContextMenu>
        
        <!-- Art with Source Symbol Overlay -->
        <Panel Grid.Column="0" Grid.RowSpan="2" Width="56" Height="56" Margin="2">
            <Border CornerRadius="4" ClipToBounds="True" Background="{DynamicResource TertiaryBackgroundBrush}"
                    BoxShadow="0 2 6 0 #30000000">
                <Image Source="{Binding DisplayArtUrl, Converter={StaticResource BitmapValueConverter}}" Stretch="UniformToFill"/>
            </Border>
            
            <!-- Source Icon Badge -->
            <Border VerticalAlignment="Bottom" HorizontalAlignment="Right" 
                    Background="#AA000000" CornerRadius="4" Margin="0,0,-4,-4" Padding="3"
                    BorderBrush="#33FFFFFF" BorderThickness="1">
                <TextBlock Text="{Binding SourceIcon}" FontSize="12"/>
            </Border>
        </Panel>

        <!-- Text Info -->
        <StackPanel Grid.Column="1" Grid.Row="0" VerticalAlignment="Top" Margin="12,2,0,0" Spacing="4">
            <TextBlock Text="{Binding SourceTitle, FallbackValue='(Fallback Title)', TargetNullValue='(Untitled)'}" 
                       FontWeight="SemiBold" FontSize="14" TextTrimming="CharacterEllipsis"/>

            <StackPanel Orientation="Horizontal" Spacing="6">
                <Border Background="#222B3642" BorderBrush="#33465B74" BorderThickness="1" CornerRadius="6" Padding="6,1">
                    <TextBlock Text="{Binding SourceType}" FontSize="10" Foreground="#99CDEB"/>
                </Border>
                <TextBlock Text="{Binding CreatedAt, StringFormat='Added {0:dd MMM}'}"
                           FontSize="10"
                           Foreground="#7C8594"/>
            </StackPanel>
            
            <!-- Stats Row -->
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,1,0,0">
                <TextBlock Text="{Binding TotalTracks, StringFormat='{}Tracks: {0}'}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" ToolTip.Tip="Total tracks"/>
                <TextBlock Text="{Binding SuccessfulCount, StringFormat='{}Done: {0}'}" FontSize="11" Foreground="#66D89B" ToolTip.Tip="Downloaded"/>
                <TextBlock Text="{Binding MissingCount, StringFormat='{}Pending: {0}'}" FontSize="11" Foreground="#E4B75D" ToolTip.Tip="Pending"/>
                <TextBlock Text="{Binding ActiveDownloadsCount, StringFormat='{}Live: {0}'}" FontSize="11" Foreground="#5DB6F0" ToolTip.Tip="Downloading" IsVisible="{Binding HasActiveDownloads}"/>
            </StackPanel>
        </StackPanel>
        
        <!-- Progress Bar & Downloading Info (Premium Refinement) -->
        <Panel Grid.Column="1" Grid.Row="1" Margin="12,4,8,4">
            <!-- Thinner Progress Line -->
            <ProgressBar Height="2" VerticalAlignment="Top" Minimum="0" Maximum="100" 
                         Value="{Binding ProgressPercentage}" Foreground="{StaticResource AccentBrush}" Background="{StaticResource GlassThinBrush}"
                         IsVisible="True"/>

            <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,6,0,0">
                <!-- Downloading Label in subtle glass -->
                <Border Background="{StaticResource GlassBrush}" CornerRadius="4" Padding="6,2"
                        IsVisible="{Binding CurrentDownloadingTrack, Converter={x:Static ObjectConverters.IsNotNull}}">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="↓" FontSize="10" Foreground="{StaticResource AccentBrush}"/>
                        <TextBlock Text="{Binding CurrentDownloadingTrack}" 
                                   FontSize="10" Foreground="{StaticResource TextSecondaryBrush}" MaxWidth="120" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Border>
                
                <!-- Stats in subtle glass -->
                <Border Background="{StaticResource GlassThinBrush}" CornerRadius="4" Padding="6,2">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="{Binding SuccessfulCount, StringFormat='{}Done {0}'}" FontSize="9" Foreground="#66D89B"/>
                        <TextBlock Text="{Binding FailedCount, StringFormat='{}Failed {0}'}" FontSize="9" Foreground="#F44336"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Panel>

        <!-- Controls (Refined) -->
        <StackPanel Grid.Column="2" Grid.Row="0" Grid.RowSpan="2" Orientation="Horizontal" VerticalAlignment="Center" Spacing="0" Margin="4,0,0,0">
            <Button Classes="icon-btn" ToolTip.Tip="Play" Padding="6" Background="Transparent"
                    Opacity="0.6"
                    Command="{Binding $parent[views:LibraryPage].DataContext.PlayAlbumCommand}"
                    CommandParameter="{Binding}">
                 <TextBlock Text="▶️" FontSize="14"/>
                 <Button.Styles><Style Selector="Button:pointerover"><Setter Property="Opacity" Value="1"/></Style></Button.Styles>
            </Button>
                <Button Classes="icon-btn" ToolTip.Tip="Download Album" Padding="6" Background="Transparent"
                    Opacity="0.6"
                    Command="{Binding $parent[views:LibraryPage].DataContext.DownloadAlbumCommand}"
                    CommandParameter="{Binding}">
                 <TextBlock Text="⬇️" FontSize="14"/>
                 <Button.Styles><Style Selector="Button:pointerover"><Setter Property="Opacity" Value="1"/></Style></Button.Styles>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
