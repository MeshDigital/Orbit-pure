<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:SLSKDONET.ViewModels"
             xmlns:controls="clr-namespace:SLSKDONET.Views.Avalonia.Controls"
             mc:Ignorable="d" d:DesignWidth="340" d:DesignHeight="900"
             x:Class="SLSKDONET.Views.Avalonia.Controls.LibraryTrackInspector"
             x:DataType="vm:PlaylistTrackViewModel">

    <Border Background="#1A1B1C" BorderBrush="#2D2D2D" BorderThickness="1,0,0,0">
        <Grid RowDefinitions="Auto, Auto, *">

            <!-- ── Row 0: Header — artwork + identity ───────────────── -->
            <Grid Grid.Row="0" ColumnDefinitions="100, *" Margin="20,20,20,12">
                <Border Grid.Column="0" CornerRadius="8" ClipToBounds="True"
                        BoxShadow="0 4 12 0 #40000000" Width="100" Height="100">
                    <Panel>
                        <Image Source="{Binding Artwork.Image}"
                               Stretch="UniformToFill" Width="100" Height="100"
                               IsVisible="{Binding Artwork.Image, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                        <Border Background="#252526"
                                IsVisible="{Binding Artwork.Image, Converter={x:Static ObjectConverters.IsNull}}">
                            <TextBlock Text="🎵" FontSize="32"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Panel>
                </Border>

                <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center" Spacing="4">
                    <TextBlock Text="{Binding ArtistName}" FontSize="12" FontWeight="Light"
                               Foreground="#AAA" TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding TrackTitle}" FontSize="17" FontWeight="Bold"
                               Foreground="White" TextWrapping="Wrap" MaxLines="2"/>
                    <TextBlock Text="{Binding AlbumName}" FontSize="10" Foreground="#666"
                               TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,4,0,0">
                        <Border Background="#12FFFFFF" CornerRadius="4" Padding="6,2" IsVisible="{Binding !IsGhost}">
                            <TextBlock Text="{Binding FormatDisplay}" FontSize="10"
                                       FontWeight="Bold" Foreground="#4EC9B0"/>
                        </Border>
                        <Border Background="#12FFFFFF" CornerRadius="4" Padding="6,2"
                                IsVisible="{Binding Bitrate, Converter={x:Static ObjectConverters.IsNotNull}}">
                            <TextBlock Text="{Binding Bitrate}" FontSize="10" Foreground="#888"
                                       IsVisible="{Binding !IsGhost}"/>
                        </Border>
                        <Border Background="#12FFFFFF" CornerRadius="4" Padding="6,2"
                                IsVisible="{Binding IntegrityBadge, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                            <TextBlock Text="{Binding IntegrityBadge}" FontSize="10"
                                       Foreground="{Binding IntegrityColor}" FontWeight="Bold"/>
                        </Border>
                        <Border Background="#1A5C3C3C" BorderBrush="#8C3C3C" BorderThickness="1" CornerRadius="4"
                                Padding="6,2" IsVisible="{Binding IsGhost}">
                            <TextBlock Text="FILE MISSING" FontSize="10" FontWeight="Bold" Foreground="#FF6B6B"/>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <!-- ── Row 1: Waveform strip ────────────────────────────── -->
            <StackPanel Grid.Row="1" Margin="20,0,20,12" Spacing="4" IsVisible="{Binding !IsGhost}">
                <Border CornerRadius="6" ClipToBounds="True" Background="#0D0D0D">
                    <controls:WaveformControl
                        WaveformData="{Binding WaveformData}"
                        Cues="{Binding Cues}"
                        Height="56"
                        IsEditing="False"/>
                </Border>
                <controls:PhraseSegmentStrip
                    Segments="{Binding PhraseSegments}"
                    Height="8"
                    IsVisible="{Binding HasPhraseSegments}"
                    ToolTip.Tip="Track structure: Intro / Build / Drop / Outro"/>
            </StackPanel>

            <!-- ── Row 2: Tabs ──────────────────────────────────────── -->
            <TabControl Grid.Row="2"
                        SelectedIndex="{Binding SelectedInspectorTab, Mode=TwoWay}"
                        Padding="0" Margin="0">
                <TabControl.Styles>
                    <Style Selector="TabItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="#555"/>
                        <Setter Property="FontSize" Value="11"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Padding" Value="16,10"/>
                        <Setter Property="MinHeight" Value="36"/>
                        <Setter Property="BorderThickness" Value="0,0,0,2"/>
                        <Setter Property="BorderBrush" Value="Transparent"/>
                    </Style>
                    <Style Selector="TabItem:selected">
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="BorderBrush" Value="#4EC9B0"/>
                    </Style>
                    <Style Selector="TabItem:pointerover">
                        <Setter Property="Foreground" Value="#AAA"/>
                        <Setter Property="Background" Value="#0DFFFFFF"/>
                    </Style>
                </TabControl.Styles>

                <!-- TAB 0 — IDENTITY -->
                <TabItem Header="IDENTITY">
                    <ScrollViewer Padding="20,12,20,20" VerticalScrollBarVisibility="Auto">
                        <StackPanel Spacing="16">

                            <!-- Status badges -->
                            <StackPanel Spacing="6">
                                <TextBlock Text="STATUS" FontSize="10" FontWeight="Black" Foreground="#444"/>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Border Background="#12FFFFFF" CornerRadius="4" Padding="8,4">
                                        <TextBlock Text="{Binding StatusText}" FontSize="12"
                                                   Foreground="{Binding StatusColor}" FontWeight="SemiBold"/>
                                    </Border>
                                    <Border Background="#1AFFA500" CornerRadius="4" Padding="8,4"
                                            IsVisible="{Binding IsDjTool}">
                                        <TextBlock Text="DJ TOOL" FontSize="11" Foreground="#FFA500" FontWeight="Bold"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>

                            <Separator Background="#252526" Height="1"/>

                            <!-- Track details 2×3 grid (always visible) -->
                            <StackPanel Spacing="8" IsVisible="{Binding !IsGhost}">
                                <TextBlock Text="TRACK DETAILS" FontSize="10" FontWeight="Black" Foreground="#444"/>
                                <Grid ColumnDefinitions="*, *, *" RowDefinitions="Auto, Auto">
                                    <StackPanel Grid.Row="0" Grid.Column="0" Spacing="3">
                                        <TextBlock Text="DURATION" FontSize="9" Foreground="#555"/>
                                        <TextBlock Text="{Binding DurationDisplay}" FontSize="13" Foreground="#CCC"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="0" Grid.Column="1" Spacing="3">
                                        <TextBlock Text="BITRATE" FontSize="9" Foreground="#555"/>
                                        <TextBlock Text="{Binding Bitrate}" FontSize="13" Foreground="#CCC"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="0" Grid.Column="2" Spacing="3">
                                        <TextBlock Text="FORMAT" FontSize="9" Foreground="#555"/>
                                        <TextBlock Text="{Binding FormatDisplay}" FontSize="13"
                                                   Foreground="#4EC9B0" FontWeight="Bold"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="1" Grid.Column="0" Spacing="3" Margin="0,10,0,0">
                                        <TextBlock Text="SAMPLE RATE" FontSize="9" Foreground="#555"/>
                                        <TextBlock Text="{Binding SampleRateDisplay}" FontSize="13" Foreground="#CCC"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="1" Grid.Column="1" Spacing="3" Margin="0,10,0,0">
                                        <TextBlock Text="FILE SIZE" FontSize="9" Foreground="#555"/>
                                        <TextBlock Text="{Binding FileSizeDisplay}" FontSize="13" Foreground="#CCC"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="1" Grid.Column="2" Spacing="3" Margin="0,10,0,0">
                                        <TextBlock Text="YEAR" FontSize="9" Foreground="#555"/>
                                        <TextBlock Text="{Binding YearDisplay}" FontSize="13" Foreground="#CCC"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>

                            <Separator Background="#252526" Height="1"/>

                            <!-- Cue Points -->
                            <StackPanel Spacing="8">
                                <TextBlock Text="CUE POINTS" FontSize="10" FontWeight="Black" Foreground="#444"/>
                                <ItemsControl ItemsSource="{Binding Cues}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Spacing="4"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#15FFFFFF" CornerRadius="6" Padding="10,6">
                                                <Grid ColumnDefinitions="22,*,Auto">
                                                    <Border Grid.Column="0" Width="12" Height="12"
                                                            CornerRadius="6" Background="{Binding Color}"
                                                            VerticalAlignment="Center"/>
                                                    <TextBox Grid.Column="1" Text="{Binding Name}"
                                                             FontSize="11" Background="Transparent"
                                                             BorderThickness="0" Foreground="#CCC"
                                                             Padding="0" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2"
                                                               Text="{Binding Timestamp, StringFormat='{}{0:0.0}s'}"
                                                               FontSize="10" Foreground="#888"
                                                               VerticalAlignment="Center"
                                                               FontFamily="JetBrains Mono, Consolas, monospace"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="No cue points" FontSize="11" Foreground="#444"
                                           IsVisible="{Binding !HasCues}"/>
                            </StackPanel>

                            <!-- Source provenance -->
                            <StackPanel Spacing="6"
                                        IsVisible="{Binding Source, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                <Separator Background="#252526" Height="1"/>
                                <TextBlock Text="SOURCE" FontSize="10" FontWeight="Black" Foreground="#444"/>
                                <Border Background="#12FFFFFF" CornerRadius="6" Padding="12,8">
                                    <TextBlock Text="{Binding Source}" FontSize="12" Foreground="#888" TextWrapping="Wrap"/>
                                </Border>
                            </StackPanel>

                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- TAB 1 — ANALYSIS -->
                <TabItem Header="ANALYSIS">
                    <ScrollViewer Padding="20,12,20,20" VerticalScrollBarVisibility="Auto">
                        <StackPanel Spacing="16" IsVisible="{Binding !IsGhost}">

                            <!-- Musical numbers 3×2 -->
                            <StackPanel Spacing="10">
                                <TextBlock Text="MUSICAL" FontSize="10" FontWeight="Black" Foreground="#444"/>
                                <Grid ColumnDefinitions="*, *, *" RowDefinitions="Auto, Auto">
                                    <StackPanel Grid.Row="0" Grid.Column="0" Spacing="3">
                                        <TextBlock Text="BPM" FontSize="9" Foreground="#555"/>
                                        <TextBlock Text="{Binding BpmDisplay}" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="#9CDCFE"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="0" Grid.Column="1" Spacing="3">
                                        <TextBlock Text="KEY" FontSize="9" Foreground="#555"/>
                                        <TextBlock Text="{Binding CamelotDisplay}" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{Binding ColorBrush}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="0" Grid.Column="2" Spacing="3">
                                        <TextBlock Text="ENERGY" FontSize="9" Foreground="#555"/>
                                        <TextBlock Text="{Binding EnergyRating}" FontSize="13" Foreground="#CCC"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="1" Grid.Column="0" Spacing="3" Margin="0,10,0,0">
                                        <TextBlock Text="LOUDNESS" FontSize="9" Foreground="#555"/>
                                        <TextBlock Text="{Binding LoudnessDisplay}" FontSize="13" Foreground="#CCC"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="1" Grid.Column="1" Spacing="3" Margin="0,10,0,0">
                                        <TextBlock Text="TRUE PEAK" FontSize="9" Foreground="#555"/>
                                        <TextBlock Text="{Binding TruePeakDisplay}" FontSize="13" Foreground="#CCC"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="1" Grid.Column="2" Spacing="3" Margin="0,10,0,0">
                                        <TextBlock Text="DYN. RANGE" FontSize="9" Foreground="#555"/>
                                        <TextBlock Text="{Binding DynamicRangeDisplay}" FontSize="13" Foreground="#CCC"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>

                            <!-- Camelot Wheel -->
                            <controls:CamelotWheelControl
                                SelectedKey="{Binding CamelotDisplay}"
                                KeyClickedCommand="{Binding FilterByKeyCommand}"
                                Height="150"
                                HorizontalAlignment="Center"
                                IsVisible="{Binding HasKey}"
                                Cursor="Hand"
                                ToolTip.Tip="Click a Camelot position to filter the library to that key"/>

                            <Separator Background="#252526" Height="1"/>

                            <!-- Sonic Profile bars -->
                            <StackPanel Spacing="8">
                                <TextBlock Text="SONIC PROFILE" FontSize="10" FontWeight="Black" Foreground="#444"/>
                                <Grid ColumnDefinitions="80,*,40">
                                    <TextBlock Text="Energy" FontSize="10" Foreground="#666" VerticalAlignment="Center"/>
                                    <ProgressBar Grid.Column="1" Value="{Binding Energy}" Minimum="0" Maximum="1"
                                                 Height="6" Margin="4,0" Foreground="#E05C5C" Background="#1A1A1A"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Energy, StringFormat={}{0:P0}}"
                                               FontSize="10" Foreground="#666" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                </Grid>
                                <Grid ColumnDefinitions="80,*,40">
                                    <TextBlock Text="Arousal" FontSize="10" Foreground="#666" VerticalAlignment="Center"/>
                                    <ProgressBar Grid.Column="1" Value="{Binding ArousalNorm}" Minimum="0" Maximum="1"
                                                 Height="6" Margin="4,0" Foreground="#FF8C00" Background="#1A1A1A"/>
                                    <TextBlock Grid.Column="2" Text="{Binding ArousalNorm, StringFormat={}{0:P0}}"
                                               FontSize="10" Foreground="#666" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                </Grid>
                                <Grid ColumnDefinitions="80,*,40">
                                    <TextBlock Text="Valence" FontSize="10" Foreground="#666" VerticalAlignment="Center"/>
                                    <ProgressBar Grid.Column="1" Value="{Binding ValenceNorm}" Minimum="0" Maximum="1"
                                                 Height="6" Margin="4,0" Foreground="#5CB8E0" Background="#1A1A1A"/>
                                    <TextBlock Grid.Column="2" Text="{Binding ValenceNorm, StringFormat={}{0:P0}}"
                                               FontSize="10" Foreground="#666" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                </Grid>
                                <Grid ColumnDefinitions="80,*,40">
                                    <TextBlock Text="Danceability" FontSize="10" Foreground="#666" VerticalAlignment="Center"/>
                                    <ProgressBar Grid.Column="1" Value="{Binding Danceability}" Minimum="0" Maximum="1"
                                                 Height="6" Margin="4,0" Foreground="#4EC9B0" Background="#1A1A1A"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Danceability, StringFormat={}{0:P0}}"
                                               FontSize="10" Foreground="#666" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                </Grid>
                            </StackPanel>

                            <Separator Background="#252526" Height="1"/>

                            <!-- Vibe -->
                            <StackPanel Spacing="8" IsVisible="{Binding HasVibeData}">
                                <TextBlock Text="VIBE" FontSize="10" FontWeight="Black" Foreground="#444"/>
                                <controls:VibePillContainer Items="{Binding VibePills}"/>
                                <TextBlock Text="{Binding GenresDisplay}" FontSize="11" Foreground="#666" TextWrapping="Wrap"
                                           IsVisible="{Binding GenresDisplay, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                            </StackPanel>

                            <!-- A10 pair snapshot (only when neighbor context exists) -->
                            <StackPanel Spacing="8" IsVisible="{Binding HasInspectorA10PairwiseContext}">
                                <Separator Background="#252526" Height="1"/>
                                <TextBlock Text="A10 PAIR" FontSize="10" FontWeight="Black" Foreground="#444"/>
                                <Border Background="#12FFFFFF" CornerRadius="6" Padding="10,8">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="{Binding InspectorA10PairContextLabel}"
                                                   FontSize="11" Foreground="#B8B8B8" TextWrapping="Wrap"/>
                                        <StackPanel Orientation="Horizontal" Spacing="10">
                                            <TextBlock Text="A10" FontSize="10" FontWeight="SemiBold" Foreground="#6AA9FF"/>
                                            <TextBlock Text="{Binding InspectorA10OverallScore, StringFormat={}{0:P0}}" FontSize="10" Foreground="#E6E6E6"/>
                                            <TextBlock Text="H" FontSize="10" FontWeight="SemiBold" Foreground="#CE93D8"/>
                                            <TextBlock Text="{Binding InspectorA10HarmonicScore, StringFormat={}{0:P0}}" FontSize="10" Foreground="#E6E6E6"/>
                                            <TextBlock Text="B" FontSize="10" FontWeight="SemiBold" Foreground="#9CDCFE"/>
                                            <TextBlock Text="{Binding InspectorA10BeatScore, StringFormat={}{0:P0}}" FontSize="10" Foreground="#E6E6E6"/>
                                            <TextBlock Text="D" FontSize="10" FontWeight="SemiBold" Foreground="#4EC9B0"/>
                                            <TextBlock Text="{Binding InspectorA10DropScore, StringFormat={}{0:P0}}" FontSize="10" Foreground="#E6E6E6"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding InspectorA10ReasonTags}" FontSize="10" Foreground="#8A8A8A" TextWrapping="Wrap"
                                                   IsVisible="{Binding InspectorA10ReasonTags, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- Deep Analysis (collapsible) -->
                            <Expander Header="Deep Analysis" IsExpanded="False" Padding="0" Margin="0"
                                      IsVisible="{Binding HasAnalysisData}">
                                <StackPanel Spacing="8" Margin="0,8,0,0">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0" Text="LAST ANALYZED" FontSize="10"
                                                   FontWeight="Black" Foreground="#444" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding LastAnalyzedDisplay}"
                                                   FontSize="10" Foreground="#555" VerticalAlignment="Center"
                                                   ToolTip.Tip="{Binding AnalysisModelVersion}"/>
                                    </Grid>
                                    <Separator Background="#252526" Height="1"/>
                                    <TextBlock Text="BEAT GRID" FontSize="10" FontWeight="Black" Foreground="#444"/>
                                    <ProgressBar Value="{Binding BpmConfidence}" Minimum="0" Maximum="1"
                                                 Height="6" Foreground="#9CDCFE" Background="#1A1A1A"/>
                                    <TextBlock Text="{Binding BpmConfidence, StringFormat={}{0:P0}}" FontSize="10" Foreground="#666"/>
                                    <Separator Background="#252526" Height="1"/>
                                    <TextBlock Text="AUDIO PROFILE" FontSize="10" FontWeight="Black" Foreground="#444"/>
                                    <WrapPanel Orientation="Horizontal">
                                        <controls:ConfidenceRadar Label="Energy"    Value="{Binding RadarEnergy}"           Color="#E05C5C" Margin="4"/>
                                        <controls:ConfidenceRadar Label="Dance"     Value="{Binding RadarDanceability}"     Color="#4EC9B0" Margin="4"/>
                                        <controls:ConfidenceRadar Label="Valence"   Value="{Binding ValenceNorm}"           Color="#5CB8E0" Margin="4"/>
                                        <controls:ConfidenceRadar Label="Arousal"   Value="{Binding ArousalNorm}"           Color="#FF8C00" Margin="4"/>
                                        <controls:ConfidenceRadar Label="Instrumen" Value="{Binding RadarInstrumentalness}" Color="#C586C0" Margin="4"/>
                                    </WrapPanel>
                                    <Separator Background="#252526" Height="1"/>
                                    <TextBlock Text="ENERGY CURVE" FontSize="10" FontWeight="Black" Foreground="#444"/>
                                    <Border CornerRadius="4" Height="36" ClipToBounds="True">
                                        <controls:EnergyCurveBar Points="{Binding EnergyCurvePoints}" Segments="{Binding PhraseSegments}"/>
                                    </Border>
                                    <Separator Background="#252526" Height="1"/>
                                    <TextBlock Text="VOCAL ANALYSIS" FontSize="10" FontWeight="Black" Foreground="#444"/>
                                    <Grid ColumnDefinitions="80,*,40">
                                        <TextBlock Text="{Binding DetectedVocalTypeDisplay}" FontSize="12" Foreground="#CCC" VerticalAlignment="Center"/>
                                        <ProgressBar Grid.Column="1" Value="{Binding AudioVocalDensity}" Minimum="0" Maximum="1"
                                                     Height="6" Margin="4,0" Foreground="#C586C0" Background="#1A1A1A"/>
                                        <TextBlock Grid.Column="2" Text="{Binding AudioVocalDensity, StringFormat={}{0:P0}}"
                                                   FontSize="10" Foreground="#666" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                    </Grid>
                                </StackPanel>
                            </Expander>

                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- TAB 2 — ACTIONS -->
                <TabItem Header="ACTIONS">
                    <ScrollViewer Padding="20,16,20,20" VerticalScrollBarVisibility="Auto">
                        <StackPanel Spacing="10">

                            <!-- Ghost file section (only when file is missing) -->
                            <StackPanel Spacing="8" IsVisible="{Binding IsGhost}">
                                <TextBlock Text="FILE MISSING" FontSize="10" FontWeight="Black" Foreground="#8C3C3C" Margin="0,0,0,4"/>
                                <Border Background="#1A2A1A20" BorderBrush="#5C2A2A" BorderThickness="1" CornerRadius="6" Padding="12,10" Margin="0,0,0,4">
                                    <TextBlock Text="The audio file for this track was not found on disk. You can search for it again or remove it from the library."
                                               FontSize="11" Foreground="#AA8080" TextWrapping="Wrap"/>
                                </Border>
                                <Button Command="{Binding SearchAgainCommand}"
                                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                        Background="#1A1DB954" BorderBrush="#1DB954" BorderThickness="1"
                                        Foreground="#8FD6A8"
                                        Padding="14,10" CornerRadius="6">
                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <TextBlock Text="🔍" FontSize="16"/>
                                        <TextBlock Text="Search Again" FontSize="13"/>
                                    </StackPanel>
                                </Button>
                                <Separator Background="#252526" Height="1" Margin="0,4"/>
                            </StackPanel>

                            <!-- File operations (available tracks only) -->
                            <StackPanel Spacing="8" IsVisible="{Binding IsCompleted}">
                                <TextBlock Text="FILE OPERATIONS" FontSize="10" FontWeight="Black" Foreground="#444" Margin="0,0,0,4"/>

                                <Button Command="{Binding OpenWorkstationCommand}"
                                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                        Background="#252526" Foreground="#CCC"
                                        Padding="14,10" CornerRadius="6">
                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <TextBlock Text="🎚" FontSize="16"/>
                                        <TextBlock Text="Open in Workstation" FontSize="13"/>
                                    </StackPanel>
                                </Button>

                                <Button Command="{Binding RevealFileCommand}"
                                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                        Background="#252526" Foreground="#CCC"
                                        Padding="14,10" CornerRadius="6">
                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <PathIcon Data="{StaticResource folder_open_regular}" Width="16" Height="16"/>
                                        <TextBlock Text="Reveal in Explorer" FontSize="13"/>
                                    </StackPanel>
                                </Button>

                                <Separator Background="#252526" Height="1" Margin="0,4"/>
                            </StackPanel>

                            <!-- Metadata edit (always available) -->
                            <TextBlock Text="METADATA" FontSize="10" FontWeight="Black" Foreground="#444" Margin="0,0,0,4"
                                       IsVisible="{Binding IsCompleted}"/>
                            <Button Command="{Binding RequestEditTagsCommand}"
                                    IsVisible="{Binding IsCompleted}"
                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                    Background="#252526" Foreground="#CCC"
                                    Padding="14,10" CornerRadius="6">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <TextBlock Text="✏️" FontSize="16"/>
                                    <TextBlock Text="Edit Metadata" FontSize="13"/>
                                </StackPanel>
                            </Button>

                            <!-- Analysis -->
                            <StackPanel Spacing="8" IsVisible="{Binding IsCompleted}" Margin="0,4,0,0">
                                <TextBlock Text="ANALYSIS" FontSize="10" FontWeight="Black" Foreground="#444" Margin="0,0,0,4"/>
                                <Button Command="{Binding AnalyzeTrackCommand}"
                                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                        Background="#252526" Foreground="#CCC"
                                        Padding="14,10" CornerRadius="6">
                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <TextBlock Text="🔬" FontSize="16"/>
                                        <TextBlock Text="Re-analyse Track" FontSize="13"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>

                            <Separator Background="#252526" Height="1" Margin="0,4"/>

                            <!-- Destructive zone -->
                            <TextBlock Text="DANGER ZONE" FontSize="10" FontWeight="Black" Foreground="#555" Margin="0,0,0,4"/>

                            <Button Command="{Binding RequestRemoveCommand}"
                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                    Background="#1AC0392B" BorderBrush="#C0392B" BorderThickness="1"
                                    Foreground="#FF6B6B"
                                    Padding="14,10" CornerRadius="6">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <TextBlock Text="🗑" FontSize="16"/>
                                    <TextBlock Text="Remove from Library" FontSize="13"/>
                                </StackPanel>
                            </Button>

                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

            </TabControl>

        </Grid>
    </Border>
</UserControl>
