<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:SLSKDONET.ViewModels"
             xmlns:controls="clr-namespace:SLSKDONET.Views.Avalonia.Controls"
             mc:Ignorable="d" d:DesignWidth="450" d:DesignHeight="900"
             x:Class="SLSKDONET.Views.Avalonia.Controls.LibraryTrackInspector"
             x:DataType="vm:PlaylistTrackViewModel">

    <Border Background="#1A1B1C" BorderBrush="#2D2D2D" BorderThickness="1,0,0,0">
        <Grid RowDefinitions="*, Auto">

            <!-- Scrollable Content -->
            <ScrollViewer Grid.Row="0" Padding="24">
                <StackPanel Spacing="24">

                    <!-- Artwork & Primary Info -->
                    <Grid ColumnDefinitions="120, *">
                        <Border Grid.Column="0" CornerRadius="10" ClipToBounds="True"
                                BoxShadow="0 6 16 0 #40000000" Width="120" Height="120">
                            <Panel>
                                <Image Source="{Binding Artwork.Image}"
                                       Stretch="UniformToFill" Width="120" Height="120"
                                       IsVisible="{Binding Artwork.Image, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                                <Border Background="#252526"
                                        IsVisible="{Binding Artwork.Image, Converter={x:Static ObjectConverters.IsNull}}">
                                    <TextBlock Text="🎵" FontSize="40"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Panel>
                        </Border>

                        <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center" Spacing="6">
                            <TextBlock Text="{Binding ArtistName}" FontSize="13" FontWeight="Light"
                                       Foreground="#AAA" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding TrackTitle}" FontSize="20" FontWeight="Bold"
                                       Foreground="White" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding AlbumName}" FontSize="11" Foreground="#666"
                                       TextWrapping="Wrap"/>

                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,6,0,0">
                                <Border Background="#12FFFFFF" CornerRadius="4" Padding="6,2">
                                    <TextBlock Text="{Binding FormatDisplay}" FontSize="10"
                                               FontWeight="Bold" Foreground="#4EC9B0"/>
                                </Border>
                                <Border Background="#12FFFFFF" CornerRadius="4" Padding="6,2"
                                        IsVisible="{Binding Bitrate, Converter={x:Static ObjectConverters.IsNotNull}}">
                                    <TextBlock Text="{Binding Bitrate}" FontSize="10" Foreground="#888"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <Separator Background="#252526" Height="1"/>

                    <!-- Waveform Strip with Cue Markers -->
                    <StackPanel Spacing="6">
                        <TextBlock Text="WAVEFORM" FontSize="10" FontWeight="Black" Foreground="#444"/>
                        <Border CornerRadius="6" ClipToBounds="True" Background="#0D0D0D">
                            <controls:WaveformControl
                                WaveformData="{Binding WaveformData}"
                                Cues="{Binding Cues}"
                                Height="64"
                                IsEditing="False"/>
                        </Border>
                    </StackPanel>

                    <Separator Background="#252526" Height="1"/>
                    <StackPanel Spacing="6">
                        <TextBlock Text="STATUS" FontSize="10" FontWeight="Black" Foreground="#444"/>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Border Background="#12FFFFFF" CornerRadius="4" Padding="8,4">
                                <TextBlock Text="{Binding StatusText}" FontSize="12"
                                           Foreground="{Binding StatusColor}" FontWeight="SemiBold"/>
                            </Border>
                            <Border Background="#12FFFFFF" CornerRadius="4" Padding="8,4"
                                    IsVisible="{Binding IntegrityBadge, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                <TextBlock Text="{Binding IntegrityBadge}" FontSize="12"
                                           Foreground="{Binding IntegrityColor}" FontWeight="Bold"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>

                    <Separator Background="#252526" Height="1"/>

                    <!-- Technical Metadata -->
                    <StackPanel Spacing="12">
                        <TextBlock Text="TECHNICAL METADATA" FontSize="10" FontWeight="Black" Foreground="#444"/>
                        <Grid ColumnDefinitions="*, *, *" RowDefinitions="Auto, Auto">
                            <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4">
                                <TextBlock Text="DURATION" FontSize="9" Foreground="#555"/>
                                <TextBlock Text="{Binding DurationDisplay}" FontSize="13" Foreground="#CCC"/>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                                <TextBlock Text="BITRATE" FontSize="9" Foreground="#555"/>
                                <TextBlock Text="{Binding Bitrate}" FontSize="13" Foreground="#CCC"/>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="2" Spacing="4">
                                <TextBlock Text="FORMAT" FontSize="9" Foreground="#555"/>
                                <TextBlock Text="{Binding FormatDisplay}" FontSize="13"
                                           Foreground="#4EC9B0" FontWeight="Bold"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="0" Spacing="4" Margin="0,12,0,0">
                                <TextBlock Text="SAMPLE RATE" FontSize="9" Foreground="#555"/>
                                <TextBlock Text="{Binding SampleRateDisplay}" FontSize="13" Foreground="#CCC"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4" Margin="0,12,0,0">
                                <TextBlock Text="FILE SIZE" FontSize="9" Foreground="#555"/>
                                <TextBlock Text="{Binding FileSizeDisplay}" FontSize="13" Foreground="#CCC"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="2" Spacing="4" Margin="0,12,0,0">
                                <TextBlock Text="YEAR" FontSize="9" Foreground="#555"/>
                                <TextBlock Text="{Binding YearDisplay}" FontSize="13" Foreground="#CCC"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <Separator Background="#252526" Height="1"/>

                    <!-- Musical Analysis -->
                    <StackPanel Spacing="12">
                        <TextBlock Text="MUSICAL ANALYSIS" FontSize="10" FontWeight="Black" Foreground="#444"/>
                        <Grid ColumnDefinitions="*, *, *" RowDefinitions="Auto, Auto">
                            <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4">
                                <TextBlock Text="BPM" FontSize="9" Foreground="#555"/>
                                <TextBlock Text="{Binding BpmDisplay}" FontSize="13" FontWeight="SemiBold"
                                           Foreground="#9CDCFE"/>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                                <TextBlock Text="KEY" FontSize="9" Foreground="#555"/>
                                <TextBlock Text="{Binding CamelotDisplay}" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{Binding ColorBrush}"/>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="2" Spacing="4">
                                <TextBlock Text="ENERGY" FontSize="9" Foreground="#555"/>
                                <TextBlock Text="{Binding EnergyRating}" FontSize="13" Foreground="#CCC"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="0" Spacing="4" Margin="0,12,0,0">
                                <TextBlock Text="LOUDNESS" FontSize="9" Foreground="#555"/>
                                <TextBlock Text="{Binding LoudnessDisplay}" FontSize="13" Foreground="#CCC"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4" Margin="0,12,0,0">
                                <TextBlock Text="TRUE PEAK" FontSize="9" Foreground="#555"/>
                                <TextBlock Text="{Binding TruePeakDisplay}" FontSize="13" Foreground="#CCC"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="2" Spacing="4" Margin="0,12,0,0">
                                <TextBlock Text="DYN. RANGE" FontSize="9" Foreground="#555"/>
                                <TextBlock Text="{Binding DynamicRangeDisplay}" FontSize="13" Foreground="#CCC"/>
                            </StackPanel>
                        </Grid>

                        <!-- Sonic Profile — Energy / Valence / Danceability bars -->
                        <StackPanel Spacing="8" Margin="0,8,0,0">
                            <!-- Energy bar -->
                            <Grid ColumnDefinitions="80,*,40">
                                <TextBlock Text="Energy" FontSize="10" Foreground="#666" VerticalAlignment="Center"/>
                                <ProgressBar Grid.Column="1" Value="{Binding Energy}" Minimum="0" Maximum="1"
                                             Height="6" Margin="4,0"
                                             Foreground="#E05C5C" Background="#1A1A1A"/>
                                <TextBlock Grid.Column="2" Text="{Binding Energy, StringFormat={}{0:P0}}"
                                           FontSize="10" Foreground="#666" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                            </Grid>
                            <!-- Valence bar -->
                            <Grid ColumnDefinitions="80,*,40">
                                <TextBlock Text="Valence" FontSize="10" Foreground="#666" VerticalAlignment="Center"/>
                                <ProgressBar Grid.Column="1" Value="{Binding Valence}" Minimum="0" Maximum="1"
                                             Height="6" Margin="4,0"
                                             Foreground="#5CB8E0" Background="#1A1A1A"/>
                                <TextBlock Grid.Column="2" Text="{Binding Valence, StringFormat={}{0:P0}}"
                                           FontSize="10" Foreground="#666" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                            </Grid>
                            <!-- Danceability bar -->
                            <Grid ColumnDefinitions="80,*,40">
                                <TextBlock Text="Danceability" FontSize="10" Foreground="#666" VerticalAlignment="Center"/>
                                <ProgressBar Grid.Column="1" Value="{Binding Danceability}" Minimum="0" Maximum="1"
                                             Height="6" Margin="4,0"
                                             Foreground="#4EC9B0" Background="#1A1A1A"/>
                                <TextBlock Grid.Column="2" Text="{Binding Danceability, StringFormat={}{0:P0}}"
                                           FontSize="10" Foreground="#666" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>
                    </StackPanel>

                    <!-- Vibe / Mood Chips (only shown when any analysis data is available) -->
                    <StackPanel Spacing="8"
                                IsVisible="{Binding HasGenre}">
                        <Separator Background="#252526" Height="1"/>
                        <TextBlock Text="VIBE" FontSize="10" FontWeight="Black" Foreground="#444"/>
                        <controls:VibePillContainer Items="{Binding VibePills}"/>
                        <!-- Fallback text genres if pills are empty -->
                        <TextBlock Text="{Binding GenresDisplay}" FontSize="11" Foreground="#666"
                                   TextWrapping="Wrap"
                                   IsVisible="{Binding GenresDisplay, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                    </StackPanel>

                    <!-- Source Provenance -->
                    <StackPanel Spacing="8"
                                IsVisible="{Binding Source, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                        <Separator Background="#252526" Height="1"/>
                        <TextBlock Text="SOURCE" FontSize="10" FontWeight="Black" Foreground="#444"/>
                        <Border Background="#12FFFFFF" CornerRadius="6" Padding="12,8">
                            <TextBlock Text="{Binding Source}" FontSize="12" Foreground="#888"
                                       TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>

                    <!-- Cue Points -->
                    <StackPanel Spacing="8">
                        <Separator Background="#252526" Height="1"/>
                        <TextBlock Text="CUE POINTS" FontSize="10" FontWeight="Black" Foreground="#444"/>
                        <ItemsControl ItemsSource="{Binding Cues}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Spacing="4"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#15FFFFFF" CornerRadius="6" Padding="10,6">
                                        <Grid ColumnDefinitions="22,*,Auto">
                                            <!-- Color dot -->
                                            <Border Grid.Column="0" Width="12" Height="12"
                                                    CornerRadius="6"
                                                    Background="{Binding Color}"
                                                    VerticalAlignment="Center"/>
                                            <!-- Editable label — two-way binds to OrbitCue.Name -->
                                            <TextBox Grid.Column="1"
                                                     Text="{Binding Name}"
                                                     FontSize="11"
                                                     Background="Transparent"
                                                     BorderThickness="0"
                                                     Foreground="#CCC"
                                                     Padding="0"
                                                     VerticalAlignment="Center"/>
                                            <!-- Timestamp -->
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding Timestamp, StringFormat='{}{0:0.0}s'}"
                                                       FontSize="10" Foreground="#888"
                                                       VerticalAlignment="Center"
                                                       FontFamily="JetBrains Mono, Consolas, monospace"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="No cue points" FontSize="11" Foreground="#444"
                                   IsVisible="{Binding !HasCues}"/>
                    </StackPanel>

                    <!-- Last Analysis Timestamp -->
                    <StackPanel Spacing="6" Margin="0,4,0,0">
                        <Separator Background="#252526" Height="1"/>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="LAST ANALYZED" FontSize="10"
                                       FontWeight="Black" Foreground="#444"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding LastAnalyzedDisplay}"
                                       FontSize="10" Foreground="#555"
                                       VerticalAlignment="Center"
                                       ToolTip.Tip="{Binding AnalysisModelVersion}"/>
                        </Grid>
                    </StackPanel>

                    <!-- ── Beat Grid Stats ─────────────────────────────── -->
                    <StackPanel Spacing="8" IsVisible="{Binding HasAnalysisData}">
                        <Separator Background="#252526" Height="1"/>
                        <TextBlock Text="BEAT GRID" FontSize="10" FontWeight="Black" Foreground="#444"/>
                        <Grid ColumnDefinitions="*,*">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="BPM CONFIDENCE" FontSize="9" Foreground="#555"/>
                                <ProgressBar Value="{Binding BpmConfidence}" Minimum="0" Maximum="1"
                                             Height="6" Foreground="#9CDCFE" Background="#1A1A1A"/>
                                <TextBlock Text="{Binding BpmConfidence, StringFormat={}{0:P0}}"
                                           FontSize="10" Foreground="#666"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <!-- ── Audio Profile Radar ─────────────────────────── -->
                    <StackPanel Spacing="8" IsVisible="{Binding HasAnalysisData}">
                        <Separator Background="#252526" Height="1"/>
                        <TextBlock Text="AUDIO PROFILE" FontSize="10" FontWeight="Black" Foreground="#444"/>
                        <WrapPanel Orientation="Horizontal">
                            <controls:ConfidenceRadar Label="Energy"    Value="{Binding RadarEnergy}"
                                                      Color="#E05C5C" Margin="4"/>
                            <controls:ConfidenceRadar Label="Dance"     Value="{Binding RadarDanceability}"
                                                      Color="#4EC9B0" Margin="4"/>
                            <controls:ConfidenceRadar Label="Valence"   Value="{Binding ValenceNorm}"
                                                      Color="#5CB8E0" Margin="4"/>
                            <controls:ConfidenceRadar Label="Arousal"   Value="{Binding ArousalNorm}"
                                                      Color="#FF8C00" Margin="4"/>
                            <controls:ConfidenceRadar Label="Instrumen" Value="{Binding RadarInstrumentalness}"
                                                      Color="#C586C0" Margin="4"/>
                        </WrapPanel>
                    </StackPanel>

                    <!-- ── Energy Curve Sparkline ──────────────────────── -->
                    <StackPanel Spacing="6" IsVisible="{Binding HasAnalysisData}">
                        <Separator Background="#252526" Height="1"/>
                        <TextBlock Text="ENERGY CURVE" FontSize="10" FontWeight="Black" Foreground="#444"/>
                        <Border Background="#0D0D0D" CornerRadius="4" Height="40">
                            <controls:SparklineControl Values="{Binding EnergyCurvePoints}" Height="40"/>
                        </Border>
                    </StackPanel>

                    <!-- ── Vocal Analysis ──────────────────────────────── -->
                    <StackPanel Spacing="8" IsVisible="{Binding HasAnalysisData}">
                        <Separator Background="#252526" Height="1"/>
                        <TextBlock Text="VOCAL ANALYSIS" FontSize="10" FontWeight="Black" Foreground="#444"/>
                        <Grid ColumnDefinitions="80,*,40">
                            <TextBlock Text="{Binding DetectedVocalTypeDisplay}" FontSize="12"
                                       Foreground="#CCC" VerticalAlignment="Center"/>
                            <ProgressBar Grid.Column="1" Value="{Binding AudioVocalDensity}"
                                         Minimum="0" Maximum="1"
                                         Height="6" Margin="4,0"
                                         Foreground="#C586C0" Background="#1A1A1A"/>
                            <TextBlock Grid.Column="2" Text="{Binding AudioVocalDensity, StringFormat={}{0:P0}}"
                                       FontSize="10" Foreground="#666" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>

            <!-- Bottom Actions -->
            <Border Grid.Row="1" Background="#1E1E1F" Padding="20"
                    BorderBrush="#2D2D2D" BorderThickness="0,1,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                    <Button Command="{Binding OpenWorkstationCommand}"
                            Background="#2D2D2D" Foreground="#CCC"
                            Padding="14,8" CornerRadius="6">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="🎚" FontSize="14"/>
                            <TextBlock Text="WORKSTATION" FontWeight="Bold" FontSize="11"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding RevealFileCommand}"
                            IsVisible="{Binding IsCompleted}"
                            Background="#00BFFF" Foreground="White"
                            Padding="16,8" CornerRadius="6">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <PathIcon Data="{StaticResource folder_open_regular}" Width="16" Height="16"/>
                            <TextBlock Text="REVEAL IN EXPLORER" FontWeight="Bold" FontSize="11"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

        </Grid>
    </Border>
</UserControl>
