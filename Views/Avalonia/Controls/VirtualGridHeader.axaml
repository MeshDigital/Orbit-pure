<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="50"
             x:Class="SLSKDONET.Views.Avalonia.Controls.VirtualGridHeader"
             Background="Transparent">

    <Border Background="#1A1A1D" 
            BorderBrush="#3E3E3E" 
            BorderThickness="0,0,0,1" 
            Padding="16,8">
        <ContentPresenter Content="{Binding HeaderContent, RelativeSource={RelativeSource AncestorType=UserControl}}" />
    </Border>
</UserControl>
