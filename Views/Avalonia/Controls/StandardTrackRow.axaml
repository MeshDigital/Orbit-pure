<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:SLSKDONET.ViewModels"
             xmlns:views="clr-namespace:SLSKDONET.Views.Avalonia"
             xmlns:controls="clr-namespace:SLSKDONET.Views.Avalonia.Controls"
             xmlns:converters="clr-namespace:SLSKDONET.Views.Avalonia.Converters"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="60"
             x:Class="SLSKDONET.Views.Avalonia.Controls.StandardTrackRow"
             x:Name="RootControl">
             
    <UserControl.Styles>
        <Style Selector="Button.ActionBtn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.ActionBtn:hover">
            <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>
        <Style Selector="ToggleButton.ActionBtn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="ToggleButton.ActionBtn:hover">
            <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>
        <Style Selector="ToggleButton.ActionBtn:checked">
            <Setter Property="Background" Value="{DynamicResource AccentGlowBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
        </Style>

        <Style Selector="Button.pending">
            <Setter Property="Opacity" Value="0.5"/>
        </Style>
        
        <!-- Integrity Badge Styles -->
        <Style Selector="Border.IntegrityBadge">
            <Setter Property="CornerRadius" Value="2"/>
            <Setter Property="Padding" Value="4,1"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="Border.IntegrityBadge.Secure">
            <Setter Property="Background" Value="{DynamicResource GlassThinBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BrushSuccess}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="Border.IntegrityBadge.Suspect">
            <Setter Property="Background" Value="{DynamicResource GlassThinBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BrushWarning}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        
        <Style Selector="Border.PrepBadge">
            <Setter Property="CornerRadius" Value="2"/>
            <Setter Property="Padding" Value="4,1"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- Root Styles -->
        <Style Selector="Border.root">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="{StaticResource GlassBrush}"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.2"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.root:pointerover">
            <Setter Property="Background" Value="{StaticResource GlassBrush}"/>
        </Style>
        <Style Selector="Border.root:pointerover StackPanel.ActionHub">
            <Setter Property="Opacity" Value="1"/>
        </Style>

        <!-- Action Hub Visibility -->
        <Style Selector="StackPanel.ActionHub">
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.15"/>
                </Transitions>
            </Setter>
        </Style>
        
        <!-- Card Style (Phase 0.7) -->
        <Style Selector=":is(UserControl).card Border.root">
            <Setter Property="Background" Value="{DynamicResource SecondaryBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="{DynamicResource RadiusMd}"/>
            <Setter Property="Padding" Value="{DynamicResource PaddingMd}"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <!-- Pending Text Style -->
        <Style Selector="TextBlock.pending">
            <Setter Property="FontStyle" Value="Italic"/>
        </Style>

        <!-- Phase 8: In-Flight Row Aesthetics (Glass) -->
        <Style Selector="Border.InFlightRow">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Padding" Value="{DynamicResource PaddingMd}"/>
        </Style>
        <Style Selector="Border.InFlightRow:hover">
            <Setter Property="Background" Value="{DynamicResource GlassHeavyBrush}"/>
        </Style>

        <Style Selector="TextBlock.LED">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Black"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style Selector="Border.root.active">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BoxShadow" Value="{DynamicResource ShadowAccent}"/>
            <Style.Animations>
                <Animation Duration="0:0:3" IterationCount="Infinite">
                    <KeyFrame KeyTime="0:0:0"><Setter Property="Opacity" Value="1.0" /></KeyFrame>
                    <KeyFrame KeyTime="0:0:1.5"><Setter Property="Opacity" Value="0.85" /></KeyFrame>
                    <KeyFrame KeyTime="0:0:3"><Setter Property="Opacity" Value="1.0" /></KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        
        <Style Selector="Border.root.stalled">
            <Setter Property="BorderBrush" Value="{DynamicResource BrushWarning}"/>
            <Setter Property="Opacity" Value="0.7"/>
            <Style.Animations>
                <Animation Duration="0:0:1" IterationCount="Infinite">
                    <KeyFrame KeyTime="0:0:0"><Setter Property="BorderBrush" Value="{DynamicResource BrushWarning}"/></KeyFrame>
                    <KeyFrame KeyTime="0:0:0.5"><Setter Property="BorderBrush" Value="Transparent"/></KeyFrame>
                    <KeyFrame KeyTime="0:0:1"><Setter Property="BorderBrush" Value="{DynamicResource BrushWarning}"/></KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>

        <!-- Unified Session Ledger: completed row — faint green tint, dimmed -->
        <Style Selector="Border.root.completed">
            <Setter Property="Opacity" Value="0.65"/>
            <Setter Property="Background" Value="{DynamicResource BrushAccentSubtle}"/>
        </Style>

        <!-- Unified Session Ledger: failed row — faint red tint -->
        <Style Selector="Border.root.failed">
            <Setter Property="Background" Value="{DynamicResource GlassHeavyBrush}"/>
        </Style>

        <!-- Always reveal action hub for terminal states so the user can act without hovering -->
        <Style Selector="Border.root.completed StackPanel.ActionHub">
            <Setter Property="Opacity" Value="1"/>
        </Style>
        <Style Selector="Border.root.failed StackPanel.ActionHub">
            <Setter Property="Opacity" Value="1"/>
        </Style>

        <!-- Ghost state styling -->
        <Style Selector="Border.root.ghost">
            <Setter Property="Opacity" Value="0.45"/>
        </Style>
        <Style Selector="Border.root.ghost:pointerover">
            <Setter Property="Opacity" Value="0.75"/>
        </Style>
        <!-- Always reveal action hub for Ghost tracks so the user sees the Acquire button -->
        <Style Selector="Border.root.ghost StackPanel.ActionHub">
            <Setter Property="Opacity" Value="1"/>
        </Style>

    </UserControl.Styles>

    <Border Classes="root"
            Classes.active="{Binding IsDownloading}"
            Classes.stalled="{Binding IsStalled}"
            Classes.completed="{Binding IsCompleted}"
            Classes.failed="{Binding IsFailed}"
            Classes.ghost="{Binding IsGhost}">
        <Panel>

        <!-- Full-length RGB waveform underlay — rendered behind metadata.
             SkiaSharp tri-band bitmap, background thread, cached per row. -->
        <controls:LibraryWaveformView
            WaveformData="{Binding WaveformData}"
            IsVisible="{Binding HasWaveformData}"
            Opacity="0.22"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            IsHitTestVisible="False"/>

        <StackPanel>
        <!-- Column 0: Art & Health, 1: Artist, 2: Title, 3: BPM/Key, 4: Badges, 5: Actions -->
        <Grid RowDefinitions="Auto, *" Margin="0,2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="2"/> <!-- Underline space -->
            </Grid.RowDefinitions>
            
            <Grid Grid.Row="0" ColumnDefinitions="58,*,*,*,*,*,Auto" PointerPressed="OnRowPointerPressed" PointerMoved="OnRowPointerMoved" Background="Transparent" Name="MainRowGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="58"/>
                <ColumnDefinition SharedSizeGroup="ArtistCol"/> <!-- Artist -->
                <ColumnDefinition SharedSizeGroup="TitleCol"/> <!-- Title -->
                <ColumnDefinition SharedSizeGroup="BpmKeyCol"/> <!-- BPM/Key -->
                <ColumnDefinition SharedSizeGroup="ForensicCol"/> <!-- Forensics -->
                <ColumnDefinition Width="*"/> <!-- Badges -->
                <ColumnDefinition Width="Auto"/> <!-- Actions -->
            </Grid.ColumnDefinitions>
            
            <!-- Column 0: Album Art / Status / Health -->
            <Border Grid.Column="0" Width="44" Height="44" Margin="6,4,8,4" CornerRadius="4" ClipToBounds="True" Background="{DynamicResource SurfaceBrush}" VerticalAlignment="Center">
                <Panel>
                    <Image Source="{Binding Artwork.Image}" Stretch="UniformToFill" RenderOptions.BitmapInterpolationMode="MediumQuality" IsVisible="{Binding Artwork.Image, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                    <PathIcon Data="{StaticResource music_regular}" Foreground="{DynamicResource TextDisabledBrush}" Width="20" Height="20" IsVisible="{Binding Artwork.Image, Converter={x:Static ObjectConverters.IsNull}}"/>
                    
                    <!-- Spotify Icon for Ghost tracks -->
                    <Border IsVisible="{Binding IsGhost}" Width="16" Height="16" Background="#1DB954" CornerRadius="8" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="2">
                        <PathIcon Data="{StaticResource icons_spotify}" Width="10" Height="10" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    
                    <!-- Progress Overlay -->
                    <Arc Width="36" Height="36" StartAngle="-90" SweepAngle="{Binding Progress, Converter={StaticResource PercentageToAngleConverter}}" Stroke="{DynamicResource AccentBrush}" StrokeThickness="2" IsVisible="{Binding IsActive}" Opacity="0.8"/>
                    
                    <!-- Activity Icons (Phase 11.1 Gating) -->
                    <Border Background="{DynamicResource GlassHeavyBrush}" IsVisible="{Binding IsActive}" CornerRadius="4">
                        <Panel>
                             <TextBlock Text="🔍" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" IsVisible="{Binding IsSearching}">
                                 <TextBlock.Styles>
                                     <Style Selector="TextBlock">
                                         <Style.Animations>
                                             <Animation Duration="0:0:1.5" IterationCount="Infinite">
                                                 <KeyFrame KeyTime="0:0:0"><Setter Property="Opacity" Value="1"/></KeyFrame>
                                                 <KeyFrame KeyTime="0:0:0.75"><Setter Property="Opacity" Value="0.3"/></KeyFrame>
                                                 <KeyFrame KeyTime="0:0:1.5"><Setter Property="Opacity" Value="1"/></KeyFrame>
                                             </Animation>
                                         </Style.Animations>
                                     </Style>
                                 </TextBlock.Styles>
                             </TextBlock>
                             <TextBlock Text="📥" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" IsVisible="{Binding IsDownloading}"/>
                        </Panel>
                    </Border>
                    
                    <!-- Enrichment Progress (Phase 2.1) -->
                    <Arc Stroke="{DynamicResource BrushStemOther}" StrokeThickness="2" StartAngle="0" SweepAngle="300" Width="42" Height="42" IsVisible="{Binding IsAnalyzing}">
                        <Arc.RenderTransform>
                            <RotateTransform Angle="0"/>
                        </Arc.RenderTransform>
                        <Arc.Styles>
                            <Style Selector="Arc">
                                <Style.Animations>
                                    <Animation Duration="0:0:1.5" IterationCount="Infinite">
                                        <KeyFrame KeyTime="0:0:0">
                                            <Setter Property="RotateTransform.Angle" Value="0"/>
                                        </KeyFrame>
                                        <KeyFrame KeyTime="0:0:1.5">
                                            <Setter Property="RotateTransform.Angle" Value="360"/>
                                        </KeyFrame>
                                    </Animation>
                                </Style.Animations>
                            </Style>
                        </Arc.Styles>
                    </Arc>

                    <!-- Spotify/MB Enrichment Progress (Phase 2.1) -->
                    <Arc Stroke="{DynamicResource BrushSuccess}" StrokeThickness="2" StartAngle="180" SweepAngle="120" Width="48" Height="48" IsVisible="{Binding IsEnriching}">
                        <Arc.RenderTransform>
                            <RotateTransform Angle="0"/>
                        </Arc.RenderTransform>
                        <Arc.Styles>
                            <Style Selector="Arc">
                                <Style.Animations>
                                    <Animation Duration="0:0:2" IterationCount="Infinite">
                                        <KeyFrame KeyTime="0:0:0">
                                            <Setter Property="RotateTransform.Angle" Value="360"/>
                                        </KeyFrame>
                                        <KeyFrame KeyTime="0:0:2">
                                            <Setter Property="RotateTransform.Angle" Value="0"/>
                                        </KeyFrame>
                                    </Animation>
                                </Style.Animations>
                            </Style>
                        </Arc.Styles>
                    </Arc>

                    <!-- Phase 12.3: Bulk Selection Overlay -->
                    <Border Background="{DynamicResource GlassHeavyBrush}" IsVisible="{Binding IsSelected}" VerticalAlignment="Stretch" HorizontalAlignment="Stretch"/>
                    <CheckBox IsChecked="{Binding IsSelected}" 
                              HorizontalAlignment="Left" VerticalAlignment="Top" 
                              Margin="-2,-2,0,0">
                         <CheckBox.Styles>
                             <Style Selector="CheckBox">
                                 <Setter Property="Opacity" Value="0"/> 
                                 <Setter Property="Background" Value="{DynamicResource SecondaryBackgroundBrush}"/>
                                 <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                             </Style>
                             <Style Selector="CheckBox:pointerover">
                                 <Setter Property="Opacity" Value="1"/>
                             </Style>
                             <Style Selector="CheckBox:checked">
                                 <Setter Property="Opacity" Value="1"/>
                                 <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                             </Style>
                         </CheckBox.Styles>
                    </CheckBox>
                </Panel>
            </Border>
            
            <!-- Health Bar -->
            <Rectangle Grid.Column="0" Width="3" HorizontalAlignment="Left" Fill="{Binding QualityColor}" RadiusX="1.5" RadiusY="1.5" Margin="2,8">
                <Rectangle.IsVisible>
                    <MultiBinding Converter="{x:Static BoolConverters.And}"><Binding Path="IsCompleted"/><Binding Path="$parent[views:LibraryPage].DataContext.ViewSettings.ShowQualityBar"/></MultiBinding>
                </Rectangle.IsVisible>
            </Rectangle>

            <!-- Column 1: Artist (Shared) -->
            <Border Grid.Column="1" Padding="8,0" VerticalAlignment="Center">
                <TextBlock Text="{Binding ArtistName}" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" FontSize="13" TextTrimming="CharacterEllipsis"/>
            </Border>

            <!-- Column 2: Title (Shared) -->
            <Border Grid.Column="2" Padding="8,0" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="{Binding TrackTitle}" Foreground="{DynamicResource TextBrush}" FontSize="13" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="❤️" IsVisible="{Binding IsLiked}" FontSize="11" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Column 3: BPM & Key (Shared) -->
            <Border Grid.Column="3" Padding="12,0" VerticalAlignment="Center" IsVisible="{Binding !IsCompact, ElementName=RootControl}">
                <Panel>
                     <!-- The Data is Present -->
                     <StackPanel Orientation="Horizontal" Spacing="10" IsVisible="{Binding HasBpm}">
                         <TextBlock Text="{Binding BpmDisplay}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Width="32" TextAlignment="Right" VerticalAlignment="Center"/>
                         <Border Background="{Binding ColorBrush}" CornerRadius="4" Padding="4,1" MinWidth="32" VerticalAlignment="Center">
                             <TextBlock Text="{Binding CamelotDisplay}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center"/>
                         </Border>
                     </StackPanel>

                     <!-- The Data is Missing (Skeleton loading style) -->
                     <StackPanel Orientation="Horizontal" Spacing="10" IsVisible="{Binding !HasBpm}">
                         <Border Classes="skeleton" Width="32" Height="14" VerticalAlignment="Center"/>
                         <Border Classes="skeleton" Width="32" Height="14" VerticalAlignment="Center" CornerRadius="4"/>
                     </StackPanel>
                </Panel>
            </Border>

            <!-- Column 4: Unified Metadata & Health (Refined Phase 3) -->
            <Border Grid.Column="4" VerticalAlignment="Center" Margin="12,0" IsVisible="{Binding !IsCompact, ElementName=RootControl}">
                <Panel>
                    <!-- STATE A: Searching (Clean, No clutter) -->
                    <StackPanel Spacing="4" IsVisible="{Binding IsSearching}">
                        <TextBlock Text="Searching Soulseek..." Classes="pulsing" FontSize="11" Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding SearchCountdownDisplay, StringFormat='{}Time Left: {0}'}" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" Opacity="0.8"/>
                    </StackPanel>

                    <!-- STATE B: Downloading / Finalized (Metrics visible) -->
                    <StackPanel Spacing="4" IsVisible="{Binding !IsSearching}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                             <!-- Forensic Orbs (Refined) -->
                             <Border Background="{StaticResource GlassThinBrush}" CornerRadius="10" Padding="6,3">
                                 <StackPanel Orientation="Horizontal" Spacing="6">
                                     <Ellipse Width="6" Height="6" Fill="{Binding BitrateLed, Converter={StaticResource LedColorConverter}}" ToolTip.Tip="Bitrate Integrity"/>
                                     <Ellipse Width="6" Height="6" Fill="{Binding KeyLed, Converter={StaticResource LedColorConverter}}" ToolTip.Tip="Key Accuracy"/>
                                     <Ellipse Width="6" Height="6" Fill="{Binding PeakLed, Converter={StaticResource LedColorConverter}}" ToolTip.Tip="Peak Levels"/>
                                 </StackPanel>
                             </Border>
                             
                             <!-- Technical Bitrate/Duration -->
                             <TextBlock Text="{Binding TechnicalSummary}" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Opacity="0.8"/>

                             <!-- Synergy (Core) -->
                             <Border Background="{DynamicResource GlassThinBrush}" CornerRadius="4" Padding="6,2" BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1" IsVisible="{Binding HasCrossProjectReference}">
                                 <StackPanel Orientation="Horizontal" Spacing="6">
                                     <TextBlock Text="🔗" FontSize="10" VerticalAlignment="Center"/>
                                     <TextBlock Text="{Binding CrossProjectReference}" FontSize="9" Foreground="{DynamicResource AccentBrush}" FontWeight="Black" VerticalAlignment="Center" MaxWidth="120" TextTrimming="CharacterEllipsis"/>
                                 </StackPanel>
                             </Border>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="6" IsVisible="{Binding !IsCompleted}">
                             <!-- Download Status / Stalled / Failed -->
                             <TextBlock Text="{Binding StatusText}" FontSize="10" Foreground="{Binding StatusColor}" Opacity="0.9" VerticalAlignment="Center" FontWeight="SemiBold"/>
                             
                             <!-- Speed Context (Core) -->
                             <StackPanel Orientation="Horizontal" Spacing="6" IsVisible="{Binding IsDownloading}">
                                 <Border Background="{StaticResource AccentBrush}" CornerRadius="4" Padding="4,1">
                                     <StackPanel Orientation="Horizontal" Spacing="4">
                                         <TextBlock Text="{Binding SpeedTrend}" FontSize="9" FontWeight="Black" Foreground="{DynamicResource BrushBg0}"/>
                                         <TextBlock Text="{Binding SpeedDisplay}" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource BrushBg0}"/>
                                     </StackPanel>
                                 </Border>
                                 <!-- Speed sparkline (30-point rolling history) -->
                                 <controls:SparklineControl Values="{Binding SpeedHistory}"
                                                            Width="48" Height="16"
                                                            VerticalAlignment="Center"/>
                             </StackPanel>
                             
                             <!-- Rejection Summary (Core) -->
                                 <TextBlock Text="{Binding RejectionSummary}" FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" IsVisible="{Binding IsFailed}" TextTrimming="CharacterEllipsis" MaxWidth="300" Opacity="0.7"/>
                        </StackPanel>

                        <Border IsVisible="{Binding HasIncomingResults}" Background="{DynamicResource GlassThinBrush}" BorderBrush="{Binding LatestIncomingStateColor}" BorderThickness="1" CornerRadius="4" Padding="6,3" MaxWidth="520">
                            <Grid ColumnDefinitions="Auto,Auto,*">
                                <TextBlock Grid.Column="0" Text="{Binding LatestIncomingTimeDisplay}" FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                <Border Grid.Column="1" Background="{DynamicResource SecondaryBackgroundBrush}" BorderBrush="{Binding LatestIncomingStateColor}" BorderThickness="1" CornerRadius="3" Padding="5,1" VerticalAlignment="Center" Margin="8,0,0,0">
                                    <TextBlock Text="{Binding LatestIncomingStateLabel}" FontSize="9" FontWeight="Bold" Foreground="{Binding LatestIncomingStateColor}"/>
                                </Border>
                                <TextBlock Grid.Column="2" Text="{Binding LatestIncomingMessage}" FontSize="10" Foreground="{DynamicResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Panel>
            </Border>

            <!-- Column 5: Badge Tray (Flexible) -->
            <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center" Spacing="4" Margin="8,0" IsVisible="{Binding !IsCompact, ElementName=RootControl}">
                <!-- Quality Pill -->
                <Border IsVisible="{Binding HasQualityPill}"
                        Background="{DynamicResource GlassThinBrush}" BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1"
                        CornerRadius="10" Padding="8,1" ToolTip.Tip="Bitrate / sample rate from Soulseek attributes">
                    <TextBlock Text="{Binding QualityPillText}" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                </Border>

                <!-- Forensic Badge -->
                <Border IsVisible="{Binding IsDownloading}"
                        Background="{Binding ForensicBadgeBackground}"
                        BorderBrush="{Binding ForensicBadgeBorderColor}"
                        BorderThickness="1"
                        CornerRadius="10" Padding="8,1"
                        ToolTip.Tip="{Binding ForensicBadgeHud}">
                    <TextBlock Text="{Binding ForensicBadgeText}"
                               FontSize="9" FontWeight="Bold"
                               Foreground="{Binding ForensicBadgeForeground}"
                               VerticalAlignment="Center"/>
                </Border>

                <!-- Spectral Integrity Badge (shown on completed tracks after post-download analysis) -->
                <Border IsVisible="{Binding HasSpectralVerdict}"
                    Background="{DynamicResource GlassThinBrush}"
                        BorderBrush="{Binding SpectralVerdictColor}"
                        BorderThickness="1"
                        CornerRadius="10" Padding="8,1"
                        ToolTip.Tip="{Binding SpectralVerdictTooltip}">
                    <TextBlock Text="{Binding SpectralVerdictBadgeText}"
                               FontSize="9" FontWeight="Bold"
                               Foreground="{Binding SpectralVerdictColor}"
                               VerticalAlignment="Center"/>
                </Border>

                <!-- Energy Score Badge -->
                <Border IsVisible="{Binding HasEnergyBadge}"
                        Background="{DynamicResource GlassThinBrush}"
                        BorderBrush="{Binding EnergyBadgeColor}"
                        BorderThickness="1"
                        CornerRadius="10" Padding="8,1"
                        ToolTip.Tip="Energy Score (1–10)">
                    <TextBlock Text="{Binding EnergyBadgeText}"
                               FontSize="9" FontWeight="Bold"
                               Foreground="{Binding EnergyBadgeColor}"
                               VerticalAlignment="Center"/>
                </Border>

                <!-- Instrumental Badge -->
                <Border IsVisible="{Binding ShowInstrumentalBadge}"
                        Background="{DynamicResource GlassThinBrush}"
                        BorderBrush="#7BA7BC"
                        BorderThickness="1"
                        CornerRadius="10" Padding="8,1"
                        ToolTip.Tip="Confirmed Instrumental">
                    <TextBlock Text="INST"
                               FontSize="9" FontWeight="Bold"
                               Foreground="#7BA7BC"
                               VerticalAlignment="Center"/>
                </Border>

                <!-- Mood Tag Badge -->
                <Border IsVisible="{Binding HasMoodTag}"
                        Background="{DynamicResource GlassThinBrush}"
                        BorderBrush="#9B6FD6"
                        BorderThickness="1"
                        CornerRadius="10" Padding="8,1"
                        ToolTip.Tip="Detected mood / vibe">
                    <TextBlock Text="{Binding MoodTagText}"
                               FontSize="9" FontWeight="Bold"
                               Foreground="#9B6FD6"
                               VerticalAlignment="Center"/>
                </Border>

                <!-- BPM Drift Warning Badge -->
                <Border IsVisible="{Binding HasBpmDriftWarning}"
                        Background="{DynamicResource GlassThinBrush}"
                        BorderBrush="#E07040"
                        BorderThickness="1"
                        CornerRadius="10" Padding="8,1"
                        ToolTip.Tip="Variable/drifting BPM — may cause beat sync issues">
                    <TextBlock Text="~BPM"
                               FontSize="9" FontWeight="Bold"
                               Foreground="#E07040"
                               VerticalAlignment="Center"/>
                </Border>

                <!-- Warning Badges (Shield, Risk, etc) -->
                <Border IsVisible="{Binding IsHighRisk}" Background="{DynamicResource BrushError}" CornerRadius="4" Padding="6,2" ToolTip.Tip="{Binding FlagReason}">
                    <TextBlock Text="HIGH RISK" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                </Border>
                
                <!-- Match Reasons (Only if not minimal) -->
                <Border IsVisible="{Binding !MinimalBadges}" Background="{StaticResource GlassThinBrush}" BorderBrush="{DynamicResource BrushWarning}" BorderThickness="1" CornerRadius="4" Padding="6,2">
                    <TextBlock Text="{Binding DiscoveryBadgeText}" FontSize="9" Foreground="{DynamicResource BrushWarning}" IsVisible="{Binding DiscoveryBadgeText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                </Border>
                
                <!-- Peer Info -->
                <Border IsVisible="{Binding !MinimalBadges}" Background="{StaticResource GlassThinBrush}" CornerRadius="4" Padding="6,2">
                    <TextBlock Text="{Binding PeerName}" FontSize="10" Foreground="{StaticResource AccentBrush}" IsVisible="{Binding PeerName, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                </Border>
            </StackPanel>

            <!-- Column 6: Action Hub (Unified Session Ledger) -->
            <StackPanel Grid.Column="6" Classes="ActionHub" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center" Margin="0,0,8,0">
                <!-- Group 4: Ghost Track Acquisition -->
                <Button Classes="ActionBtn" Command="{Binding AcquireTrackCommand}" IsVisible="{Binding IsGhost}" ToolTip.Tip="Acquire Track (Download from Soulseek)">
                    <PathIcon Data="{StaticResource cloud_download_regular}" Width="16" Height="16" Foreground="{DynamicResource AccentBrush}"/>
                </Button>

                <!-- Session Ledger: terminal state indicators -->
                <TextBlock Text="✓" FontSize="13" FontWeight="Black" Foreground="{DynamicResource BrushSuccess}" IsVisible="{Binding IsCompleted}" Margin="0,0,4,0"/>
                <TextBlock Text="✕" FontSize="13" FontWeight="Black" Foreground="{DynamicResource BrushError}" IsVisible="{Binding IsFailed}" Margin="0,0,4,0"/>

                <!-- Group 1: Terminal/Success -->
                <Button Classes="ActionBtn" Command="{Binding PlayCommand}" IsVisible="{Binding IsCompleted}" ToolTip.Tip="Play"><PathIcon Data="{StaticResource play_circle_regular}" Width="18" Height="18" Foreground="{StaticResource AccentBrush}"/></Button>
                <Button Classes="ActionBtn" Command="{Binding RevealFileCommand}" IsVisible="{Binding IsCompleted}" ToolTip.Tip="Show in Explorer"><PathIcon Data="{StaticResource folder_open_regular}" Width="16" Height="16"/></Button>
                <Button Classes="ActionBtn" Command="{Binding FindSimilarCommand}" IsVisible="{Binding IsCompleted}" ToolTip.Tip="Find Similar Tracks (Harmonic + Sound Match)">
                    <PathIcon Data="{StaticResource sparkles_regular}" Width="16" Height="16" Foreground="#9B6FD6"/>
                </Button>
                
                <!-- Group 2: Recovery (Core Feature) -->
                <Button Classes="ActionBtn" Command="{Binding ViewAllSearchResultsCommand}" IsVisible="{Binding IsFailed}" ToolTip.Tip="Deep Search (Manual Overwrite)" Background="{DynamicResource AccentGlowBrush}" BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1">
                    <PathIcon Data="{StaticResource search_regular}" Width="16" Height="16" Foreground="{DynamicResource AccentBrush}"/>
                </Button>
                <Button Classes="ActionBtn" Command="{Binding RetryCommand}" IsVisible="{Binding CanRetry}" ToolTip.Tip="Retry"><PathIcon Data="{StaticResource arrow_counterclockwise_regular}" Width="14" Height="14" Foreground="{DynamicResource BrushSuccess}"/></Button>

                <!-- Group 3: Active Controls -->
                <Button Classes="ActionBtn" Command="{Binding ForceStartCommand}" IsVisible="{Binding CanForceStart}" ToolTip.Tip="Force Start (Priority 0)"><PathIcon Data="{StaticResource rocket_regular}" Width="18" Height="18" Foreground="{DynamicResource BrushWarning}"/></Button>
                <Button Classes="ActionBtn" Command="{Binding ResumeCommand}" IsVisible="{Binding CanResume}" ToolTip.Tip="Resume"><PathIcon Data="{StaticResource play_regular}" Width="14" Height="14" Foreground="{DynamicResource BrushSuccess}"/></Button>
                <Button Classes="ActionBtn" Command="{Binding PauseCommand}" IsVisible="{Binding IsActive}" ToolTip.Tip="Pause"><PathIcon Data="{StaticResource pause_regular}" Width="14" Height="14"/></Button>
                <Button Classes="ActionBtn" Command="{Binding CancelCommand}" IsVisible="{Binding IsActive}" ToolTip.Tip="Cancel"><PathIcon Data="{StaticResource dismiss_regular}" Width="14" Height="14" Foreground="{DynamicResource BrushError}"/></Button>
                
                <ToggleButton Classes="ActionBtn" IsChecked="{Binding IsConsoleOpen}" ToolTip.Tip="Toggle Live Log"><PathIcon Data="{StaticResource text_bullet_list_square_regular}" Width="14" Height="14"/></ToggleButton>
            </StackPanel>
        </Grid>

        <!-- Phase 12.8: Progress Underline (Hyper-optimized render) -->
        <ProgressBar Grid.Row="1" Height="2" Minimum="0" Maximum="100" Value="{Binding Progress}" 
                     IsVisible="{Binding IsActive}" Foreground="{DynamicResource AccentBrush}" Background="Transparent" 
                     BorderThickness="0" CornerRadius="0" VerticalAlignment="Bottom"
                     Opacity="0.8"/>
    </Grid>
</StackPanel>
        </Panel>
</Border>
</UserControl>
