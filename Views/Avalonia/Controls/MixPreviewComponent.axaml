<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="using:SLSKDONET.Views.Avalonia.Controls"
             xmlns:vm="using:SLSKDONET.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="300"
             x:Class="SLSKDONET.Views.Avalonia.Controls.MixPreviewComponent">

    <Design.DataContext>
        <vm:MixPreviewViewModel/>
    </Design.DataContext>

    <UserControl.Styles>
        <Style Selector="Button.PreviewAction">
            <Setter Property="Background" Value="#22FFFFFF"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#44FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.2"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.PreviewAction:pointerover">
            <Setter Property="Background" Value="#44FFFFFF"/>
        </Style>
        <Style Selector="Button.Accept">
            <Setter Property="Background" Value="#CC00E676"/> <!-- Neon Green -->
            <Setter Property="BorderBrush" Value="#00E676"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
         <Style Selector="Button.Nudge">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Padding" Value="6,2"/>
        </Style>
    </UserControl.Styles>

    <Border Background="#CC0A0A0A" CornerRadius="12" BorderBrush="#33FFFFFF" BorderThickness="1" Padding="15">
        <!-- Glass Effect -->
        <Grid RowDefinitions="Auto, *, Auto, *, Auto">
            
            <!-- Header -->
            <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto" Margin="0,0,0,10">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <PathIcon Data="{StaticResource mixer_regular}" Foreground="#00E5FF"/>
                    <TextBlock Text="TRANSITION PREVIEW" FontWeight="SemiBold" Foreground="#00E5FF" VerticalAlignment="Center"/>
                </StackPanel>
                
                <TextBlock Grid.Column="1" Text="{Binding StatusMessage}" HorizontalAlignment="Center" Foreground="#AAFFFFFF" VerticalAlignment="Center"/>
                
                <Button Grid.Column="2" Command="{Binding CancelCommand}" Background="Transparent" BorderThickness="0">
                     <PathIcon Data="{StaticResource dismiss_regular}" Foreground="#AAFFFFFF"/>
                </Button>
            </Grid>

            <!-- Track A (Outgoing) -->
            <Grid Grid.Row="1">
                 <!-- Background for rail -->
                 <Rectangle Width="2" HorizontalAlignment="Center" Fill="#33FFFFFF"/>
                 
                 <controls:WaveformControl 
                    WaveformData="{Binding WaveformDataA}"
                    Progress="{Binding ProgressA}"
                    ZoomLevel="4" 
                    ViewOffset="{Binding ProgressA, Converter={x:Static ObjectConverters.IsNull}}" 
                    Height="80"
                    Foreground="#00E5FF"
                    Background="Transparent"
                    PlayheadBrush="#88FFFFFF"/>
                    
                 <TextBlock Text="OUTGOING" Foreground="#00E5FF" Opacity="0.5" FontSize="10" Margin="4" HorizontalAlignment="Right" VerticalAlignment="Top"/>
            </Grid>
            
            <!-- Phase Meter (Middle) -->
            <Grid Grid.Row="2" Height="20" Margin="0,4">
                 <Rectangle Fill="#11FFFFFF" Height="4" VerticalAlignment="Center"/>
                 <!-- Center Mark -->
                 <Rectangle Width="2" Height="12" Fill="White" HorizontalAlignment="Center"/>
                 
                 <!-- Phase Confidence Indicator (Dynamic Width/Color based on PhaseConfidence) -->
                 <Rectangle Height="6" RadiusX="3" RadiusY="3" HorizontalAlignment="Center" Width="{Binding PhaseConfidenceWidth}">
                    <Rectangle.Fill>
                        <SolidColorBrush Color="#00E676" Opacity="0.8"/> 
                    </Rectangle.Fill>
                 </Rectangle>

                 <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="20">
                     <Button Classes="PreviewAction Nudge" Command="{Binding NudgeBackCommand}" Content="◄ NUDGE"/>
                     <Button Classes="PreviewAction Nudge" Command="{Binding NudgeForwardCommand}" Content="NUDGE ►"/>
                 </StackPanel>
            </Grid>

            <!-- Track B (Incoming) -->
            <Grid Grid.Row="3">
                 <Rectangle Width="2" HorizontalAlignment="Center" Fill="#33FFFFFF"/>

                 <controls:WaveformControl 
                    WaveformData="{Binding WaveformDataB}"
                    Progress="{Binding ProgressB}"
                    ZoomLevel="4"
                    Height="80"
                    Foreground="#E040FB"
                    Background="Transparent"
                    PlayheadBrush="#88FFFFFF"/>

                 <TextBlock Text="INCOMING" Foreground="#E040FB" Opacity="0.5" FontSize="10" Margin="4" HorizontalAlignment="Right" VerticalAlignment="Top"/>
            </Grid>

            <!-- Controls -->
            <Grid Grid.Row="4" ColumnDefinitions="Auto, *, Auto" Margin="0,15,0,0">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10">
                    <Button Classes="PreviewAction" Command="{Binding PlayCommand}" IsVisible="{Binding !IsPlaying}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <PathIcon Data="{StaticResource play_regular}"/>
                            <TextBlock Text="PREVIEW"/>
                        </StackPanel>
                    </Button>
                    <Button Classes="PreviewAction" Command="{Binding PauseCommand}" IsVisible="{Binding IsPlaying}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <PathIcon Data="{StaticResource pause_regular}"/>
                            <TextBlock Text="PAUSE"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10">
                    <Button Classes="PreviewAction" Command="{Binding CancelCommand}" Content="Dismiss"/>
                    <Button Classes="PreviewAction Accept" Command="{Binding CommitCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <PathIcon Data="{StaticResource checkmark_regular}"/>
                            <TextBlock Text="ACCEPT TRANSITION"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
            
            <!-- Vertical Alignment Rail Overlay (Global) -->
            <Rectangle Grid.Row="1" Grid.RowSpan="3" Width="1" HorizontalAlignment="Center" Fill="#88FFFFFF" IsHitTestVisible="False"/>

        </Grid>
    </Border>
</UserControl>
