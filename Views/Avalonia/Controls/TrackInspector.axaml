<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:SLSKDONET.ViewModels.Downloads"
             xmlns:controls="clr-namespace:SLSKDONET.Views.Avalonia.Controls"
             mc:Ignorable="d" d:DesignWidth="450" d:DesignHeight="800"
             x:Class="SLSKDONET.Views.Avalonia.Controls.TrackInspector"
             x:DataType="vm:UnifiedTrackViewModel">
    
    <Border Background="#1A1B1C" BorderBrush="#2D2D2D" BorderThickness="1,0,0,0">
        <Grid RowDefinitions="Auto, *, Auto">
            
            <!-- Content -->
            <ScrollViewer Grid.Row="1" Padding="24">
                <StackPanel Spacing="24">
                    
                    <!-- Artwork & Primary Info -->
                    <Grid ColumnDefinitions="140, *">
                        <Border Grid.Column="0" CornerRadius="12" ClipToBounds="True" BoxShadow="0 8 20 0 #40000000">
                             <Panel>
                                 <Image Source="{Binding Artwork}" Stretch="UniformToFill" Width="140" Height="140"/>
                                 <Border Background="#50000000" IsVisible="{Binding !Artwork}"/>
                             </Panel>
                        </Border>
                        
                        <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Center" Spacing="8">
                            <TextBlock Text="{Binding ArtistName}" FontSize="18" FontWeight="Light" Foreground="#AAA" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding TrackTitle}" FontSize="24" FontWeight="Bold" Foreground="White" TextWrapping="Wrap"/>
                            
                            <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,8,0,0">
                                <Border Background="#12FFFFFF" CornerRadius="4" Padding="6,2">
                                     <TextBlock Text="{Binding FileFormat}" FontSize="10" FontWeight="Bold" Foreground="#4EC9B0"/>
                                </Border>
                                <TextBlock Text="{Binding BitrateDisplay}" FontSize="12" Foreground="#888" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                    
                    <Separator Background="#252526" Height="1"/>
                    
                    <!-- Metadata Stats -->
                    <StackPanel Spacing="12">
                         <TextBlock Text="TECHNICAL METADATA" FontSize="10" FontWeight="Black" Foreground="#444"/>
                         <Grid ColumnDefinitions="*, *, *" RowDefinitions="Auto, Auto">
                             <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4">
                                 <TextBlock Text="SAMPLE RATE" FontSize="9" Foreground="#555"/>
                                 <TextBlock Text="{Binding SpectralSampleRateDisplay}" FontSize="13" Foreground="#CCC"/>
                             </StackPanel>
                             <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                                 <TextBlock Text="DURATION" FontSize="9" Foreground="#555"/>
                                 <TextBlock Text="{Binding DurationDisplay}" FontSize="13" Foreground="#CCC"/>
                             </StackPanel>
                             <StackPanel Grid.Row="0" Grid.Column="2" Spacing="4">
                                 <TextBlock Text="FILE SIZE" FontSize="9" Foreground="#555"/>
                                 <TextBlock Text="{Binding FileSizeDisplay}" FontSize="13" Foreground="#CCC"/>
                             </StackPanel>
                             <StackPanel Grid.Row="1" Grid.Column="0" Spacing="4" Margin="0,12,0,0">
                                 <TextBlock Text="BIT DEPTH" FontSize="9" Foreground="#555"/>
                                 <TextBlock Text="{Binding SpectralBitDepthDisplay}" FontSize="13" Foreground="#CCC"/>
                             </StackPanel>
                             <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4" Margin="0,12,0,0">
                                 <TextBlock Text="BITRATE" FontSize="9" Foreground="#555"/>
                                 <TextBlock Text="{Binding BitrateDisplay}" FontSize="13" Foreground="#CCC"/>
                             </StackPanel>
                             <StackPanel Grid.Row="1" Grid.Column="2" Spacing="4" Margin="0,12,0,0">
                                 <TextBlock Text="FORMAT" FontSize="9" Foreground="#555"/>
                                 <TextBlock Text="{Binding FileFormat}" FontSize="13" Foreground="#4EC9B0" FontWeight="Bold"/>
                             </StackPanel>
                         </Grid>
                    </StackPanel>

                    <Separator Background="#252526" Height="1"/>

                    <!-- Spectral Forensics (only shown after post-download analysis completes) -->
                    <StackPanel Spacing="12" IsVisible="{Binding HasSpectralDetails}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="SPECTRAL FORENSICS" FontSize="10" FontWeight="Black" Foreground="#444"/>
                            <Border Background="#15FFFFFF" CornerRadius="4" Padding="6,1">
                                <TextBlock Text="{Binding SpectralVerdictBadgeText}" FontSize="9" FontWeight="Bold"
                                           Foreground="{Binding SpectralVerdictColor}"/>
                            </Border>
                        </StackPanel>

                        <!-- Authenticity verdict card -->
                        <Border Background="#12FFFFFF" CornerRadius="8" Padding="14,10">
                            <StackPanel Spacing="6">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="VERDICT" FontSize="9" Foreground="#555" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding SpectralVerdictText}" FontSize="12" FontWeight="Bold"
                                               Foreground="{Binding SpectralVerdictColor}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="{Binding SpectralVerdictTooltip}" FontSize="10" Foreground="#666"
                                           TextWrapping="Wrap" Opacity="0.85"/>
                            </StackPanel>
                        </Border>

                        <!-- Spectral measurements grid -->
                        <Grid ColumnDefinitions="*, *" RowDefinitions="Auto, Auto, Auto, Auto">
                            <!-- Row 0: Cutoff / Rolloff -->
                            <StackPanel Grid.Row="0" Grid.Column="0" Spacing="3" Margin="0,0,6,10">
                                <TextBlock Text="SAMPLE RATE" FontSize="9" Foreground="#555"/>
                                <TextBlock Text="{Binding SpectralSampleRateDisplay}" FontSize="12" FontWeight="SemiBold" Foreground="#CCC"/>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="1" Spacing="3" Margin="6,0,0,10">
                                <TextBlock Text="ROLLOFF SLOPE" FontSize="9" Foreground="#555"/>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="{Binding SpectralRolloffDisplay}" FontSize="12" FontWeight="SemiBold" Foreground="#CCC"/>
                                    <TextBlock Text="{Binding SpectralRolloffLabel}" FontSize="9" Foreground="#666" VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Row 1: Band energies -->
                            <StackPanel Grid.Row="1" Grid.Column="0" Spacing="3" Margin="0,0,6,10">
                                <TextBlock Text="MID BAND (1–15 kHz)" FontSize="9" Foreground="#555"/>
                                <TextBlock Text="{Binding SpectralMidBandDisplay}" FontSize="12" FontWeight="SemiBold" Foreground="#CCC"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="1" Spacing="3" Margin="6,0,0,10">
                                <TextBlock Text="HIGH BAND (15–20 kHz)" FontSize="9" Foreground="#555"/>
                                <TextBlock Text="{Binding SpectralHighBandDisplay}" FontSize="12" FontWeight="SemiBold" Foreground="#CCC"/>
                            </StackPanel>

                            <!-- Row 2: RMS / Crest -->
                            <StackPanel Grid.Row="2" Grid.Column="0" Spacing="3" Margin="0,0,6,10">
                                <TextBlock Text="RMS LEVEL" FontSize="9" Foreground="#555"/>
                                <TextBlock Text="{Binding SpectralRmsDisplay}" FontSize="12" FontWeight="SemiBold" Foreground="#CCC"/>
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="1" Spacing="3" Margin="6,0,0,10">
                                <TextBlock Text="CREST FACTOR" FontSize="9" Foreground="#555"/>
                                <TextBlock Text="{Binding SpectralCrestFactorDisplay}" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{Binding SpectralCrestFactorColor}"/>
                            </StackPanel>

                            <!-- Row 3: Noise floor / Confidence -->
                            <StackPanel Grid.Row="3" Grid.Column="0" Spacing="3">
                                <TextBlock Text="NOISE FLOOR" FontSize="9" Foreground="#555"/>
                                <TextBlock Text="{Binding SpectralNoiseFloorDisplay}" FontSize="12" FontWeight="SemiBold" Foreground="#CCC"/>
                            </StackPanel>
                            <StackPanel Grid.Row="3" Grid.Column="1" Spacing="3" Margin="6,0,0,0">
                                <TextBlock Text="CONFIDENCE" FontSize="9" Foreground="#555"/>
                                <TextBlock Text="{Binding SpectralConfidenceDisplay}" FontSize="12" FontWeight="SemiBold"
                                           Foreground="#888"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                    
                    <!-- Provenance / Source -->
                    <Border Background="#12FFFFFF" CornerRadius="8" Padding="16">
                        <StackPanel Spacing="10">
                            <TextBlock Text="SOURCE PROVENANCE" FontSize="10" FontWeight="Black" Foreground="#666"/>
                            <Grid ColumnDefinitions="Auto, *">
                                <PathIcon Grid.Column="0" Data="{StaticResource person_regular}" Width="14" Height="14" Foreground="#00BFFF" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding PeerName}" Margin="10,0,0,0" FontSize="14" FontWeight="SemiBold" Foreground="#00BFFF"/>
                            </Grid>
                            <TextBlock Text="{Binding PeerCountry}" FontSize="11" Foreground="#666" Margin="24,0,0,0"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Search History / Logs (Expanded) -->
                    <StackPanel Spacing="12">
                        <TextBlock Text="DECISION FORENSICS &amp; HISTORY" FontSize="10" FontWeight="Black" Foreground="#444"/>
                        <ItemsControl ItemsSource="{Binding SearchLogs}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#12FFFFFF" Margin="0,0,0,4" Padding="10,8" CornerRadius="4">
                                        <Grid ColumnDefinitions="50, *">
                                            <TextBlock Grid.Column="0" Text="{Binding Timestamp, StringFormat='{}{0:mm:ss}'}" FontSize="10" Foreground="#444" FontFamily="Consolas"/>
                                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                                <TextBlock Text="{Binding Message}" FontSize="11" Foreground="#BBB" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding State}" FontSize="9" Foreground="{Binding StateColor}" FontWeight="Bold" Opacity="0.7"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- ── Energy Curve (read-only, download tracks) ─── -->
                    <StackPanel Spacing="6">
                        <Separator Background="#252526" Height="1"/>
                        <TextBlock Text="ENERGY CURVE" FontSize="10" FontWeight="Black" Foreground="#444"/>
                        <Border Background="#0D0D0D" CornerRadius="4" Height="32">
                            <controls:SparklineControl Values="{Binding SpeedHistory}" Height="32"/>
                        </Border>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
            
            <!-- Bottom Actions -->
            <Border Grid.Row="2" Background="#1E1E1F" Padding="20" BorderBrush="#2D2D2D" BorderThickness="0,1,0,0">
                 <Grid ColumnDefinitions="*, Auto">
                      <Button Grid.Column="1" Command="{Binding RevealFileCommand}" IsVisible="{Binding IsCompleted}" 
                              Background="#00BFFF" Foreground="White" Padding="16,8" CornerRadius="6">
                          <StackPanel Orientation="Horizontal" Spacing="8">
                              <PathIcon Data="{StaticResource folder_open_regular}" Width="16" Height="16"/>
                              <TextBlock Text="REVEAL IN EXPLORER" FontWeight="Bold" FontSize="11"/>
                          </StackPanel>
                      </Button>
                      
                      <Button Grid.Column="1" Command="{Binding RetryCommand}" IsVisible="{Binding CanRetry}" 
                              Background="#4CAF50" Foreground="White" Padding="16,8" CornerRadius="6">
                          <StackPanel Orientation="Horizontal" Spacing="8">
                              <PathIcon Data="{StaticResource arrow_counterclockwise_regular}" Width="16" Height="16"/>
                              <TextBlock Text="RETRY SEARCH" FontWeight="Bold" FontSize="11"/>
                          </StackPanel>
                      </Button>
                 </Grid>
            </Border>
            
        </Grid>
    </Border>
</UserControl>
