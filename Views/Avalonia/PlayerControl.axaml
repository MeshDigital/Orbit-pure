<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:SLSKDONET.ViewModels"
             xmlns:controls="clr-namespace:SLSKDONET.Views.Avalonia.Controls"

             mc:Ignorable="d" d:DesignWidth="300" d:DesignHeight="800"
             x:Class="SLSKDONET.Views.Avalonia.PlayerControl"
             x:DataType="vm:PlayerViewModel"
             Background="#252526">
    
    <!-- Vertical Player for Right Sidebar -->
    <Grid ColumnDefinitions="2*,*" RowDefinitions="Auto,Auto,*,Auto">
        
        <!-- Header -->
        <Border Grid.Row="0" 
                Background="#2D2D2D" 
                Padding="16,12"
                BorderBrush="#3E3E3E"
                BorderThickness="0,0,0,1">
            <TextBlock Text="Now Playing" 
                       FontSize="14" 
                       FontWeight="SemiBold"
                       Foreground="White"/>
        </Border>
        
        <!-- Album Art & Track Info -->
        <StackPanel Grid.Row="1" Margin="16,20,16,16" Spacing="16">
            <!-- Album Art -->
            <Border x:Name="PlayNowZone" 
                    Width="260" Height="260" 
                    Background="#1E1E1E" 
                    CornerRadius="8"
                    HorizontalAlignment="Center"
                    DragDrop.AllowDrop="True">
                <Panel>
                    
                    <Grid ColumnDefinitions="4,*,4" Margin="4">
                        <!-- VU Meter Left -->
                        <Border Grid.Column="0" VerticalAlignment="Bottom" 
                                Background="#1DB954" Width="4"
                                Height="{Binding VuLeft, Converter={StaticResource VuHeightConverter}, ConverterParameter=250}"/>
                                
                        <!-- Dynamic Album Artwork -->
                        <Image Grid.Column="1" Source="{Binding CurrentTrack.ArtworkBitmap}" 
                               Stretch="UniformToFill"
                               IsVisible="{Binding CurrentTrack.ArtworkBitmap, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                               
                        <!-- VU Meter Right -->
                        <Border Grid.Column="2" VerticalAlignment="Bottom" 
                                Background="#1DB954" Width="4"
                                Height="{Binding VuRight, Converter={StaticResource VuHeightConverter}, ConverterParameter=250}"/>
                    </Grid>
                    
                    <!-- Professional fallback with Path geometry instead of emoji -->
                    <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 14.5v-9l6 4.5-6 4.5z" 
                          Fill="#404040" 
                          Stretch="Uniform"
                          Width="80" Height="80"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          IsVisible="{Binding CurrentTrack.ArtworkBitmap, Converter={x:Static ObjectConverters.IsNull}}"/>
                </Panel>
            </Border>

            
            <!-- Phase 9.2: Loading State -->
            <Border IsVisible="{Binding IsLoading}" 
                    Background="#1E1E1E" 
                    CornerRadius="8"
                    Padding="16"
                    Margin="0,8,0,0">
                <StackPanel Spacing="8" HorizontalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" 
                                  Width="100" Height="4" 
                                  Foreground="#1DB954"
                                  IsVisible="{Binding IsLoading}"/>
                    <TextBlock Text="Loading track..." 
                               FontSize="12" 
                               Foreground="#B3B3B3"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Phase 9.2: Error Banner with Auto-Dismiss -->
            <Border IsVisible="{Binding HasPlaybackError}" 
                    Background="#4D0000" 
                    BorderBrush="#FF0000" 
                    BorderThickness="1" 
                    CornerRadius="4"
                    Padding="12"
                    Margin="0,8,0,0">
                <StackPanel Spacing="4">
                    <TextBlock Text="⚠️ Playback Error" 
                               FontSize="12" 
                               FontWeight="SemiBold" 
                               Foreground="#FF6B6B"/>
                    <TextBlock Text="{Binding PlaybackError}" 
                               FontSize="11" 
                               Foreground="#DDD" 
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Track Info -->
            <StackPanel Spacing="8">
                <Border Classes.skeleton="{Binding IsLoading}"
                        CornerRadius="4"
                        Height="20"
                        IsVisible="{Binding IsLoading}"/>
                <TextBlock Text="{Binding TrackTitle}" 
                           FontSize="16" 
                           FontWeight="SemiBold"
                           Foreground="White"
                           TextTrimming="CharacterEllipsis"
                           TextWrapping="Wrap"
                           MaxLines="2"
                           TextAlignment="Center"
                           IsVisible="{Binding IsLoading, Converter={StaticResource BoolInverseConverter}}"/>
                <Border Classes.skeleton="{Binding IsLoading}"
                        CornerRadius="4"
                        Height="16"
                        IsVisible="{Binding IsLoading}"/>
                <TextBlock Text="{Binding TrackArtist}" 
                           FontSize="13" 
                           Foreground="#B3B3B3"
                           TextTrimming="CharacterEllipsis"
                           TextAlignment="Center"
                           IsVisible="{Binding IsLoading, Converter={StaticResource BoolInverseConverter}}"/>
                <Border Background="#181A1F"
                        BorderBrush="#2B3240"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="10,6"
                        IsVisible="{Binding IsLoading, Converter={StaticResource BoolInverseConverter}}">
                    <StackPanel Spacing="6">
                        <TextBlock Text="{Binding CurrentTrackContextSummary}"
                                   FontSize="11"
                                   Foreground="#AFC6DD"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"/>
                        <TextBlock Text="{Binding CurrentTrackWorkflowHint}"
                                   FontSize="10"
                                   Foreground="#8FD6A8"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"/>
                        <TextBlock Text="{Binding CurrentTrackWorkstationPrepSummary}"
                                   FontSize="10"
                                   Foreground="#D9C7FF"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"/>
                        <TextBlock Text="{Binding CurrentTrackRoutingSummary}"
                                   FontSize="10"
                                   Foreground="#8FD6A8"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"/>
                        <TextBlock Text="{Binding CurrentTrackTransitionPlanSummary}"
                                   FontSize="10"
                                   Foreground="#FFD58A"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"/>
                        <TextBlock Text="{Binding AnalysisLaneSummary}"
                                   FontSize="10"
                                   Foreground="#9EEFFF"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"/>
                    </StackPanel>
                </Border>
                <WrapPanel HorizontalAlignment="Center" ItemHeight="24" Margin="0,0,0,2">
                    <Border Background="#1F2933" BorderBrush="#324556" BorderThickness="1" CornerRadius="999" Padding="8,3">
                        <TextBlock Text="{Binding CurrentTrackStatusBadge}" FontSize="9" FontWeight="SemiBold" Foreground="#D9EEFF"/>
                    </Border>
                    <Border Background="#1E3224" BorderBrush="#2E6B4D" BorderThickness="1" CornerRadius="999" Padding="8,3" Margin="6,0,0,0">
                        <TextBlock Text="{Binding CurrentTrackTempoBadge}" FontSize="9" FontWeight="SemiBold" Foreground="#DFFFE8"/>
                    </Border>
                    <Border Background="#2A2035" BorderBrush="#6E4A88" BorderThickness="1" CornerRadius="999" Padding="8,3" Margin="6,0,0,0">
                        <TextBlock Text="{Binding CurrentTrackKeyBadge}" FontSize="9" FontWeight="SemiBold" Foreground="#F2DEFF"/>
                    </Border>
                    <Border Background="#332B18" BorderBrush="#8E7340" BorderThickness="1" CornerRadius="999" Padding="8,3" Margin="6,0,0,0">
                        <TextBlock Text="{Binding CurrentTrackEnergyBadge}" FontSize="9" FontWeight="SemiBold" Foreground="#FFF3D8"/>
                    </Border>
                    <Border Background="#2D2D2D" BorderBrush="#4C4C4C" BorderThickness="1" CornerRadius="999" Padding="8,3" Margin="6,0,0,0">
                        <TextBlock Text="{Binding CurrentTrackCueBadge}" FontSize="9" FontWeight="SemiBold" Foreground="#E3E3E3"/>
                    </Border>
                </WrapPanel>
                <WrapPanel HorizontalAlignment="Center" ItemHeight="30" Margin="0,2,0,0">
                    <Button Command="{Binding ToggleExpandedPlayerCommand}"
                            Padding="10,4"
                            Background="#2D2D2D"
                            BorderBrush="#3E3E3E"
                            BorderThickness="1"
                            ToolTip.Tip="Open Expanded Player">
                        <TextBlock Text="EXPAND" FontSize="10" FontWeight="Bold" Foreground="#DDEEE3"/>
                    </Button>
                    <Button Command="{Binding OpenPlayerViewCommand}"
                            Padding="10,4"
                            Margin="6,0,0,0"
                            Background="#221DB954"
                            BorderBrush="#1DB954"
                            BorderThickness="1"
                            ToolTip.Tip="Open Full Player View">
                        <TextBlock Text="FULL VIEW" FontSize="10" FontWeight="Bold" Foreground="#DFFFE8"/>
                    </Button>
                    <Button Command="{Binding $parent[Window].DataContext.TogglePlayerLocationCommand}"
                            Padding="10,4"
                            Margin="6,0,0,0"
                            Background="#2D2D2D"
                            BorderBrush="#3E3E3E"
                            BorderThickness="1"
                            ToolTip.Tip="Move player between the sidebar and bottom dock">
                        <TextBlock Text="{Binding $parent[Window].DataContext.IsPlayerAtBottom, Converter={StaticResource BoolToTextConverter}, ConverterParameter='DOCK: BOTTOM,DOCK: RIGHT'}"
                                   FontSize="10" FontWeight="Bold" Foreground="#CCCCCC"/>
                    </Button>
                </WrapPanel>
                <WrapPanel HorizontalAlignment="Center" ItemHeight="30">
                    <Button Command="{Binding AnalyzeCurrentTrackCommand}"
                            IsEnabled="{Binding HasCurrentTrack}"
                            Padding="10,4"
                            Background="#332B18"
                            BorderBrush="#8E7340"
                            BorderThickness="1"
                            ToolTip.Tip="Analyze the current track for cue prep and timing data">
                        <TextBlock Text="ANALYZE" FontSize="10" FontWeight="Bold" Foreground="#FFF3D8"/>
                    </Button>
                    <Button Command="{Binding SeparateCurrentTrackStemsCommand}"
                            IsEnabled="{Binding HasCurrentTrack}"
                            Padding="10,4"
                            Margin="6,0,0,0"
                            Background="#1E3224"
                            BorderBrush="#4EC9B0"
                            BorderThickness="1"
                            ToolTip.Tip="Open or prepare stems for the current track in the workstation">
                        <TextBlock Text="STEMS" FontSize="10" FontWeight="Bold" Foreground="#DFFFE8"/>
                    </Button>
                    <Button Command="{Binding OpenCurrentTrackInspectorCommand}"
                            IsEnabled="{Binding HasCurrentTrack}"
                            Padding="10,4"
                            Margin="6,0,0,0"
                            Background="#1D2A3A"
                            BorderBrush="#5DADE2"
                            BorderThickness="1"
                            ToolTip.Tip="Open the current track in the Inspector">
                        <TextBlock Text="INSPECT" FontSize="10" FontWeight="Bold" Foreground="#D9EEFF"/>
                    </Button>
                    <Button Command="{Binding OpenCurrentTrackWorkstationCommand}"
                            IsEnabled="{Binding HasCurrentTrack}"
                            Padding="10,4"
                            Margin="6,0,0,0"
                            Background="#2A2035"
                            BorderBrush="#C586C0"
                            BorderThickness="1"
                            ToolTip.Tip="Send the current track to the focused workstation deck">
                        <TextBlock Text="WORKSTATION" FontSize="10" FontWeight="Bold" Foreground="#F2DEFF"/>
                    </Button>
                    <Button Command="{Binding OpenCurrentTrackFlowCommand}"
                            IsEnabled="{Binding HasCurrentTrack}"
                            Padding="10,4"
                            Margin="6,0,0,0"
                            Background="#183020"
                            BorderBrush="#5BCB8A"
                            BorderThickness="1"
                            ToolTip.Tip="Open the current track in the flow workspace">
                        <TextBlock Text="FLOW" FontSize="10" FontWeight="Bold" Foreground="#DFFFE8"/>
                    </Button>
                    <Button Command="{Binding LoadCurrentTrackToDeckACommand}"
                            IsEnabled="{Binding HasCurrentTrack}"
                            Padding="10,4"
                            Margin="6,0,0,0"
                            Background="#1B2230"
                            BorderBrush="#7DA2F7"
                            BorderThickness="1"
                            ToolTip.Tip="Send the current track straight to Deck A">
                        <TextBlock Text="DECK A" FontSize="10" FontWeight="Bold" Foreground="#DDE7FF"/>
                    </Button>
                    <Button Command="{Binding LoadCurrentTrackToDeckBCommand}"
                            IsEnabled="{Binding HasCurrentTrack}"
                            Padding="10,4"
                            Margin="6,0,0,0"
                            Background="#1B2230"
                            BorderBrush="#7DA2F7"
                            BorderThickness="1"
                            ToolTip.Tip="Send the current track straight to Deck B">
                        <TextBlock Text="DECK B" FontSize="10" FontWeight="Bold" Foreground="#DDE7FF"/>
                    </Button>
                    <Button Command="{Binding AddCurrentTrackToProjectCommand}"
                            IsEnabled="{Binding HasCurrentTrack}"
                            Padding="10,4"
                            Margin="6,0,0,0"
                            Background="#1E3224"
                            BorderBrush="#4EC9B0"
                            BorderThickness="1"
                            ToolTip.Tip="Add the current track to the mix project">
                        <TextBlock Text="ADD TO MIX" FontSize="10" FontWeight="Bold" Foreground="#DFFFE8"/>
                    </Button>
                    <Button Command="{Binding RevealCurrentTrackCommand}"
                            IsEnabled="{Binding HasCurrentTrack}"
                            Padding="10,4"
                            Margin="6,0,0,0"
                            Background="#2D2D2D"
                            BorderBrush="#3E3E3E"
                            BorderThickness="1"
                            ToolTip.Tip="Reveal the current file in Explorer">
                        <TextBlock Text="REVEAL" FontSize="10" FontWeight="Bold" Foreground="#CCCCCC"/>
                    </Button>
                </WrapPanel>
            </StackPanel>
        </StackPanel>
        
        <!-- Spacer -->
        <Border Grid.Row="2"/>
        
        <!-- Controls Section -->
        <StackPanel x:Name="QueueZone" Grid.Row="3" Grid.Column="0" Spacing="16" Margin="16,0,16,20" DragDrop.AllowDrop="True">
            
            <!-- Waveform Seekbar -->
            <StackPanel Spacing="8">
                <Panel Height="60">
                    <!-- Background Waveform with Centered Playhead -->
                    <controls:WaveformControl WaveformData="{Binding CurrentTrack.WaveformData}" 
                                               LowBand="{Binding CurrentTrack.LowData}"
                                               MidBand="{Binding CurrentTrack.MidData}"
                                               HighBand="{Binding CurrentTrack.HighData}"
                                               PhraseSegments="{Binding CurrentTrack.PhraseSegments}"
                                             Progress="{Binding Position}"
                                             IsRolling="False"
                                             Background="#01000000"
                                             PlayheadBrush="#1DB954"
                                             SeekCommand="{Binding SeekCommand}"
                                             VerticalAlignment="Stretch"
                                             HorizontalAlignment="Stretch"/>
                </Panel>
                
                <!-- Time Labels -->
                <Grid ColumnDefinitions="*,*">
                    <TextBlock Grid.Column="0" 
                               Text="{Binding CurrentTimeStr}" 
                               FontSize="11" 
                               Foreground="#B3B3B3"/>
                    <TextBlock Grid.Column="1" 
                               Text="{Binding TotalTimeStr}" 
                               FontSize="11" 
                               Foreground="#B3B3B3"
                               HorizontalAlignment="Right"/>
                </Grid>

                <Border Background="#181A1F"
                        BorderBrush="#2B3240"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="8,6">
                    <StackPanel Spacing="6">
                        <TextBlock Text="{Binding CurrentTrackPhraseJumpSummary}"
                                   FontSize="10"
                                   Foreground="#B7CCE0"
                                   TextWrapping="Wrap"/>
                        <WrapPanel HorizontalAlignment="Center" ItemHeight="26">
                            <Button Command="{Binding JumpToIntroCommand}" IsEnabled="{Binding HasCurrentTrack}" Padding="8,3" Background="#1D2A3A" BorderBrush="#3E566E" BorderThickness="1" ToolTip.Tip="Jump to the prepared intro cue or guided intro position">
                                <TextBlock Text="INTRO" FontSize="9" FontWeight="Bold" Foreground="#D9EEFF"/>
                            </Button>
                            <Button Command="{Binding JumpToBuildCommand}" IsEnabled="{Binding HasCurrentTrack}" Padding="8,3" Margin="6,0,0,0" Background="#2A2035" BorderBrush="#6E4A88" BorderThickness="1" ToolTip.Tip="Jump to the build-up marker">
                                <TextBlock Text="BUILD" FontSize="9" FontWeight="Bold" Foreground="#F2DEFF"/>
                            </Button>
                            <Button Command="{Binding JumpToDropCommand}" IsEnabled="{Binding HasCurrentTrack}" Padding="8,3" Margin="6,0,0,0" Background="#332B18" BorderBrush="#8E7340" BorderThickness="1" ToolTip.Tip="Jump to the drop / impact section">
                                <TextBlock Text="DROP" FontSize="9" FontWeight="Bold" Foreground="#FFF3D8"/>
                            </Button>
                            <Button Command="{Binding JumpToOutroCommand}" IsEnabled="{Binding HasCurrentTrack}" Padding="8,3" Margin="6,0,0,0" Background="#1E3224" BorderBrush="#2E6B4D" BorderThickness="1" ToolTip.Tip="Jump to the outro / mix-out zone">
                                <TextBlock Text="OUTRO" FontSize="9" FontWeight="Bold" Foreground="#DFFFE8"/>
                            </Button>
                        </WrapPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
            
            <!-- Playback Controls -->
            <StackPanel Orientation="Horizontal" 
                        HorizontalAlignment="Center" 
                        Spacing="16">
                <!-- Previous -->
                <Button Command="{Binding PreviousTrackCommand}"
                        Background="Transparent"
                        BorderThickness="0"
                        Width="40" Height="40"
                        KeyboardNavigation.IsTabStop="True"
                        ToolTip.Tip="Previous">
                    <Button.Styles>
                        <Style Selector="Button:pointerover">
                            <Setter Property="Background" Value="#2D2D2D"/>
                        </Style>
                    </Button.Styles>
                    <TextBlock Text="⏮️" FontSize="20"/>
                </Button>
                
                <!-- Play/Pause -->
                <Button Command="{Binding TogglePlayPauseCommand}"
                        Background="#1DB954"
                        Foreground="Black"
                        Width="48" Height="48"
                        CornerRadius="24"
                        BorderThickness="0"
                        KeyboardNavigation.IsTabStop="True"
                        Cursor="Hand">
                    <Button.Styles>
                        <Style Selector="Button:pointerover">
                            <Setter Property="Background" Value="#1ED760"/>
                        </Style>
                    </Button.Styles>
                    <TextBlock Text="{Binding IsPlaying, Converter={StaticResource BoolToPlayPauseIconConverter}}" 
                               FontSize="22"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Button>
                
                <!-- Next -->
                <Button Command="{Binding NextTrackCommand}"
                        Background="Transparent"
                        BorderThickness="0"
                        Width="40" Height="40"
                        KeyboardNavigation.IsTabStop="True"
                        ToolTip.Tip="Next">
                    <Button.Styles>
                        <Style Selector="Button:pointerover">
                            <Setter Property="Background" Value="#2D2D2D"/>
                        </Style>
                    </Button.Styles>
                    <TextBlock Text="⏭️" FontSize="20"/>
                </Button>
            </StackPanel>
            
            <!-- Shuffle & Repeat Controls -->
            <StackPanel Orientation="Horizontal" 
                        HorizontalAlignment="Center" 
                        Spacing="16"
                        Margin="0,12,0,0">
                <!-- Shuffle -->
                <Button Command="{Binding ToggleShuffleCommand}"
                        Background="Transparent"
                        BorderThickness="0"
                        Width="36" Height="36"
                        ToolTip.Tip="Shuffle">
                    <Button.Styles>
                        <Style Selector="Button:pointerover">
                            <Setter Property="Background" Value="#2D2D2D"/>
                        </Style>
                    </Button.Styles>
                    <TextBlock Text="🔀" 
                               FontSize="16" 
                               Foreground="{Binding IsShuffling, Converter={StaticResource BoolToColorConverter}}"/>
                </Button>
                
                <!-- Repeat -->
                <Button Command="{Binding ToggleRepeatCommand}"
                        Background="Transparent"
                        BorderThickness="0"
                        Width="36" Height="36"
                        ToolTip.Tip="{Binding RepeatMode}">
                    <Button.Styles>
                        <Style Selector="Button:pointerover">
                            <Setter Property="Background" Value="#2D2D2D"/>
                        </Style>
                    </Button.Styles>
                    <TextBlock Text="{Binding RepeatMode, Converter={StaticResource RepeatModeIconConverter}}" 
                               FontSize="16" 
                               Foreground="{Binding RepeatMode, Converter={StaticResource RepeatModeColorConverter}}"/>
                </Button>
            </StackPanel>
            
            <!-- Pitch & Volume Controls -->
            <StackPanel Spacing="12">
                <!-- Pitch Slider -->
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <TextBlock Grid.Column="0" Text="-" FontSize="12" Foreground="#B3B3B3" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <Slider x:Name="PitchSlider"
                            Grid.Column="1" 
                            Minimum="0.9" Maximum="1.1" 
                            Value="{Binding Pitch, Mode=TwoWay}"
                            Height="20"
                            KeyboardNavigation.IsTabStop="True"
                            ToolTip.Tip="Pitch / Tempo (double-click to reset)"/>
                    <TextBlock Grid.Column="2" Text="+" FontSize="12" Foreground="#B3B3B3" VerticalAlignment="Center" Margin="8,0,0,0"/>
                </Grid>

                <Grid ColumnDefinitions="Auto,*">
                    <Button Grid.Column="0"
                            Command="{Binding ToggleMuteCommand}"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="0"
                            Width="24" Height="24"
                            VerticalAlignment="Center"
                            Margin="0,0,8,0"
                            ToolTip.Tip="Toggle mute">
                        <TextBlock Text="{Binding VolumeIcon}" 
                                   FontSize="14" 
                                   Foreground="#B3B3B3"/>
                    </Button>
                    
                    <Slider Grid.Column="1"
                            Minimum="0"
                            Maximum="100"
                            Value="{Binding Volume, Mode=TwoWay}"
                            Height="20"
                            KeyboardNavigation.IsTabStop="True">
                        <Slider.Styles>
                            <Style Selector="Slider /template/ Thumb">
                                <Setter Property="Background" Value="White"/>
                                <Setter Property="Width" Value="12"/>
                                <Setter Property="Height" Value="12"/>
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Slider.Styles>
                    </Slider>
                </Grid>
            </StackPanel>
            
            <!-- Like & Queue Buttons -->
            <StackPanel Orientation="Horizontal" 
                        HorizontalAlignment="Center" 
                        Spacing="12">
                <!-- Phase 9.3: Like Button -->
                <Button Command="{Binding ToggleLikeCommand}"
                        Background="Transparent"
                        BorderThickness="0"
                        Width="36" Height="36"
                        ToolTip.Tip="Like"
                        Classes.liked="{Binding IsCurrentTrackLiked}">
                    <Button.Styles>
                        <Style Selector="Button:pointerover">
                            <Setter Property="Background" Value="#2D2D2D"/>
                        </Style>
                        <!-- Pulsing Heart Animation -->
                        <Style Selector="Button.liked TextBlock">
                            <Style.Animations>
                                <Animation Duration="0:0:0.5" Easing="BackEaseOut" IterationCount="1">
                                    <KeyFrame KeyTime="0:0:0.0">
                                        <Setter Property="ScaleTransform.ScaleX" Value="1.0"/>
                                        <Setter Property="ScaleTransform.ScaleY" Value="1.0"/>
                                    </KeyFrame>
                                    <KeyFrame KeyTime="0:0:0.25">
                                        <Setter Property="ScaleTransform.ScaleX" Value="1.4"/>
                                        <Setter Property="ScaleTransform.ScaleY" Value="1.4"/>
                                    </KeyFrame>
                                    <KeyFrame KeyTime="0:0:0.5">
                                        <Setter Property="ScaleTransform.ScaleX" Value="1.0"/>
                                        <Setter Property="ScaleTransform.ScaleY" Value="1.0"/>
                                    </KeyFrame>
                                </Animation>
                            </Style.Animations>
                        </Style>
                    </Button.Styles>
                    <TextBlock Text="{Binding IsCurrentTrackLiked, Converter={StaticResource BoolToHeartConverter}}" 
                               FontSize="18" 
                               Foreground="{Binding IsCurrentTrackLiked, Converter={StaticResource BoolToHeartColorConverter}}"
                               RenderTransformOrigin="50%,50%">
                        <TextBlock.RenderTransform>
                            <ScaleTransform ScaleX="1.0" ScaleY="1.0"/>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                </Button>
                
                <Button Command="{Binding ToggleQueueCommand}"
                        Background="Transparent"
                        BorderThickness="0"
                        Width="36" Height="36"
                        ToolTip.Tip="Queue">
                    <Button.Styles>
                        <Style Selector="Button:pointerover">
                            <Setter Property="Background" Value="#2D2D2D"/>
                        </Style>
                    </Button.Styles>
                    <TextBlock Text="📋" FontSize="16" Foreground="{Binding IsQueueOpen, Converter={StaticResource BoolToColorConverter}}"/>
                </Button>
            </StackPanel>
        </StackPanel>

        <Border Grid.Column="1"
                Grid.RowSpan="4"
                Margin="0,0,8,8"
                Padding="10,10,10,12"
            MinWidth="140"
            MaxWidth="220"
                CornerRadius="8"
                Background="#1E1E1E"
                BorderBrush="#3E3E3E"
                BorderThickness="1"
                IsVisible="{Binding IsQueueOpen}">
            <Grid RowDefinitions="Auto,Auto,*">
                <TextBlock Grid.Row="0"
                           Text="UP NEXT"
                           FontSize="10"
                           LetterSpacing="1.4"
                           FontWeight="SemiBold"
                           Foreground="#88FFFFFF"/>

                <Button Grid.Row="1"
                        Command="{Binding ClearQueueCommand}"
                        HorizontalAlignment="Right"
                        Margin="0,6,0,8"
                        Padding="8,2"
                        FontSize="10"
                        Background="#2D2D2D"
                        BorderBrush="#3E3E3E"
                        BorderThickness="1"
                        IsVisible="{Binding IsQueueEmpty, Converter={StaticResource BoolInverseConverter}}"
                        ToolTip.Tip="Clear queue">
                    <TextBlock Text="CLEAR" Foreground="#CCCCCC"/>
                </Button>

                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Spacing="6">
                        <Border IsVisible="{Binding IsQueueEmpty}" Padding="8" CornerRadius="6" Background="#182028">
                            <TextBlock Text="Queue is empty"
                                       FontSize="11"
                                       Foreground="#8FA5B8"
                                       TextAlignment="Center"/>
                        </Border>

                        <ItemsControl ItemsSource="{Binding Queue}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VirtualizingStackPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:PlaylistTrackViewModel">
                                    <Border Padding="6" CornerRadius="6" Background="#262626">
                                        <Grid ColumnDefinitions="*,Auto,Auto">
                                            <Button Grid.Column="0"
                                                    Command="{Binding $parent[UserControl].DataContext.PlayQueueItemCommand}"
                                                    CommandParameter="{Binding}"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    HorizontalContentAlignment="Stretch"
                                                    ToolTip.Tip="Play this queued track now">
                                                <StackPanel Spacing="2">
                                                    <TextBlock Text="{Binding TrackTitle}"
                                                               FontSize="11"
                                                               Foreground="White"
                                                               TextTrimming="CharacterEllipsis"
                                                               MaxWidth="140"/>
                                                    <TextBlock Text="{Binding ArtistName}"
                                                               FontSize="10"
                                                               Foreground="#AFAFAF"
                                                               TextTrimming="CharacterEllipsis"
                                                               MaxWidth="140"/>
                                                </StackPanel>
                                            </Button>
                                            <Button Grid.Column="1"
                                                    Command="{Binding $parent[UserControl].DataContext.PlayQueueItemCommand}"
                                                    CommandParameter="{Binding}"
                                                    Width="26" Height="26"
                                                    Padding="0"
                                                    Background="#1E3A2B"
                                                    BorderBrush="#1DB954"
                                                    BorderThickness="1"
                                                    ToolTip.Tip="Play queued track">
                                                <TextBlock Text="▶" Foreground="#DFFFE8" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Button>
                                            <Button Grid.Column="2"
                                                    Command="{Binding $parent[UserControl].DataContext.RemoveFromQueueCommand}"
                                                    CommandParameter="{Binding}"
                                                    Width="26" Height="26"
                                                    Padding="0"
                                                    Background="#3A1E1E"
                                                    BorderBrush="#8B3A3A"
                                                    BorderThickness="1"
                                                    ToolTip.Tip="Remove from queue">
                                                <TextBlock Text="✕" Foreground="#FFD6D6" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
