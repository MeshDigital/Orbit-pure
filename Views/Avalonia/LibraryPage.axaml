<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ds="clr-namespace:DraggingService;assembly=Simple-Avalonia-DragnDrop-Service"
             xmlns:vm="clr-namespace:SLSKDONET.ViewModels"
             xmlns:controls="clr-namespace:SLSKDONET.Views.Avalonia.Controls"
             xmlns:views="clr-namespace:SLSKDONET.Views.Avalonia"
             xmlns:conv="clr-namespace:SLSKDONET.Views.Avalonia.Converters"
             xmlns:dg="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls.DataGrid"
             xmlns:rootConv="clr-namespace:SLSKDONET.Converters"
             xmlns:models="clr-namespace:SLSKDONET.Models"
             xmlns:helpers="clr-namespace:SLSKDONET.Helpers"
             xmlns:interactivity="clr-namespace:Avalonia.Xaml.Interactivity;assembly=Avalonia.Xaml.Interactivity"
             xmlns:ia="clr-namespace:Avalonia.Xaml.Interactions.Core;assembly=Avalonia.Xaml.Interactions"
             x:Class="SLSKDONET.Views.Avalonia.LibraryPage"
             x:DataType="vm:LibraryViewModel"
             Background="#1E1E1E" Foreground="White">


    <UserControl.Resources>
        <conv:BitmapValueConverter x:Key="BitmapValueConverter"/>
        <conv:RankColorConverter x:Key="RankColorConverter"/>
        <rootConv:BoolOpacityConverter x:Key="BoolOpacityConverter"/>
        <conv:BoolBlurConverter x:Key="BoolBlurConverter"/>
        <conv:EnumToBooleanConverter x:Key="EnumToBoolConverter"/>
        <rootConv:BoolToWidthConverter x:Key="BoolToWidthConverter"/>
        <rootConv:BoolToTextConverter x:Key="BoolToTextConverter"/>
        <x:Double x:Key="NonDownloadedOpacity">0.3</x:Double>
    </UserControl.Resources>

    <UserControl.KeyBindings>
        <!-- Workspace Switching (Ctrl + 1-5) - These are safe as they use Ctrl -->
        <KeyBinding Gesture="Ctrl+D1" Command="{Binding SwitchWorkspaceCommand}" CommandParameter="{x:Static vm:ActiveWorkspace.Selector}"/>

        <KeyBinding Gesture="Escape" Command="{Binding SmartEscapeCommand}"/>
        
        <!-- Ctrl+Alt+N: Toggle Library Navigation -->
        <KeyBinding Gesture="Ctrl+Alt+N" Command="{Binding ToggleNavigationCommand}"/>
    </UserControl.KeyBindings>

    <Panel>
    <Grid ColumnDefinitions="Auto,*">
        <!-- LEFT PANE: Collapsible Playlist Navigation -->
        <Border Grid.Column="0" 
                Width="{Binding IsNavigationCollapsed, Converter={StaticResource BoolToWidthConverter}, ConverterParameter='60,300'}"
                Background="#1A1A1D" BorderBrush="#2A2A2E" BorderThickness="0,0,1,0">
                <interactivity:Interaction.Behaviors>
                    <ia:EventTriggerBehavior EventName="PointerEntered">
                        <ia:InvokeCommandAction Command="{Binding ExpandNavigationCommand}"/>
                    </ia:EventTriggerBehavior>
                    <ia:EventTriggerBehavior EventName="PointerExited">
                        <ia:InvokeCommandAction Command="{Binding CollapseNavigationCommand}"/>
                    </ia:EventTriggerBehavior>
                </interactivity:Interaction.Behaviors>
                <Grid RowDefinitions="Auto,*,Auto">
                    
                    <!-- Header / Tools -->
                    <Grid Grid.Row="0" Margin="12,16,12,8" ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto">
                        <Button Grid.Column="0" Command="{Binding ToggleNavigationCommand}"
                                Classes="icon-button" ToolTip.Tip="Toggle Library Navigation (Ctrl+Alt+N)" Margin="0,0,8,0">
                            <TextBlock Text="{Binding IsNavigationCollapsed, Converter={StaticResource BoolToTextConverter}, ConverterParameter='▶,◀'}" FontSize="16" Opacity="0.8"/>
                        </Button>
                        <TextBlock Grid.Column="1" Text="LIBRARY" FontSize="12" FontWeight="Bold" Foreground="#888" VerticalAlignment="Center" IsVisible="{Binding !IsNavigationCollapsed}"/>

                        <Button Grid.Column="2" Command="{Binding Projects.AddPlaylistCommand}"
                                Classes="icon-button" ToolTip.Tip="New Playlist" Padding="6,4"
                                IsVisible="{Binding !IsNavigationCollapsed}">
                            <TextBlock Text="➕" FontSize="14"/>
                        </Button>
                        <Button Grid.Column="3" Command="{Binding SyncPhysicalLibraryCommand}"
                                Classes="icon-button" ToolTip.Tip="Sync Physical Library (Ctrl+L)" Padding="6,4"
                                IsVisible="{Binding !IsNavigationCollapsed}">
                            <TextBlock Text="🔗" FontSize="14"/>
                        </Button>
                        <Button Grid.Column="4" Command="{Binding Operations.RetryOfflineTracksCommand}"
                                Classes="icon-button" ToolTip.Tip="Retry Offline Tracks" Padding="6,4"
                                IsVisible="{Binding !IsNavigationCollapsed}">
                            <TextBlock Text="🔄" FontSize="14"/>
                        </Button>
                        <DropDownButton Content="Tools" Classes="tool" CornerRadius="4" Padding="8,4" FontSize="12" Grid.Column="5" IsVisible="{Binding !IsNavigationCollapsed}">
                            <DropDownButton.Flyout>
                                <MenuFlyout>
                                    <MenuItem Header="View Mode" Command="{Binding ToggleViewModeCommand}">
                                        <MenuItem.Icon><TextBlock Text="{Binding UseCardView, Converter={StaticResource BoolToTextConverter}, ConverterParameter='📋,🎴'}"/></MenuItem.Icon>
                                    </MenuItem>
                                    <Separator/>
                                     <MenuItem Header="Import History" Command="{Binding ViewHistoryCommand}" InputGesture="Ctrl+H">
                                         <MenuItem.Icon><TextBlock Text="📜"/></MenuItem.Icon>
                                     </MenuItem>

                                     <Separator/>
                                     <MenuItem Header="Manage Sources" Command="{Binding OpenSourcesCommand}" InputGesture="Ctrl+,">
                                         <MenuItem.Icon><TextBlock Text="📁"/></MenuItem.Icon>
                                     </MenuItem>
                                     <MenuItem Header="New Smart Playlist" Command="{Binding CreateSmartPlaylistCommand}" InputGesture="Ctrl+N">
                                         <MenuItem.Icon><TextBlock Text="⚡"/></MenuItem.Icon>
                                     </MenuItem>
                                     <MenuItem Header="Retry Offline Tracks" Command="{Binding Operations.RetryOfflineTracksCommand}">
                                         <MenuItem.Icon><TextBlock Text="🔄"/></MenuItem.Icon>
                                     </MenuItem>
                                     <MenuItem Header="Sync Physical Library" Command="{Binding SyncPhysicalLibraryCommand}" InputGesture="Ctrl+L">
                                         <MenuItem.Icon><TextBlock Text="🔗"/></MenuItem.Icon>
                                     </MenuItem>
                                     <Separator/>
                                     <MenuItem Header="🌊 Flow Builder" Command="{Binding OpenFlowBuilderCommand}"
                                               ToolTip.Tip="Build your DJ set timeline">
                                         <MenuItem.Icon><TextBlock Text="🌊"/></MenuItem.Icon>
                                     </MenuItem>
                                     <Separator/>
                                     <MenuItem Header="Export Monthly Drop" Command="{Binding ExportMonthlyDropCommand}" InputGesture="Ctrl+E">
                                         <MenuItem.Icon><TextBlock Text="📂"/></MenuItem.Icon>
                                     </MenuItem>
                                 </MenuFlyout>
                             </DropDownButton.Flyout>
                         </DropDownButton>
                    </Grid>

                    <!-- Navigation Content: List View -->
                    <ScrollViewer Grid.Row="1" IsVisible="{Binding !UseCardView}">
                        <StackPanel Spacing="2">
                            <!-- Section: Library Management -->
                            <TextBlock Text="LIBRARY" FontSize="10" FontWeight="Bold" Foreground="#555" Margin="16,12,16,4"/>

                            <Button Command="{Binding Projects.LoadAllTracksCommand}" Classes="nav-item" Margin="8,0">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <Border Width="24" Height="24" CornerRadius="4" Background="#111128" VerticalAlignment="Center">
                                        <TextBlock Text="📚" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="All Tracks" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding Projects.ImportLikedSongsCommand}" Classes="nav-item" Margin="8,0">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <Border Width="24" Height="24" CornerRadius="4" Background="#281111" VerticalAlignment="Center">
                                        <TextBlock Text="❤️" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Liked Songs" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding OpenSourcesCommand}" Classes="nav-item" Margin="8,0">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <Border Width="24" Height="24" CornerRadius="4" Background="#112811" VerticalAlignment="Center">
                                        <TextBlock Text="📁" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Folders" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Section: Project Workspace -->
                            <Separator Height="1" Background="#2A2A2A" Margin="12,12"/>
                            <TextBlock Text="PROJECTS" FontSize="10" FontWeight="Bold" Foreground="#555" Margin="16,4,16,4"/>

                            <!-- Project Filter -->
                            <Border Background="#2D2D2D" BorderBrush="#333" BorderThickness="1" CornerRadius="8" Margin="8,4,8,8" Padding="10,2">
                                <Grid ColumnDefinitions="Auto,*">
                                    <TextBlock Grid.Column="0" Text="🔍" FontSize="12" VerticalAlignment="Center" Foreground="#666"/>
                                    <TextBox Grid.Column="1" Text="{Binding Projects.SearchText, Mode=TwoWay}" Watermark="Filter projects..." Background="Transparent" BorderThickness="0" FontSize="12" Padding="8,6" Foreground="White"/>
                                </Grid>
                            </Border>

                            <ListBox ItemsSource="{Binding Projects.FilteredProjects}"
                                     SelectedItem="{Binding Projects.SelectedProject, Mode=TwoWay}"
                                     Background="Transparent" BorderThickness="0" Padding="0,4">
                                <ListBox.Styles>
                                    <Style Selector="ListBoxItem">
                                        <Setter Property="Padding" Value="4"/>
                                        <Setter Property="Margin" Value="8,2"/>
                                        <Setter Property="CornerRadius" Value="8"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="2,0,0,0"/>
                                        <Setter Property="Transitions">
                                            <Transitions>
                                                <BrushTransition Property="Background" Duration="0:0:0.2"/>
                                                <BrushTransition Property="BorderBrush" Duration="0:0:0.2"/>
                                            </Transitions>
                                        </Setter>
                                    </Style>
                                    <Style Selector="ListBoxItem:pointerover">
                                        <Setter Property="Background" Value="{StaticResource GlassBrush}"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource GlassHeavyBrush}"/>
                                    </Style>
                                    <Style Selector="ListBoxItem:selected">
                                        <Setter Property="Background" Value="{StaticResource AccentGlowBrush}"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                    </Style>
                                    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                                        <Setter Property="Background" Value="{Binding $parent[ListBoxItem].Background}"/>
                                    </Style>
                                </ListBox.Styles>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="Transparent">
                                            <Border.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="Export to Rekordbox XML" Command="{Binding $parent[UserControl].DataContext.ExportPlaylistCommand}" CommandParameter="{Binding}">
                                                        <MenuItem.Icon><TextBlock Text="📂"/></MenuItem.Icon>
                                                    </MenuItem>
                                                    <MenuItem Header="Remove Playlist From List" Command="{Binding $parent[UserControl].DataContext.DeleteProjectCommand}" CommandParameter="{Binding}" InputGesture="Delete">
                                                        <MenuItem.Icon><TextBlock Text="🗑️"/></MenuItem.Icon>
                                                    </MenuItem>
                                                    <Separator/>
                                                    <MenuItem Header="Rename Playlist" Command="{Binding $parent[UserControl].DataContext.RenameProjectCommand}" CommandParameter="{Binding}">
                                                        <MenuItem.Icon><TextBlock Text="✏️"/></MenuItem.Icon>
                                                    </MenuItem>
                                                </ContextMenu>
                                            </Border.ContextMenu>
                                            <controls:CompactPlaylistTemplate/>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Navigation Content: 2026 Card View -->
                    <ScrollViewer Grid.Row="1" IsVisible="{Binding UseCardView}">
                        <views:PlaylistGridView/>
                    </ScrollViewer>

                    <!-- Bottom Actions / Compact Icon Bar -->
                    <Grid Grid.Row="2" Margin="12,12">
                        <!-- Full Actions (when expanded) -->
                        <StackPanel Spacing="8" IsVisible="{Binding !IsNavigationCollapsed}">
                            <Button Command="{Binding Projects.AddPlaylistCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="➕"/>
                                    <TextBlock Text="New Playlist"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding DeleteProjectCommand}" CommandParameter="{Binding SelectedProject}" Classes="danger" IsVisible="{Binding !!SelectedProject}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center">
                                 <TextBlock Text="Delete Project"/>
                            </Button>
                        </StackPanel>

                        <!-- Compact Icon Bar (when collapsed) -->
                        <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center" IsVisible="{Binding IsNavigationCollapsed}">
                            <Button Command="{Binding Projects.LoadAllTracksCommand}" Classes="icon-button" ToolTip.Tip="All Tracks">
                                <TextBlock Text="📚" FontSize="16"/>
                            </Button>
                            <Button Command="{Binding Projects.ImportLikedSongsCommand}" Classes="icon-button" ToolTip.Tip="Liked Songs">
                                <TextBlock Text="❤️" FontSize="16"/>
                            </Button>
                            <Button Command="{Binding OpenSourcesCommand}" Classes="icon-button" ToolTip.Tip="Folders">
                                <TextBlock Text="📁" FontSize="16"/>
                            </Button>
                            <Separator Background="#444" Width="1" Height="20" Margin="4,0"/>
                            <Button Command="{Binding Projects.AddPlaylistCommand}" Classes="icon-button" ToolTip.Tip="New Playlist">
                                <TextBlock Text="➕" FontSize="16"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

        <!-- MAIN CONTENT AREA -->
        <ContentControl Grid.Column="1" Content="{Binding Tracks}">
            <ContentControl.DataTemplates>
                <DataTemplate DataType="vm:Library.TrackListViewModel">
                    <views:TrackListView/>
                </DataTemplate>
            </ContentControl.DataTemplates>
        </ContentControl>
    </Grid>

    <!-- ═══ BATCH ACTION FAB ════════════════════════════════════════════════
         Floats above the library grid. Visible only when ≥1 track selected.
         Uses Tracks.HasSelectedTracks because LibraryViewModel.Tracks is
         the TrackListViewModel which owns the selection state.
    ════════════════════════════════════════════════════════════════════════ -->
    <Border IsVisible="{Binding Tracks.HasSelectedTracks}"
            VerticalAlignment="Bottom" HorizontalAlignment="Center"
            Background="#E01E1E2E" CornerRadius="32"
            BorderBrush="#334EC9B0" BorderThickness="1"
            Padding="20,12" Margin="0,0,0,24"
            ZIndex="100">
        <StackPanel Orientation="Horizontal" Spacing="10">

            <!-- Selection count badge -->
            <Border Background="#304EC9B0" CornerRadius="16" Padding="10,4">
                <TextBlock Text="{Binding Tracks.SelectedTracks.Count, StringFormat='{}{0} selected'}"
                           FontSize="12" FontWeight="SemiBold" Foreground="#4EC9B0"
                           VerticalAlignment="Center"/>
            </Border>

            <!-- Separator -->
            <Border Width="1" Background="#33FFFFFF" Margin="2,4"/>

            <!-- Play Selected -->
            <Button Command="{Binding Tracks.Operations.PlayTrackCommand}"
                    ToolTip.Tip="Clear queue and play selected tracks"
                    Padding="10,6" CornerRadius="18" FontSize="11"
                    Background="#1A4EC9B0" Foreground="#4EC9B0">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="▶️" FontSize="13"/>
                    <TextBlock Text="Play" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- Add to Queue -->
            <Button Command="{Binding Tracks.Operations.AddSelectedToQueueCommand}"
                    ToolTip.Tip="Add selected tracks to play queue"
                    Padding="10,6" CornerRadius="18" FontSize="11"
                    Background="#1AFFFFFF" Foreground="#DDD">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="⊕" FontSize="13"/>
                    <TextBlock Text="Add to Queue" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- Separator -->
            <Border Width="1" Background="#33FFFFFF" Margin="2,4"/>

            <!-- Batch Tag Edit -->
            <Button Command="{Binding BatchTagEditCommand}"
                    ToolTip.Tip="Edit tags for selected tracks"
                    Padding="10,6" CornerRadius="18" FontSize="11"
                    Background="#1AFFFFFF" Foreground="#DDD">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="✏️" FontSize="13"/>
                    <TextBlock Text="Tag Edit" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- Queue Analysis -->
            <Button Command="{Binding BatchQueueAnalysisCommand}"
                    ToolTip.Tip="Queue selected tracks for audio analysis"
                    Padding="10,6" CornerRadius="18" FontSize="11"
                    Background="#1A4EC9B0" Foreground="#4EC9B0">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="🔬" FontSize="13"/>
                    <TextBlock Text="Analyse" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- Add to Playlist -->
            <Button Command="{Binding BatchAddToPlaylistCommand}"
                    ToolTip.Tip="Add selected tracks to a playlist"
                    Padding="10,6" CornerRadius="18" FontSize="11"
                    Background="#1AFFFFFF" Foreground="#DDD">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="➕" FontSize="13"/>
                    <TextBlock Text="Add to Playlist" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- Export Rekordbox -->
            <Button Command="{Binding BatchExportRekordboxCommand}"
                    ToolTip.Tip="Export to Rekordbox XML"
                    Padding="10,6" CornerRadius="18" FontSize="11"
                    Background="#1AFFFFFF" Foreground="#DDD">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="📤" FontSize="13"/>
                    <TextBlock Text="Rekordbox" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- Separator -->
            <Border Width="1" Background="#33FFFFFF" Margin="2,4"/>

            <!-- Clear selection -->
            <Button Command="{Binding BatchClearSelectionCommand}"
                    ToolTip.Tip="Deselect all"
                    Padding="8,6" CornerRadius="18" FontSize="11"
                    Background="Transparent" Foreground="#888">
                <TextBlock Text="✕" FontSize="14"/>
            </Button>

        </StackPanel>
    </Border>

    </Panel>
</UserControl>
