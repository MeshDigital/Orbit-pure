<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:views="clr-namespace:SLSKDONET.Views.Avalonia"
             xmlns:controls="clr-namespace:SLSKDONET.Views.Avalonia.Controls"
             xmlns:models="clr-namespace:SLSKDONET.Models"
             xmlns:vm="clr-namespace:SLSKDONET.ViewModels"
             xmlns:converters="clr-namespace:SLSKDONET.Views.Avalonia.Converters"
             xmlns:tree="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls.TreeDataGrid"
             xmlns:tp="clr-namespace:Avalonia.Controls.Primitives;assembly=Avalonia.Controls.TreeDataGrid"
             xmlns:dg="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls.DataGrid"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
             x:Class="SLSKDONET.Views.Avalonia.SearchPage"
             x:CompileBindings="False"
             x:DataType="vm:SearchViewModel"
             Background="#1E1E1E" Foreground="White">

    <Grid>

    <DockPanel>



        <!-- ZONE A: The Initiator (Top Bar) -->
        <Border DockPanel.Dock="Top" Background="#252526" BorderBrush="#3E3E3E" BorderThickness="0,0,0,1" Padding="24,20" VerticalAlignment="Top">
            <StackPanel Spacing="20">
                <!-- Search Input Row -->
                <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                    <!-- Search Box -->
                    <Border Grid.Column="0" Background="#1E1E1E" CornerRadius="14" BorderBrush="#333" BorderThickness="1" Height="56" MaxWidth="800" HorizontalAlignment="Stretch">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <TextBlock Grid.Column="0" Text="🔍" VerticalAlignment="Center" Margin="20,0,8,0" Foreground="#888" FontSize="18"/>
                            <TextBox Grid.Column="1" Text="{Binding SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Watermark="Search for tracks, artists..."
                                     Background="Transparent" BorderThickness="0"
                                     FontSize="16" VerticalContentAlignment="Center" Margin="4,0" Padding="12,0"/>
                            <Button Grid.Column="2" Command="{Binding ClearSearchCommand}" Background="Transparent" BorderThickness="0"
                                    IsVisible="{Binding CanSearch}" Margin="0,0,12,0" Padding="8">
                                <TextBlock Text="✕" Foreground="#888" VerticalAlignment="Center" FontSize="16"/>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- CSV/Paste Buttons -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="16,0,0,0" Spacing="10">
                        <Button Command="{Binding BrowseCsvCommand}" Classes="secondary hover-bright" Height="56" CornerRadius="12" Padding="16,0" ToolTip.Tip="Import CSV">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="📂" FontSize="16"/>
                                <TextBlock Text="CSV" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding PasteTracklistCommand}" Classes="secondary hover-bright" Height="56" CornerRadius="12" Padding="16,0" ToolTip.Tip="Paste Tracklist">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="📋" FontSize="16"/>
                                <TextBlock Text="Paste" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Search Button -->
                    <Button Grid.Column="2" Command="{Binding UnifiedSearchCommand}" Classes="secondary accent" Margin="16,0,0,0" Padding="32,0" Height="56" CornerRadius="12">
                        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                            <TextBlock Text="SEARCH" FontWeight="Bold" FontSize="14" LetterSpacing="1.5"/>
                            <TextBlock Text="➡️" FontSize="16"/>
                        </StackPanel>
                    </Button>

                    <!-- Stop Listening Button (final/cancel semantics) -->
                    <Button Grid.Column="3"
                            Command="{Binding CancelSearchCommand}"
                            IsEnabled="{Binding IsListening}"
                            Classes="secondary"
                            Margin="10,0,0,0"
                            Padding="20,0"
                            Height="56"
                            CornerRadius="12"
                            ToolTip.Tip="Stop current stream listening (final for this search)">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <TextBlock Text="⏹" FontSize="14"/>
                            <TextBlock Text="STOP LISTENING" FontWeight="SemiBold" FontSize="12"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- Search Style - compact single row -->
                <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBlock Text="Style" Foreground="#888" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" LetterSpacing="1"/>
                        <Border Background="#222B36" BorderBrush="#35506E" BorderThickness="1" CornerRadius="8" Padding="8,4" HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="{Binding SelectedQualityPresetIcon}" FontSize="13" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding SelectedQualityPresetName}" Foreground="#F3F6FA" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center"/>
                                <TextBlock Text="—" Foreground="#444" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding SelectedQualityPresetSubtitle}" Foreground="#AEB9C5" FontSize="11" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    <Grid Grid.Column="1" ColumnDefinitions="Auto,*,Auto" MaxWidth="360" Margin="20,0">
                        <TextBlock Grid.Column="0" Text="⚡" FontSize="12" VerticalAlignment="Center" Foreground="#555" ToolTip.Tip="Fast — reliable and speedy"/>
                        <Slider Grid.Column="1" Minimum="0" Maximum="3" Value="{Binding QualityPresetSliderValue, Mode=TwoWay}" SmallChange="1" LargeChange="1" Margin="6,0"/>
                        <TextBlock Grid.Column="2" Text="💎" FontSize="12" VerticalAlignment="Center" Foreground="#555" ToolTip.Tip="Lossless — strict quality"/>
                    </Grid>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ZONE C: Gatekeeper & Results (Main Content) -->
        <Grid RowDefinitions="Auto,Auto,*,Auto">

            <!-- Filters & Toggles -->
            <Border Grid.Row="0" Background="#1E1E1E" Padding="16,10" BorderBrush="#333" BorderThickness="0,0,0,1">
                <StackPanel Spacing="6">
                    <!-- Primary row: format toggles + action buttons + disclosure toggle -->
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                            <TextBlock Text="FORMATS" VerticalAlignment="Center" Foreground="#888" FontWeight="Bold" FontSize="10" LetterSpacing="1" Margin="0,0,8,0"/>
                            <ToggleButton IsChecked="{Binding IsMp3Enabled}" Content="MP3" CornerRadius="4"/>
                            <ToggleButton IsChecked="{Binding IsFlacEnabled}" Content="FLAC" CornerRadius="4"/>
                            <ToggleButton IsChecked="{Binding IsWavEnabled}" Content="WAV" CornerRadius="4"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <Button Command="{Binding AddToDownloadsCommand}" IsEnabled="{Binding HasSelectedResults}" Classes="primary" Padding="16,6">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="⬇️"/>
                                    <TextBlock Text="{Binding SelectedResults.Count, StringFormat='Download ({0})'}" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding AddToPlaylistCommand}" IsEnabled="{Binding HasSelectedResults}" Classes="secondary" Padding="16,6">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="🎚️"/>
                                    <TextBlock Text="{Binding SelectedResults.Count, StringFormat='Add to Mix ({0})'}" />
                                </StackPanel>
                            </Button>
                            <ToggleButton x:Name="MoreFiltersToggle" Content="Filters ▾" Padding="10,6" CornerRadius="6" FontSize="11" ToolTip.Tip="Show quality and safety filters"/>
                        </StackPanel>
                    </Grid>

                    <!-- Secondary row: bouncer + safety (disclosed on toggle) -->
                    <Grid ColumnDefinitions="*,Auto" IsVisible="{Binding #MoreFiltersToggle.IsChecked}">
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="20" VerticalAlignment="Center">
                            <TextBlock Text="THE BOUNCER" VerticalAlignment="Center" Foreground="#888" FontWeight="Bold" FontSize="10" LetterSpacing="1" Margin="0,0,8,0"/>
                            <RadioButton GroupName="Bouncer" Content="Strict"
                                         IsChecked="{Binding FilterViewModel.BouncerMode, Converter={x:Static converters:EnumConverters.BouncerModeEquals}, ConverterParameter={x:Static models:BouncerMode.Strict}}"
                                         ToolTip.Tip="Only shows high quality, trusted files."/>
                            <RadioButton GroupName="Bouncer" Content="Standard"
                                         IsChecked="{Binding FilterViewModel.BouncerMode, Converter={x:Static converters:EnumConverters.BouncerModeEquals}, ConverterParameter={x:Static models:BouncerMode.Standard}}"
                                         ToolTip.Tip="Blocks fake/upscaled files and very low bitrate."/>
                            <RadioButton GroupName="Bouncer" Content="Relaxed"
                                         IsChecked="{Binding FilterViewModel.BouncerMode, Converter={x:Static converters:EnumConverters.BouncerModeEquals}, ConverterParameter={x:Static models:BouncerMode.Relaxed}}"/>
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsChecked="{Binding FilterViewModel.HideSuspects}" OnContent="Safety On" OffContent="Safety Off" VerticalAlignment="Center" ToolTip.Tip="Filter out potential fake/upscaled files"/>
                    </Grid>

                    <!-- Status text and warning (always visible when applicable) -->
                    <TextBlock Text="{Binding SelectedResultsSummary}"
                               Foreground="#8FD6A8"
                               FontSize="11"
                               TextWrapping="Wrap"
                               IsVisible="{Binding HasSelectedResults}"/>
                    <Border IsVisible="{Binding AllResultsFilteredByRules}"
                            Background="#3A2A00"
                            BorderBrush="#FFB020"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="10,6">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="⚠" Foreground="#FFB020" FontWeight="Bold"/>
                            <TextBlock Text="All streamed results are filtered by current Safety/Bouncer rules."
                                       Foreground="#FFD27A"
                                       FontSize="11"
                                       VerticalAlignment="Center"/>
                            <Button Command="{Binding RelaxFiltersCommand}"
                                    Classes="secondary"
                                    Padding="8,2"
                                    Margin="8,0,0,0">
                                <TextBlock Text="Relax" FontSize="10"/>
                            </Button>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Results DataGrid -->
            <!-- Column Header -->
            <controls:VirtualGridHeader Grid.Row="1" Margin="16,0">
                <controls:VirtualGridHeader.HeaderContent>
                    <Grid ColumnDefinitions="50,60,80,*,80,120,80">
                        <!-- Column 0: Tier -->
                        <TextBlock Grid.Column="0" Text="TIER" FontSize="10" FontWeight="Bold" Foreground="#555" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <!-- Column 1: Trust -->
                        <TextBlock Grid.Column="1" Text="TRUST" FontSize="10" FontWeight="Bold" Foreground="#555" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        <!-- Column 2: Match -->
                        <TextBlock Grid.Column="2" Text="MATCH" FontSize="10" FontWeight="Bold" Foreground="#555" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <!-- Column 3: Track Details -->
                        <TextBlock Grid.Column="3" Text="TRACK DETAILS" FontSize="10" FontWeight="Bold" Foreground="#555" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="8,0"/>
                        <!-- Column 4: Bitrate -->
                        <TextBlock Grid.Column="4" Text="BITRATE" FontSize="10" FontWeight="Bold" Foreground="#555" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        <!-- Column 5: Source -->
                        <TextBlock Grid.Column="5" Text="SOURCE" FontSize="10" FontWeight="Bold" Foreground="#555" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        <!-- Column 6: Speed -->
                        <TextBlock Grid.Column="6" Text="SPEED" FontSize="10" FontWeight="Bold" Foreground="#555" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    </Grid>
                </controls:VirtualGridHeader.HeaderContent>
            </controls:VirtualGridHeader>

            <controls:VirtualGrid Grid.Row="2" Name="ResultsGrid" 
                                  ItemsSource="{Binding SearchResultsView}"
                                  SelectionMode="Multiple"
                                  SelectionChanged="ValidatingSelectionChanged"
                                  Margin="16,0">
                <controls:VirtualGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Download Selected" Command="{Binding DownloadSelectedCommand}"/>
                        <MenuItem Header="Add Selected to Mix" Command="{Binding AddToPlaylistCommand}"/>
                        <MenuItem Header="Explore User Collection" 
                                  Command="{Binding BrowseUserSharesCommand}"
                                  CommandParameter="{Binding #ResultsGrid.SelectedItem}"/>
                        <Separator/>
                        <MenuItem Header="Copy Metadata" Command="{Binding CopyMetadataCommand}"/>
                    </ContextMenu>
                </controls:VirtualGrid.ContextMenu>
                <controls:VirtualGrid.ItemTemplate>
                    <DataTemplate DataType="vm:AnalyzedSearchResultViewModel">
                        <Border Classes="track-row"
                                Height="64"
                                Focusable="True">
                            <Grid ColumnDefinitions="50,60,80,*,80,120,80">
                                <!-- Column 0: Tier Badge -->
                                <TextBlock Grid.Column="0" Text="{Binding TierBadge}" 
                                           ToolTip.Tip="{Binding TierDescription}"
                                           VerticalAlignment="Center" 
                                           HorizontalAlignment="Center" 
                                           FontSize="18" />

                                <!-- Column 1: Trust Score -->
                                <TextBlock Grid.Column="1" Text="{Binding TrustScore}" VerticalAlignment="Center"/>

                                <!-- Column 2: Match Confidence -->
                                <Border Grid.Column="2" CornerRadius="999" Padding="8,3"
                                        Background="#182127"
                                        BorderBrush="{Binding MatchConfidenceColor}"
                                        BorderThickness="1"
                                        VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock Text="●" FontSize="9" Foreground="{Binding MatchConfidenceColor}"/>
                                        <TextBlock Text="{Binding MatchConfidence, StringFormat='{}{0:0}%'}"
                                                   FontSize="10" FontWeight="SemiBold" Foreground="#EAF2F7"/>
                                    </StackPanel>
                                </Border>

                                <!-- Column 3: Track Details -->
                                <StackPanel Grid.Column="3" Margin="8,8" Spacing="4" Opacity="{Binding Opacity}">
                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"
                                               FontSize="13"
                                               TextTrimming="CharacterEllipsis" Foreground="#F3F5F7"/>

                                    <TextBlock Text="{Binding MatchReason, StringFormat='Why this matched: {0}'}"
                                               FontSize="10"
                                               Foreground="#AEB9C5"
                                               TextWrapping="Wrap"
                                               IsVisible="{Binding HasMatchReason}"/>

                                    <Border CornerRadius="4" Padding="6,2" HorizontalAlignment="Left"
                                            Margin="0,2,0,0" Background="#2A2415" BorderBrush="#7A6224" BorderThickness="1"
                                            IsVisible="{Binding IsFilteredOut}"
                                            ToolTip.Tip="{Binding FilteredOutReason}">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <TextBlock Text="⚠" FontSize="10" Foreground="#FFD27A"/>
                                            <TextBlock Text="Filtered by current rules" FontSize="10"
                                                       FontWeight="SemiBold" Foreground="#F6E6B6"/>
                                        </StackPanel>
                                    </Border>

                                    <Border CornerRadius="4" Padding="6,2" HorizontalAlignment="Left"
                                            Margin="0,2,0,0" Background="#301C22" BorderBrush="#8A3D56" BorderThickness="1"
                                            IsVisible="{Binding ShowHighRiskBadge}"
                                            ToolTip.Tip="{Binding FlagReason}">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <TextBlock Text="⚠" FontSize="10" Foreground="#FF9FBA"/>
                                            <TextBlock Text="Needs review" FontSize="10"
                                                       FontWeight="SemiBold" Foreground="#FFD7E3"/>
                                        </StackPanel>
                                    </Border>

                                    <Border CornerRadius="4" Padding="6,2" HorizontalAlignment="Left"
                                            Margin="0,2,0,0" Background="#302515" BorderBrush="#8C6A2A" BorderThickness="1"
                                            IsVisible="{Binding IsSuspiciousLossless}"
                                            ToolTip.Tip="{Binding SuspiciousLosslessReason}">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <TextBlock Text="⚠" FontSize="10" Foreground="#FFD27A"/>
                                            <TextBlock Text="Possible fake lossless" FontSize="10"
                                                       FontWeight="SemiBold" Foreground="#F6E6B6"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Sub-info -->
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Border Background="#20262D" BorderBrush="#36414D" BorderThickness="1" CornerRadius="3" Padding="5,1">
                                            <TextBlock Text="{Binding RawResult.FileFormat}" Foreground="#D6DEE7" FontSize="10" FontWeight="SemiBold"/>
                                        </Border>
                                        <Border Background="#2A2415" BorderBrush="#5B4B20" BorderThickness="1" CornerRadius="3" Padding="5,1"
                                                IsVisible="{Binding !!AudioQualityDisplay.Length}">
                                            <TextBlock Text="{Binding AudioQualityDisplay}" Foreground="#E7D39C" FontSize="10"/>
                                        </Border>
                                        <TextBlock Text="{Binding DisplaySize}" Foreground="#9AA7B4" FontSize="10" VerticalAlignment="Center"/>
                                        <TextBlock Text="•" Foreground="#4C5864" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding User}" Foreground="#78AEE8" FontSize="10" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Column 4: Bitrate -->
                                <TextBlock Grid.Column="4" Text="{Binding BitRate}" VerticalAlignment="Center"/>

                                <!-- Column 5: Source -->
                                <TextBlock Grid.Column="5" Text="{Binding User}" VerticalAlignment="Center"/>

                                <!-- Column 6: Speed -->
                                <TextBlock Grid.Column="6" Text="{Binding UploadSpeedDisplay}" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </controls:VirtualGrid.ItemTemplate>
            </controls:VirtualGrid>

            <!-- Empty State (Premium) -->
            <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center"
                        IsVisible="{Binding !HasDisplayedResults}" Spacing="16">
                <TextBlock Text="📡" FontSize="48" HorizontalAlignment="Center" Opacity="0.5"/>
                <TextBlock Text="Ready for Extraction" Foreground="#555" FontSize="20" FontWeight="Light" HorizontalAlignment="Center"/>
                <TextBlock Text="Initiate a search to scan the Soulseek network" Foreground="#333" HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Footer / Ghost Counter -->
            <Border Grid.Row="2" Background="{DynamicResource RegionBrush}" BorderBrush="#333" BorderThickness="0,1,0,0" Padding="12,4">
                <StackPanel Orientation="Horizontal" Spacing="24">
                    <TextBlock Text="{Binding StatusText}" Foreground="#CCC" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,20,0"/>

                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="{Binding DisplayedResultsCount}" FontWeight="Bold" Foreground="#1DB954"/>
                        <TextBlock Text="results shown" Foreground="#888" FontSize="11" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="4" IsVisible="{Binding HasHiddenResults}">
                        <TextBlock Text="•" Foreground="#444"/>
                        <TextBlock Text="{Binding HiddenResultsCount}" FontWeight="Bold" Foreground="#FF9800"/>
                        <TextBlock Text="cached as filtered-out results" Foreground="#888" FontSize="11" VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding HasHiddenResults}" Margin="20,0,0,0">
                        <Button Command="{Binding ToggleHiddenResultsCommand}" Classes="secondary" VerticalAlignment="Center" Padding="8,2">
                            <TextBlock Text="{Binding ShowHiddenResultsButtonText}" FontSize="10"/>
                        </Button>
                        <Button Command="{Binding RelaxFiltersCommand}" Classes="secondary" VerticalAlignment="Center" Padding="8,2">
                            <TextBlock Text="Relax Filters" FontSize="10"/>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

    </DockPanel>

    <Border Background="#CC000000"
            IsVisible="{Binding IsUserCollectionBrowserOpen}"
            ZIndex="200">
        <Border Background="#252526"
                Width="1100"
                Height="720"
                CornerRadius="12"
                BorderBrush="#3E3E3E"
                BorderThickness="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="0">
            <Grid RowDefinitions="Auto,*,Auto">
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="20,16,20,12">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="🗂️" FontSize="20" VerticalAlignment="Center"/>
                        <StackPanel Spacing="2">
                            <TextBlock Text="{Binding UserCollectionBrowser.CurrentUsername, StringFormat='Explore {0}'}" FontSize="18" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding UserCollectionBrowser.StatusText}" FontSize="12" Foreground="#888"/>
                        </StackPanel>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Command="{Binding CloseUserCollectionBrowserCommand}"
                            Background="Transparent"
                            Padding="8">
                        <TextBlock Text="✖" FontSize="16"/>
                    </Button>
                </Grid>

                <Grid Grid.Row="1" ColumnDefinitions="2*,*" Margin="20,0,20,16">
                    <Border Grid.Column="0" Background="#1E1E1E" CornerRadius="10" BorderBrush="#333" BorderThickness="1" Padding="12">
                        <Grid RowDefinitions="Auto,Auto,*">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Border Background="#333" CornerRadius="10" Padding="8,2">
                                    <TextBlock Text="{Binding UserCollectionBrowser.MusicFileCount, StringFormat='{}{0} tracks'}" FontSize="12" Foreground="#4EC9B0"/>
                                </Border>
                                <Border Background="#333" CornerRadius="10" Padding="8,2" IsVisible="{Binding UserCollectionBrowser.HasSuspiciousLossless}">
                                    <TextBlock Text="{Binding UserCollectionBrowser.SuspiciousLosslessCount, StringFormat='{}{0} suspicious lossless'}" FontSize="12" Foreground="#F59E0B"/>
                                </Border>
                                <TextBlock Text="Loading..." Foreground="#888" VerticalAlignment="Center" IsVisible="{Binding UserCollectionBrowser.IsLoading}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Margin="0,12,0,0" Spacing="10">
                                <TextBox Text="{Binding UserCollectionBrowser.FilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Watermark="Filter by file, artist, album or path"
                                         Background="#252526"
                                         BorderBrush="#3E3E3E"
                                         Foreground="White"/>
                                <Grid ColumnDefinitions="Auto,*,Auto">
                                    <ToggleSwitch IsChecked="{Binding UserCollectionBrowser.ShowMusicOnly}"
                                                  OnContent="Music only"
                                                  OffContent="All files"/>
                                    <TextBlock Grid.Column="1"
                                               Margin="10,0"
                                               Text="{Binding UserCollectionBrowser.FilterSummary}"
                                               Foreground="#888"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                    <ComboBox Grid.Column="2"
                                              Margin="10,0,0,0"
                                              Width="120"
                                              ItemsSource="{Binding UserCollectionBrowser.SortOptions}"
                                              SelectedItem="{Binding UserCollectionBrowser.SelectedSortOption, Mode=TwoWay}"/>
                                </Grid>
                            </StackPanel>

                            <TreeView Grid.Row="2"
                                      Margin="0,12,0,0"
                                      ItemsSource="{Binding UserCollectionBrowser.RootNodes}"
                                      SelectedItem="{Binding UserCollectionBrowser.SelectedNode, Mode=TwoWay}"
                                      Background="Transparent"
                                      IsVisible="{Binding UserCollectionBrowser.HasVisibleNodes}">
                                <TreeView.ItemTemplate>
                                    <TreeDataTemplate ItemsSource="{ReflectionBinding Children}">
                                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="2">
                                            <TextBlock Text="{ReflectionBinding Icon}" VerticalAlignment="Center"/>
                                            <StackPanel Spacing="1">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <TextBlock Text="{ReflectionBinding DisplayName}" Foreground="White" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="⚠️" Foreground="#F59E0B" IsVisible="{ReflectionBinding HasWarning}" ToolTip.Tip="{ReflectionBinding WarningText}"/>
                                                </StackPanel>
                                                <TextBlock Text="{ReflectionBinding SecondaryText}" FontSize="11" Foreground="#888" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </TreeDataTemplate>
                                </TreeView.ItemTemplate>
                            </TreeView>

                            <StackPanel Grid.Row="2"
                                        Margin="0,24,0,0"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Spacing="8"
                                        IsVisible="{Binding !UserCollectionBrowser.HasVisibleNodes}">
                                <TextBlock Text="No visible items" FontSize="18" Foreground="#AAA" HorizontalAlignment="Center"/>
                                <TextBlock Text="Adjust the browser filters or try another user." Foreground="#666" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Column="1" Spacing="12" Margin="16,0,0,0">
                        <Border Background="#1E1E1E" CornerRadius="10" BorderBrush="#333" BorderThickness="1" Padding="16">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Selection" FontSize="12" FontWeight="Bold" Foreground="#888"/>
                                <TextBlock Text="{Binding UserCollectionBrowser.SelectedNodeTitle}" FontSize="16" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding UserCollectionBrowser.SelectedNodeSubtitle}" Foreground="#AAA" TextWrapping="Wrap"/>
                                <Border Background="#4A2A00" CornerRadius="6" Padding="10,8" IsVisible="{Binding UserCollectionBrowser.HasSelectedNodeWarning}">
                                    <TextBlock Text="{Binding UserCollectionBrowser.SelectedNodeWarning}" Foreground="#F7C66B" TextWrapping="Wrap"/>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Background="#1E1E1E" CornerRadius="10" BorderBrush="#333" BorderThickness="1" Padding="16">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Actions" FontSize="12" FontWeight="Bold" Foreground="#888"/>
                                <Button Command="{Binding UserCollectionBrowser.QueueSelectedCommand}" Classes="primary" Padding="12,8">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="⬇️"/>
                                        <TextBlock Text="Queue Selected"/>
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding UserCollectionBrowser.QueueAllCommand}" Classes="secondary" Padding="12,8">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="📦"/>
                                        <TextBlock Text="Queue All Music Files"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>

                        <Border Background="#1E1E1E" CornerRadius="10" BorderBrush="#333" BorderThickness="1" Padding="16">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Pure Notes" FontSize="12" FontWeight="Bold" Foreground="#888"/>
                                <TextBlock Text="• Tree is built locally from the peer’s shared file paths." Foreground="#AAA" TextWrapping="Wrap"/>
                                <TextBlock Text="• Only music files are queueable." Foreground="#AAA" TextWrapping="Wrap"/>
                                <TextBlock Text="• Low-bitrate FLAC entries are flagged before queueing." Foreground="#AAA" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <Border Grid.Row="2" Background="#1E1E1E" Padding="16,10" CornerRadius="0,0,12,12">
                    <StackPanel Orientation="Horizontal" Spacing="14">
                        <TextBlock Text="{Binding UserCollectionBrowser.TotalFiles, StringFormat='Visible entries: {0}'}" Foreground="#888" FontSize="12"/>
                        <TextBlock Text="•" Foreground="#444"/>
                        <TextBlock Text="{Binding UserCollectionBrowser.MusicFileCount, StringFormat='Music files: {0}'}" Foreground="#888" FontSize="12"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Border>

    </Grid>

    <UserControl.Styles>
        <Style Selector="Button.pill">
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Background" Value="#333"/>
            <Setter Property="Foreground" Value="#DDD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#444"/>
        </Style>
        <Style Selector="Button.pill:pointerover">
            <Setter Property="Background" Value="#444"/>
            <Setter Property="BorderBrush" Value="#666"/>
        </Style>
        <Style Selector="ToggleButton">
            <Setter Property="Background" Value="#333"/>
            <Setter Property="Foreground" Value="#AAA"/>
            <Setter Property="Padding" Value="12,6"/>
        </Style>
        <Style Selector="ToggleButton:checked">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <!-- Zebra Striping for TreeDataGrid -->
        <Style Selector="tp|TreeDataGridRow:nth-child(even)">
            <Setter Property="Background" Value="#252525"/>
        </Style>

        <!-- Track Row Styles for VirtualGrid -->
        <Style Selector="Border.track-row">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#151A20"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.15"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.track-row:pointerover">
            <Setter Property="Background" Value="#18202A"/>
        </Style>
        <Style Selector="Border.track-row.selected">
            <Setter Property="Background" Value="#223041"/>
        </Style>
        <Style Selector="Border.track-row.focused">
            <Setter Property="BorderBrush" Value="#4EC9B0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
    </UserControl.Styles>
</UserControl>
