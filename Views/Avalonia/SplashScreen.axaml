<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:SLSKDONET.Views"
        x:Class="SLSKDONET.Views.Avalonia.SplashScreen"
        x:DataType="vm:MainViewModel"
        Title="Loading ORBIT..."
        Width="460" Height="280"
        WindowStartupLocation="CenterScreen"
        SystemDecorations="None"
        Topmost="True"
        Background="Transparent"
        TransparencyLevelHint="Transparent">
    
    <Border Background="#1E1E1E" BorderBrush="#3E3E3E" BorderThickness="1" CornerRadius="12" Margin="10">
        <Border.Effect>
            <DropShadowDirectionEffect ShadowDepth="4" BlurRadius="10" Opacity="0.4" Color="Black" Direction="270" />
        </Border.Effect>

        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="24">
            <TextBlock Text="ORBIT" FontSize="48" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" LetterSpacing="8"/>
            <TextBlock Text="INITIALIZATION SEQUENCE" FontSize="12" FontWeight="SemiBold" Foreground="#4EC9B0" HorizontalAlignment="Center" LetterSpacing="2" Margin="0,-16,0,0"/>
            
            <StackPanel Spacing="16" Margin="0,24,0,0">
                <ProgressBar IsIndeterminate="True" Width="280" Height="4" Foreground="#4EC9B0" Background="#333333"/>
                <TextBlock x:Name="StatusTextBlock" Text="Ready" FontSize="13" Foreground="#888888" HorizontalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="340"/>
            </StackPanel>
        </StackPanel>
    </Border>

</Window>
