<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:SLSKDONET.ViewModels.Workstation"
             xmlns:wsViews="clr-namespace:SLSKDONET.Views.Avalonia.Workstation"
             xmlns:models="clr-namespace:SLSKDONET.Models"
             xmlns:views="clr-namespace:SLSKDONET.Views.Avalonia"
             xmlns:ctrl="clr-namespace:SLSKDONET.Views.Avalonia.Controls"
             mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="900"
             x:Class="SLSKDONET.Views.Avalonia.WorkstationPage"
             x:DataType="vm:WorkstationViewModel"
             x:Name="PageRoot"
             Focusable="True"
             KeyDown="OnCockpitKeyDown"
             Background="#141414">

    <UserControl.Styles>
        <Style Selector="ToggleButton.header-toggle">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="#A0A0A0"/>
            <Setter Property="BorderBrush" Value="#3A3A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style Selector="ToggleButton.header-toggle:checked">
            <Setter Property="Foreground" Value="#00D7FF"/>
            <Setter Property="BorderBrush" Value="#00D7FF"/>
        </Style>
    </UserControl.Styles>

    <Grid x:Name="CockpitGrid" RowDefinitions="Auto,*,Auto,300">

        <!-- Row 0: Global Header -->
        <Grid Grid.Row="0" RowDefinitions="Auto,Auto">
            <Border Grid.RowSpan="2"
                    Background="{DynamicResource RegionBrush}"
                    BorderBrush="#2F2F2F"
                    BorderThickness="0,0,0,1"/>

            <Grid Grid.Row="0" Margin="12,8,12,0" ColumnDefinitions="*,Auto,Auto,Auto">
                <StackPanel Grid.Column="0" Spacing="6" VerticalAlignment="Center">
                    <TextBlock Text="WORKSTATION"
                               FontSize="15"
                               FontWeight="Bold"
                               Foreground="#F0F0F0"/>
                    <TextBlock Text="{Binding DeckStatusSummary}"
                               FontSize="11"
                               Foreground="#8EC8FF"/>
                    <TextBlock Text="{Binding DeckFocusSummary}"
                               FontSize="10"
                               Foreground="#D8B4FE"/>
                    <TextBlock Text="{Binding ActivePlaylistFlowSummary}"
                               FontSize="10"
                               Foreground="#B8E986"
                               TextWrapping="Wrap"
                               MaxWidth="560"/>
                    <TextBlock Text="{Binding AnalysisQueueSummary}"
                               FontSize="10"
                               Foreground="#9EEFFF"
                               TextWrapping="Wrap"
                               MaxWidth="560"/>
                    <TextBlock Text="{Binding FlowWindowSummary}"
                               FontSize="10"
                               Foreground="#AFC6DD"/>
                    <WrapPanel Orientation="Horizontal" ItemHeight="28">
                        <ToggleButton Classes="header-toggle"
                                      IsChecked="{Binding IsWaveformMode, Mode=OneWay}"
                                      Command="{Binding SetModeCommand}"
                                      CommandParameter="{x:Static vm:WorkstationMode.Waveform}">Wave</ToggleButton>
                        <ToggleButton Classes="header-toggle"
                                      Margin="6,0,0,0"
                                      IsChecked="{Binding IsFlowMode, Mode=OneWay}"
                                      Command="{Binding SetModeCommand}"
                                      CommandParameter="{x:Static vm:WorkstationMode.Flow}">Flow</ToggleButton>
                        <ToggleButton Classes="header-toggle"
                                      Margin="6,0,0,0"
                                      IsChecked="{Binding IsStemsMode, Mode=OneWay}"
                                      Command="{Binding SetModeCommand}"
                                      CommandParameter="{x:Static vm:WorkstationMode.Stems}">Stems</ToggleButton>
                        <ToggleButton Classes="header-toggle"
                                      Margin="6,0,0,0"
                                      IsChecked="{Binding IsExportMode, Mode=OneWay}"
                                      Command="{Binding SetModeCommand}"
                                      CommandParameter="{x:Static vm:WorkstationMode.Export}">Export</ToggleButton>
                        <ToggleButton Classes="header-toggle"
                                      Margin="12,0,0,0"
                                      IsChecked="{Binding IsSnapEnabled, Mode=TwoWay}">Snap</ToggleButton>
                        <ToggleButton Classes="header-toggle"
                                      Margin="6,0,0,0"
                                      IsChecked="{Binding IsQuantizeEnabled, Mode=TwoWay}">Qtz</ToggleButton>
                        <ToggleButton Classes="header-toggle"
                                      Margin="6,0,0,0"
                                      IsChecked="{Binding IsMetronomeEnabled, Mode=TwoWay}">Met</ToggleButton>
                    </WrapPanel>
                    <TextBlock Text="{Binding ToolbarHint}"
                               FontSize="10"
                               Foreground="#B8E986"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <Button Classes="icon"
                            Command="{Binding UndoCommand}"
                            ToolTip.Tip="Undo [Ctrl+Z]">↩</Button>
                    <Button Classes="icon"
                            Command="{Binding RedoCommand}"
                            ToolTip.Tip="Redo [Ctrl+Y]">↪</Button>
                </StackPanel>

                <StackPanel Grid.Column="2" Spacing="5" Margin="10,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding TransportStatusSummary}"
                               FontSize="10"
                               Foreground="#FFD58A"/>
                    <TextBlock Text="{Binding FocusedDeckActionSummary}"
                               FontSize="10"
                               Foreground="#D8B4FE"/>
                    <TextBlock Text="{Binding MixCoachSummary}"
                               FontSize="10"
                               Foreground="#9EEFFF"
                               TextWrapping="Wrap"
                               MaxWidth="420"/>
                    <WrapPanel Orientation="Horizontal" ItemHeight="28">
                        <Button Classes="secondary" Command="{Binding PlayPauseAllCommand}" ToolTip.Tip="Play or pause all decks">Play</Button>
                        <Button Classes="secondary" Margin="6,0,0,0" Command="{Binding StopAllCommand}" ToolTip.Tip="Stop and cue all decks">Stop</Button>
                        <Button Classes="secondary" Margin="6,0,0,0" Command="{Binding SyncBpmCommand}" ToolTip.Tip="Beat-match Deck B to Deck A">Sync</Button>
                        <Button Classes="secondary" Margin="6,0,0,0" Command="{Binding TapTempoCommand}" ToolTip.Tip="Tap the master BPM">Tap</Button>
                        <Button Classes="icon" Margin="10,0,0,0" Command="{Binding Loop1Command}" ToolTip.Tip="Set 1-beat loop">1</Button>
                        <Button Classes="icon" Command="{Binding Loop2Command}" ToolTip.Tip="Set 2-beat loop">2</Button>
                        <Button Classes="icon" Command="{Binding Loop4Command}" ToolTip.Tip="Set 4-beat loop">4</Button>
                        <Button Classes="icon" Command="{Binding Loop8Command}" ToolTip.Tip="Set 8-beat loop">8</Button>
                        <Button Classes="icon" Command="{Binding ExitLoopFocusedCommand}" ToolTip.Tip="Exit the focused loop">×</Button>
                    </WrapPanel>
                    <WrapPanel Orientation="Horizontal" ItemHeight="28">
                        <ToggleButton Classes="header-toggle"
                                      IsChecked="{Binding IsDeckAFocused, Mode=OneWay}"
                                      Command="{Binding FocusDeckCommand}"
                                      CommandParameter="A">A</ToggleButton>
                        <ToggleButton Classes="header-toggle"
                                      Margin="6,0,0,0"
                                      IsChecked="{Binding IsDeckBFocused, Mode=OneWay}"
                                      Command="{Binding FocusDeckCommand}"
                                      CommandParameter="B">B</ToggleButton>
                        <ToggleButton Classes="header-toggle"
                                      Margin="6,0,0,0"
                                      IsChecked="{Binding IsDeckCFocused, Mode=OneWay}"
                                      Command="{Binding FocusDeckCommand}"
                                      CommandParameter="C">C</ToggleButton>
                        <ToggleButton Classes="header-toggle"
                                      Margin="6,0,0,0"
                                      IsChecked="{Binding IsDeckDFocused, Mode=OneWay}"
                                      Command="{Binding FocusDeckCommand}"
                                      CommandParameter="D">D</ToggleButton>
                        <Button Classes="secondary"
                                Margin="10,0,0,0"
                                Command="{Binding AddDeckCommand}"
                                ToolTip.Tip="Add deck (max 4)">+ Deck</Button>
                        <Button Classes="icon" Margin="6,0,0,0" Command="{Binding PanLeftCommand}" ToolTip.Tip="Pan timeline left">◀</Button>
                        <Button Classes="icon" Command="{Binding PanRightCommand}" ToolTip.Tip="Pan timeline right">▶</Button>
                        <Button Classes="icon" Command="{Binding ZoomInCommand}" ToolTip.Tip="Zoom in">＋</Button>
                        <Button Classes="icon" Command="{Binding ZoomOutCommand}" ToolTip.Tip="Zoom out">－</Button>
                    </WrapPanel>
                </StackPanel>

                <Button Grid.Column="3"
                        Margin="12,0,0,0"
                        Background="#0078D4"
                        Foreground="White"
                        BorderBrush="#0078D4"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="14,7"
                        Command="{Binding ExportMixCommand}">Export Mixdown...</Button>
            </Grid>

            <Slider Grid.Row="1"
                    Margin="300,8,220,8"
                    Minimum="0"
                    Maximum="{Binding MaxTimelineOffsetSeconds}"
                    Value="{Binding TimelineOffsetSeconds, Mode=TwoWay}"
                    Height="4"
                    VerticalAlignment="Top"
                    ToolTip.Tip="Timeline viewport position"/>
        </Grid>

        <!-- Row 1: Timeline Workspace -->
        <Grid Grid.Row="1" RowDefinitions="Auto,*,Auto">
            <Border Grid.Row="0" Background="#181818" BorderBrush="#2B2B2B" BorderThickness="0,0,0,1" Padding="10,5">
                <Grid ColumnDefinitions="250,*">
                    <TextBlock Grid.Column="0"
                               Text="TRACK STRIP"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Foreground="#8A8A8A"
                               VerticalAlignment="Center"/>
                    <Canvas Grid.Column="1" ClipToBounds="True">
                        <TextBlock Text="{Binding TimelineTick0}" Canvas.Left="0" FontSize="10" Foreground="#666"/>
                        <TextBlock Text="{Binding TimelineTick1}" Canvas.Left="140" FontSize="10" Foreground="#666"/>
                        <TextBlock Text="{Binding TimelineTick2}" Canvas.Left="280" FontSize="10" Foreground="#666"/>
                        <TextBlock Text="{Binding TimelineTick3}" Canvas.Left="420" FontSize="10" Foreground="#666"/>
                        <TextBlock Text="{Binding TimelineTick4}" Canvas.Left="560" FontSize="10" Foreground="#666"/>
                        <TextBlock Text="{Binding TimelineTick5}" Canvas.Left="700" FontSize="10" Foreground="#666"/>
                        <Border IsVisible="{Binding IsSnapGuideVisible}"
                                Canvas.Left="{Binding SnapGuideCanvasLeft}"
                                Canvas.Top="0"
                                Width="2"
                                Height="18"
                                Background="#00D7FF"
                                CornerRadius="1"/>
                        <Border IsVisible="{Binding IsSnapGuideVisible}"
                                Canvas.Left="{Binding SnapGuideCanvasLeft}"
                                Canvas.Top="18"
                                Background="#0F1F24"
                                BorderBrush="#00D7FF"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="6,1">
                            <TextBlock Text="{Binding SnapGuideLabel}" FontSize="9" Foreground="#9EEFFF"/>
                        </Border>
                    </Canvas>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Decks}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:WorkstationDeckViewModel">
                            <wsViews:WorkstationDeckRow/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Row 2: Mixer Center Strip (crossfader · transport · BPM/SNAP/QTZ/MET) -->
            <wsViews:MixerCenter Grid.Row="2"/>
        </Grid>

        <!-- Row 2: Resizer -->
        <GridSplitter Grid.Row="2"
                      ResizeDirection="Rows"
                      ResizeBehavior="PreviousAndNext"
                      Background="#222"
                      Height="8"
                      HorizontalAlignment="Stretch"
                      DoubleTapped="OnDrawerSplitterDoubleTapped"/>

        <!-- Row 3: Flow Drawer -->
        <Border Grid.Row="3" Background="#151515" BorderBrush="#2B2B2B" BorderThickness="0,1,0,0">
            <Grid RowDefinitions="Auto,Auto,*">

                <!-- Flow drawer header -->
                <Border Grid.Row="0" Background="{DynamicResource RegionBrush}" BorderBrush="#2D2D2D" BorderThickness="0,0,0,1" Padding="10,6">
                    <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto">
                        <TextBlock Grid.Column="0" Text="FLOW DRAWER" FontSize="11" FontWeight="Bold" Foreground="#A0A0A0" VerticalAlignment="Center"/>

                        <!-- Analyze playlist button -->
                        <Button Grid.Column="2"
                                Margin="0,0,6,0"
                                Padding="10,5"
                                FontSize="11"
                                FontWeight="SemiBold"
                                Background="#1B3A1B"
                                BorderBrush="#3A7A3A"
                                BorderThickness="1"
                                CornerRadius="6"
                                Foreground="#7FD47F"
                                Command="{Binding AnalyzePlaylistCuesCommand}"
                                IsEnabled="{Binding !IsAnalyzing}"
                                ToolTip.Tip="Auto-detect drops, builds, phrase markers for all tracks in this playlist that have no cues yet">⚡ Analyze Playlist</Button>

                        <!-- Analyze selected button (wired from code-behind via Click) -->
                        <Button Grid.Column="3"
                                x:Name="AnalyzeSelectedBtn"
                                Margin="0,0,6,0"
                                Padding="10,5"
                                FontSize="11"
                                FontWeight="SemiBold"
                                Background="#1B2A3A"
                                BorderBrush="#3A6A9A"
                                BorderThickness="1"
                                CornerRadius="6"
                                Foreground="#7FB8D4"
                                IsEnabled="{Binding !IsAnalyzing}"
                                Click="OnAnalyzeSelectedClick"
                                ToolTip.Tip="Auto-detect cues only for the selected rows (skips tracks that already have cues)">⚡ Selected</Button>

                        <ComboBox Grid.Column="4"
                                  Width="260"
                                  ItemsSource="{Binding Playlists}"
                                  SelectedItem="{Binding ActivePlaylist}"
                                  VerticalAlignment="Center">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding SourceTitle}" FontSize="12"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </Grid>
                </Border>

                <!-- Analysis progress strip (hidden when idle) -->
                <Border Grid.Row="1"
                        IsVisible="{Binding IsAnalyzing}"
                        Background="#0A1A0A"
                        BorderBrush="#2A4A2A"
                        BorderThickness="0,0,0,1"
                        Padding="10,4">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Orientation="Vertical" Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="{Binding AnalysisStatusText}"
                                       FontSize="10"
                                       Foreground="#7FD47F"/>
                            <ProgressBar Minimum="0"
                                         Maximum="100"
                                         Value="{Binding AnalysisProgress}"
                                         Height="3"
                                         Foreground="#4CAF50"
                                         Background="#1E1E1E"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding AnalysisProgress, StringFormat='{}{0}%'}"
                                   FontSize="10"
                                   Foreground="#7FD47F"
                                   VerticalAlignment="Center"
                                   Margin="10,0,0,0"/>
                    </Grid>
                </Border>

                <!-- Status text when done (visible when not analyzing and text is set) -->
                <Border Grid.Row="1"
                        IsVisible="{Binding !IsAnalyzing}"
                        Background="Transparent"
                        Padding="10,2">
                    <TextBlock Text="{Binding AnalysisStatusText}"
                               FontSize="10"
                               Foreground="#5A7A5A"
                               IsVisible="{Binding AnalysisStatusText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                </Border>

                <Grid Grid.Row="2" ColumnDefinitions="2*,3*">
                    <views:FlowBuilderView Grid.Column="0"/>

                    <Border Grid.Column="1" BorderBrush="#2D2D2D" BorderThickness="1,0,0,0">
                        <DataGrid x:Name="FlowTrackGrid"
                                  ItemsSource="{Binding PlaylistTracks}"
                                  Background="Transparent"
                                  GridLinesVisibility="Horizontal"
                                  BorderThickness="0"
                                  RowBackground="#141414"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  SelectionMode="Extended"
                                  PointerPressed="OnFlowTrackGridPointerPressed"
                                  PointerMoved="OnFlowTrackGridPointerMoved">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="#" Width="40" Binding="{Binding TrackNumber}"/>
                                <DataGridTextColumn Header="ARTIST" Width="180" Binding="{Binding Artist}"/>
                                <DataGridTextColumn Header="TITLE" Width="*" Binding="{Binding Title}"/>
                                <DataGridTextColumn Header="KEY" Width="60" Binding="{Binding Key}"/>
                                <DataGridTextColumn Header="BPM" Width="60" Binding="{Binding BPM, StringFormat='{}{0:F0}'}"/>
                                <DataGridTemplateColumn Header="LOAD" Width="150" IsReadOnly="True">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate x:DataType="models:PlaylistTrack">
                                            <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                                                <Button Content="F"
                                                        Command="{Binding #PageRoot.DataContext.LoadToFocusedDeckCommand}"
                                                        CommandParameter="{Binding}"
                                                        ToolTip.Tip="Load to the focused deck"/>
                                                <Button Content="A"
                                                        Command="{Binding #PageRoot.DataContext.LoadToDeckACommand}"
                                                        CommandParameter="{Binding}"
                                                        ToolTip.Tip="Load to Deck A"/>
                                                <Button Content="B"
                                                        Command="{Binding #PageRoot.DataContext.LoadToDeckBCommand}"
                                                        CommandParameter="{Binding}"
                                                        ToolTip.Tip="Load to Deck B"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </Grid>
        </Border>

    <!-- Keyboard shortcut overlay — F1 to open/close, spans entire cockpit -->
    <ctrl:KeyboardOverlayView Grid.Row="0" Grid.RowSpan="4"
                              DataContext="{Binding KeyboardOverlay}"
                              ZIndex="200"/>

    </Grid>
</UserControl>

