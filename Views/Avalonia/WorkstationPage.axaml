<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:SLSKDONET.ViewModels.Workstation"
             xmlns:wsViews="clr-namespace:SLSKDONET.Views.Avalonia.Workstation"
             xmlns:models="clr-namespace:SLSKDONET.Models"
             xmlns:views="clr-namespace:SLSKDONET.Views.Avalonia"
             xmlns:ctrl="clr-namespace:SLSKDONET.Views.Avalonia.Controls"
             mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="900"
             x:Class="SLSKDONET.Views.Avalonia.WorkstationPage"
             x:DataType="vm:WorkstationViewModel"
             x:Name="PageRoot"
             Focusable="True"
             KeyDown="OnCockpitKeyDown"
             Background="#141414">

    <UserControl.Styles>
        <Style Selector="ToggleButton.header-toggle">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="#C2CCD6"/>
            <Setter Property="BorderBrush" Value="#3A3A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="{StaticResource WsPadHeaderToggle}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="{StaticResource WsFontMd}"/>
        </Style>
        <Style Selector="ToggleButton.header-toggle:checked">
            <Setter Property="Foreground" Value="#00D7FF"/>
            <Setter Property="BorderBrush" Value="#00D7FF"/>
        </Style>
        <Style Selector="Border.ws-chip">
            <Setter Property="Background" Value="#18222C"/>
            <Setter Property="BorderBrush" Value="#2F3D4A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="999"/>
            <Setter Property="Padding" Value="{StaticResource WsPadChip}"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
        </Style>
        <Style Selector="Border.ws-lane">
            <Setter Property="Background" Value="#161C23"/>
            <Setter Property="BorderBrush" Value="#2D3945"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="{StaticResource WsPadLane}"/>
        </Style>
        <Style Selector="Button.secondary">
            <Setter Property="Background" Value="#1A2430"/>
            <Setter Property="BorderBrush" Value="#314557"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Foreground" Value="#DDE9F5"/>
            <Setter Property="Padding" Value="{StaticResource WsPadSecondary}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="{StaticResource WsFontMd}"/>
        </Style>
        <Style Selector="Button.icon">
            <Setter Property="Width" Value="{StaticResource WsIconButtonSize}"/>
            <Setter Property="Height" Value="{StaticResource WsIconButtonSize}"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="#1A2430"/>
            <Setter Property="BorderBrush" Value="#314557"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Foreground" Value="#DDE9F5"/>
            <Setter Property="FontSize" Value="{StaticResource WsIconButtonFontSize}"/>
        </Style>
        <Style Selector="Button.drawer-header-action">
            <Setter Property="Padding" Value="{StaticResource WsPadSecondary}"/>
            <Setter Property="FontSize" Value="{StaticResource WsFontMd}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        <Style Selector="Border.flow-status-busy">
            <Setter Property="Padding" Value="{StaticResource WsPadDrawerStatusBusy}"/>
        </Style>
        <Style Selector="Border.flow-status-idle">
            <Setter Property="Padding" Value="{StaticResource WsPadDrawerStatusIdle}"/>
        </Style>
        <Style Selector="Border.overlay-panel">
            <Setter Property="Margin" Value="44"/>
            <Setter Property="Padding" Value="{StaticResource WsPadOverlay}"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
        </Style>
        <Style Selector="Border.overlay-panel.size-compact">
            <Setter Property="Margin" Value="120,72,120,72"/>
        </Style>
        <Style Selector="Border.overlay-panel.size-comfort">
            <Setter Property="Margin" Value="72,48,72,48"/>
        </Style>
        <Style Selector="Border.overlay-panel.size-full">
            <Setter Property="Margin" Value="18"/>
        </Style>
        <Style Selector="TabControl.drawer-tabs TabItem.drawer-tab">
            <Setter Property="Foreground" Value="{StaticResource WsTextSecondaryReadable}"/>
        </Style>
        <Style Selector="TabControl.drawer-tabs TabItem.drawer-tab:selected">
            <Setter Property="Foreground" Value="{StaticResource WsTextPrimaryReadable}"/>
        </Style>
        <Style Selector="DataGrid.drawer-grid">
            <Setter Property="Foreground" Value="{StaticResource WsTextPrimaryReadable}"/>
            <Setter Property="BorderBrush" Value="#304252"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <!-- Stems, Phrase chips and Hot Cues styling for Workstation -->
        <Style Selector="ToggleButton.stem-toggle">
            <Setter Property="Background" Value="#202020"/>
            <Setter Property="BorderBrush" Value="#404040"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#DDDDDD"/>
            <Setter Property="Padding" Value="{StaticResource WsPadStemToggle}"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="{StaticResource WsFontXs}"/>
            <Setter Property="MinWidth" Value="60"/>
        </Style>
        <Style Selector="Button.phrase-chip">
            <Setter Property="Background" Value="#20242A"/>
            <Setter Property="BorderBrush" Value="#3E4958"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#D9E2F2"/>
            <Setter Property="Padding" Value="{StaticResource WsPadPhraseChip}"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="{StaticResource WsFontXs}"/>
            <Setter Property="MinWidth" Value="52"/>
        </Style>
        <Style Selector="ToggleButton.stem-v:checked">
            <Setter Property="Background" Value="#C2185B"/>
            <Setter Property="BorderBrush" Value="#E91E63"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="ToggleButton.stem-d:checked">
            <Setter Property="Background" Value="#1B5E20"/>
            <Setter Property="BorderBrush" Value="#4CAF50"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="ToggleButton.stem-b:checked">
            <Setter Property="Background" Value="#0D47A1"/>
            <Setter Property="BorderBrush" Value="#2196F3"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="ToggleButton.stem-o:checked">
            <Setter Property="Background" Value="#E65100"/>
            <Setter Property="BorderBrush" Value="#FF9800"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style Selector="Button.hotcue">
            <Setter Property="Width" Value="{StaticResource WsHotCueWidth}"/>
            <Setter Property="Height" Value="{StaticResource WsHotCueHeight}"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="{StaticResource WsHotCueFontSize}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Opacity" Value="0.65"/>
        </Style>
        <Style Selector="Button.hotcue:pointerover"><Setter Property="Opacity" Value="1.0"/></Style>
        <Style Selector="Button.hotcue-1"><Setter Property="Background" Value="#E91E63"/></Style>
        <Style Selector="Button.hotcue-2"><Setter Property="Background" Value="#FF9800"/></Style>
        <Style Selector="Button.hotcue-3"><Setter Property="Background" Value="#CDDC39"/><Setter Property="Foreground" Value="#111"/></Style>
        <Style Selector="Button.hotcue-4"><Setter Property="Background" Value="#4CAF50"/></Style>
        <Style Selector="Button.hotcue-5"><Setter Property="Background" Value="#00BCD4"/></Style>
        <Style Selector="Button.hotcue-6"><Setter Property="Background" Value="#2196F3"/></Style>
        <Style Selector="Button.hotcue-7"><Setter Property="Background" Value="#9C27B0"/></Style>
        <Style Selector="Button.hotcue-8"><Setter Property="Background" Value="#9E9E9E"/></Style>

        <Style Selector="UserControl.ws-density-compact Button.hotcue">
            <Setter Property="Width" Value="{StaticResource WsHotCueWidthCompact}"/>
            <Setter Property="Height" Value="{StaticResource WsHotCueHeightCompact}"/>
            <Setter Property="FontSize" Value="{StaticResource WsHotCueFontSizeCompact}"/>
        </Style>
        <Style Selector="UserControl.ws-density-compact ToggleButton.stem-toggle">
            <Setter Property="Padding" Value="{StaticResource WsPadStemToggleCompact}"/>
            <Setter Property="FontSize" Value="{StaticResource WsFontXs}"/>
            <Setter Property="MinWidth" Value="54"/>
        </Style>
        <Style Selector="UserControl.ws-density-compact Button.phrase-chip">
            <Setter Property="Padding" Value="{StaticResource WsPadPhraseChipCompact}"/>
            <Setter Property="FontSize" Value="{StaticResource WsFontXs}"/>
            <Setter Property="MinWidth" Value="50"/>
        </Style>
    </UserControl.Styles>

    <Grid x:Name="CockpitGrid" RowDefinitions="Auto,*,Auto,280">
        <Grid Grid.Row="0" RowDefinitions="Auto,Auto">
            <Border Grid.RowSpan="2"
                    Background="{DynamicResource RegionBrush}"
                    BorderBrush="#2F2F2F"
                    BorderThickness="0,0,0,1"/>

            <Grid Grid.Row="0" Margin="{StaticResource WsMarginHeaderMain}" ColumnDefinitions="*,Auto,Auto,Auto">
                <StackPanel Grid.Column="0" Spacing="6" VerticalAlignment="Center">
                    <TextBlock Text="WORKSTATION"
                               FontSize="15"
                               FontWeight="Bold"
                               Foreground="#F0F0F0"/>
                    <ItemsControl ItemsSource="{Binding ToolOptions}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="6"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:WorkstationToolOptionViewModel">
                                <ToggleButton Classes="header-toggle"
                                               IsChecked="{Binding IsSelected, Mode=OneWay}"
                                               IsEnabled="{Binding IsAvailable}"
                                               Command="{Binding #PageRoot.DataContext.SetModeCommand}"
                                               CommandParameter="{Binding Mode}"
                                               ToolTip.Tip="{Binding StatusText}">
                                    <TextBlock Text="{Binding ShortLabel}"/>
                                </ToggleButton>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <Button Classes="icon"
                            Command="{Binding UndoCommand}"
                            ToolTip.Tip="Undo [Ctrl+Z]">
                        <PathIcon Data="{StaticResource arrow_counterclockwise_regular}" Width="12" Height="12"/>
                    </Button>
                    <Button Classes="icon"
                            Command="{Binding RedoCommand}"
                            ToolTip.Tip="Redo [Ctrl+Y]">
                        <PathIcon Data="{StaticResource ws_redo_regular}" Width="12" Height="12"/>
                    </Button>
                </StackPanel>

                <StackPanel Grid.Column="2" Spacing="8" Margin="{StaticResource WsMarginHeaderCenter}" VerticalAlignment="Center" Orientation="Horizontal">
                    <!-- Transport Group -->
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <Button Classes="secondary" Command="{Binding PlayPauseAllCommand}" ToolTip.Tip="Play or pause timeline playback">
                            <PathIcon Data="{StaticResource play_regular}" Width="12" Height="12"/>
                        </Button>
                        <Button Classes="secondary" Command="{Binding StopAllCommand}" ToolTip.Tip="Stop playback and return to cue">
                            <PathIcon Data="{StaticResource dismiss_regular}" Width="12" Height="12"/>
                        </Button>
                    </StackPanel>

                    <Border Width="1" Background="#3A3A3A" Margin="6,2" VerticalAlignment="Stretch"/>

                    <!-- BPM Group -->
                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                        <TextBox Width="60" Height="28" Padding="4,0"
                                 Text="{Binding MasterBpm, Mode=TwoWay, StringFormat='{}{0:F1}'}"
                                 HorizontalContentAlignment="Center"
                                 VerticalContentAlignment="Center"
                                 FontSize="12"
                                 FontWeight="Bold"
                                 Foreground="#E5EEF8"
                                 Background="#1A2430"
                                 BorderBrush="#314557"
                                 BorderThickness="1"
                                 CornerRadius="6"
                                 ToolTip.Tip="Master BPM — edit directly or use Tap Tempo"/>
                        <Button Classes="secondary" Command="{Binding TapTempoCommand}" Height="28" ToolTip.Tip="Tap tempo (4+ clicks)">Tap</Button>
                    </StackPanel>

                    <Border Width="1" Background="#3A3A3A" Margin="6,2" VerticalAlignment="Stretch"/>

                    <!-- Grid Settings -->
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <ToggleButton Classes="header-toggle" Height="28" Padding="8,0" IsChecked="{Binding IsSnapEnabled, Mode=TwoWay}" ToolTip.Tip="Snap playhead to beat grid">SNAP</ToggleButton>
                        <ToggleButton Classes="header-toggle" Height="28" Padding="8,0" IsChecked="{Binding IsQuantizeEnabled, Mode=TwoWay}" ToolTip.Tip="Quantize triggers to beat boundaries">QTZ</ToggleButton>
                        <ToggleButton Classes="header-toggle" Height="28" Padding="8,0" IsChecked="{Binding IsMetronomeEnabled, Mode=TwoWay}" ToolTip.Tip="Metronome audio click">MET</ToggleButton>
                    </StackPanel>

                    <Border Width="1" Background="#3A3A3A" Margin="6,2" VerticalAlignment="Stretch"/>

                    <!-- Viewport Navigation (Zoom/Pan) -->
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <Button Classes="icon" Command="{Binding PanLeftCommand}" ToolTip.Tip="Pan timeline left">
                            <PathIcon Data="{StaticResource ws_pan_left_regular}" Width="12" Height="12"/>
                        </Button>
                        <Button Classes="icon" Command="{Binding PanRightCommand}" ToolTip.Tip="Pan timeline right">
                            <PathIcon Data="{StaticResource ws_pan_right_regular}" Width="12" Height="12"/>
                        </Button>
                        <Button Classes="icon" Command="{Binding ZoomInCommand}" ToolTip.Tip="Zoom in">
                            <PathIcon Data="{StaticResource ws_zoom_in_regular}" Width="12" Height="12"/>
                        </Button>
                        <Button Classes="icon" Command="{Binding ZoomOutCommand}" ToolTip.Tip="Zoom out">
                            <PathIcon Data="{StaticResource ws_zoom_out_regular}" Width="12" Height="12"/>
                        </Button>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="3" Margin="{StaticResource WsMarginHeaderRight}" Spacing="6" VerticalAlignment="Center">
                    <Button Classes="secondary"
                            Click="OnToggleDrawerClick"
                            ToolTip.Tip="Show or hide Flow Drawer to prioritize waveform space">Toggle Flow Drawer</Button>
                </StackPanel>
            </Grid>

            <Slider Grid.Row="1"
                    Margin="{StaticResource WsMarginTimelineSlider}"
                    Minimum="0"
                    Maximum="{Binding MaxTimelineOffsetSeconds}"
                    Value="{Binding TimelineOffsetSeconds, Mode=TwoWay}"
                    Height="{StaticResource WsTimelineHeight}"
                    VerticalAlignment="Top"
                    ToolTip.Tip="Timeline viewport position"/>
        </Grid>

        <Grid Grid.Row="1" ColumnDefinitions="*,276" RowDefinitions="Auto,Auto,*,Auto">
            <Border Grid.Row="0" Grid.Column="0" Background="#131C26" BorderBrush="#293949" BorderThickness="0,0,0,1" Padding="{StaticResource WsPadLane}">
                <Grid ColumnDefinitions="250,*,Auto">
                    <TextBlock Grid.Column="0"
                               Text="TRACK STRIP"
                               FontSize="{StaticResource WsFontSm}"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource WsTextSecondaryReadable}"
                               VerticalAlignment="Center"/>
                    <Canvas Grid.Column="1" ClipToBounds="True">
                        <TextBlock Text="{Binding TimelineTick0}" Canvas.Left="0" FontSize="{StaticResource WsFontSm}" Foreground="{StaticResource WsTextMutedReadable}"/>
                        <TextBlock Text="{Binding TimelineTick1}" Canvas.Left="140" FontSize="{StaticResource WsFontSm}" Foreground="{StaticResource WsTextMutedReadable}"/>
                        <TextBlock Text="{Binding TimelineTick2}" Canvas.Left="280" FontSize="{StaticResource WsFontSm}" Foreground="{StaticResource WsTextMutedReadable}"/>
                        <TextBlock Text="{Binding TimelineTick3}" Canvas.Left="420" FontSize="{StaticResource WsFontSm}" Foreground="{StaticResource WsTextMutedReadable}"/>
                        <TextBlock Text="{Binding TimelineTick4}" Canvas.Left="560" FontSize="{StaticResource WsFontSm}" Foreground="{StaticResource WsTextMutedReadable}"/>
                        <TextBlock Text="{Binding TimelineTick5}" Canvas.Left="700" FontSize="{StaticResource WsFontSm}" Foreground="{StaticResource WsTextMutedReadable}"/>
                        <Border IsVisible="{Binding IsSnapGuideVisible}"
                                Canvas.Left="{Binding SnapGuideCanvasLeft}"
                                Canvas.Top="0"
                                Width="{StaticResource WsSnapGuideMarkerWidth}"
                                Height="{StaticResource WsSnapGuideMarkerHeight}"
                                Background="#00D7FF"
                                CornerRadius="1"/>
                        <Border IsVisible="{Binding IsSnapGuideVisible}"
                                Canvas.Left="{Binding SnapGuideCanvasLeft}"
                                Canvas.Top="{StaticResource WsSnapGuideMarkerHeight}"
                                Background="{DynamicResource BrushBg2}"
                                BorderBrush="{DynamicResource BrushAccent}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="{StaticResource WsPadSnapGuide}">
                            <TextBlock Text="{Binding SnapGuideLabel}" FontSize="{StaticResource WsFontXxs}" Foreground="#9EEFFF"/>
                        </Border>
                    </Canvas>
                </Grid>
            </Border>

            <Border Grid.Row="1" Grid.Column="0" Background="#131C26" BorderBrush="#293949" BorderThickness="0,0,0,1" Padding="{StaticResource WsPadLane}">
                <Grid>
                    <Border Classes="ws-lane" IsVisible="{Binding IsWaveformMode}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Waveform Lane" FontSize="{StaticResource WsFontSm}" FontWeight="SemiBold" Foreground="#8EC8FF"/>
                            <TextBlock Text="{Binding FlowWindowSummary}" FontSize="{StaticResource WsFontSm}" Foreground="{StaticResource WsTextMutedReadable}"/>
                        </StackPanel>
                    </Border>
                    <Border Classes="ws-lane" IsVisible="{Binding IsFlowMode}">
                        <StackPanel Spacing="6">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Flow Lane" FontSize="{StaticResource WsFontSm}" FontWeight="SemiBold" Foreground="#B8E986"/>
                                <TextBlock Text="{Binding ActivePlaylistFlowSummary}" FontSize="{StaticResource WsFontSm}" Foreground="{StaticResource WsTextSecondaryReadable}" TextTrimming="CharacterEllipsis" MaxWidth="760"/>
                            </StackPanel>
                            <WrapPanel Orientation="Horizontal" ItemHeight="28">
                                <Border Classes="ws-chip">
                                    <TextBlock Text="{Binding FlowLaneReadinessSummary}" FontSize="{StaticResource WsFontXs}" Foreground="{StaticResource WsTextPrimaryReadable}"/>
                                </Border>
                                <Button Classes="secondary lane-action" Click="OnFocusPlaylistCtaClick" IsVisible="{Binding ShouldShowSelectPlaylistCta}" ToolTip.Tip="{Binding SelectPlaylistCtaHint}">Select Playlist</Button>
                                <Button Classes="secondary lane-action" Click="OnDownloadTracksCtaClick" IsVisible="{Binding ShouldShowAcquireCtas}" ToolTip.Tip="{Binding DownloadTracksCtaHint}">Download Tracks</Button>
                                <Button Classes="secondary lane-action" Command="{Binding AnalyzePlaylistCuesCommand}" IsEnabled="{Binding CanAnalyzePlaylistFromLane}" IsVisible="{Binding ShouldShowReadyTrackCtas}" ToolTip.Tip="{Binding FlowLaneAnalyzeHint}">Analyze Playlist</Button>
                                <Button Classes="secondary lane-action" Click="OnOpenTrackListOverlayClick" IsEnabled="{Binding CanOpenTrackOverlayFromLane}" ToolTip.Tip="{Binding FlowLaneOverlayHint}">Track Overlay</Button>
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                    <Border Classes="ws-lane" IsVisible="{Binding IsStemsMode}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Stems Lane" FontSize="{StaticResource WsFontSm}" FontWeight="SemiBold" Foreground="#B8E986"/>
                            <TextBlock Text="{Binding FocusedDeck.StemControlSummary, TargetNullValue='Focus a loaded deck to shape stem lanes.'}" FontSize="{StaticResource WsFontSm}" Foreground="{StaticResource WsTextSecondaryReadable}" TextTrimming="CharacterEllipsis" MaxWidth="760"/>
                            <Button Classes="secondary lane-action" Command="{Binding FocusedDeck.ToggleInstrumentalCommand}" IsEnabled="{Binding CanUseFocusedDeckLaneActions}" ToolTip.Tip="{Binding StemsLaneActionHint}">Instrumental</Button>
                            <Button Classes="secondary lane-action" Command="{Binding FocusedDeck.ToggleDrumsOnlyCommand}" IsEnabled="{Binding CanUseFocusedDeckLaneActions}" ToolTip.Tip="{Binding StemsLaneActionHint}">Drums Only</Button>
                        </StackPanel>
                    </Border>
                    <Border Classes="ws-lane" IsVisible="{Binding IsExportMode}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Export Lane" FontSize="{StaticResource WsFontSm}" FontWeight="SemiBold" Foreground="#B8E0FF"/>
                            <TextBlock Text="{Binding ExportPanel.StatusMessage, TargetNullValue='Export preview lane ready. Open inspector for output configuration.'}" FontSize="{StaticResource WsFontSm}" Foreground="{StaticResource WsTextSecondaryReadable}" TextTrimming="CharacterEllipsis" MaxWidth="760"/>
                            <Button Classes="secondary lane-action" Command="{Binding ExportMixCommand}" IsEnabled="{Binding CanUseExportLaneActions}" ToolTip.Tip="{Binding ExportLaneActionHint}">Export…</Button>
                        </StackPanel>
                    </Border>
                    <Border Classes="ws-lane" IsVisible="{Binding IsAutomationMode}">
                        <StackPanel Spacing="6">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Automation Lane" FontSize="{StaticResource WsFontSm}" FontWeight="SemiBold" Foreground="#FFD58A"/>
                                <TextBlock Text="{Binding AutomationModeSummary}" FontSize="{StaticResource WsFontSm}" Foreground="{StaticResource WsTextSecondaryReadable}" TextTrimming="CharacterEllipsis" MaxWidth="760"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Border Classes="ws-lane" IsVisible="{Binding IsSamplesMode}">
                        <StackPanel Spacing="6">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Samples Lane" FontSize="{StaticResource WsFontSm}" FontWeight="SemiBold" Foreground="#FFCAA8"/>
                                <TextBlock Text="{Binding SamplesModeSummary}" FontSize="{StaticResource WsFontSm}" Foreground="{StaticResource WsTextSecondaryReadable}" TextTrimming="CharacterEllipsis" MaxWidth="760"/>
                            </StackPanel>
                            <WrapPanel Orientation="Horizontal" ItemHeight="28">
                                <Button Classes="secondary lane-action" Click="OnImportLocalFilesCtaClick" ToolTip.Tip="{Binding ImportLocalFilesCtaHint}">Import Local Files</Button>
                                <Button Classes="secondary lane-action" Margin="6,0,0,0" Click="OnFocusPlaylistCtaClick" ToolTip.Tip="{Binding SelectPlaylistCtaHint}">Select Playlist</Button>
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Row="2" Grid.Column="0">
                <Border Margin="12"
                        Background="#0E151D"
                        BorderBrush="#243545"
                        BorderThickness="1"
                        CornerRadius="8"
                        Opacity="0.72"
                        IsHitTestVisible="False">
                    <Grid Margin="14" RowDefinitions="*,*,*">
                        <Border Grid.Row="0" Margin="0,0,0,10" Background="#16212C" BorderBrush="#314355" BorderThickness="1" CornerRadius="6">
                            <Grid ColumnDefinitions="160,*">
                                <Border Grid.Column="0" Background="#0F1720" CornerRadius="6,0,0,6"/>
                                <Canvas Grid.Column="1" Margin="16,12">
                                    <Border Width="140" Height="10" CornerRadius="4" Background="#29455E"/>
                                    <Border Canvas.Left="168" Width="118" Height="10" CornerRadius="4" Background="#29455E"/>
                                    <Border Canvas.Left="312" Width="152" Height="10" CornerRadius="4" Background="#29455E"/>
                                </Canvas>
                            </Grid>
                        </Border>
                        <Border Grid.Row="1" Margin="0,0,0,10" Background="#141D26" BorderBrush="#2A3948" BorderThickness="1" CornerRadius="6">
                            <Canvas Margin="176,12,16,12">
                                <Border Width="92" Height="8" CornerRadius="4" Background="#234057"/>
                                <Border Canvas.Left="116" Width="128" Height="8" CornerRadius="4" Background="#234057"/>
                                <Border Canvas.Left="274" Width="86" Height="8" CornerRadius="4" Background="#234057"/>
                            </Canvas>
                        </Border>
                        <Border Grid.Row="2" Background="#141D26" BorderBrush="#2A3948" BorderThickness="1" CornerRadius="6">
                            <Canvas Margin="176,12,16,12">
                                <Border Width="126" Height="8" CornerRadius="4" Background="#3A6A7A"/>
                                <Border Canvas.Left="154" Width="104" Height="8" CornerRadius="4" Background="#3A6A7A"/>
                                <Border Canvas.Left="286" Width="144" Height="8" CornerRadius="4" Background="#3A6A7A"/>
                            </Canvas>
                        </Border>
                    </Grid>
                </Border>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Decks}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:WorkstationDeckViewModel">
                                <wsViews:WorkstationDeckRow/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Canvas IsVisible="{Binding IsFlowOverlayVisible}"
                        Margin="186,18,20,18"
                        ClipToBounds="True"
                        ZIndex="20">
                    <ItemsControl ItemsSource="{Binding FlowTransitions}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Width="{Binding CanvasWidth}"
                                        Canvas.Left="{Binding CanvasLeft}"
                                        Canvas.Top="14"
                                        Height="30"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="0"
                                        Command="{Binding #PageRoot.DataContext.SelectFlowTransitionCommand}"
                                        CommandParameter="{Binding}">
                                    <Grid>
                                        <Border Background="#552F7A5B"
                                                BorderBrush="#88B8E986"
                                                BorderThickness="1"
                                                CornerRadius="5"
                                                Padding="6,3">
                                            <StackPanel Spacing="1">
                                                <TextBlock Text="{Binding TransitionLabel}" FontSize="10" Foreground="#DDF7E4" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding CompatibilityLabel}" FontSize="9" Foreground="#BFE8D3" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Width="8"
                                                HorizontalAlignment="Right"
                                                CornerRadius="0,5,5,0"
                                                Background="#77FFD58A"
                                                Cursor="SizeWestEast"
                                                PointerPressed="OnFlowTransitionHandlePointerPressed"
                                                PointerMoved="OnFlowTransitionHandlePointerMoved"
                                                PointerReleased="OnFlowTransitionHandlePointerReleased"/>
                                        <Border IsVisible="{Binding IsSelected}"
                                                BorderBrush="#E6FFD58A"
                                                BorderThickness="2"
                                                CornerRadius="5"/>
                                        <Border IsVisible="{Binding IsPresetApplied}"
                                                Height="3"
                                                VerticalAlignment="Bottom"
                                                Background="#AA8EC8FF"
                                                CornerRadius="0,0,5,5"/>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <ItemsControl ItemsSource="{Binding FlowTransitions}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Canvas.Left="{Binding PhraseGuideCanvasLeft}"
                                        Canvas.Top="8"
                                        Width="4"
                                        Height="52"
                                        Background="#80A5E6FF"
                                        CornerRadius="1"
                                        Opacity="{Binding PhraseMarkerOpacity}"
                                        Cursor="SizeWestEast"
                                        ToolTip.Tip="{Binding PhraseMarkerTooltip}"
                                        PointerPressed="OnFlowPhraseMarkerPointerPressed"
                                        PointerMoved="OnFlowPhraseMarkerPointerMoved"
                                        PointerReleased="OnFlowPhraseMarkerPointerReleased"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <ItemsControl ItemsSource="{Binding FlowTransitions}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <ItemsControl ItemsSource="{Binding PhraseRegions}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <Canvas/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Canvas.Left="{Binding CanvasLeft}"
                                                    Canvas.Top="4"
                                                    Width="{Binding CanvasWidth}"
                                                    Height="28"
                                                    Background="#2258C7FF"
                                                    BorderBrush="#6BB4E6FF"
                                                    BorderThickness="1"
                                                    CornerRadius="4"
                                                    Opacity="{Binding Confidence}"
                                                    Tag="{Binding}"
                                                    ToolTip.Tip="{Binding Tooltip}"
                                                    PointerPressed="OnPhraseRegionCreatePointerPressed">
                                                <Grid ColumnDefinitions="6,*,6">
                                                    <Border Grid.Column="0"
                                                            Width="6"
                                                            Background="#A5E6FF"
                                                            CornerRadius="2"
                                                            Tag="{Binding}"
                                                            PointerPressed="OnPhraseRegionStartHandlePointerPressed"
                                                            PointerMoved="OnPhraseRegionStartHandlePointerMoved"
                                                            PointerReleased="OnPhraseRegionStartHandlePointerReleased"/>
                                                    <Border Grid.Column="2"
                                                            Width="6"
                                                            Background="#A5E6FF"
                                                            CornerRadius="2"
                                                            Tag="{Binding}"
                                                            PointerPressed="OnPhraseRegionEndHandlePointerPressed"
                                                            PointerMoved="OnPhraseRegionEndHandlePointerMoved"
                                                            PointerReleased="OnPhraseRegionEndHandlePointerReleased"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <ItemsControl ItemsSource="{Binding FlowTransitions}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Canvas.Left="{Binding BeatGuideCanvasLeft}" Canvas.Top="8" Width="2" Height="52" Background="#80FFD58A" CornerRadius="1"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Playlist harmonic roadmap: one scored marker per consecutive track pair -->
                    <ItemsControl ItemsSource="{Binding FlowPlaylistTransitions}"
                                  IsVisible="{Binding IsFlowPlaylistOverlayVisible}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Canvas.Left="{Binding CanvasLeft}"
                                        Canvas.Top="56"
                                        Width="{Binding CanvasWidth}"
                                        Height="6"
                                        Background="{Binding CompatibilityColor}"
                                        CornerRadius="2"
                                        ToolTip.Tip="{Binding TransitionLabel}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Canvas>

                <Border IsVisible="{Binding IsFlowMode}"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,20,20,0"
                    MaxWidth="300"
                    Background="#8F14202B"
                        BorderBrush="#36506A"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="10,6"
                        ZIndex="22">
                    <StackPanel Spacing="4">
                        <TextBlock Text="{Binding FlowOverlayHint}"
                                   FontSize="10"
                                   Foreground="{StaticResource WsTextSecondaryReadable}"
                                   TextWrapping="Wrap"/>
                        <Button Classes="secondary"
                                Command="{Binding ClearFlowTransitionSelectionCommand}"
                                IsVisible="{Binding HasSelectedFlowTransition}"
                                HorizontalAlignment="Left">Clear Selection</Button>
                    </StackPanel>
                </Border>

                <Border IsVisible="{Binding !HasLoadedDecks}"
                        Margin="20"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        MaxWidth="560"
                        Background="#CC101821"
                        BorderBrush="#36506A"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="14,12">
                    <StackPanel Spacing="8">
                        <TextBlock Text="EMPTY TIMELINE"
                                   FontSize="{StaticResource WsFontSm}"
                                   FontWeight="SemiBold"
                                   Foreground="#8EC8FF"/>
                        <TextBlock Text="{Binding TimelineEmptyCanvasSummary}"
                                   FontSize="{StaticResource WsFontSm}"
                                   Foreground="{StaticResource WsTextPrimaryReadable}"
                                   TextWrapping="Wrap"/>
                        <TextBlock Text="Waveforms, transition overlays, stems lanes, and automation lanes will appear here once the first track is loaded."
                                   FontSize="{StaticResource WsFontXs}"
                                   Foreground="{StaticResource WsTextHintReadable}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>

            <wsViews:MixerCenter Grid.Row="3" Grid.Column="0"/>

            <Border Grid.Row="0"
                    Grid.RowSpan="3"
                    Grid.Column="1"
                    Classes="ws-inspector"
                    Margin="12,8,8,8"
                    Background="#D0111821"
                    BorderBrush="#314355"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="{StaticResource WsPadInspector}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="8">
                        <TextBlock Text="INSPECTOR" FontSize="{StaticResource WsFontSm}" FontWeight="SemiBold" Foreground="{StaticResource WsTextSecondaryReadable}"/>
                        <TextBlock Text="{Binding ActiveToolOption.DisplayName, StringFormat='Tool • {0}', TargetNullValue='Tool • Workstation'}" FontSize="{StaticResource WsFontLg}" FontWeight="SemiBold" Foreground="#E5EEF8"/>
                        <TextBlock Text="{Binding ActiveToolSummary}" FontSize="{StaticResource WsFontSm}" Foreground="{StaticResource WsTextSecondaryReadable}" TextWrapping="Wrap"/>

                        <StackPanel Spacing="10" IsVisible="{Binding IsWaveformMode}">
                            <!-- 1. Track Info Header -->
                            <StackPanel Spacing="3">
                                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                    <Border Background="#2D2D2D" CornerRadius="4" Padding="6,2" IsVisible="{Binding FocusedDeck, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                        <TextBlock Text="{Binding FocusedDeck.DeckLabel}" FontSize="11" FontWeight="Bold" Foreground="#F5F5F5"/>
                                    </Border>
                                    <TextBlock Text="FOCUSED TRACK" FontSize="{StaticResource WsFontSm}" FontWeight="SemiBold" Foreground="#8EC8FF"/>
                                </StackPanel>
                                <TextBlock Text="{Binding FocusedDeck.TrackTitle, TargetNullValue='No Track Loaded'}" FontSize="14" FontWeight="Bold" Foreground="#E5E5E5" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding FocusedDeck.TrackArtist, TargetNullValue='—'}" FontSize="11" Foreground="#A0A0A0" TextWrapping="Wrap"/>
                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,2,0,0">
                                    <Border Classes="ws-chip" Background="#18222C" BorderBrush="#2F3D4A" BorderThickness="1" CornerRadius="4" Padding="6,2">
                                        <TextBlock Text="{Binding FocusedDeck.DisplayBpm, StringFormat='{}{0:F1} BPM', TargetNullValue='— BPM'}" FontSize="10" Foreground="#7FC7FF"/>
                                    </Border>
                                    <Border Classes="ws-chip" Background="#18222C" BorderBrush="#2F3D4A" BorderThickness="1" CornerRadius="4" Padding="6,2">
                                        <!-- Using Camelot key notation format -->
                                        <TextBlock Text="{Binding FocusedDeck.TrackKey, TargetNullValue='— Key'}" FontSize="10" Foreground="#95D36A"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>

                            <Separator Background="#252526" Height="1"/>

                            <!-- 2. CDJ Transport and Looping -->
                            <StackPanel Spacing="6" IsEnabled="{Binding FocusedDeck.IsLoaded}">
                                <TextBlock Text="PLAYBACK &amp; LOOPING" FontSize="9" FontWeight="Black" Foreground="#666"/>
                                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto">
                                    <Button Grid.Row="0" Grid.Column="0" Classes="phrase-chip" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                            Command="{Binding FocusedDeck.Deck.PlayPauseCommand}" ToolTip.Tip="Play / Pause this deck">PLAY / PAUSE</Button>
                                    <Button Grid.Row="0" Grid.Column="1" Classes="phrase-chip" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                            Command="{Binding FocusedDeck.Deck.CueCommand}" ToolTip.Tip="Return to cue point">CUE</Button>
                                    <Button Grid.Row="1" Grid.Column="0" Classes="phrase-chip" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                            Command="{Binding FocusedDeck.Deck.SetLoopCommand}" ToolTip.Tip="Arm loop at playhead">ARM LOOP</Button>
                                    <Button Grid.Row="1" Grid.Column="1" Classes="phrase-chip" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                            Command="{Binding FocusedDeck.Deck.ExitLoopCommand}" ToolTip.Tip="Exit active loop">EXIT LOOP</Button>
                                </Grid>
                                
                                <Grid ColumnDefinitions="*,*,*,*" Margin="0,4,0,0">
                                    <Button Grid.Column="0" Classes="icon" Command="{Binding Loop1Command}" ToolTip.Tip="1-beat loop">1</Button>
                                    <Button Grid.Column="1" Classes="icon" Margin="4,0,0,0" Command="{Binding Loop2Command}" ToolTip.Tip="2-beat loop">2</Button>
                                    <Button Grid.Column="2" Classes="icon" Margin="4,0,0,0" Command="{Binding Loop4Command}" ToolTip.Tip="4-beat loop">4</Button>
                                    <Button Grid.Column="3" Classes="icon" Margin="4,0,0,0" Command="{Binding Loop8Command}" ToolTip.Tip="8-beat loop">8</Button>
                                </Grid>

                                <Grid ColumnDefinitions="*,*,*" Margin="0,4,0,0">
                                    <Button Classes="phrase-chip" Command="{Binding FocusedDeck.Deck.HalfLoopCommand}" ToolTip.Tip="Halve loop size">1/2</Button>
                                    <Button Grid.Column="1" Classes="phrase-chip" Command="{Binding FocusedDeck.Deck.DoubleLoopCommand}" ToolTip.Tip="Double loop size">2×</Button>
                                    <Button Grid.Column="2" Classes="phrase-chip" Command="{Binding ExitLoopFocusedCommand}" ToolTip.Tip="Exit focused loop">EXIT</Button>
                                </Grid>

                                <Grid ColumnDefinitions="*,*" Margin="0,4,0,0">
                                    <Button Classes="phrase-chip" Command="{Binding FocusedDeck.Deck.MoveLoopCommand}" CommandParameter="-1" ToolTip.Tip="Move loop earlier">◀ MOVE</Button>
                                    <Button Grid.Column="1" Classes="phrase-chip" Command="{Binding FocusedDeck.Deck.MoveLoopCommand}" CommandParameter="1" ToolTip.Tip="Move loop later">MOVE ▶</Button>
                                </Grid>
                            </StackPanel>

                            <Separator Background="#252526" Height="1"/>

                            <!-- 3. CDJ Hot Cues (2x4 Grid) -->
                            <StackPanel Spacing="6" IsEnabled="{Binding FocusedDeck.IsLoaded}">
                                <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                    <TextBlock Grid.Column="0" Text="HOT CUES" FontSize="9" FontWeight="Black" Foreground="#666" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                                        <Button Classes="phrase-chip" Height="22" Padding="6,0" Command="{Binding FocusedDeck.AddCueAtPlayheadCommand}" ToolTip.Tip="Drop cue marker at playhead">MARK</Button>
                                        <Button Classes="phrase-chip" Height="22" Padding="6,0" Command="{Binding FocusedDeck.ResetCuePrepCommand}" ToolTip.Tip="Restore analyzed cues">AUTO</Button>
                                    </StackPanel>
                                </Grid>
                                
                                <UniformGrid Rows="2" Columns="4" Margin="0,4,0,0">
                                    <Button Classes="hotcue hotcue-1" Command="{Binding FocusedDeck.HotCue1Command}" Content="{Binding FocusedDeck.HotCue1Text}" ToolTip.Tip="{Binding FocusedDeck.HotCue1Tooltip}"/>
                                    <Button Classes="hotcue hotcue-2" Command="{Binding FocusedDeck.HotCue2Command}" Content="{Binding FocusedDeck.HotCue2Text}" ToolTip.Tip="{Binding FocusedDeck.HotCue2Tooltip}"/>
                                    <Button Classes="hotcue hotcue-3" Command="{Binding FocusedDeck.HotCue3Command}" Content="{Binding FocusedDeck.HotCue3Text}" ToolTip.Tip="{Binding FocusedDeck.HotCue3Tooltip}"/>
                                    <Button Classes="hotcue hotcue-4" Command="{Binding FocusedDeck.HotCue4Command}" Content="{Binding FocusedDeck.HotCue4Text}" ToolTip.Tip="{Binding FocusedDeck.HotCue4Tooltip}"/>
                                    <Button Classes="hotcue hotcue-5" Command="{Binding FocusedDeck.HotCue5Command}" Content="{Binding FocusedDeck.HotCue5Text}" ToolTip.Tip="{Binding FocusedDeck.HotCue5Tooltip}"/>
                                    <Button Classes="hotcue hotcue-6" Command="{Binding FocusedDeck.HotCue6Command}" Content="{Binding FocusedDeck.HotCue6Text}" ToolTip.Tip="{Binding FocusedDeck.HotCue6Tooltip}"/>
                                    <Button Classes="hotcue hotcue-7" Command="{Binding FocusedDeck.HotCue7Command}" Content="{Binding FocusedDeck.HotCue7Text}" ToolTip.Tip="{Binding FocusedDeck.HotCue7Tooltip}"/>
                                    <Button Classes="hotcue hotcue-8" Command="{Binding FocusedDeck.HotCue8Command}" Content="{Binding FocusedDeck.HotCue8Text}" ToolTip.Tip="{Binding FocusedDeck.HotCue8Tooltip}"/>
                                </UniformGrid>
                                <TextBlock Text="{Binding FocusedDeck.HotCueSummary, TargetNullValue='No cues prepped'}" FontSize="10" Foreground="#7CB8FF" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>

                            <Separator Background="#252526" Height="1"/>

                            <!-- 4. Stems Mixer Rack -->
                            <StackPanel Spacing="6" IsEnabled="{Binding FocusedDeck.IsLoaded}">
                                <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                    <TextBlock Grid.Column="0" Text="STEM MIXER" FontSize="9" FontWeight="Black" Foreground="#666" VerticalAlignment="Center"/>
                                    <Button Grid.Column="1" Classes="phrase-chip" Height="22" Padding="6,0" Command="{Binding FocusedDeck.SeparateStemsCommand}" ToolTip.Tip="Run stem separation">SEPARATE</Button>
                                </Grid>
                                
                                <Grid ColumnDefinitions="*,*,*,*" Margin="0,2,0,0">
                                    <ToggleButton Classes="stem-toggle stem-v" Height="24" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                                  IsChecked="{Binding FocusedDeck.Stems.Vocals.IsMuted, Mode=TwoWay}" ToolTip.Tip="Mute Vocals">VOCAL</ToggleButton>
                                    <ToggleButton Classes="stem-toggle stem-d" Height="24" Margin="4,0,0,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                                  IsChecked="{Binding FocusedDeck.Stems.Drums.IsMuted, Mode=TwoWay}" ToolTip.Tip="Mute Drums">DRUM</ToggleButton>
                                    <ToggleButton Classes="stem-toggle stem-b" Height="24" Margin="4,0,0,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                                  IsChecked="{Binding FocusedDeck.Stems.Bass.IsMuted, Mode=TwoWay}" ToolTip.Tip="Mute Bass">BASS</ToggleButton>
                                    <ToggleButton Classes="stem-toggle stem-o" Height="24" Margin="4,0,0,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                                  IsChecked="{Binding FocusedDeck.Stems.Other.IsMuted, Mode=TwoWay}" ToolTip.Tip="Mute Melody/Other">OTHER</ToggleButton>
                                </Grid>

                                <Grid ColumnDefinitions="*,*,*" Margin="0,4,0,0">
                                    <Button Classes="phrase-chip" Command="{Binding FocusedDeck.ToggleInstrumentalCommand}" ToolTip.Tip="Instrumental Preset">INST</Button>
                                    <Button Grid.Column="1" Classes="phrase-chip" Command="{Binding FocusedDeck.ToggleDrumsOnlyCommand}" ToolTip.Tip="Drums Only Preset">DRUMS</Button>
                                    <Button Grid.Column="2" Classes="phrase-chip" Command="{Binding FocusedDeck.ToggleVocalOffCommand}" ToolTip.Tip="Vocal Off Preset">VOCAL OFF</Button>
                                </Grid>
                                <TextBlock Text="{Binding FocusedDeck.StemControlSummary}" FontSize="9" Foreground="#B8E986" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>

                            <Separator Background="#252526" Height="1"/>

                            <!-- 5. Phrasing Sections -->
                            <StackPanel Spacing="6" IsEnabled="{Binding FocusedDeck.IsLoaded}">
                                <TextBlock Text="TRACK SECTIONS" FontSize="9" FontWeight="Black" Foreground="#666"/>
                                <Grid ColumnDefinitions="*,*,*,*,*" Margin="0,2,0,0">
                                    <Button Classes="phrase-chip" Command="{Binding FocusedDeck.ViewWaveformCommand}" ToolTip.Tip="Zoom to full/detail">VIEW</Button>
                                    <Button Grid.Column="1" Classes="phrase-chip" Command="{Binding FocusedDeck.JumpToIntroCommand}" ToolTip.Tip="Jump to Intro">INTRO</Button>
                                    <Button Grid.Column="2" Classes="phrase-chip" Command="{Binding FocusedDeck.JumpToBuildCommand}" ToolTip.Tip="Jump to Build">BUILD</Button>
                                    <Button Grid.Column="3" Classes="phrase-chip" Command="{Binding FocusedDeck.JumpToDropCommand}" ToolTip.Tip="Jump to Drop">DROP</Button>
                                    <Button Grid.Column="4" Classes="phrase-chip" Command="{Binding FocusedDeck.JumpToOutroCommand}" ToolTip.Tip="Jump to Outro">OUTRO</Button>
                                </Grid>
                                <TextBlock Text="{Binding FocusedDeck.SectionJumpSummary}" FontSize="9" Foreground="#8EC8FF" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>

                            <Separator Background="#252526" Height="1"/>

                            <!-- 6. Gain, Pitch, Key and Lock -->
                            <StackPanel Spacing="8" IsEnabled="{Binding FocusedDeck.IsLoaded}">
                                <TextBlock Text="VOLUME &amp; TEMPO FORENSICS" FontSize="9" FontWeight="Black" Foreground="#666"/>
                                
                                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                                    <!-- Gain -->
                                    <StackPanel Grid.Row="0" Grid.Column="0" Spacing="2">
                                        <TextBlock Text="GAIN" FontSize="9" FontWeight="SemiBold" Foreground="#A0A0A0"/>
                                        <Slider Minimum="-12" Maximum="12" Value="{Binding FocusedDeck.TrackGainDb, Mode=TwoWay}" Height="20"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock Text="VU" FontSize="9" Foreground="#A0A0A0" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                                        <ProgressBar Minimum="0" Maximum="1" Value="{Binding FocusedDeck.VuLevel}" Orientation="Horizontal" Width="40" Height="8" Foreground="#4CAF50" Background="#2A2A2A"/>
                                    </StackPanel>

                                    <!-- Pitch/Tempo fader -->
                                    <StackPanel Grid.Row="1" Grid.Column="0" Spacing="2">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock Grid.Column="0" Text="PITCH / TEMPO" FontSize="9" FontWeight="SemiBold" Foreground="#A0A0A0"/>
                                            <TextBlock Grid.Column="1" Text="{Binding FocusedDeck.Deck.TempoPercent, StringFormat='{}{0:+0.0;-0.0;+0.0}%'}" FontSize="9" Foreground="#FFD700" FontWeight="Bold"/>
                                        </Grid>
                                        <Slider Minimum="-8" Maximum="8" Value="{Binding FocusedDeck.Deck.TempoPercent, Mode=TwoWay}" Height="20"/>
                                    </StackPanel>
                                    <ToggleButton Grid.Row="1" Grid.Column="1" VerticalAlignment="Bottom" IsChecked="{Binding FocusedDeck.Deck.KeyLock, Mode=TwoWay}"
                                                  FontSize="8" Width="40" Height="20" Padding="2,1" CornerRadius="4"
                                                  Background="#252525" BorderBrush="#444" ToolTip.Tip="Key Lock (hold original key when speeding up/down)">LOCK</ToggleButton>
                                </Grid>

                                <!-- Key shift adjusters -->
                                <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,0">
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <TextBlock Text="KEY SHIFT:" FontSize="9" Foreground="#6E8297" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding FocusedDeck.CurrentKeyShiftText}" FontSize="10" FontWeight="Bold" Foreground="#D8B4FE" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                                        <Button Width="20" Height="18" Padding="0" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontSize="10" Command="{Binding FocusedDeck.DecreaseKeyShiftCommand}" ToolTip.Tip="Shift key down">-</Button>
                                        <Button Width="20" Height="18" Padding="0" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontSize="10" Command="{Binding FocusedDeck.ResetKeyShiftCommand}" ToolTip.Tip="Reset key shift">0</Button>
                                        <Button Width="20" Height="18" Padding="0" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontSize="10" Command="{Binding FocusedDeck.IncreaseKeyShiftCommand}" ToolTip.Tip="Shift key up">+</Button>
                                    </StackPanel>
                                </Grid>

                                <!-- Sync Tempo and Lock Position -->
                                <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,0">
                                    <Button Grid.Column="0" Classes="secondary" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Command="{Binding SyncBpmCommand}" ToolTip.Tip="Align tempo across active timeline tracks">Sync Tempo</Button>
                                    <ToggleButton Grid.Column="1" IsChecked="{Binding FocusedDeck.IsLocked, Mode=TwoWay}" ToolTip.Tip="Lock track timeline movement">🔒</ToggleButton>
                                </Grid>
                            </StackPanel>

                            <Separator Background="#252526" Height="1"/>

                            <!-- Coach and transition assistance guidance -->
                            <StackPanel Spacing="4">
                                <TextBlock Text="MIX INTELLIGENCE &amp; COACHING" FontSize="9" FontWeight="Black" Foreground="#666"/>
                                <TextBlock Text="{Binding FocusedDeck.MixReadinessText, TargetNullValue='No Mix readiness'}" FontSize="10" Foreground="#8EC8FF" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding FocusedDeck.PerformanceStatusSummary, TargetNullValue='Performance status unavailable'}" FontSize="10" Foreground="#FFD58A" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding FocusedDeck.HarmonicSuggestionText, TargetNullValue='Harmonic guidance unavailable'}" FontSize="10" Foreground="#D8B4FE" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding FocusedDeck.TransitionStatusText, TargetNullValue='Transition guidance unavailable'}" FontSize="10" Foreground="#B8E986" TextWrapping="Wrap"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Spacing="6" IsVisible="{Binding IsFlowMode}">
                            <!-- Row 1: title -->
                            <TextBlock Text="{Binding FlowInspectorTransitionLabel}" FontSize="{StaticResource WsFontMd}" FontWeight="SemiBold" Foreground="#E5EEF8" TextWrapping="Wrap"/>
                            <!-- Row 2: score + preset chips -->
                            <WrapPanel Orientation="Horizontal" ItemHeight="22">
                                <Border Classes="ws-chip"><TextBlock Text="{Binding FlowInspectorCombinedScoreLabel}" FontSize="{StaticResource WsFontSm}" Foreground="#B8E986" TextWrapping="Wrap"/></Border>
                                <Border Classes="ws-chip"><TextBlock Text="{Binding FlowInspectorPresetLabel}" FontSize="{StaticResource WsFontSm}" Foreground="#8EC8FF" TextWrapping="Wrap"/></Border>
                            </WrapPanel>
                            <!-- Row 3: warning (only when present) -->
                            <TextBlock Text="{Binding FlowInspectorWarningLabel}" FontSize="{StaticResource WsFontSm}" Foreground="#F9A94B" TextWrapping="Wrap" IsVisible="{Binding FlowInspectorHasWarnings}"/>
                            <!-- Row 4: harmonic · energy compact -->
                            <TextBlock Text="{Binding FlowInspectorScoreRow}" FontSize="{StaticResource WsFontSm}" Foreground="{StaticResource WsTextSecondaryReadable}" TextWrapping="Wrap"/>
                            <!-- Row 5: phrase · beat · length · snap -->
                            <TextBlock Text="{Binding FlowInspectorAlignmentRow}" FontSize="{StaticResource WsFontSm}" Foreground="{StaticResource WsTextSecondaryReadable}" TextWrapping="Wrap"/>
                            <!-- Row 6: curve · bands -->
                            <TextBlock Text="{Binding FlowInspectorCurveDetailRow}" FontSize="{StaticResource WsFontSm}" Foreground="{StaticResource WsTextSecondaryReadable}" TextWrapping="Wrap"/>
                            <!-- Row 7: phrase region scaffold -->
                            <TextBlock Text="{Binding FlowInspectorPhraseRegionSpanLabel}" FontSize="{StaticResource WsFontSm}" Foreground="{StaticResource WsTextSecondaryReadable}" TextWrapping="Wrap"/>
                            <!-- Row 8: actions -->
                            <WrapPanel Orientation="Horizontal" ItemHeight="26">
                                <Button Classes="secondary" Command="{Binding ApplyFlowPresetCommand}" CommandParameter="{Binding FlowInspectorTopSuggestedPresetId}" ToolTip.Tip="Apply top suggested preset">Apply</Button>
                                <Button Classes="secondary" Margin="4,0,0,0" Command="{Binding ResetFlowPresetCommand}" ToolTip.Tip="Reset preset">Reset</Button>
                                <Button Classes="secondary" Margin="4,0,0,0" Command="{Binding CycleFlowPresetCommand}" ToolTip.Tip="Cycle suggestions">Cycle</Button>
                            </WrapPanel>
                        </StackPanel>

                        <StackPanel Spacing="8" IsVisible="{Binding IsAutomationMode}">
                            <TextBlock Text="Automation" FontSize="{StaticResource WsFontLg}" FontWeight="SemiBold" Foreground="#E5EEF8"/>
                            <TextBlock Text="Timeline editing and snapping are active. Use the header grid controls to configure snapping behavior." FontSize="{StaticResource WsFontSm}" Foreground="{StaticResource WsTextSecondaryReadable}" TextWrapping="Wrap"/>
                        </StackPanel>

                        <StackPanel Spacing="8" IsVisible="{Binding IsSamplesMode}">
                            <TextBlock Text="Samples" FontSize="{StaticResource WsFontLg}" FontWeight="SemiBold" Foreground="#E5EEF8"/>
                            <WrapPanel Orientation="Horizontal" ItemHeight="28">
                                <Button Classes="secondary" Click="OnImportLocalFilesCtaClick" ToolTip.Tip="{Binding ImportLocalFilesCtaHint}">Import</Button>
                                <Button Classes="secondary" Margin="6,0,0,0" Click="OnDownloadTracksCtaClick" IsVisible="{Binding ShouldShowDownloadTracksCta}" ToolTip.Tip="{Binding DownloadTracksCtaHint}">Download</Button>
                            </WrapPanel>
                        </StackPanel>

                        <StackPanel Spacing="8" IsVisible="{Binding IsStemsMode}">
                            <TextBlock Text="Stem Rack" FontSize="{StaticResource WsFontLg}" FontWeight="SemiBold" Foreground="#E5EEF8"/>
                            <TextBlock Text="{Binding FocusedDeck.TrackTitle, TargetNullValue='Load a track and run separation to activate stem controls'}" FontSize="{StaticResource WsFontMd}" FontWeight="SemiBold" Foreground="#DDE9F5" TextWrapping="Wrap"/>
                            <Border Classes="ws-chip"><TextBlock Text="{Binding FocusedDeck.SectionJumpSummary, TargetNullValue='Phrase-aware jumps appear after cue prep.'}" FontSize="{StaticResource WsFontSm}" Foreground="#8EC8FF" TextWrapping="Wrap"/></Border>
                            <WrapPanel Orientation="Horizontal" ItemHeight="28">
                                <Button Classes="secondary" Command="{Binding FocusedDeck.ToggleVocalsCommand}" IsEnabled="{Binding FocusedDeck.IsLoaded}">Vocals</Button>
                                <Button Classes="secondary" Margin="6,0,0,0" Command="{Binding FocusedDeck.ToggleDrumsCommand}" IsEnabled="{Binding FocusedDeck.IsLoaded}">Drums</Button>
                                <Button Classes="secondary" Margin="6,0,0,0" Command="{Binding FocusedDeck.ToggleBassCommand}" IsEnabled="{Binding FocusedDeck.IsLoaded}">Bass</Button>
                                <Button Classes="secondary" Margin="6,0,0,0" Command="{Binding FocusedDeck.ToggleOtherCommand}" IsEnabled="{Binding FocusedDeck.IsLoaded}">Other</Button>
                            </WrapPanel>
                            <Button Classes="secondary" Command="{Binding FocusedDeck.SeparateStemsCommand}" IsEnabled="{Binding FocusedDeck.IsLoaded}">Separate Stems</Button>
                        </StackPanel>

                        <StackPanel Spacing="8" IsVisible="{Binding IsExportMode}">
                            <TextBlock Text="Export" FontSize="{StaticResource WsFontLg}" FontWeight="SemiBold" Foreground="#E5EEF8"/>
                            <TextBlock Text="Configure mixdown output without leaving the cockpit. Use Export Mixdown for the full dialog flow." FontSize="{StaticResource WsFontSm}" Foreground="{StaticResource WsTextSecondaryReadable}" TextWrapping="Wrap"/>
                            <StackPanel Spacing="4">
                                <TextBlock Text="Format" FontSize="{StaticResource WsFontSm}" Foreground="{StaticResource WsTextSecondaryReadable}"/>
                                <ComboBox ItemsSource="{Binding ExportPanel.AvailableFormats}" SelectedItem="{Binding ExportPanel.SelectedFormat, Mode=TwoWay}"/>
                            </StackPanel>
                            <StackPanel Spacing="4">
                                <TextBlock Text="Output Path" FontSize="{StaticResource WsFontSm}" Foreground="{StaticResource WsTextSecondaryReadable}"/>
                                <TextBox Text="{Binding ExportPanel.OutputPath, Mode=TwoWay}" Watermark="Choose output path"/>
                            </StackPanel>
                            <CheckBox IsChecked="{Binding ExportPanel.Normalize, Mode=TwoWay}">Normalize</CheckBox>
                            <CheckBox IsChecked="{Binding ExportPanel.Dither, Mode=TwoWay}">Dither</CheckBox>
                            <TextBlock Text="Loaded Tracks" FontSize="{StaticResource WsFontSm}" Foreground="{StaticResource WsTextSecondaryReadable}"/>
                            <ItemsControl ItemsSource="{Binding ExportPanel.Decks}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ExportDeckEntry">
                                        <Border Classes="ws-chip" Margin="0,0,0,4">
                                            <StackPanel Spacing="2">
                                                <TextBlock Text="{Binding Label}" FontSize="{StaticResource WsFontSm}" Foreground="#DDE9F5" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding Volume, StringFormat='Volume {0:F2}'}" FontSize="{StaticResource WsFontXs}" Foreground="{StaticResource WsTextSecondaryReadable}"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Button Background="#0078D4" Foreground="White" BorderBrush="#0078D4" BorderThickness="1" CornerRadius="6" Padding="14,7" Command="{Binding ExportMixCommand}">Export Mixdown...</Button>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <GridSplitter Grid.Row="2"
                      ResizeDirection="Rows"
                      ResizeBehavior="PreviousAndNext"
                      Background="{DynamicResource BrushBg3}"
                      Height="{StaticResource WsSplitterHeight}"
                      HorizontalAlignment="Stretch"
                      DoubleTapped="OnDrawerSplitterDoubleTapped"/>

        <Border Grid.Row="3" Background="{DynamicResource BrushBg1}" BorderBrush="{DynamicResource BrushBorder1}" BorderThickness="0,1,0,0">
            <Grid RowDefinitions="Auto,Auto,*">
                <Border Grid.Row="0" Classes="flow-drawer-header" Background="{DynamicResource RegionBrush}" BorderBrush="#2D2D2D" BorderThickness="0,0,0,1" Padding="{StaticResource WsPadDrawerHeader}">
                    <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto,Auto">
                        <TextBlock Grid.Column="0" Text="FLOW DRAWER" FontSize="{StaticResource WsFontMd}" FontWeight="Bold" Foreground="{DynamicResource BrushText1}" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Classes="drawer-header-action" Margin="10,0,0,0" Background="{DynamicResource BrushAccentSubtle}" BorderBrush="{DynamicResource BrushAccent}" BorderThickness="1" Foreground="{DynamicResource BrushAccent}" Click="OnOpenTrackListOverlayClick" ToolTip.Tip="Open a large overlay track list for focused browsing">Expand Track List</Button>
                        <Button Grid.Column="3" Classes="drawer-header-action" Margin="0,0,6,0" Background="#1B3A1B" BorderBrush="#3A7A3A" BorderThickness="1" Foreground="#7FD47F" Command="{Binding AnalyzePlaylistCuesCommand}" IsEnabled="{Binding !IsAnalyzing}" ToolTip.Tip="Auto-detect drops, builds, phrase markers for all tracks in this playlist that have no cues yet">⚡ Analyze Playlist</Button>
                        <Button Grid.Column="4" x:Name="AnalyzeSelectedBtn" Classes="drawer-header-action" Margin="0,0,6,0" Background="#1B2A3A" BorderBrush="#3A6A9A" BorderThickness="1" Foreground="#7FB8D4" IsEnabled="{Binding !IsAnalyzing}" Click="OnAnalyzeSelectedClick" ToolTip.Tip="Auto-detect cues only for the selected rows (skips tracks that already have cues)">⚡ Selected</Button>
                        <ComboBox Grid.Column="5" x:Name="PlaylistSelector" Width="260" ItemsSource="{Binding Playlists}" SelectedItem="{Binding ActivePlaylist}" VerticalAlignment="Center">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding SourceTitle}" FontSize="12"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Classes="flow-status-busy" IsVisible="{Binding IsAnalyzing}" Background="#0A1A0A" BorderBrush="#2A4A2A" BorderThickness="0,0,0,1">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Orientation="Vertical" Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="{Binding AnalysisStatusText}" FontSize="10" Foreground="{StaticResource WsTextPrimaryReadable}"/>
                            <ProgressBar Minimum="0" Maximum="100" Value="{Binding AnalysisProgress}" Height="3" Foreground="#4CAF50" Background="#1E1E1E"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="{Binding AnalysisProgress, StringFormat='{}{0}%'}" FontSize="10" Foreground="{StaticResource WsTextPrimaryReadable}" VerticalAlignment="Center" Margin="{StaticResource WsMarginDrawerStatusTrailing}"/>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Classes="flow-status-idle" IsVisible="{Binding !IsAnalyzing}" Background="Transparent">
                    <StackPanel Spacing="2">
                            <TextBlock Text="{Binding AnalysisStatusText}" FontSize="10" Foreground="{StaticResource WsTextSecondaryReadable}" IsVisible="{Binding AnalysisStatusText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                            <TextBlock Text="{Binding WorkstationEligibilitySummary}" FontSize="10" Foreground="{StaticResource WsTextPrimaryReadable}" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding HiddenEligibilityBreakdown}" FontSize="10" Foreground="{StaticResource WsTextSecondaryReadable}" TextWrapping="Wrap" IsVisible="{Binding HiddenEligibilityBreakdown, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                            <TextBlock Text="{Binding FlowCtaStateSummary}" FontSize="10" Foreground="{StaticResource WsTextMutedReadable}" TextWrapping="Wrap"/>
                        <WrapPanel Orientation="Horizontal" ItemHeight="28" Margin="{StaticResource WsMarginDrawerCtas}" IsVisible="{Binding ShouldShowSelectPlaylistCta}">
                            <Button Classes="secondary" Click="OnFocusPlaylistCtaClick" ToolTip.Tip="{Binding SelectPlaylistCtaHint}">Select Playlist</Button>
                            <Button Classes="secondary" Margin="6,0,0,0" Click="OnImportLocalFilesCtaClick" ToolTip.Tip="{Binding ImportLocalFilesCtaHint}">Import Local Files</Button>
                        </WrapPanel>
                        <WrapPanel Orientation="Horizontal" ItemHeight="28" Margin="{StaticResource WsMarginDrawerCtas}" IsVisible="{Binding ShouldShowAcquireCtas}">
                            <Button Classes="secondary" Click="OnDownloadTracksCtaClick" IsVisible="{Binding ShouldShowDownloadTracksCta}" ToolTip.Tip="{Binding DownloadTracksCtaHint}">Download Tracks</Button>
                            <Button Classes="secondary" Margin="6,0,0,0" Click="OnImportLocalFilesCtaClick" IsVisible="{Binding ShouldShowImportLocalFilesCta}" ToolTip.Tip="{Binding ImportLocalFilesCtaHint}">Import Local Files</Button>
                        </WrapPanel>
                        <WrapPanel Orientation="Horizontal" ItemHeight="28" Margin="{StaticResource WsMarginDrawerCtas}" IsVisible="{Binding ShouldShowReadyTrackCtas}">
                            <Button Classes="secondary" Click="OnLoadIntoWorkstationCtaClick" IsEnabled="{Binding HasReadyPlaylistTracks}" ToolTip.Tip="{Binding LoadIntoWorkstationCtaHint}">Load into Workstation</Button>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <Grid Grid.Row="2" ColumnDefinitions="2*,*" Margin="0,2,0,0">
                    <TabControl Grid.Column="0" x:Name="DrawerTabs" Classes="drawer-tabs" BorderThickness="0" Background="Transparent" TabStripPlacement="Top" SelectionChanged="OnDrawerTabsSelectionChanged" SelectedIndex="0">
                        <TabItem Header="Flow Builder" Classes="drawer-tab">
                            <views:FlowBuilderView/>
                        </TabItem>
                        <TabItem Header="Track List" Classes="drawer-tab">
                            <StackPanel>
                                <ctrl:VirtualGridHeader>
                                    <ctrl:VirtualGridHeader.HeaderContent>
                                        <Grid ColumnDefinitions="40,2*,3*,60,60,150">
                                            <TextBlock Grid.Column="0" Text="#" FontSize="10" FontWeight="Bold" Foreground="#666" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="ARTIST" FontSize="10" FontWeight="Bold" Foreground="#666" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="8,0"/>
                                            <TextBlock Grid.Column="2" Text="TITLE" FontSize="10" FontWeight="Bold" Foreground="#666" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="8,0"/>
                                            <TextBlock Grid.Column="3" Text="KEY" FontSize="10" FontWeight="Bold" Foreground="#666" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="4" Text="BPM" FontSize="10" FontWeight="Bold" Foreground="#666" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="5" Text="LOAD" FontSize="10" FontWeight="Bold" Foreground="#666" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Grid>
                                    </ctrl:VirtualGridHeader.HeaderContent>
                                </ctrl:VirtualGridHeader>
                                <ctrl:VirtualGrid x:Name="FlowTrackGrid"
                                                  ItemsSource="{Binding PlaylistTracks}"
                                                  SelectionMode="Multiple"
                                                  Height="200"
                                                  PointerPressed="OnFlowTrackGridPointerPressed"
                                                  PointerMoved="OnFlowTrackGridPointerMoved">
                                    <ctrl:VirtualGrid.ItemTemplate>
                                        <DataTemplate DataType="models:PlaylistTrack">
                                            <Border Classes="track-row" Height="40" Focusable="True">
                                                <Grid ColumnDefinitions="40,2*,3*,60,60,150">
                                                    <TextBlock Grid.Column="0" Text="{Binding TrackNumber}" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="11" Foreground="#A0A0A0"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding Artist}" VerticalAlignment="Center" Margin="8,0" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding Title}" VerticalAlignment="Center" Margin="8,0" FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Grid.Column="3" Text="{Binding Key}" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="12" Foreground="#8EC8FF"/>
                                                    <TextBlock Grid.Column="4" Text="{Binding BPM, StringFormat='{}{0:F0}'}" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="12"/>
                                                    <StackPanel Grid.Column="5" Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <Button Content="F" Command="{Binding #PageRoot.DataContext.LoadToFocusedDeckCommand}" CommandParameter="{Binding}" ToolTip.Tip="Load to the focused deck" Classes="ws-btn"/>
                                                        <Button Content="A" Command="{Binding #PageRoot.DataContext.LoadToDeckACommand}" CommandParameter="{Binding}" ToolTip.Tip="Load to Deck A" Classes="ws-btn"/>
                                                        <Button Content="B" Command="{Binding #PageRoot.DataContext.LoadToDeckBCommand}" CommandParameter="{Binding}" ToolTip.Tip="Load to Deck B" Classes="ws-btn"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ctrl:VirtualGrid.ItemTemplate>
                                </ctrl:VirtualGrid>
                            </StackPanel>
                        </TabItem>
                    </TabControl>

                    <Border Grid.Column="1" Margin="8,0,0,0" Background="#D1111922" BorderBrush="#314355" BorderThickness="1" CornerRadius="8" Padding="{StaticResource WsPadTrackPool}">
                        <Grid RowDefinitions="Auto,Auto,*">
                            <StackPanel Grid.Row="0" Spacing="2" Margin="0,0,0,6">
                                <TextBlock Text="TRACK POOL" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource WsTextSecondaryReadable}"/>
                                <TextBlock Text="Playlist context stays visible while editing flow. Use the full Track List tab or overlay for bulk operations." FontSize="9" Foreground="{StaticResource WsTextHintReadable}" TextWrapping="Wrap"/>
                            </StackPanel>
                            <ctrl:VirtualGridHeader Grid.Row="1">
                                <ctrl:VirtualGridHeader.HeaderContent>
                                    <Grid ColumnDefinitions="34,*,52,48">
                                        <TextBlock Grid.Column="0" Text="#" FontSize="10" FontWeight="Bold" Foreground="#666" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="TRACK" FontSize="10" FontWeight="Bold" Foreground="#666" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="8,0"/>
                                        <TextBlock Grid.Column="2" Text="BPM" FontSize="10" FontWeight="Bold" Foreground="#666" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="3" Text="LOAD" FontSize="10" FontWeight="Bold" Foreground="#666" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                </ctrl:VirtualGridHeader.HeaderContent>
                            </ctrl:VirtualGridHeader>
                            <ctrl:VirtualGrid Grid.Row="2"
                                              ItemsSource="{Binding PlaylistTracks}"
                                              SelectionMode="Single">
                                <ctrl:VirtualGrid.ItemTemplate>
                                    <DataTemplate DataType="models:PlaylistTrack">
                                        <Border Classes="track-row" Height="36" Focusable="True">
                                            <Grid ColumnDefinitions="34,*,52,48">
                                                <TextBlock Grid.Column="0" Text="{Binding TrackNumber}" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="11" Foreground="#A0A0A0"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Title}" VerticalAlignment="Center" Margin="8,0" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Grid.Column="2" Text="{Binding BPM, StringFormat='{}{0:F0}'}" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="12"/>
                                                <Button Grid.Column="3" Content="F" Command="{Binding #PageRoot.DataContext.LoadToFocusedDeckCommand}" CommandParameter="{Binding}" ToolTip.Tip="Load to the focused deck" Classes="ws-btn" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ctrl:VirtualGrid.ItemTemplate>
                            </ctrl:VirtualGrid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <Border x:Name="TrackListOverlay"
                Grid.Row="0"
                Grid.RowSpan="4"
                Classes="overlay-backdrop"
                IsVisible="False"
                ZIndex="180"
                Background="#9A11161E"
                PointerPressed="OnTrackListOverlayBackdropPressed">
            <Border x:Name="TrackListOverlayPanel"
                    Classes="overlay-panel size-comfort"
                    CornerRadius="10"
                    Background="{DynamicResource BrushBg1}"
                    BorderBrush="{DynamicResource BrushBorder1}"
                    BorderThickness="1">
                <Grid RowDefinitions="Auto,*,Auto">
                    <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Margin="{StaticResource WsMarginOverlayHeader}">
                        <TextBlock Grid.Column="0" Text="TRACK LIST OVERLAY" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrushText1}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="Expanded browser for playlist tracks" FontSize="10" Foreground="{DynamicResource BrushText2}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6">
                            <Button Classes="icon" Click="OnSetOverlayAutoSizeClick" ToolTip.Tip="Auto size based on current window width">Auto</Button>
                            <Button Classes="icon" Click="OnSetOverlayCompactSizeClick" ToolTip.Tip="Compact overlay size">S</Button>
                            <Button Classes="icon" Click="OnSetOverlayComfortSizeClick" ToolTip.Tip="Comfort overlay size">M</Button>
                            <Button Classes="icon" Click="OnSetOverlayFullSizeClick" ToolTip.Tip="Full overlay size">L</Button>
                            <Button Classes="secondary" Click="OnFocusTrackListTabClick" ToolTip.Tip="Focus the Track List tab in drawer">Focus Drawer Tab</Button>
                            <Button Click="OnCloseTrackListOverlayClick" Background="#3A1E1E" BorderBrush="#7A3A3A" Foreground="#EABABA">Close</Button>
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="1" RowDefinitions="Auto,*">
                        <ctrl:VirtualGridHeader Grid.Row="0">
                            <ctrl:VirtualGridHeader.HeaderContent>
                                <Grid ColumnDefinitions="44,2*,3*,70,70,170">
                                    <TextBlock Grid.Column="0" Text="#" FontSize="10" FontWeight="Bold" Foreground="#666" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="ARTIST" FontSize="10" FontWeight="Bold" Foreground="#666" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="8,0"/>
                                    <TextBlock Grid.Column="2" Text="TITLE" FontSize="10" FontWeight="Bold" Foreground="#666" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="8,0"/>
                                    <TextBlock Grid.Column="3" Text="KEY" FontSize="10" FontWeight="Bold" Foreground="#666" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="4" Text="BPM" FontSize="10" FontWeight="Bold" Foreground="#666" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="5" Text="LOAD" FontSize="10" FontWeight="Bold" Foreground="#666" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                            </ctrl:VirtualGridHeader.HeaderContent>
                        </ctrl:VirtualGridHeader>
                        <ctrl:VirtualGrid Grid.Row="1" x:Name="OverlayTrackGrid"
                                          ItemsSource="{Binding PlaylistTracks}"
                                          SelectionMode="Multiple"
                                          PointerPressed="OnFlowTrackGridPointerPressed"
                                          PointerMoved="OnFlowTrackGridPointerMoved">
                            <ctrl:VirtualGrid.ItemTemplate>
                                <DataTemplate DataType="models:PlaylistTrack">
                                    <Border Classes="track-row" Height="40" Focusable="True">
                                        <Grid ColumnDefinitions="44,2*,3*,70,70,170">
                                            <TextBlock Grid.Column="0" Text="{Binding TrackNumber}" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="11" Foreground="#A0A0A0"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Artist}" VerticalAlignment="Center" Margin="8,0" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Title}" VerticalAlignment="Center" Margin="8,0" FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Column="3" Text="{Binding Key}" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="12" Foreground="#8EC8FF"/>
                                            <TextBlock Grid.Column="4" Text="{Binding BPM, StringFormat='{}{0:F0}'}" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="12"/>
                                            <StackPanel Grid.Column="5" Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Button Content="F" Command="{Binding #PageRoot.DataContext.LoadToFocusedDeckCommand}" CommandParameter="{Binding}" ToolTip.Tip="Load to the focused deck" Classes="ws-btn"/>
                                                <Button Content="A" Command="{Binding #PageRoot.DataContext.LoadToDeckACommand}" CommandParameter="{Binding}" ToolTip.Tip="Load to Deck A" Classes="ws-btn"/>
                                                <Button Content="B" Command="{Binding #PageRoot.DataContext.LoadToDeckBCommand}" CommandParameter="{Binding}" ToolTip.Tip="Load to Deck B" Classes="ws-btn"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ctrl:VirtualGrid.ItemTemplate>
                        </ctrl:VirtualGrid>
                    </Grid>

                    <Grid Grid.Row="2" ColumnDefinitions="*,Auto" Margin="0,8,0,0">
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <TextBlock Text="Tip: drag the resize handle to fine-tune this overlay" FontSize="10" Foreground="{DynamicResource BrushText2}" VerticalAlignment="Center"/>
                            <Border x:Name="OverlayResizeGuidePill" IsVisible="False" Background="{DynamicResource BrushAccentSubtle}" BorderBrush="{DynamicResource BrushAccent}" BorderThickness="1" CornerRadius="4" Padding="6,2">
                                <TextBlock x:Name="OverlayResizeGuideText" Text="" FontSize="10" Foreground="{DynamicResource BrushAccent}"/>
                            </Border>
                        </StackPanel>
                        <Border Grid.Column="1"
                                x:Name="OverlayResizeGrip"
                                Width="22"
                                Height="22"
                                CornerRadius="4"
                                Cursor="TopLeftCorner"
                                Background="{DynamicResource BrushBg2}"
                                BorderBrush="{DynamicResource BrushBorder1}"
                                BorderThickness="1"
                                ToolTip.Tip="Drag to resize overlay"
                                PointerPressed="OnOverlayResizeGripPressed"
                                PointerMoved="OnOverlayResizeGripMoved"
                                PointerReleased="OnOverlayResizeGripReleased"
                                DoubleTapped="OnOverlayResizeGripDoubleTapped">
                            <TextBlock Text="◢" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource BrushText2}"/>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Border>

        <ctrl:KeyboardOverlayView Grid.Row="0" Grid.RowSpan="4"
                                  DataContext="{Binding KeyboardOverlay}"
                                  ZIndex="200"/>
    </Grid>
</UserControl>