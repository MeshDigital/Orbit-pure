<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SLSKDONET.ViewModels"
             xmlns:controls="clr-namespace:SLSKDONET.Views.Avalonia.Controls"
             x:Class="SLSKDONET.Views.Avalonia.FlowBuilderView"
             Background="#141414">

    <UserControl.Styles>
        <Style Selector="Border.fb-chip">
            <Setter Property="Background" Value="#20262D"/>
            <Setter Property="BorderBrush" Value="#2F3E4C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="999"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
        </Style>

        <Style Selector="Button.fb-primary">
            <Setter Property="Background" Value="#1D4E42"/>
            <Setter Property="BorderBrush" Value="#2D8E7A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#DDFCF5"/>
            <Setter Property="CornerRadius" Value="7"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style Selector="Button.fb-ghost">
            <Setter Property="Background" Value="#171C22"/>
            <Setter Property="BorderBrush" Value="#2A333D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#9BD7CA"/>
            <Setter Property="CornerRadius" Value="7"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,Auto,Auto,*">

        <!-- ── Header bar ───────────────────────────────────────────────── -->
        <Border Grid.Row="0"
                Background="#1E1E1E"
                BorderBrush="#3E3E3E"
                BorderThickness="0,0,0,1"
                Padding="20,12">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto,Auto,Auto">

                <!-- Title block -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2">
                    <TextBlock Text="FLOW BUILDER"
                               FontSize="16" FontWeight="Bold"
                               Foreground="#4EC9B0"/>
                    <TextBlock Text="Build your DJ set — track order, transitions, energy flow"
                               FontSize="11" Foreground="#666"/>
                    <WrapPanel Margin="0,4,0,0">
                        <Border Classes="fb-chip">
                            <TextBlock Foreground="#7FCBB9" FontSize="10">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0} tracks staged">
                                        <Binding Path="Tracks.Count"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </Border>
                        <Border Classes="fb-chip" IsVisible="{Binding IsLoading}">
                            <TextBlock Text="Optimizing transitions..."
                                       Foreground="#9CB7D9"
                                       FontSize="10"/>
                        </Border>
                    </WrapPanel>
                </StackPanel>

                <!-- Playlist combo -->
                <ComboBox Grid.Column="1"
                          Margin="24,0,8,0"
                          ItemsSource="{Binding Playlists}"
                          SelectedItem="{Binding SelectedPlaylist}"
                          PlaceholderText="Select a playlist…"
                          VerticalAlignment="Center"
                          MaxWidth="380"/>

                <!-- Load -->
                <Button Grid.Column="2"
                        Content="▶ Load"
                    Classes="fb-primary"
                        Command="{Binding LoadSelectedPlaylistCommand}"
                        IsEnabled="{Binding IsNotLoading}"
                        Margin="4,0"
                        VerticalAlignment="Center"/>

                <!-- Suggest Next -->
                <Button Grid.Column="3"
                        Content="✦ Suggest Next"
                    Classes="fb-ghost"
                        Command="{Binding SuggestNextCommand}"
                        IsEnabled="{Binding IsNotLoading}"
                        Margin="4,0"
                        VerticalAlignment="Center"/>

                <!-- Energy curve selector — drives Suggest Flow ordering shape -->
                <StackPanel Grid.Column="4" Orientation="Vertical" VerticalAlignment="Center" Margin="4,0" Spacing="2">
                    <TextBlock Text="ARC SHAPE" FontSize="9" FontWeight="Black"
                               Foreground="#3A5C70" LetterSpacing="0.8"/>
                    <ComboBox ItemsSource="{Binding EnergyCurveOptions}"
                              SelectedItem="{Binding SelectedEnergyCurveOption}"
                              MinWidth="110"
                              FontSize="12"
                              ToolTip.Tip="{Binding SelectedEnergyCurveOption.Description}"/>
                </StackPanel>

                <!-- Suggest Flow -->
                <Button Grid.Column="5"
                    Content="◎ Suggest Flow"
                    Classes="fb-ghost"
                    Command="{Binding SuggestFlowCommand}"
                    IsEnabled="{Binding HasTracks}"
                    Margin="4,0"
                    VerticalAlignment="Center"/>

                <!-- Refresh list -->
                <Button Grid.Column="6"
                        Content="↻"
                        Command="{Binding LoadPlaylistsCommand}"
                        ToolTip.Tip="Refresh playlist list"
                        Margin="4,0"
                        VerticalAlignment="Center"
                        Width="32"/>

                <!-- Clear -->
                <Button Grid.Column="7"
                        Content="✕ Clear"
                        Command="{Binding ClearCommand}"
                        IsEnabled="{Binding HasTracks}"
                        Margin="4,0"
                        VerticalAlignment="Center"/>

            </Grid>
        </Border>

        <!-- ── Status bar ────────────────────────────────────────────────── -->
        <Border Grid.Row="1" Background="#181818" Padding="20,5">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <ProgressBar Grid.Column="0"
                             IsVisible="{Binding IsLoading}"
                             IsIndeterminate="True"
                             Width="100" Height="2"
                             VerticalAlignment="Center"
                             Margin="0,0,12,0"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding StatusText}"
                           FontSize="11" Foreground="#9AA8B7"
                           VerticalAlignment="Center"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock FontSize="11" Foreground="#6E7A86" VerticalAlignment="Center">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="{}{0} tracks in set">
                                <Binding Path="Tracks.Count"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                    <Border Classes="fb-chip" IsVisible="{Binding HasTracks}">
                        <TextBlock Text="Drag cards to shape transitions" FontSize="10" Foreground="#8AA0B8"/>
                    </Border>
                    <TextBlock Text="Style filter"
                               FontSize="10"
                               Foreground="#8AA0B8"
                               VerticalAlignment="Center"
                               IsVisible="{Binding HasTracks}"/>
                    <ComboBox ItemsSource="{Binding TransitionStyleFilters}"
                              SelectedItem="{Binding SelectedTransitionStyleFilter}"
                              MinWidth="140"
                              MaxWidth="170"
                              IsVisible="{Binding HasTracks}"/>
                    <Border Classes="fb-chip" IsVisible="{Binding HasTracks}">
                        <TextBlock Text="{Binding TransitionFilterSummary}" FontSize="10" Foreground="#9CB7D9"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Suggested flow banner ─────────────────────────────────────── -->
        <Border Grid.Row="2"
            Margin="20,10,20,0"
            Padding="14,10"
            Background="#162027"
            BorderBrush="#27515D"
            BorderThickness="1"
            CornerRadius="8"
            IsVisible="{Binding HasSuggestedFlow}">
            <Grid ColumnDefinitions="*,Auto,Auto" RowDefinitions="Auto,Auto">
            <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Text="A10 Suggested Flow"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="#9BD7CA"/>
                  <TextBlock Text="{Binding SuggestedFlowStyleSummary}"
                      FontSize="11"
                      FontWeight="SemiBold"
                      Foreground="#F3D37A"
                      TextWrapping="Wrap"
                      IsVisible="{Binding SuggestedFlowStyleSummary, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                <TextBlock Text="{Binding SuggestedFlowPreview}"
                       FontSize="11"
                       Foreground="#D7E6E2"
                       TextWrapping="Wrap"/>
                <TextBlock Text="{Binding SuggestedFlowReasonSummary}"
                       FontSize="10"
                       Foreground="#8AA0B8"
                       TextWrapping="Wrap"/>
            </StackPanel>

            <Border Grid.Column="1"
                Margin="12,0,8,0"
                Classes="fb-chip"
                VerticalAlignment="Center">
                <StackPanel Spacing="4">
                    <TextBlock Text="{Binding SuggestedFlowScoreDisplay}"
                           FontSize="10"
                           Foreground="#9BD7CA"/>
                    <Button Content="Preview Impact"
                            Classes="fb-ghost"
                            Command="{Binding ViewSuggestedFlowImpactCommand}"
                            IsVisible="{Binding HasSuggestedFlowImpactPreview}"/>
                </StackPanel>
            </Border>

            <StackPanel Grid.Column="2"
                    Orientation="Horizontal"
                    Spacing="8"
                    VerticalAlignment="Center">
                <Button Content="Apply"
                    Classes="fb-primary"
                    Command="{Binding ApplySuggestedFlowCommand}"/>
                <Button Content="Dismiss"
                    Classes="fb-ghost"
                    Command="{Binding DismissSuggestedFlowCommand}"/>
            </StackPanel>
            </Grid>
        </Border>

        <!-- ── Timeline area ─────────────────────────────────────────────── -->
        <Grid Grid.Row="3">

            <!-- Empty state placeholder -->
            <StackPanel IsVisible="{Binding HasNoTracks}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                    Spacing="12"
                    MaxWidth="560">
                <TextBlock Text="SET CANVAS"
                       FontSize="13"
                       FontWeight="Bold"
                       Foreground="#5A6E83"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Your set is empty"
                           FontSize="20" FontWeight="SemiBold"
                           Foreground="#4EC9B0"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Select a playlist above and click Load — or use ✦ Suggest Next to build from scratch."
                           FontSize="13" Foreground="#666"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           MaxWidth="420"
                           TextAlignment="Center"/>
                    <WrapPanel HorizontalAlignment="Center" ItemHeight="32" Margin="0,4,0,0">
                        <Button Content="Load Playlist"
                            Classes="fb-primary"
                            Command="{Binding LoadSelectedPlaylistCommand}"
                            IsEnabled="{Binding IsNotLoading}"/>
                        <Button Content="Suggest Next"
                            Classes="fb-ghost"
                            Margin="8,0,0,0"
                            Command="{Binding SuggestNextCommand}"
                            IsEnabled="{Binding IsNotLoading}"/>
                    </WrapPanel>
                    <TextBlock Text="Tip: pick a playlist first to get full AI ordering and bridge scores."
                           FontSize="10"
                           Foreground="#6A7785"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           MaxWidth="500"/>
            </StackPanel>

            <!-- Horizontal timeline -->
            <ScrollViewer IsVisible="{Binding HasTracks}"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled"
                          Padding="20,12,20,20">

                <StackPanel Spacing="0">

                <!-- ── Set Arc: energy shape of the full set ─────────────── -->
                <StackPanel Spacing="2" Margin="0,0,0,4">
                    <TextBlock Text="SET ARC" FontSize="9" FontWeight="Black"
                               Foreground="#3A4E5C" LetterSpacing="1.5" Margin="2,0,0,0"/>
                    <Border Height="36" Background="#0A0A0A" CornerRadius="4" ClipToBounds="True">
                        <ItemsControl ItemsSource="{Binding Tracks}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="0"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:FlowTrackCardViewModel">
                                    <Grid ColumnDefinitions="196,56" Height="36">
                                        <controls:SparklineControl
                                            Grid.Column="0"
                                            Points="{Binding EnergyCurvePoints}"
                                            LineBrush="#4EC9B0"
                                            FillBrush="#1A4EC9B0"
                                            LineThickness="1.5"/>
                                        <!-- Bridge score colour fills the gap between tracks -->
                                        <Border Grid.Column="1"
                                                Background="{Binding Bridge.ScoreBrush}"
                                                Opacity="0.25"
                                                IsVisible="{Binding HasBridge}"/>
                                        <Border Grid.Column="1"
                                                Height="2"
                                                VerticalAlignment="Bottom"
                                                Background="{Binding Bridge.ScoreBrush}"
                                                IsVisible="{Binding HasBridge}"
                                                Margin="6,0"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                </StackPanel>

                <!-- ── Track cards ───────────────────────────────────────── -->
                <ItemsControl ItemsSource="{Binding Tracks}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="0"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="vm:FlowTrackCardViewModel">
                            <!-- Each item: [Card 196px] + [Bridge 56px] -->
                            <Grid ColumnDefinitions="196,56">

                                <!-- ── Track card ──────────────────────── -->
                                <Border Grid.Column="0"
                                        Width="192"
                                        Background="#1E1E1E"
                                        BorderBrush="#3C3C3C"
                                        BorderThickness="1"
                                        CornerRadius="7"
                                        Margin="2,0,2,4"
                                        DragDrop.AllowDrop="True"
                                        DragDrop.DragOver="OnCardDragOver"
                                        DragDrop.Drop="OnCardDrop">
                                    <Grid RowDefinitions="4,Auto,Auto,36,Auto,Auto">

                                        <!-- Key colour band (Camelot-matched) -->
                                        <Border Grid.Row="0"
                                                Background="{Binding KeyColorBrush}"
                                                CornerRadius="7,7,0,0"/>

                                        <!-- Artwork thumbnail (drag handle) -->
                                        <Border Grid.Row="1" Height="48" ClipToBounds="True" Margin="0"
                                                Cursor="SizeAll"
                                                PointerPressed="OnCardArtworkPressed">
                                            <Panel>
                                                <Border Background="#181818"
                                                        IsVisible="{Binding AlbumArtUrl, Converter={x:Static ObjectConverters.IsNull}}">
                                                    <PathIcon Data="{DynamicResource disc_regular}"
                                                              Width="20" Height="20"
                                                              Foreground="#333"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                                </Border>
                                                <Image Source="{Binding AlbumArtUrl}"
                                                       Stretch="UniformToFill"
                                                       IsVisible="{Binding AlbumArtUrl, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                                            </Panel>
                                        </Border>

                                        <!-- Artist + Title -->
                                        <StackPanel Grid.Row="2" Margin="10,6,10,4" Spacing="2">
                                            <TextBlock Text="{Binding Artist}"
                                                       FontSize="10" Foreground="#888"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Title}"
                                                       FontSize="12" FontWeight="SemiBold"
                                                       Foreground="#E0E0E0"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>

                                        <!-- Energy sparkline -->
                                        <Border Grid.Row="3" Margin="10,0" Height="36">
                                            <controls:SparklineControl
                                                Points="{Binding EnergyCurvePoints}"
                                                LineBrush="#4EC9B0"
                                                FillBrush="#224EC9B0"
                                                LineThickness="1.2"/>
                                        </Border>

                                        <!-- BPM / Key / Time info row -->
                                        <Grid Grid.Row="4"
                                              ColumnDefinitions="*,*,*"
                                              Margin="8,4,8,6">
                                            <StackPanel Grid.Column="0" Spacing="1" HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding BpmDisplay}"
                                                           FontSize="13" FontWeight="Bold"
                                                           Foreground="#E0E0E0"
                                                           HorizontalAlignment="Center"/>
                                                <TextBlock Text="BPM"
                                                           FontSize="9" Foreground="#555"
                                                           HorizontalAlignment="Center"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Spacing="1" HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding KeyDisplay}"
                                                           FontSize="13" FontWeight="Bold"
                                                           Foreground="{Binding KeyColorBrush}"
                                                           HorizontalAlignment="Center"/>
                                                <TextBlock Text="KEY"
                                                           FontSize="9" Foreground="#555"
                                                           HorizontalAlignment="Center"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" Spacing="1" HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding DurationDisplay}"
                                                           FontSize="13" FontWeight="Bold"
                                                           Foreground="#E0E0E0"
                                                           HorizontalAlignment="Center"/>
                                                <TextBlock Text="TIME"
                                                           FontSize="9" Foreground="#555"
                                                           HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Reorder / remove buttons -->
                                        <StackPanel Grid.Row="5"
                                                    Orientation="Horizontal"
                                                    HorizontalAlignment="Center"
                                                    Spacing="6"
                                                    Margin="8,2,8,8">
                                            <Button Content="◀"
                                                    Command="{Binding MoveLeftCommand}"
                                                    ToolTip.Tip="Move left"
                                                    Width="28" Height="22"
                                                    FontSize="10"
                                                    Padding="0"/>
                                            <Button Content="▶"
                                                    Command="{Binding MoveRightCommand}"
                                                    ToolTip.Tip="Move right"
                                                    Width="28" Height="22"
                                                    FontSize="10"
                                                    Padding="0"/>
                                                <Button Content="🔗"
                                                    Command="{Binding FindBridgeToNextCommand}"
                                                    ToolTip.Tip="Find bridge track to the next item"
                                                    Width="28" Height="22"
                                                    FontSize="10"
                                                    Padding="0"
                                                    IsVisible="{Binding HasBridge}"
                                                    Foreground="#FFB800"/>
                                            <Button Content="✕"
                                                    Command="{Binding RemoveCommand}"
                                                    ToolTip.Tip="Remove from set"
                                                    Width="28" Height="22"
                                                    FontSize="10"
                                                    Padding="0"
                                                    Foreground="#E74C3C"/>
                                        </StackPanel>

                                    </Grid>
                                </Border>

                                <!-- ── Transition bridge ───────────────── -->
                                <Button Grid.Column="1"
                                        IsVisible="{Binding HasBridge}"
                                        VerticalAlignment="Top"
                                        Margin="0,22,0,0"
                                        Background="Transparent"
                                        BorderBrush="Transparent"
                                        BorderThickness="0"
                                        Padding="0"
                                        Command="{Binding SelectTransitionInspectorCommand}"
                                        ToolTip.Tip="{Binding Bridge.Tooltip}">
                                    <StackPanel Spacing="4">

                                        <!-- BPM delta -->
                                        <TextBlock Text="{Binding Bridge.BpmDeltaDisplay}"
                                                   FontSize="9" Foreground="#AAA"
                                                   HorizontalAlignment="Center"/>

                                        <!-- Coloured horizontal bar (score) -->
                                        <Border Height="3"
                                                CornerRadius="1.5"
                                                Margin="4,0"
                                                Background="{Binding Bridge.ScoreBrush}"/>

                                        <!-- Key label -->
                                        <TextBlock Text="{Binding Bridge.KeyLabel}"
                                                   FontSize="9"
                                                   Foreground="{Binding Bridge.ScoreBrush}"
                                                   HorizontalAlignment="Center"/>

                                        <TextBlock Text="{Binding Bridge.BreakdownDisplay}"
                                                   FontSize="8"
                                                   Foreground="#8AA0B8"
                                                   HorizontalAlignment="Center"
                                                   TextAlignment="Center"
                                                   TextWrapping="Wrap"
                                                   MaxWidth="56"/>

                                    </StackPanel>
                                </Button>

                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
