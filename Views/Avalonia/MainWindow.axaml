<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
         xmlns:vm="clr-namespace:SLSKDONET.Views"
         xmlns:views="clr-namespace:SLSKDONET.Views.Avalonia"
         xmlns:controls="clr-namespace:SLSKDONET.Views.Avalonia.Controls"
         xmlns:models="clr-namespace:SLSKDONET.Models"
         xmlns:vmCore="clr-namespace:SLSKDONET.ViewModels"
         xmlns:vmDownloads="clr-namespace:SLSKDONET.ViewModels.Downloads"
        mc:Ignorable="d" d:DesignWidth="1400" d:DesignHeight="900"
        x:Class="SLSKDONET.Views.Avalonia.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="ORBIT"
        Width="1400" Height="900"
        MinWidth="360" MinHeight="500"
        FontSize="{Binding BaseFontSize}"
        TransparencyLevelHint="Mica, AcrylicBlur"
        Background="Transparent">

    <Window.KeyBindings>
        <!-- Quick Navigation -->
        <KeyBinding Gesture="Ctrl+D1" Command="{Binding NavigateHomeCommand}"/>
        <KeyBinding Gesture="Ctrl+D2" Command="{Binding NavigateSearchCommand}"/>
        <KeyBinding Gesture="Ctrl+D3" Command="{Binding NavigateLibraryCommand}"/>
        <KeyBinding Gesture="Ctrl+D4" Command="{Binding NavigateProjectsCommand}"/>
        <KeyBinding Gesture="Ctrl+D5" Command="{Binding NavigateSettingsCommand}"/>
        
        <!-- Playback -->
        <KeyBinding Gesture="Space" Command="{Binding PlayPauseCommand}"/>
        <KeyBinding Gesture="Right" Command="{Binding PlayerViewModel.SeekForwardCommand}"/>
        <KeyBinding Gesture="Left" Command="{Binding PlayerViewModel.SeekBackwardCommand}"/>

        <!-- Search & Library -->
        <KeyBinding Gesture="Ctrl+F" Command="{Binding FocusSearchCommand}"/>
        <KeyBinding Gesture="Ctrl+L" Command="{Binding NavigateLibraryCommand}"/>

        <!-- App Controls -->
        <KeyBinding Gesture="Ctrl+D" Command="{Binding NavigateProjectsCommand}"/>
        <KeyBinding Gesture="Ctrl+Shift+S" Command="{Binding NavigateSettingsCommand}"/>
        <KeyBinding Gesture="Ctrl+Q" Command="{Binding QuitApplicationCommand}"/>
        <KeyBinding Gesture="Ctrl+P" Command="{Binding TogglePlayerCommand}"/>
    <KeyBinding Gesture="Ctrl+Shift+P" Command="{Binding NavigatePlayerCommand}"/>
        <KeyBinding Gesture="Ctrl+N" Command="{Binding ToggleNavigationCommand}"/>
        <KeyBinding Gesture="Ctrl+K" Command="{Binding ToggleCommandPaletteCommand}"/>
        <KeyBinding Gesture="F10" Command="{Binding ToggleZenModeCommand}"/>
        <KeyBinding Gesture="F11" Command="{Binding ToggleTopBarCommand}"/>
    </Window.KeyBindings>

    <Window.Styles>
        <StyleInclude Source="/Themes/AvaloniaTheme.axaml"/>
        
        <!-- Navigation Sidebar Styles -->
        <Style Selector="Border.nav-sidebar">
            <Setter Property="Width" Value="220"/>
            <Setter Property="Background" Value="{StaticResource DeepBackgroundBrush}"/>
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Width" Duration="0:0:0.25" Easing="QuarticEaseOut"/>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.2"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.nav-sidebar.mini">
            <Setter Property="Width" Value="56"/>
        </Style>
        <Style Selector="Border.nav-sidebar.mini TextBlock:nth-child(2)">
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="IsVisible" Value="False"/>
        </Style>
        <Style Selector="Border.nav-sidebar.mini Border.GroupHeader">
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="IsVisible" Value="False"/>
        </Style>
        <Style Selector="Border.nav-sidebar.mini Button.nav StackPanel">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Spacing" Value="0"/>
            <Setter Property="Margin" Value="0"/>
        </Style>
        <Style Selector="Border.nav-sidebar.mini Button.nav">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>
    </Window.Styles>
    
    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Unified Top Command Bar -->
        <Border Grid.Row="0" 
                Background="#1E1E1E" 
                Padding="12,10" 
                BorderBrush="#000" 
                BorderThickness="0,0,0,1"
                IsVisible="{Binding IsTopCommandBarVisible}">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <!-- Left: Navigation & Connection -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Spacing="16">
                    <Button Command="{Binding ToggleNavigationCommand}" 
                            Background="Transparent" 
                            BorderThickness="0" 
                            Padding="8,4"
                            ToolTip.Tip="Toggle Navigation">
                        <TextBlock Text="☰" FontSize="18" Foreground="#CCC"/>
                    </Button>
                    
                    <Border Background="#252526" CornerRadius="4" Padding="8,4">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Command="{Binding ConnectionViewModel.ShowLoginCommand}"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="0"
                                    ToolTip.Tip="Click to manage Soulseek connection">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <Ellipse Width="8" Height="8" Fill="{Binding ConnectionViewModel.IsConnected, Converter={StaticResource BoolToColorConverter}}"/>
                                    <TextBlock Text="Soulseek" FontSize="11" Foreground="#999" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Rectangle Width="1" Height="12" Fill="#444" Margin="4,0"/>
                            <Ellipse Width="8" Height="8" Fill="{Binding ConnectionViewModel.IsSpotifyConnected, Converter={StaticResource BoolToColorConverter}}"
                                     ToolTip.Tip="Spotify Connection Status"/>
                            <TextBlock Text="Spotify" FontSize="11" Foreground="#999" VerticalAlignment="Center"/>
                            <Rectangle Width="1" Height="12" Fill="#444" Margin="4,0"/>
                            <!-- Phase 6: Share Health LED (click to open Sharing/Folders settings) -->
                            <Button Command="{Binding StatusBar.OpenShareSettingsCommand}"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="0"
                                    ToolTip.Tip="{Binding StatusBar.ShareHealthTooltip}">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <Ellipse Width="8" Height="8"
                                             Fill="{Binding StatusBar.ShareHealthColor}"/>
                                    <TextBlock Text="Share" FontSize="11" Foreground="#999" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Center: Smart Status text & Global Activity -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                    <!-- Global Activity Spinner -->
                    <TextBlock Text="⏳" 
                               FontSize="14" 
                               Foreground="#4EC9B0"
                               IsVisible="{Binding IsGlobalActivityActive}"/>
                               
                    <TextBlock Text="{Binding StatusText}" 
                               FontSize="12" 
                               Foreground="#DDD" 
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>

                        <Border Background="#252526"
                            CornerRadius="4"
                            Padding="6,2"
                            ToolTip.Tip="{Binding StatusBar.AdaptiveLaneTooltip}">
                        <TextBlock Text="{Binding StatusBar.AdaptiveLaneReadout}"
                               FontSize="11"
                               Foreground="#9CDCFE"
                               VerticalAlignment="Center"/>
                        </Border>

                        <Border Background="#252526"
                            CornerRadius="4"
                            Padding="6,2"
                            ToolTip.Tip="{Binding StatusBar.SearchPressureTooltip}">
                        <TextBlock Text="{Binding StatusBar.SearchPressureReadout}"
                               FontSize="11"
                               Foreground="#D7BA7D"
                               VerticalAlignment="Center"/>
                        </Border>
                               
                    <Button Command="{Binding ExecuteBrainTestCommand}"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="4"
                            ToolTip.Tip="Run Smart Logic Verification"
                            VerticalAlignment="Center">
                        <TextBlock Text="🧠" FontSize="12" Opacity="0.5"/>
                    </Button>

                    <TextBlock Text="{Binding ApplicationVersion, StringFormat='v{0}'}" 
                               Foreground="#555"
                               FontSize="10"
                               VerticalAlignment="Center"
                               Margin="4,0,0,0"/>
                </StackPanel>

                <!-- Right: Activity Monitor & System Controls -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Spacing="16">
                    <!-- Activity Monitor Group -->
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <!-- Downloads -->
                        <StackPanel Orientation="Horizontal" Spacing="6" ToolTip.Tip="Downloads: In Progress / Completed / Failed">
                            <TextBlock Text="📥" FontSize="12" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding TodoCount}" Foreground="#4EC9B0" FontWeight="Bold" FontSize="12" VerticalAlignment="Center"/>
                            <TextBlock Text="✓" FontSize="10" Foreground="#AAA" Margin="4,0,0,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding SuccessfulCount}" Foreground="#AAA" FontSize="11" VerticalAlignment="Center"/>
                            
                            <StackPanel Orientation="Horizontal" IsVisible="{Binding FailedCount}" Margin="4,0,0,0">
                                <TextBlock Text="⚠️" FontSize="10" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding FailedCount}" Foreground="#F44336" FontSize="11" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>

                        <Rectangle Width="1" Height="16" Fill="#333"/>

                        <!-- Analysis -->
                        <StackPanel Orientation="Horizontal" Spacing="6" ToolTip.Tip="Analysis Queue: Pending / Done">
                            <TextBlock Text="🧠" FontSize="12" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding AnalysisQueueCount}" Foreground="#C586C0" FontWeight="Bold" FontSize="12" VerticalAlignment="Center"/>
                            <TextBlock Text="done" FontSize="10" Foreground="#666" VerticalAlignment="Bottom" Margin="2,0,0,1"/>
                        </StackPanel>
                    </StackPanel>

                    <Border Width="1" Height="20" Background="#404040"/>

                    <!-- System Controls -->
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <!-- Condensed Zoom -->
                        <Button Command="{Binding ZoomOutCommand}" Background="Transparent" BorderThickness="0" Padding="4" ToolTip.Tip="Zoom Out">
                            <TextBlock Text="🔍-" FontSize="12" Foreground="#888"/>
                        </Button>
                        <TextBlock Text="{Binding UIScalePercentage}" Foreground="#666" FontSize="10" VerticalAlignment="Center" MinWidth="30" TextAlignment="Center"/>
                        <Button Command="{Binding ZoomInCommand}" Background="Transparent" BorderThickness="0" Padding="4" ToolTip.Tip="Zoom In">
                            <TextBlock Text="🔍+" FontSize="12" Foreground="#888"/>
                        </Button>

                        <Rectangle Width="1" Height="16" Fill="#333" Margin="4,0"/>

                        <Button Command="{Binding TogglePlayerCommand}" 
                                Background="Transparent" 
                                BorderThickness="0" 
                                Padding="6,4"
                                ToolTip.Tip="Toggle Music Player">
                            <TextBlock Text="🎵" Foreground="{Binding IsPlayerSidebarVisible, Converter={StaticResource ActiveColorConverter}}" FontSize="14"/>
                        </Button>

                        <Button Command="{Binding NavigatePlayerCommand}"
                                Background="#221DB954"
                                BorderBrush="#1DB954"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="10,4"
                                ToolTip.Tip="Open Full Player View">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="▣" FontSize="12" Foreground="#DFFFE8"/>
                                <TextBlock Text="PLAYER" FontSize="10" FontWeight="Bold" Foreground="#DFFFE8"/>
                            </StackPanel>
                        </Button>
                        
                        <Button Command="{Binding TogglePlayerLocationCommand}" 
                                Background="Transparent" 
                                BorderThickness="0" 
                                Padding="6,4"
                                ToolTip.Tip="Switch Player Location (Sidebar/Bottom)">
                            <TextBlock Text="{Binding IsPlayerAtBottom, Converter={StaticResource PlayerDockIconConverter}}" 
                                       FontSize="14" Foreground="#A0A0A0"/>
                        </Button>
                        
                        <Button Command="{Binding NavigateSettingsCommand}"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="6,4"
                                ToolTip.Tip="Settings">
                            <TextBlock Text="⚙️" FontSize="14" Foreground="#A0A0A0"/>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content Area with Sidebars -->
        <Grid Grid.Row="1" ColumnDefinitions="Auto,*">
            
            <!-- Left Navigation Sidebar -->
            <Border Grid.Column="0" 
                    Background="{StaticResource DeepBackgroundBrush}" 
                    BorderBrush="{StaticResource BorderBrush}" 
                    Classes="nav-sidebar"
                    Classes.mini="{Binding IsNavigationMini}">
                <Border.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Show ACQUIRE" IsChecked="{Binding IsAcquireVisible}" ToggleType="CheckBox"/>
                        <MenuItem Header="Show ENRICH" IsChecked="{Binding IsEnrichVisible}" ToggleType="CheckBox"/>
                        <MenuItem Header="Show CURATE" IsChecked="{Binding IsCurateVisible}" ToggleType="CheckBox"/>
                        <MenuItem Header="Show DELIVER" IsChecked="{Binding IsDeliverVisible}" ToggleType="CheckBox"/>
                        <MenuItem Header="Show SYSTEM" IsChecked="{Binding IsSystemVisible}" ToggleType="CheckBox"/>
                        <Separator/>
                        <MenuItem Header="Zen Mode (F10)" IsChecked="{Binding IsZenMode}" ToggleType="CheckBox"/>
                    </ContextMenu>
                </Border.ContextMenu>
                <ScrollViewer>
                    <StackPanel Margin="0,16,0,0" Spacing="8">
                        
                        <!-- ACQUIRE -->
                        <StackPanel IsVisible="{Binding IsAcquireVisible}">
                            <Border Classes="GroupHeader" Padding="16,8,0,4">
                                <TextBlock Text="ACQUIRE" Classes="GroupTitle" FontSize="11" FontWeight="Bold" Foreground="#666" LetterSpacing="1"/>
                            </Border>
                            
                            <StackPanel Spacing="2">
                                <Button Classes="nav" Command="{Binding NavigateSearchCommand}"
                                        ToolTip.Tip="Search"
                                        Classes.selected="{Binding CurrentPageType, Converter={StaticResource EqualityConverter}, ConverterParameter={x:Static models:PageType.Search}}">
                                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="16,0">
                                        <TextBlock Text="🔍" FontSize="16"/>
                                        <TextBlock Text="Search" FontSize="14"/>
                                    </StackPanel>
                                </Button>

                                <Button Classes="nav" Command="{Binding NavigateProjectsCommand}"
                                        ToolTip.Tip="Inbox"
                                        Classes.selected="{Binding CurrentPageType, Converter={StaticResource EqualityConverter}, ConverterParameter={x:Static models:PageType.Projects}}">
                                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="16,0">
                                        <TextBlock Text="📥" FontSize="16"/>
                                        <TextBlock Text="Inbox" FontSize="14"/>
                                    </StackPanel>
                                </Button>

                                <Button Classes="nav" Command="{Binding NavigateImportCommand}"
                                        ToolTip.Tip="Import"
                                        Classes.selected="{Binding CurrentPageType, Converter={StaticResource EqualityConverter}, ConverterParameter={x:Static models:PageType.Import}}">
                                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="16,0">
                                        <TextBlock Text="🔗" FontSize="16"/>
                                        <TextBlock Text="Import" FontSize="14"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </StackPanel>

                        <Border Height="1" Background="#333" Margin="12,12"/>

                        <!-- SYSTEM UTILITIES -->
                        <StackPanel IsVisible="{Binding IsSystemVisible}">
                            <Border Classes="GroupHeader" Padding="16,8,0,4">
                                <TextBlock Text="SYSTEM" Classes="GroupTitle" FontSize="11" FontWeight="Bold" Foreground="#666" LetterSpacing="1"/>
                            </Border>

                            <StackPanel Spacing="2">
                                 <Button Classes="nav" Command="{Binding NavigateHomeCommand}"
                                        ToolTip.Tip="Dashboard"
                                        Classes.selected="{Binding CurrentPageType, Converter={StaticResource EqualityConverter}, ConverterParameter={x:Static models:PageType.Home}}">
                                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="16,0">
                                        <TextBlock Text="🏠" FontSize="16"/>
                                        <TextBlock Text="Dashboard" FontSize="14"/>
                                    </StackPanel>
                                </Button>

                                <Button Classes="nav" Command="{Binding NavigateLibraryCommand}"
                                        ToolTip.Tip="Library"
                                        Classes.selected="{Binding CurrentPageType, Converter={StaticResource EqualityConverter}, ConverterParameter={x:Static models:PageType.Library}}">
                                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="16,0">
                                        <TextBlock Text="📚" FontSize="16"/>
                                        <TextBlock Text="Library" FontSize="14"/>
                                    </StackPanel>
                                </Button>

                                <Button Classes="nav" Command="{Binding NavigateAnalysisCommand}"
                                        ToolTip.Tip="Analysis Pipeline"
                                        Classes.selected="{Binding CurrentPageType, Converter={StaticResource EqualityConverter}, ConverterParameter={x:Static models:PageType.Analysis}}">
                                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="16,0">
                                        <TextBlock Text="🔬" FontSize="16"/>
                                        <TextBlock Text="Analysis" FontSize="14"/>
                                    </StackPanel>
                                </Button>

                                <Button Classes="nav" Command="{Binding NavigatePlayerCommand}"
                                        ToolTip.Tip="Player"
                                        Classes.selected="{Binding CurrentPageType, Converter={StaticResource EqualityConverter}, ConverterParameter={x:Static models:PageType.Player}}">
                                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="16,0">
                                        <TextBlock Text="🎛️" FontSize="16"/>
                                        <TextBlock Text="Player" FontSize="14"/>
                                    </StackPanel>
                                </Button>

                                <Button Classes="nav" Command="{Binding NavigateSettingsCommand}"
                                        ToolTip.Tip="Settings"
                                        Classes.selected="{Binding CurrentPageType, Converter={StaticResource EqualityConverter}, ConverterParameter={x:Static models:PageType.Settings}}">
                                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="16,0">
                                        <TextBlock Text="⚙️" FontSize="16"/>
                                        <TextBlock Text="Settings" FontSize="14"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Center Content Area with Global Contextual Sidebar -->
            <SplitView Grid.Column="1"
                       IsPaneOpen="{Binding IsGlobalSidebarOpen}"
                       DisplayMode="Inline"
                       PanePlacement="Right"
                       OpenPaneLength="450">
                
                <SplitView.Pane>
                    <Border Background="#252526" BorderBrush="#3E3E3E" BorderThickness="1,0,0,0">
                        <Grid RowDefinitions="Auto,*">
                            <Border Grid.Row="0" Padding="12" Background="#1E1E1E" BorderBrush="#3E3E3E" BorderThickness="0,0,0,1">
                                <Grid ColumnDefinitions="Auto,*,Auto">
                                    <TextBlock Text="{Binding Sidebar.ModeIcon}" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Sidebar.ModeLabel}" FontWeight="Bold" VerticalAlignment="Center" Foreground="#DDD"/>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
                                        <Button Classes="tool" Command="{Binding Sidebar.Close}" Content="✖" Foreground="#888"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            
                            <ContentControl Grid.Row="1" Content="{Binding Sidebar.CurrentContent}">
                                <ContentControl.DataTemplates>
                                    <DataTemplate DataType="vmCore:PlayerViewModel">
                                        <views:PlayerControl/>
                                    </DataTemplate>
                                    
                                    <DataTemplate DataType="vmDownloads:UnifiedTrackViewModel">
                                        <controls:TrackInspector/>
                                    </DataTemplate>

                                    <DataTemplate DataType="vmCore:AnalyzedSearchResultViewModel">
                                        <controls:SearchInspector/>
                                    </DataTemplate>
                                </ContentControl.DataTemplates>
                            </ContentControl>
                        </Grid>
                    </Border>
                </SplitView.Pane>

                <Grid Background="#1E1E1E">
                    <TransitioningContentControl Content="{Binding CurrentPage}">
                        <TransitioningContentControl.PageTransition>
                            <CrossFade Duration="0:0:0.25"/>
                        </TransitioningContentControl.PageTransition>
                    </TransitioningContentControl>

                    <Border Background="#1E1E1E"
                            IsVisible="{Binding CurrentPage, Converter={x:Static ObjectConverters.IsNull}}">
                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Spacing="10">
                            <TextBlock Text="Page failed to load"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#DDFFFFFF"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Returning to Home usually restores the shell."
                                       FontSize="12"
                                       Foreground="#99FFFFFF"
                                       HorizontalAlignment="Center"/>
                            <Button Content="Go Home"
                                    Command="{Binding NavigateHomeCommand}"
                                    HorizontalAlignment="Center"
                                    Padding="16,8"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </SplitView>

        </Grid>

        <!-- Login Overlay -->
        <Grid Grid.RowSpan="3" 
              Background="#DD000000" 
              IsVisible="{Binding ConnectionViewModel.IsLoginOverlayVisible}" 
              ZIndex="1000">
            <Border Background="#252526" 
                    CornerRadius="8" 
                    Padding="32"
                    Width="420"
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Center"
                    BorderBrush="#404040"
                    BorderThickness="1">
                <StackPanel Spacing="12">
                    <TextBlock Text="Sign in to Soulseek" 
                               FontSize="20" 
                               FontWeight="Bold" 
                               Foreground="White" 
                               Margin="0,0,0,12"
                               HorizontalAlignment="Center"/>

                    <TextBlock Text="Username" Foreground="#A0A0A0" FontSize="12"/>
                    <TextBox Text="{Binding ConnectionViewModel.Username, Mode=TwoWay}" 
                             Watermark="Username"
                             Padding="12,8"
                             FontSize="14"/>

                    <TextBlock Text="Password" Foreground="#A0A0A0" FontSize="12"/>
                    <TextBox x:Name="LoginPasswordBox" 
                             Watermark="Password"
                             PasswordChar="●"
                             Padding="12,8"
                             FontSize="14"/>

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <CheckBox Content="Remember me" 
                                  IsChecked="{Binding ConnectionViewModel.RememberPassword, Mode=TwoWay}" 
                                  Foreground="White"/>
                        <CheckBox Content="Auto-connect" 
                                  IsChecked="{Binding ConnectionViewModel.AutoConnectEnabled, Mode=TwoWay}" 
                                  Foreground="White"/>
                    </StackPanel>

                    <Button Classes="primary"
                            Content="Connect" 
                            Command="{Binding ConnectionViewModel.LoginCommand}" 
                            CommandParameter="{Binding #LoginPasswordBox.Text}"
                            Height="44"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Margin="0,8,0,0"/>
                    
                    <Button Content="Maybe Later" 
                            Command="{Binding ConnectionViewModel.DismissLoginCommand}"
                            Background="Transparent" 
                            Foreground="#A0A0A0" 
                            FontSize="12"
                            BorderThickness="0" 
                            Padding="0,12"
                            HorizontalContentAlignment="Center">
                        <Button.Styles>
                            <Style Selector="Button:pointerover">
                                <Setter Property="Foreground" Value="White"/>
                            </Style>
                        </Button.Styles>
                    </Button>

                    <TextBlock Text="{Binding ConnectionViewModel.StatusText}" 
                               Foreground="#FFB347" 
                               FontSize="12" 
                               TextWrapping="Wrap"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
        
        <!-- Bottom Player Drawer -->
        <Border Grid.Row="2" 
                Background="#252526" 
                BorderBrush="#3E3E3E" 
                BorderThickness="0,1,0,0"
                Height="100">
             <Border.IsVisible>
                <MultiBinding Converter="{x:Static BoolConverters.And}">
                    <Binding Path="IsPlayerAtBottomVisible"/>
                    <Binding Path="PlayerViewModel.IsPlayerVisible"/>
                </MultiBinding>
            </Border.IsVisible>
             <Grid>
                 <views:HorizontalPlayerControl DataContext="{Binding PlayerViewModel}"/>
             </Grid>
        </Border>

        <Grid Grid.RowSpan="3"
              Background="#F20B1018"
              IsVisible="{Binding PlayerViewModel.IsExpandedPlayerOpen}"
              ZIndex="950">
            <views:ExpandedPlayerView DataContext="{Binding PlayerViewModel}"/>
        </Grid>

        </Grid>
</Window>
