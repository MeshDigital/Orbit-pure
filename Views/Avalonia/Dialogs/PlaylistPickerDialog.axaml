<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="using:SLSKDONET.Models"
        xmlns:vm="using:SLSKDONET.ViewModels.Library"
        x:Class="SLSKDONET.Views.Avalonia.Dialogs.PlaylistPickerDialog"
        Title="Add to Playlist" Width="400" Height="480"
        WindowStartupLocation="CenterOwner"
        Background="#151520" TransparencyLevelHint="AcrylicBlur"
        ExtendClientAreaToDecorationsHint="True">

    <Grid RowDefinitions="Auto,*,Auto,Auto" Margin="20">
        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="8" Margin="0,10,0,16">
            <TextBlock Text="Add Selected Tracks to Playlist" FontSize="18" FontWeight="SemiBold" Foreground="White"/>
            <TextBlock Text="Choose an existing playlist or create a new one." FontSize="12" Foreground="#AAA"/>
        </StackPanel>

        <!-- Existing Playlists List -->
        <ListBox Grid.Row="1" ItemsSource="{Binding Playlists}" 
                 SelectedItem="{Binding SelectedPlaylist}"
                 Background="#1E1E2E" BorderBrush="#3E3E42" BorderThickness="1"
                 CornerRadius="8" Margin="0,0,0,16">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="models:PlaylistJob">
                    <Grid ColumnDefinitions="Auto,*" Margin="4">
                        <TextBlock Grid.Column="0" Text="🎵" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding SourceTitle}" Foreground="White" FontWeight="Medium" FontSize="13"/>
                            <TextBlock Text="{Binding TotalTracks, StringFormat='{}{0} tracks'}" Foreground="#777" FontSize="11"/>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Create New Playlist Section -->
        <StackPanel Grid.Row="2" Spacing="8" Margin="0,0,0,16">
            <TextBlock Text="Or Create New Playlist" FontSize="12" FontWeight="SemiBold" Foreground="#4EC9B0"/>
            <TextBox Text="{Binding NewPlaylistName, Mode=TwoWay}" 
                     Watermark="Enter new playlist name..."
                     Background="#1E1E2E" Foreground="White" 
                     BorderThickness="1" BorderBrush="#3E3E42"
                     CornerRadius="6" Padding="10,8"/>
        </StackPanel>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12">
            <Button Content="Cancel" Click="Cancel_Click" Background="Transparent" Foreground="#AAA" Padding="16,8"/>
            <Button Content="Add to Playlist" Click="Save_Click" 
                    IsEnabled="{Binding CanConfirm}"
                    Background="#4EC9B0" Foreground="#151520" Padding="16,8" CornerRadius="6" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>
