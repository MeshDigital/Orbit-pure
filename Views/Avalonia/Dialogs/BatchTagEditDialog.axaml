<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SLSKDONET.ViewModels.Library"
        x:Class="SLSKDONET.Views.Avalonia.Dialogs.BatchTagEditDialog"
        Title="Batch Edit Tags" Width="420" Height="580"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="#151520" TransparencyLevelHint="AcrylicBlur"
        ExtendClientAreaToDecorationsHint="True">

    <Grid RowDefinitions="Auto,*,Auto" Margin="20">
        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="8" Margin="0,10,0,16">
            <TextBlock Text="Edit Track Tags" FontSize="18" FontWeight="SemiBold" Foreground="White"/>
            <TextBlock Text="Modify metadata for selected tracks." FontSize="12" Foreground="#AAA"/>
            <Border Background="#204EC9B0" CornerRadius="4" Padding="8" Margin="0,4,0,0">
                <TextBlock Text="💡 Blank fields keep their original values. Filename rename is single-track only."
                           Foreground="#4EC9B0" FontSize="11" TextWrapping="Wrap"/>
            </Border>
        </StackPanel>

        <!-- Form Fields -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="14" Margin="0,0,10,0">
                <!-- Artist -->
                <StackPanel Spacing="5">
                    <TextBlock Text="Artist" Foreground="#AAA" FontSize="12" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding Artist, Mode=TwoWay}" Watermark="Keep original artist"
                             Background="#1E1E2E" Foreground="White" BorderThickness="1" BorderBrush="#3E3E42"
                             CornerRadius="6" Padding="10,8"/>
                </StackPanel>

                <!-- Title -->
                <StackPanel Spacing="5">
                    <TextBlock Text="Track Title" Foreground="#AAA" FontSize="12" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding Title, Mode=TwoWay}" Watermark="Keep original title"
                             Background="#1E1E2E" Foreground="White" BorderThickness="1" BorderBrush="#3E3E42"
                             CornerRadius="6" Padding="10,8"/>
                </StackPanel>

                <!-- Album -->
                <StackPanel Spacing="5">
                    <TextBlock Text="Album" Foreground="#AAA" FontSize="12" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding Album, Mode=TwoWay}" Watermark="Keep original album"
                             Background="#1E1E2E" Foreground="White" BorderThickness="1" BorderBrush="#3E3E42"
                             CornerRadius="6" Padding="10,8"/>
                </StackPanel>

                <!-- Genre -->
                <StackPanel Spacing="5">
                    <TextBlock Text="Genre" Foreground="#AAA" FontSize="12" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding Genre, Mode=TwoWay}" Watermark="Keep original genre"
                             Background="#1E1E2E" Foreground="White" BorderThickness="1" BorderBrush="#3E3E42"
                             CornerRadius="6" Padding="10,8"/>
                </StackPanel>

                <!-- Year -->
                <StackPanel Spacing="5">
                    <TextBlock Text="Year" Foreground="#AAA" FontSize="12" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding Year, Mode=TwoWay}" Watermark="Keep original year (e.g. 2026)"
                             Background="#1E1E2E" Foreground="White" BorderThickness="1" BorderBrush="#3E3E42"
                             CornerRadius="6" Padding="10,8"/>
                </StackPanel>

                <!-- File Name (single-track only) -->
                <StackPanel Spacing="5">
                    <TextBlock Text="File Name (without extension)" Foreground="#AAA" FontSize="12" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding NewFileName, Mode=TwoWay}"
                             Watermark="{Binding FileNameWatermark}"
                             IsEnabled="{Binding IsSingleTrack}"
                             Background="#1E1E2E" Foreground="White" BorderThickness="1" BorderBrush="#3E3E42"
                             CornerRadius="6" Padding="10,8"/>
                    <TextBlock IsVisible="{Binding !IsSingleTrack}"
                               Text="Select a single track to enable file rename."
                               Foreground="#666" FontSize="10"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12" Margin="0,16,0,0">
            <Button Content="Cancel" Click="Cancel_Click" Background="Transparent" Foreground="#AAA" Padding="16,8"/>
            <Button Content="Save" Click="Save_Click"
                    IsEnabled="{Binding CanSave}"
                    Background="#4EC9B0" Foreground="#151520" Padding="16,8" CornerRadius="6" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>
