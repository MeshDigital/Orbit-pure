<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SLSKDONET.ViewModels"
             xmlns:avConverters="clr-namespace:SLSKDONET.Views.Avalonia.Converters"
             x:Class="SLSKDONET.Views.Avalonia.SimilarTracksPanel"
             x:DataType="vm:SimilarTracksViewModel"
             Background="#1A1A1A" Foreground="White">

    <UserControl.Styles>
        <Style Selector="TextBlock.label">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#999"/>
        </Style>
        <Style Selector="TextBlock.value">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Border.row">
            <Setter Property="Background" Value="#242424"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>
        <Style Selector="Border.row:pointerover">
            <Setter Property="Background" Value="#2E2E2E"/>
        </Style>
        <Style Selector="Border.row:pointerover Button.addBtn">
            <Setter Property="Opacity" Value="1"/>
        </Style>
        <Style Selector="Border.bridgeRow">
            <Setter Property="Background" Value="#1E2A20"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="BorderBrush" Value="#2D5A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style Selector="Border.ddBadge">
            <Setter Property="Background" Value="#2A1A00"/>
            <Setter Property="BorderBrush" Value="#FF9800"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="5,2"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
        </Style>
        <Style Selector="TextBlock.miniScore">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="#888"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,Auto,*,Auto,Auto">

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8" Spacing="8">
            <TextBlock Text="Similar Tracks" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"
                       IsVisible="{Binding !IsBridgeMode}"/>
            <TextBlock Text="Bridge Mode" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"
                       Foreground="#4EC9B0"
                       IsVisible="{Binding IsBridgeMode}"/>
            <Border IsVisible="{Binding IsBusy}"
                    CornerRadius="10" Background="#3A3A3A"
                    Padding="8,3" VerticalAlignment="Center">
                <TextBlock Text="Loading…" FontSize="11" Foreground="#AAA"/>
            </Border>
            <Button Command="{Binding RefreshCommand}"
                    Background="Transparent" Padding="4" VerticalAlignment="Center"
                    ToolTip.Tip="Refresh" IsEnabled="{Binding !IsBusy}">
                <TextBlock Text="↺" FontSize="14"/>
            </Button>
            <Button Command="{Binding ShowSimilarModeCommand}"
                    Background="#2D2D2D" Foreground="#DDD"
                    BorderBrush="#4A4A4A" BorderThickness="1"
                    CornerRadius="4" Padding="8,3" VerticalAlignment="Center"
                    IsVisible="{Binding IsBridgeMode}">
                <TextBlock Text="← Similar List" FontSize="11"/>
            </Button>
            <!-- Add All button (shown when there are results) -->
            <Button Command="{Binding AddAllCommand}"
                    Background="#1E3A2B" Foreground="#4EC9B0"
                    BorderBrush="#4EC9B0" BorderThickness="1"
                    CornerRadius="4" Padding="8,3" VerticalAlignment="Center"
                    ToolTip.Tip="Add all results to a project"
                    IsVisible="{Binding Results.Count, Converter={x:Static avConverters:NumericConverters.IsNotZero}}">
                <TextBlock Text="+ Add All" FontSize="11"/>
            </Button>
            <!-- Bridge suggestions button -->
            <Button Command="{Binding BridgeSuggestionsCommand}"
                    Background="#1A2A3A" Foreground="#63B3ED"
                    BorderBrush="#63B3ED" BorderThickness="1"
                    CornerRadius="4" Padding="8,3" VerticalAlignment="Center"
                    ToolTip.Tip="Find bridge-friendly transition ideas"
                    IsEnabled="{Binding !IsBusy}">
                <TextBlock Text="↻ Bridge Ideas" FontSize="11"/>
            </Button>
        </StackPanel>

        <!-- Status message -->
        <TextBlock Grid.Row="1"
                   Text="{Binding StatusMessage}"
                   IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                   FontSize="12" Foreground="#888" Margin="0,0,0,8" TextWrapping="Wrap"/>

        <!-- Results list (standard similarity mode) -->
        <ScrollViewer Grid.Row="2" HorizontalScrollBarVisibility="Disabled"
                      IsVisible="{Binding !IsBridgeMode}">
            <ItemsControl ItemsSource="{Binding Results}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:SimilarTrackRowViewModel">
                        <Border Classes="row">
                            <Grid ColumnDefinitions="*,Auto,Auto,Auto">

                                <!-- Title + Artist + score strip -->
                                <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2">
                                    <Grid ColumnDefinitions="Auto,*">
                                        <!-- Double-drop lightning badge -->
                                        <Border Grid.Column="0"
                                                Classes="ddBadge"
                                                IsVisible="{Binding IsPotentialDoubleDrop}"
                                                Margin="0,0,5,0"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="⚡" FontSize="11"/>
                                        </Border>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Title, FallbackValue='(loading…)'}"
                                                   Classes="value" TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                    <TextBlock Text="{Binding Artist, FallbackValue=''}"
                                               Classes="label" TextTrimming="CharacterEllipsis"/>

                                    <!-- Harmony + Beat labels (shown once loaded) -->
                                    <StackPanel Orientation="Horizontal" Spacing="6"
                                                IsVisible="{Binding HarmonyLabel,
                                                    Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                        <TextBlock Text="{Binding HarmonyLabel}"
                                                   Classes="miniScore" Foreground="#9F7AEA"/>
                                        <TextBlock Text="·" Classes="miniScore"/>
                                        <TextBlock Text="{Binding BeatLabel}"
                                                   Classes="miniScore" Foreground="#63B3ED"/>
                                        <!-- Drop label only when meaningful -->
                                        <TextBlock Text="{Binding DropLabel}"
                                                   Classes="miniScore"
                                                   Foreground="#FF9800"
                                                   IsVisible="{Binding DropLabel,
                                                       Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Key badge -->
                                <Border Grid.Column="1" CornerRadius="4"
                                        Background="#2D3748" Padding="5,2" Margin="6,0"
                                        VerticalAlignment="Center"
                                        IsVisible="{Binding Key, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                    <TextBlock Text="{Binding Key}" FontSize="11" Foreground="#90CDF4"/>
                                </Border>

                                <!-- Score columns: Overall + mini H/B/D breakdown -->
                                <StackPanel Grid.Column="2" VerticalAlignment="Center"
                                            Spacing="2" MinWidth="56">
                                    <!-- Overall score (prominent) -->
                                    <StackPanel Orientation="Vertical">
                                        <TextBlock Classes="label" Text="Match" HorizontalAlignment="Center" FontSize="9"/>
                                        <TextBlock Classes="value" HorizontalAlignment="Center" FontSize="13"
                                                   Text="{Binding OverallScore, StringFormat={}{0:P0}}"/>
                                    </StackPanel>
                                    <!-- Mini H/B/D bars -->
                                    <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto"
                                          HorizontalAlignment="Center">
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="H" Classes="miniScore" HorizontalAlignment="Center" Foreground="#9F7AEA"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="B" Classes="miniScore" HorizontalAlignment="Center" Foreground="#63B3ED"/>
                                        <TextBlock Grid.Row="0" Grid.Column="2" Text="D" Classes="miniScore" HorizontalAlignment="Center" Foreground="#FC8181"/>
                                        <TextBlock Grid.Row="1" Grid.Column="0" HorizontalAlignment="Center"
                                                   FontSize="10" Foreground="#9F7AEA"
                                                   Text="{Binding HarmonyScore, StringFormat={}{0:P0}}"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" HorizontalAlignment="Center"
                                                   FontSize="10" Foreground="#63B3ED"
                                                   Text="{Binding BeatScore, StringFormat={}{0:P0}}"/>
                                        <TextBlock Grid.Row="1" Grid.Column="2" HorizontalAlignment="Center"
                                                   FontSize="10" Foreground="#FC8181"
                                                   Text="{Binding DropSonicScore, StringFormat={}{0:P0}}"/>
                                    </Grid>
                                </StackPanel>

                                <!-- Add to playlist button -->
                                <Button Grid.Column="3"
                                        Command="{Binding AddToPlaylistCommand}"
                                        Background="Transparent" Foreground="#4EC9B0"
                                        BorderThickness="0" Padding="6,4" Margin="4,0,0,0"
                                        VerticalAlignment="Center"
                                        ToolTip.Tip="Add to project/playlist"
                                        Opacity="0.6" Classes="addBtn">
                                    <TextBlock Text="+" FontSize="16" FontWeight="Bold"/>
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Bridge Mode header -->
        <Border Grid.Row="3" IsVisible="{Binding IsBridgeMode}"
                Background="#141E16" CornerRadius="6" Padding="10,6" Margin="0,4,0,4">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="🌉" FontSize="14" VerticalAlignment="Center"/>
                <TextBlock Text="Bridging tracks" FontSize="12" FontWeight="SemiBold"
                           Foreground="#4EC9B0" VerticalAlignment="Center"/>
                <TextBlock Text="BPM-matched · Camelot compatible"
                           FontSize="11" Foreground="#666" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Bridge suggestions list -->
        <ScrollViewer Grid.Row="4" HorizontalScrollBarVisibility="Disabled"
                      IsVisible="{Binding IsBridgeMode}">
            <ItemsControl ItemsSource="{Binding BridgeSuggestions}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:SimilarTrackRowViewModel">
                        <Border Classes="bridgeRow">
                            <Grid ColumnDefinitions="*,Auto,Auto,Auto">

                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Title, FallbackValue='(loading…)'}"
                                               Classes="value" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding Artist, FallbackValue=''}"
                                               Classes="label" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>

                                <Border Grid.Column="1" CornerRadius="4"
                                        Background="#1A3A2B" Padding="5,2" Margin="6,0"
                                        VerticalAlignment="Center"
                                        IsVisible="{Binding Key, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                    <TextBlock Text="{Binding Key}" FontSize="11" Foreground="#68D391"/>
                                </Border>

                                <StackPanel Grid.Column="2" VerticalAlignment="Center" MinWidth="48">
                                    <TextBlock Classes="label" Text="Score" HorizontalAlignment="Center"/>
                                    <TextBlock Classes="value" HorizontalAlignment="Center"
                                               Text="{Binding Score, StringFormat={}{0:P0}}"/>
                                </StackPanel>

                                <Button Grid.Column="3"
                                        Command="{Binding AddToPlaylistCommand}"
                                        Background="Transparent" Foreground="#68D391"
                                        BorderThickness="0" Padding="6,4" Margin="4,0,0,0"
                                        VerticalAlignment="Center"
                                        ToolTip.Tip="Add bridging track to project/playlist"
                                        Opacity="0.6" Classes="addBtn">
                                    <TextBlock Text="+" FontSize="16" FontWeight="Bold"/>
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

    </Grid>
</UserControl>
