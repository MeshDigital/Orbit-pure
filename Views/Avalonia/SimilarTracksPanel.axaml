<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SLSKDONET.ViewModels"
             x:Class="SLSKDONET.Views.Avalonia.SimilarTracksPanel"
             x:DataType="vm:SimilarTracksViewModel"
             Background="#1A1A1A" Foreground="White">

    <UserControl.Styles>
        <Style Selector="TextBlock.label">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#999"/>
        </Style>
        <Style Selector="TextBlock.value">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Border.row">
            <Setter Property="Background" Value="#242424"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>
        <Style Selector="Border.row:pointerover">
            <Setter Property="Background" Value="#2E2E2E"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8" Spacing="8">
            <TextBlock Text="Similar Tracks" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
            <Border IsVisible="{Binding IsBusy}"
                    CornerRadius="10" Background="#3A3A3A"
                    Padding="8,3" VerticalAlignment="Center">
                <TextBlock Text="Loading…" FontSize="11" Foreground="#AAA"/>
            </Border>
            <Button Command="{Binding RefreshCommand}"
                    Background="Transparent" Padding="4" VerticalAlignment="Center"
                    ToolTip.Tip="Refresh" IsEnabled="{Binding !IsBusy}">
                <TextBlock Text="↺" FontSize="14"/>
            </Button>
        </StackPanel>

        <!-- Status message -->
        <TextBlock Grid.Row="1"
                   Text="{Binding StatusMessage}"
                   IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                   FontSize="12" Foreground="#888" Margin="0,0,0,8" TextWrapping="Wrap"/>

        <!-- Results list -->
        <ScrollViewer Grid.Row="2" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding Results}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:SimilarTrackRowViewModel">
                        <Border Classes="row">
                            <Grid ColumnDefinitions="*,Auto,Auto">

                                <!-- Title + Artist -->
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Title, FallbackValue='(loading…)'}"
                                               Classes="value" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding Artist, FallbackValue=''}"
                                               Classes="label" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>

                                <!-- Key badge -->
                                <Border Grid.Column="1" CornerRadius="4"
                                        Background="#2D3748" Padding="5,2" Margin="6,0"
                                        VerticalAlignment="Center"
                                        IsVisible="{Binding Key, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                    <TextBlock Text="{Binding Key}" FontSize="11" Foreground="#90CDF4"/>
                                </Border>

                                <!-- Similarity score -->
                                <StackPanel Grid.Column="2" VerticalAlignment="Center" MinWidth="48">
                                    <TextBlock Classes="label" Text="Match" HorizontalAlignment="Center"/>
                                    <TextBlock Classes="value" HorizontalAlignment="Center"
                                               Text="{Binding Score, StringFormat={}{0:P0}}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

    </Grid>
</UserControl>
