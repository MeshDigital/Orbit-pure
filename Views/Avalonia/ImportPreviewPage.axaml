<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:SLSKDONET.Views.Avalonia.Controls"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="700"
             x:Class="SLSKDONET.Views.Avalonia.ImportPreviewPage"
             Background="#1E1E1E" Foreground="White">

    <UserControl.Styles>
        <Style Selector="TextBox.clean-grid-edit">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="Margin" Value="0"/>
        </Style>
        <Style Selector="TextBox.clean-grid-edit:pointerover">
            <Setter Property="Background" Value="#15FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#44FFFFFF"/>
        </Style>
        <Style Selector="TextBox.clean-grid-edit:focus">
            <Setter Property="Background" Value="#2A2A2E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#0078D4"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,*,Auto">
        
        <!-- Header -->
        <Border Grid.Row="0" Background="#252526" Padding="24,20" BorderBrush="#3E3E3E" BorderThickness="0,0,0,1">
            <StackPanel Spacing="8">
                <TextBlock Text="{Binding SourceTitle}" FontSize="24" FontWeight="Bold" Foreground="White"/>
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="{Binding SourceType}" FontSize="13" Foreground="#A0A0A0"/>
                    <TextBlock Text="•" FontSize="13" Foreground="#666"/>
                    <TextBlock Text="{Binding TrackCount, StringFormat='{}{0} tracks'}" FontSize="13" Foreground="#A0A0A0"/>
                </StackPanel>
            </StackPanel>
        </Border>



        <!-- Deduplication Alert Banner -->
        <Border Grid.Row="1" Background="#663300" BorderBrush="#FF8C00" BorderThickness="0,0,0,1" Padding="16,12" IsVisible="{Binding IsDuplicate}">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                    <TextBlock Text="⚠️" FontSize="20" VerticalAlignment="Center"/>
                    <StackPanel Spacing="4">
                        <TextBlock Text="Existing Playlist Found" FontWeight="Bold" Foreground="#FFD580"/>
                        <TextBlock Foreground="#FFD580" FontSize="12"
                                   Text="{Binding ExistingTrackCount, StringFormat='We found an existing playlist with {0} tracks. Do you want to merge new tracks into it?'}"/>
                    </StackPanel>
                </StackPanel>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <Button Command="{Binding SelectMergeCandidatesCommand}" Background="#1AFFFFFF" Foreground="White" Padding="12,6" CornerRadius="4">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="✨" FontSize="14"/>
                            <TextBlock Text="Select Merge Candidates" FontSize="12"/>
                        </StackPanel>
                    </Button>
                    <Border Width="1" Height="16" Background="#444" Margin="4,0"/>
                    <Button Command="{Binding CreateNewCommand}" Background="#424242" Foreground="White" Padding="12,6" CornerRadius="4">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="📄" FontSize="14"/> <!-- Clone Icon -->
                            <TextBlock Text="Create New Clone" FontSize="12"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding MergeCommand}" Background="#FF8C00" Foreground="Black" Padding="12,6" CornerRadius="4">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="🔗" FontSize="14"/> <!-- Link/Merge Icon -->
                            <TextBlock Text="Merge to Existing" FontSize="12" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Toolbar -->
        <Border Grid.Row="2" Background="#1F2A33" BorderBrush="#355066" BorderThickness="0,0,0,1" Padding="16,10" IsVisible="{Binding HasMergeTargets}">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <TextBlock Text="Target Playlist" Foreground="#9FC8E6" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold"/>

                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding MergeTargets}"
                          SelectedItem="{Binding SelectedMergeTarget, Mode=TwoWay}"
                          MinWidth="360"
                          Background="#172028"
                          BorderBrush="#355066"
                          BorderThickness="1"
                          Foreground="White"
                          Padding="8,4">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Subtitle}" Foreground="#90A4B5" FontSize="11"/>
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <Button Grid.Column="2"
                        Command="{Binding UseSelectedMergeTargetCommand}"
                        Background="#2C6E49"
                        Foreground="White"
                        Padding="12,6"
                        CornerRadius="4"
                        IsEnabled="{Binding !IsMergeTargetLoading}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="🔗" FontSize="12"/>
                        <TextBlock Text="Use As Merge Target" FontSize="12"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <Border Grid.Row="3" Background="#1E1E1E" Padding="24,16" BorderBrush="#3E3E3E" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto">
                <!-- Left: Selection Actions -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                    <Button Command="{Binding SelectAllCommand}"
                            Background="#0078D4"
                            Foreground="White"
                            Padding="12,8"
                            CornerRadius="6">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="☑" FontSize="14"/>
                            <TextBlock Text="Select All" FontSize="13"/>
                        </StackPanel>
                    </Button>
                    
                    <Button Command="{Binding DeselectAllCommand}"
                            Background="#424242"
                            Foreground="White"
                            Padding="12,8"
                            CornerRadius="6">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="☐" FontSize="14"/>
                            <TextBlock Text="Deselect All" FontSize="13"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding SelectMissingCommand}"
                            Background="#2D2D2D"
                            Foreground="White"
                            Padding="12,8"
                            CornerRadius="6">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="✨" FontSize="14"/>
                            <TextBlock Text="Select Missing" FontSize="13"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                
                <!-- Right: Status -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12">
                    <Border Background="#1A4CAF50" 
                            CornerRadius="12" 
                            Padding="10,6"
                            IsVisible="{Binding !!SelectedCount}">
                        <TextBlock Text="{Binding SelectedCount, StringFormat='{}{0} selected'}" 
                                   FontSize="12" 
                                   Foreground="White"
                                   FontWeight="SemiBold"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Track List -->
        <Grid Grid.Row="4" RowDefinitions="Auto,*">
            <!-- Column Header -->
            <controls:VirtualGridHeader Grid.Row="0" Margin="16,0,16,4">
                <controls:VirtualGridHeader.HeaderContent>
                    <Grid ColumnDefinitions="50,3*,2*,3*,2*,80,100">
                        <TextBlock Grid.Column="0" Text="✓" FontSize="10" FontWeight="Bold" Foreground="#888" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="RAW INPUT" FontSize="10" FontWeight="Bold" Foreground="#888" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="4,0"/>
                        <TextBlock Grid.Column="2" Text="ARTIST" FontSize="10" FontWeight="Bold" Foreground="#888" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="4,0"/>
                        <TextBlock Grid.Column="3" Text="TITLE" FontSize="10" FontWeight="Bold" Foreground="#888" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="4,0"/>
                        <TextBlock Grid.Column="4" Text="ALBUM" FontSize="10" FontWeight="Bold" Foreground="#888" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="4,0"/>
                        <TextBlock Grid.Column="5" Text="LENGTH" FontSize="10" FontWeight="Bold" Foreground="#888" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="4,0"/>
                        <TextBlock Grid.Column="6" Text="STATUS" FontSize="10" FontWeight="Bold" Foreground="#888" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                </controls:VirtualGridHeader.HeaderContent>
            </controls:VirtualGridHeader>

            <!-- Results Grid -->
            <controls:VirtualGrid Grid.Row="1" ItemsSource="{Binding ImportedTracks}" SelectionMode="Multiple">
                <controls:VirtualGrid.ItemTemplate>
                    <DataTemplate>
                        <Border Classes="track-row" Height="40" Background="Transparent" BorderBrush="#2D2D2D" BorderThickness="0,0,0,1" Padding="16,0">
                            <Grid ColumnDefinitions="50,3*,2*,3*,2*,80,100">
                                <!-- Column 0: Selection Checkbox -->
                                <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected, Mode=TwoWay}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                
                                <!-- Column 1: Raw Input -->
                                <TextBlock Grid.Column="1" Text="{Binding RawInputDisplay}" Foreground="#888" FontSize="11" Margin="4,0" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                
                                <!-- Column 2: Artist -->
                                <Grid Grid.Column="2" ColumnDefinitions="*,Auto" Margin="4,0" VerticalAlignment="Center">
                                    <TextBox Grid.Column="0" Text="{Binding Artist, Mode=TwoWay}" Classes="clean-grid-edit" FontSize="11"/>
                                    <!-- Cleaned badge -->
                                    <Border Grid.Column="1" Background="#33FF8C00" CornerRadius="4" Padding="4,2" Margin="6,0,0,0" VerticalAlignment="Center" IsVisible="{Binding IsCleaned}" ToolTip.Tip="{Binding CleanTooltip}">
                                        <TextBlock Text="⚠" FontSize="9" Foreground="#FF8C00" FontWeight="SemiBold"/>
                                    </Border>
                                </Grid>
                                
                                <!-- Column 3: Title -->
                                <Grid Grid.Column="3" ColumnDefinitions="*,Auto" Margin="4,0" VerticalAlignment="Center">
                                    <TextBox Grid.Column="0" Text="{Binding Title, Mode=TwoWay}" Classes="clean-grid-edit" FontSize="11"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" Margin="6,0,2,0" VerticalAlignment="Center" IsVisible="{Binding HasAnyChange}">
                                        <Button Command="{Binding RestoreOriginalCommand}" ToolTip.Tip="Restore original artist &amp; title" Background="Transparent" Foreground="#FF8C00" BorderThickness="0" Padding="4,2" FontSize="12" VerticalAlignment="Center" Cursor="Hand">↩</Button>
                                    </StackPanel>
                                </Grid>
                                
                                <!-- Column 4: Album -->
                                <TextBlock Grid.Column="4" Text="{Binding Model.Album}" FontSize="11" Margin="4,0" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" IsVisible="{Binding $parent[Window].Bounds.Width, Converter={StaticResource WidthToVisibilityConverter}, ConverterParameter=800}"/>
                                
                                <!-- Column 5: Length -->
                                <TextBlock Grid.Column="5" Text="{Binding Model.Length, StringFormat='{}{0:mm\\:ss}'}" FontSize="11" Margin="4,0" VerticalAlignment="Center" IsVisible="{Binding $parent[Window].Bounds.Width, Converter={StaticResource WidthToVisibilityConverter}, ConverterParameter=600}"/>
                                
                                <!-- Column 6: Status (IN LIB / DUPE? / MISSING) -->
                                <Panel Grid.Column="6" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       IsVisible="{Binding $parent[Window].Bounds.Width, Converter={StaticResource WidthToVisibilityConverter}, ConverterParameter=500}">
                                    <!-- Already in library (exact or high-confidence fuzzy match) -->
                                    <Border CornerRadius="4" Padding="6,3" Background="#1A6B2A" IsVisible="{Binding IsInLibrary}">
                                        <TextBlock Text="IN LIB" FontSize="10" Foreground="#5ED67F" FontWeight="SemiBold"/>
                                    </Border>
                                    <!-- Fuzzy near-match warning (75–88% similarity) -->
                                    <Border CornerRadius="4" Padding="6,3" Background="#5C4A00"
                                            IsVisible="{Binding IsPossibleDuplicate}"
                                            ToolTip.Tip="{Binding PossibleDuplicateTooltip}">
                                        <TextBlock Text="DUPE?" FontSize="10" Foreground="#F5C842" FontWeight="SemiBold"/>
                                    </Border>
                                    <!-- Not found in library -->
                                    <Border CornerRadius="4" Padding="6,3" Background="#2A2A2A" IsVisible="{Binding IsMissingFromLibrary}">
                                        <TextBlock Text="MISSING" FontSize="10" Foreground="#888" FontWeight="SemiBold"/>
                                    </Border>
                                </Panel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </controls:VirtualGrid.ItemTemplate>
            </controls:VirtualGrid>
        </Grid>

        <!-- Footer Actions -->
        <Border Grid.Row="5" 
                Background="#252526" 
                BorderBrush="#3E3E3E" 
                BorderThickness="0,1,0,0" 
                Padding="24,16">
            <Grid ColumnDefinitions="*,Auto">
                <!-- Left: Status Message -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" 
                                 Width="24" 
                                 Height="24"
                                 Foreground="#4CAF50"
                                 IsVisible="{Binding IsLoading}"/>
                    <TextBlock Text="{Binding StatusMessage}" 
                               Foreground="#A0A0A0" 
                               FontSize="13"
                               VerticalAlignment="Center"/>
                </StackPanel>
                
                <!-- Right: Action Buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12">
                    <Button Command="{Binding CancelCommand}"
                            Background="#424242"
                            Foreground="White"
                            Padding="16,10"
                            CornerRadius="6">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="✕" FontSize="14"/>
                            <TextBlock Text="Cancel" FontSize="13"/>
                        </StackPanel>
                    </Button>
                    
                    <Button Command="{Binding AddToLibraryCommand}"
                            Classes="primary"
                            IsEnabled="{Binding CanAddToLibrary}"
                            Padding="20,10"
                            CornerRadius="6">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="📚" FontSize="14"/>
                            <TextBlock Text="Add to Library" FontSize="13" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
