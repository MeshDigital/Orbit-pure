<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:SLSKDONET.ViewModels"
             xmlns:conv="clr-namespace:SLSKDONET.Converters"
             xmlns:viewConv="clr-namespace:SLSKDONET.Views.Avalonia.Converters"
             x:Class="SLSKDONET.Views.Avalonia.PlaylistGridView"
             x:DataType="vm:LibraryViewModel">

    <UserControl.Resources>
        <viewConv:BitmapValueConverter x:Key="BitmapValueConverter"/>
        <conv:RatioToWidthConverter x:Key="RatioToWidthConverter"/>
        <conv:ColorToBrushConverter x:Key="ColorToBrushConverter"/>
        <conv:CircularProgressConverter x:Key="CircularProgressConverter"/>
    </UserControl.Resources>

    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <ItemsRepeater ItemsSource="{Binding Projects.FilteredProjectCards}"
                       Margin="16">
            <ItemsRepeater.Layout>
                <UniformGridLayout MinItemWidth="200" MinColumnSpacing="12" MinRowSpacing="12"/>
            </ItemsRepeater.Layout>
            <ItemsRepeater.ItemTemplate>
                <DataTemplate x:DataType="vm:LibraryPlaylistCardViewModel">
                    <Grid Margin="8" Width="200" Height="280">
                        <Button Command="{Binding ((vm:LibraryViewModel)DataContext).Projects.OpenProjectCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding Model}"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="0"
                                Cursor="Hand">
                            <Border Width="200" Height="280"
                                Background="#1A1A1D"
                                CornerRadius="16"
                                BorderBrush="#2A2A2E"
                                BorderThickness="1"
                                ClipToBounds="True">

                            <!-- Health Ring Overlay -->
                            <Border.Styles>
                                <Style Selector="Border:pointerover">
                                    <Setter Property="BorderBrush" Value="#3E3E42"/>
                                    <Setter Property="Effect">
                                        <DropShadowEffect BlurRadius="8" Color="#000000" Opacity="0.3"/>
                                    </Setter>
                                </Style>
                            </Border.Styles>

                            <Grid>
                                <!-- Cover Image -->
                                <Border Height="160" VerticalAlignment="Top" Background="#262629">
                                    <Grid>
                                        <PathIcon Data="{StaticResource icons_library}"
                                                 Width="40" Height="40"
                                                 Foreground="#333"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center"/>
                                        <Image Source="{Binding CoverImageUrl, Converter={StaticResource BitmapValueConverter}}"
                                               Stretch="UniformToFill"/>
                                    </Grid>
                                </Border>

                                  <!-- Health Ring (Circular Forensic Ring) + Acrylic Flyout -->
                                  <Grid Width="54" Height="54"
                                      HorizontalAlignment="Right"
                                      VerticalAlignment="Top"
                                      Margin="0,10,10,0"
                                      PointerEntered="OnHealthRingPointerEntered"
                                      PointerExited="OnHealthRingPointerExited"
                                      ToolTip.Tip="{Binding HealthStatusText}">
                                    <Ellipse Width="54" Height="54"
                                             Stroke="#2F2F34"
                                             StrokeThickness="5"
                                             Fill="#99141418"/>
                                    <Path Data="{Binding LosslessRatio, Converter={StaticResource CircularProgressConverter}}"
                                          Stroke="{Binding HealthRingColor}"
                                          StrokeThickness="5"
                                          StrokeLineCap="Round"/>
                                    <TextBlock Text="{Binding LosslessRatio, StringFormat='{}{0:P0}'}"
                                               FontSize="10"
                                               FontWeight="Bold"
                                               Foreground="White"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>

                                    <FlyoutBase.AttachedFlyout>
                                        <Flyout Placement="BottomEdgeAlignedRight" ShowMode="TransientWithDismissOnPointerMoveAway">
                                            <Border Background="#B21A1A1D"
                                                    BorderBrush="#4A4A50"
                                                    BorderThickness="1"
                                                    CornerRadius="10"
                                                    Padding="12"
                                                    MaxWidth="260">
                                                <StackPanel Spacing="6">
                                                    <TextBlock Text="Forensic Snapshot"
                                                               Foreground="#DCDCDC"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding ForensicFlyoutText}"
                                                               Foreground="#AFAFB6"
                                                               FontSize="11"
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Border>
                                        </Flyout>
                                    </FlyoutBase.AttachedFlyout>

                                </Grid>

                                <!-- Playlist Info -->
                                <StackPanel Margin="16,176,16,16" Spacing="8">
                                    <TextBlock Text="{Binding Name}"
                                               Foreground="White"
                                               FontWeight="SemiBold"
                                               FontSize="16"
                                               TextTrimming="CharacterEllipsis"
                                               MaxLines="2"
                                               Height="40"/>

                                    <TextBlock Text="{Binding TrackCountText}"
                                               Foreground="#808080"
                                               FontSize="12"/>

                                    <!-- Health Status -->
                                    <Border Background="{Binding HealthRingColor, Converter={StaticResource ColorToBrushConverter}}"
                                            CornerRadius="12"
                                            Padding="8,4"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding LosslessRatio, StringFormat='Lossless: {0:P0}'}"
                                                   Foreground="White"
                                                   FontSize="11"
                                                   FontWeight="Bold"/>
                                    </Border>
                                </StackPanel>

                            </Grid>
                            </Border>
                        </Button>

                        <!-- Quick Action: Queue full album immediately -->
                        <Button HorizontalAlignment="Right"
                                VerticalAlignment="Bottom"
                                Margin="0,0,10,10"
                                Padding="8,4"
                                CornerRadius="10"
                                Background="#CC0E1D33"
                                BorderBrush="#00BFFF"
                                BorderThickness="1"
                                ToolTip.Tip="Queue complete album now"
                                Command="{Binding ((vm:LibraryViewModel)DataContext).DownloadAlbumCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding Model}">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="⬇" FontSize="11" Foreground="#00BFFF"/>
                                <TextBlock Text="Album" FontSize="11" FontWeight="SemiBold" Foreground="#00BFFF"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </DataTemplate>
            </ItemsRepeater.ItemTemplate>
        </ItemsRepeater>
    </ScrollViewer>
</UserControl>