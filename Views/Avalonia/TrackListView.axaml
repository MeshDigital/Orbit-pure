<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:SLSKDONET.ViewModels"
             xmlns:models="clr-namespace:SLSKDONET.Models"
             xmlns:controls="clr-namespace:SLSKDONET.Views.Avalonia.Controls"
             xmlns:conv="clr-namespace:SLSKDONET.Views.Avalonia.Converters"
             xmlns:rootConv="clr-namespace:SLSKDONET.Converters"
             xmlns:dg="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls.DataGrid"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="SLSKDONET.Views.Avalonia.TrackListView"
             x:DataType="vm:Library.TrackListViewModel"
             Background="#1E1E1E">

    <UserControl.Resources>
        <rootConv:BoolToWidthConverter x:Key="BoolToWidthConverter"/>
        <rootConv:BoolToTextConverter x:Key="BoolToTextConverter"/>
        <conv:TrackStateToColorConverter x:Key="TrackStateToColorConverter"/>
        <conv:TrackStateToTextConverter x:Key="TrackStateToTextConverter"/>
        <x:Double x:Key="NonDownloadedOpacity">0.3</x:Double>
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="DataGridColumnHeader">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="12,8"/>
        </Style>
        <Style Selector="DataGridRow:pointerover /template/ Border#RowBorder">
            <Setter Property="Background" Value="#2A2A2E"/>
        </Style>
        <Style Selector="DataGridRow:selected /template/ Border#RowBorder">
            <Setter Property="Background" Value="#3300BFFF"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,*">

        <!-- Search Bar -->
        <Border Grid.Row="0" Background="#252526" BorderBrush="#3E3E3E" BorderThickness="0,0,0,1" Padding="16,12">
            <Grid ColumnDefinitions="Auto,*">
                <TextBlock Grid.Column="0" Text="🔍" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#888"/>
                <TextBox Grid.Column="1" Text="{Binding SearchText, Mode=TwoWay}" Watermark="Search tracks, artists, albums..." Background="Transparent" BorderThickness="0" Padding="0,8" Foreground="White"/>
            </Grid>
        </Border>

        <!-- Status Filters: primary chips only -->
        <Border Grid.Row="1" Background="#1E1E1E" BorderBrush="#3E3E3E" BorderThickness="0,0,0,1" Padding="16,8">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6">
                    <ToggleButton Content="All" IsChecked="{Binding IsFilterAll, Mode=TwoWay}" Classes="chip" Padding="12,5" FontSize="11"/>
                    <ToggleButton Content="Downloaded" IsChecked="{Binding IsFilterDownloaded, Mode=TwoWay}" Classes="chip" Padding="12,5" FontSize="11"/>
                    <ToggleButton Content="Pending" IsChecked="{Binding IsFilterPending, Mode=TwoWay}" Classes="chip" Padding="12,5" FontSize="11"/>
                    <ToggleButton Content="Review" IsChecked="{Binding IsFilterNeedsReview, Mode=TwoWay}" Classes="chip danger" Padding="12,5" FontSize="11"/>
                    <ToggleButton Content="❤️" IsChecked="{Binding IsFilterLiked, Mode=TwoWay}" Classes="chip" Padding="10,5" FontSize="11" ToolTip.Tip="Show Liked Tracks Only"/>
                </StackPanel>
                <TextBlock Grid.Column="1" Text="{Binding FilteredTracks.Count, StringFormat='{}{0} tracks'}"
                           VerticalAlignment="Center" FontSize="11" Foreground="#555"/>
            </Grid>
        </Border>

        <!-- Library Toolbar: Format/Quality flyouts + Column toggles -->
        <Border Grid.Row="2" Background="#1A1A1D" BorderBrush="#3E3E3E" BorderThickness="0,0,0,1" Padding="16,6">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">

                    <!-- Format + Quality filter flyout -->
                    <DropDownButton Classes="tool" Padding="10,5" FontSize="11" CornerRadius="6"
                                    ToolTip.Tip="Filter by format or quality tier">
                        <TextBlock Text="Filters" FontSize="11"/>
                        <DropDownButton.Flyout>
                            <Flyout Placement="BottomEdgeAlignedLeft">
                                <Border Background="#1E1E2A" BorderBrush="#2E3040" BorderThickness="1" CornerRadius="8" Padding="14,12">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="FORMAT" FontSize="9" FontWeight="Bold" Foreground="#555" LetterSpacing="1"/>
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <ToggleButton Content="FLAC" IsChecked="{Binding IsFilterFlac, Mode=TwoWay}" Classes="chip" Padding="10,5" FontSize="11" ToolTip.Tip="FLAC tracks only"/>
                                            <ToggleButton Content="MP3" IsChecked="{Binding IsFilterMp3, Mode=TwoWay}" Classes="chip" Padding="10,5" FontSize="11" ToolTip.Tip="MP3 tracks only"/>
                                            <ToggleButton Content="WAV" IsChecked="{Binding IsFilterWav, Mode=TwoWay}" Classes="chip" Padding="10,5" FontSize="11" ToolTip.Tip="WAV tracks only"/>
                                            <ToggleButton Content="Lossless" IsChecked="{Binding IsFilterLossless, Mode=TwoWay}" Classes="chip" Padding="10,5" FontSize="11" ToolTip.Tip="Lossless formats (FLAC, WAV, AIFF, ALAC)"/>
                                        </StackPanel>
                                        <Border Background="#2A2A35" Height="1" Margin="0,4"/>
                                        <TextBlock Text="QUALITY" FontSize="9" FontWeight="Bold" Foreground="#555" LetterSpacing="1"/>
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <ToggleButton Content="🥇 Gold" IsChecked="{Binding IsFilterQualityGold, Mode=TwoWay}" Classes="chip" Padding="10,5" FontSize="11" ToolTip.Tip="Gold-verified tracks only"/>
                                            <ToggleButton Content="🛡️ Verified" IsChecked="{Binding IsFilterQualityVerified, Mode=TwoWay}" Classes="chip" Padding="10,5" FontSize="11" ToolTip.Tip="Verified tracks only"/>
                                            <ToggleButton Content="📉 Review" IsChecked="{Binding IsFilterQualityReview, Mode=TwoWay}" Classes="chip danger" Padding="10,5" FontSize="11" ToolTip.Tip="Tracks needing forensic review"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Flyout>
                        </DropDownButton.Flyout>
                    </DropDownButton>

                    <!-- Inline text filter toggle -->
                    <ToggleButton Content="🔬 Text Filter" IsChecked="{Binding IsColumnFilterStripVisible, Mode=TwoWay}"
                                  Classes="chip" Padding="10,5" FontSize="11"
                                  ToolTip.Tip="Toggle per-column artist/title filters"/>

                    <!-- Add to Queue — only when tracks are selected -->
                    <Rectangle Width="1" Height="14" Fill="#444" VerticalAlignment="Center" Margin="4,0"
                               IsVisible="{Binding HasSelectedTracks}"/>
                    <Button Command="{Binding Operations.AddSelectedToQueueCommand}"
                            IsVisible="{Binding HasSelectedTracks}"
                            Padding="10,5" FontSize="11"
                            Background="#1A2A3A" Foreground="#00BFFF"
                            BorderBrush="#00BFFF" BorderThickness="1" CornerRadius="4"
                            ToolTip.Tip="Add selected tracks to queue">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="➕" FontSize="11" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding SelectedCountText}" FontSize="11" VerticalAlignment="Center"/>
                            <TextBlock Text="→ Queue" FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Columns flyout (right-aligned) -->
                <DropDownButton Grid.Column="1" Classes="tool" Padding="8,5" FontSize="11" CornerRadius="6"
                                ToolTip.Tip="Toggle column visibility">
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <TextBlock Text="⚙" FontSize="13" VerticalAlignment="Center"/>
                        <TextBlock Text="Columns" FontSize="11" VerticalAlignment="Center"/>
                    </StackPanel>
                    <DropDownButton.Flyout>
                        <Flyout Placement="BottomEdgeAlignedRight">
                            <Border Background="#1E1E2A" BorderBrush="#2E3040" BorderThickness="1" CornerRadius="8" Padding="14,12">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="SHOW COLUMNS" FontSize="9" FontWeight="Bold" Foreground="#555" LetterSpacing="1"/>
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <ToggleButton Content="Format" IsChecked="{Binding IsFormatColumnVisible, Mode=TwoWay}" Classes="chip" Padding="10,5" FontSize="11" ToolTip.Tip="Toggle Format column"/>
                                        <ToggleButton Content="Forensics" IsChecked="{Binding IsForensicsColumnVisible, Mode=TwoWay}" Classes="chip" Padding="10,5" FontSize="11" ToolTip.Tip="Toggle Forensics column"/>
                                        <ToggleButton Content="Duration" IsChecked="{Binding IsDurationColumnVisible, Mode=TwoWay}" Classes="chip" Padding="10,5" FontSize="11" ToolTip.Tip="Toggle Duration column"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Flyout>
                    </DropDownButton.Flyout>
                </DropDownButton>
            </Grid>
        </Border>

        <!-- Inline Column Filters (Task 10.4) -->
        <Border Grid.Row="3"
                Background="#1A1A1E"
                BorderBrush="#3E3E3E"
                BorderThickness="0,0,0,1"
                Padding="16,8"
                IsVisible="{Binding IsColumnFilterStripVisible}">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock Text="Artist:" VerticalAlignment="Center" FontSize="11" Foreground="#888"/>
                <Border Background="#252526" BorderBrush="#3E3E3E" BorderThickness="1" CornerRadius="4" Padding="8,4" MinWidth="160">
                    <TextBox Text="{Binding FilterArtist, Mode=TwoWay}"
                             Watermark="Filter by artist..."
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="0"
                             FontSize="11"
                             Foreground="White"/>
                </Border>
                <TextBlock Text="Title:" VerticalAlignment="Center" FontSize="11" Foreground="#888"/>
                <Border Background="#252526" BorderBrush="#3E3E3E" BorderThickness="1" CornerRadius="4" Padding="8,4" MinWidth="200">
                    <TextBox Text="{Binding FilterTitle, Mode=TwoWay}"
                             Watermark="Filter by title..."
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="0"
                             FontSize="11"
                             Foreground="White"/>
                </Border>
                <Button Command="{Binding ToggleColumnFilterStripCommand}"
                        Padding="8,4" FontSize="10" Background="Transparent"
                        Foreground="#666" BorderThickness="0"
                        ToolTip.Tip="Close filter strip">✕</Button>
            </StackPanel>
        </Border>

        <!-- Track List -->
        <DataGrid Grid.Row="4" Name="TrackGrid" 
                  ItemsSource="{Binding FilteredTracks}"
                  CanUserSortColumns="True"
                  IsReadOnly="True"
                  Background="Transparent"
                  BorderThickness="0"
                  HeadersVisibility="Column"
                  Margin="0"
                  RowHeight="48"
                  Padding="16,0"
                  SelectionMode="Extended"
                  GridLinesVisibility="None"
                  AutoGenerateColumns="False">

            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Play Track" Command="{Binding Operations.PlayTrackCommand}">
                        <MenuItem.Icon><TextBlock Text="▶️" FontSize="12"/></MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Queue Track" Command="{Binding Operations.AddToQueueCommand}">
                        <MenuItem.Icon><TextBlock Text="➕" FontSize="12"/></MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Queue Selected Tracks" Command="{Binding Operations.AddSelectedToQueueCommand}">
                        <MenuItem.Icon><TextBlock Text="📋" FontSize="12"/></MenuItem.Icon>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="Analyse Track" Command="{Binding Operations.AnalyseTrackCommand}">
                         <MenuItem.Icon><TextBlock Text="🔬" FontSize="12"/></MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Hard Retry" Command="{Binding Operations.HardRetryCommand}">
                         <MenuItem.Icon><TextBlock Text="🔄" FontSize="12"/></MenuItem.Icon>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="Open Folder" Command="{Binding Operations.OpenFolderCommand}">
                         <MenuItem.Icon><TextBlock Text="📂" FontSize="12"/></MenuItem.Icon>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="Export to CSV" Command="{Binding BulkExportCsvCommand}">
                         <MenuItem.Icon><TextBlock Text="📊" FontSize="12"/></MenuItem.Icon>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="Remove Track" Command="{Binding Operations.RemoveTrackCommand}" InputGesture="Delete">
                         <MenuItem.Icon><TextBlock Text="🗑️" FontSize="12" Foreground="#FF5252"/></MenuItem.Icon>
                    </MenuItem>
                </ContextMenu>
            </DataGrid.ContextMenu>

            <DataGrid.Columns>
                <!-- Column 0: Artwork/Status -->
                <DataGridTemplateColumn Header="" Width="60">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate DataType="vm:PlaylistTrackViewModel">
                            <Panel Margin="12,0,0,0">
                                <Border Width="32" Height="32" CornerRadius="4" Background="#2A2A2E" ClipToBounds="True">
                                    <Panel>
                                        <Image Source="{Binding Artwork.Image}" Stretch="UniformToFill" IsVisible="{Binding Artwork.Image, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                                        <TextBlock Text="🎵" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.3" IsVisible="{Binding Artwork.Image, Converter={x:Static ObjectConverters.IsNull}}"/>
                                        
                                        <!-- Status Overlay -->
                                        <Border VerticalAlignment="Bottom" HorizontalAlignment="Right" Width="8" Height="8" Margin="0,0,2,2" CornerRadius="4" 
                                                Background="{Binding State, Converter={StaticResource TrackStateToColorConverter}}"
                                                BorderBrush="#1E1E1E" BorderThickness="1"/>
                                    </Panel>
                                </Border>
                            </Panel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="Q" Width="44">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate DataType="vm:PlaylistTrackViewModel">
                            <Button Command="{Binding $parent[UserControl].DataContext.Operations.AddToQueueCommand}"
                                    CommandParameter="{Binding}"
                                    Width="22"
                                    Height="22"
                                    Padding="0"
                                    Margin="8,0,0,0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Opacity="0.55"
                                    ToolTip.Tip="Queue track (or selected tracks)">
                                <TextBlock Text="＋" FontSize="11" Foreground="#6F8192" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Button>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Artist Column -->
                <DataGridTemplateColumn Header="ARTIST" Width="180" CanUserSort="True" SortMemberPath="Artist">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate DataType="vm:PlaylistTrackViewModel">
                            <TextBlock Text="{Binding Artist}" VerticalAlignment="Center" Margin="12,0" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Title Column -->
                <DataGridTemplateColumn Header="TITLE" Width="*" CanUserSort="True" SortMemberPath="Title">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate DataType="vm:PlaylistTrackViewModel">
                            <TextBlock Text="{Binding Title}" VerticalAlignment="Center" Margin="12,0" Foreground="White" FontWeight="SemiBold" FontSize="12"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- X-Ray Sparkline Column -->
                <DataGridTemplateColumn Header="ENERGY" Width="90">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate DataType="vm:PlaylistTrackViewModel">
                            <controls:SparklineControl
                                Points="{Binding EnergyCurvePoints}"
                                LineBrush="#4EC9B0"
                                FillBrush="#224EC9B0"
                                LineThickness="1.2"
                                Height="22"
                                Margin="8,0"
                                VerticalAlignment="Center"
                                IsVisible="{Binding HasAnalysisData}"
                                ToolTip.Tip="Energy contour — analysed audio"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="FORMAT" Width="100" IsVisible="{Binding #TrackGrid.DataContext.IsFormatColumnVisible}">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate DataType="vm:PlaylistTrackViewModel">
                            <Border Background="#1A1F2C" BorderBrush="#3300BFFF" BorderThickness="1" CornerRadius="4" Padding="6,2" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="12,0">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="{Binding Format}" FontSize="9" FontWeight="Bold" Foreground="#00BFFF" Opacity="0.8"/>
                                    <TextBlock Text="{Binding Bitrate, StringFormat='{}{0}k'}" FontSize="9" Foreground="#00BFFF"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Forensic Verdict Column -->
                <DataGridTemplateColumn Header="FORENSICS" Width="120" IsVisible="{Binding #TrackGrid.DataContext.IsForensicsColumnVisible}">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate DataType="vm:PlaylistTrackViewModel">
                            <Border Background="{Binding IntegrityColor}"
                                    CornerRadius="10"
                                    Padding="8,3"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Margin="12,0"
                                    ToolTip.Tip="{Binding ForensicHudText}">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="{Binding IntegrityBadge}" FontSize="10"/>
                                    <TextBlock Text="{Binding ForensicVerdictText}"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Foreground="Black"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Duration Column -->
                <DataGridTemplateColumn Header="DURATION" Width="80" IsVisible="{Binding #TrackGrid.DataContext.IsDurationColumnVisible}">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate DataType="vm:PlaylistTrackViewModel">
                            <TextBlock Text="{Binding DurationDisplay}" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="12,0" Opacity="0.5"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>