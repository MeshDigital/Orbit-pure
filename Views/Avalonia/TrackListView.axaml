<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:SLSKDONET.ViewModels"
             xmlns:models="clr-namespace:SLSKDONET.Models"
             xmlns:controls="clr-namespace:SLSKDONET.Views.Avalonia.Controls"
             xmlns:views="clr-namespace:SLSKDONET.Views.Avalonia"
             xmlns:conv="clr-namespace:SLSKDONET.Views.Avalonia.Converters"
             xmlns:rootConv="clr-namespace:SLSKDONET.Converters"
             xmlns:dg="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls.DataGrid"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="SLSKDONET.Views.Avalonia.TrackListView"
             x:DataType="vm:Library.TrackListViewModel"
             Background="#1E1E1E">

    <UserControl.Resources>
        <rootConv:BoolToWidthConverter x:Key="BoolToWidthConverter"/>
        <rootConv:BoolToTextConverter x:Key="BoolToTextConverter"/>
        <conv:TrackStateToColorConverter x:Key="TrackStateToColorConverter"/>
        <conv:TrackStateToTextConverter x:Key="TrackStateToTextConverter"/>
        <x:Double x:Key="NonDownloadedOpacity">0.3</x:Double>
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="Button.sortableHeader">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.sortableHeader:pointerover">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="Button.sortableHeader TextBlock.label">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#555"/>
        </Style>
        <Style Selector="Button.sortableHeader:pointerover TextBlock.label">
            <Setter Property="Foreground" Value="#999"/>
        </Style>
        <Style Selector="Border.track-row">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#2A2A2E"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.15"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.track-row:pointerover">
            <Setter Property="Background" Value="#252528"/>
        </Style>
        <Style Selector="Border.track-row.selected">
            <Setter Property="Background" Value="#1A00BFFF"/>
        </Style>
        <Style Selector="Border.track-row.focused">
            <Setter Property="BorderBrush" Value="#4EC9B0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
        <!-- MixedInKey-style harmonic mixing highlight -->
        <Style Selector="Border.track-row.harmonic-match:not(.selected)">
            <Setter Property="Background" Value="#124EC9B0"/>
        </Style>
        <Style Selector="Border.key-badge">
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="Border.key-badge.harmonic-match">
            <Setter Property="BorderBrush" Value="#4EC9B0"/>
            <Setter Property="BorderThickness" Value="1.5"/>
        </Style>
        <Style Selector="Border.key-badge.exact-match">
            <Setter Property="BorderBrush" Value="White"/>
            <Setter Property="BorderThickness" Value="1.5"/>
        </Style>
        <Style Selector="Button.insert-affordance">
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="IsHitTestVisible" Value="False"/>
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.12"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.track-row:pointerover Button.insert-affordance">
            <Setter Property="Opacity" Value="1"/>
            <Setter Property="IsHitTestVisible" Value="True"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,*">

        <!-- Search Bar -->
        <Border Grid.Row="0" Background="#252526" BorderBrush="#3E3E3E" BorderThickness="0,0,0,1" Padding="16,12">
            <Grid ColumnDefinitions="Auto,*">
                <TextBlock Grid.Column="0" Text="🔍" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#888"/>
                <TextBox Grid.Column="1" Text="{Binding SearchText, Mode=TwoWay}" Watermark="Search tracks, artists, albums..." Background="Transparent" BorderThickness="0" Padding="0,8" Foreground="White"/>
            </Grid>
        </Border>

        <!-- Status Filters: primary chips only -->
        <Border Grid.Row="1" Background="#1E1E1E" BorderBrush="#3E3E3E" BorderThickness="0,0,0,1" Padding="16,8">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6">
                    <ToggleButton Content="All" IsChecked="{Binding IsFilterAll, Mode=TwoWay}" Classes="chip" Padding="12,5" FontSize="11"/>
                    <ToggleButton Content="Downloaded" IsChecked="{Binding IsFilterDownloaded, Mode=TwoWay}" Classes="chip" Padding="12,5" FontSize="11"/>
                    <ToggleButton Content="Pending" IsChecked="{Binding IsFilterPending, Mode=TwoWay}" Classes="chip" Padding="12,5" FontSize="11"/>
                    <ToggleButton Content="Review" IsChecked="{Binding IsFilterNeedsReview, Mode=TwoWay}" Classes="chip danger" Padding="12,5" FontSize="11"/>
                    <ToggleButton Content="❤️" IsChecked="{Binding IsFilterLiked, Mode=TwoWay}" Classes="chip" Padding="10,5" FontSize="11" ToolTip.Tip="Show Liked Tracks Only"/>
                </StackPanel>
                <TextBlock Grid.Column="1" Text="{Binding FilteredTracks.Count, StringFormat='{}{0} tracks'}"
                           VerticalAlignment="Center" FontSize="11" Foreground="#555"/>
            </Grid>
        </Border>

        <!-- Library Toolbar: Format/Quality flyouts + Column toggles -->
        <Border Grid.Row="2" Background="#1A1A1D" BorderBrush="#3E3E3E" BorderThickness="0,0,0,1" Padding="16,6">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">

                    <!-- Format + Quality filter flyout -->
                    <DropDownButton Classes="tool" Padding="10,5" FontSize="11" CornerRadius="6"
                                    ToolTip.Tip="Filter by format or quality tier">
                        <TextBlock Text="Filters" FontSize="11"/>
                        <DropDownButton.Flyout>
                            <Flyout Placement="BottomEdgeAlignedLeft">
                                <Border Background="#1E1E2A" BorderBrush="#2E3040" BorderThickness="1" CornerRadius="8" Padding="14,12">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="FORMAT" FontSize="9" FontWeight="Bold" Foreground="#555" LetterSpacing="1"/>
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <ToggleButton Content="FLAC" IsChecked="{Binding IsFilterFlac, Mode=TwoWay}" Classes="chip" Padding="10,5" FontSize="11" ToolTip.Tip="FLAC tracks only"/>
                                            <ToggleButton Content="MP3" IsChecked="{Binding IsFilterMp3, Mode=TwoWay}" Classes="chip" Padding="10,5" FontSize="11" ToolTip.Tip="MP3 tracks only"/>
                                            <ToggleButton Content="WAV" IsChecked="{Binding IsFilterWav, Mode=TwoWay}" Classes="chip" Padding="10,5" FontSize="11" ToolTip.Tip="WAV tracks only"/>
                                            <ToggleButton Content="Lossless" IsChecked="{Binding IsFilterLossless, Mode=TwoWay}" Classes="chip" Padding="10,5" FontSize="11" ToolTip.Tip="Lossless formats (FLAC, WAV, AIFF, ALAC)"/>
                                        </StackPanel>
                                        <Border Background="#2A2A35" Height="1" Margin="0,4"/>
                                        <TextBlock Text="QUALITY" FontSize="9" FontWeight="Bold" Foreground="#555" LetterSpacing="1"/>
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <ToggleButton Content="🥇 Gold" IsChecked="{Binding IsFilterQualityGold, Mode=TwoWay}" Classes="chip" Padding="10,5" FontSize="11" ToolTip.Tip="Gold-verified tracks only"/>
                                            <ToggleButton Content="🛡️ Verified" IsChecked="{Binding IsFilterQualityVerified, Mode=TwoWay}" Classes="chip" Padding="10,5" FontSize="11" ToolTip.Tip="Verified tracks only"/>
                                            <ToggleButton Content="📉 Review" IsChecked="{Binding IsFilterQualityReview, Mode=TwoWay}" Classes="chip danger" Padding="10,5" FontSize="11" ToolTip.Tip="Tracks needing forensic review"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Flyout>
                        </DropDownButton.Flyout>
                    </DropDownButton>

                    <!-- Inline text filter toggle -->
                    <ToggleButton Content="🔬 Text Filter" IsChecked="{Binding IsColumnFilterStripVisible, Mode=TwoWay}"
                                  Classes="chip" Padding="10,5" FontSize="11"
                                  ToolTip.Tip="Toggle per-column artist/title filters"/>

                    <!-- Add to Queue — only when tracks are selected -->
                    <Rectangle Width="1" Height="14" Fill="#444" VerticalAlignment="Center" Margin="4,0"
                               IsVisible="{Binding HasSelectedTracks}"/>
                    <Button Command="{Binding Operations.AddSelectedToQueueCommand}"
                            IsVisible="{Binding HasSelectedTracks}"
                            Padding="10,5" FontSize="11"
                            Background="#1A2A3A" Foreground="#00BFFF"
                            BorderBrush="#00BFFF" BorderThickness="1" CornerRadius="4"
                            ToolTip.Tip="Add selected tracks to queue">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="➕" FontSize="11" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding SelectedCountText}" FontSize="11" VerticalAlignment="Center"/>
                            <TextBlock Text="→ Queue" FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Columns flyout (right-aligned) -->
                <DropDownButton Grid.Column="1" Classes="tool" Padding="8,5" FontSize="11" CornerRadius="6"
                                ToolTip.Tip="Toggle column visibility">
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <TextBlock Text="⚙" FontSize="13" VerticalAlignment="Center"/>
                        <TextBlock Text="Columns" FontSize="11" VerticalAlignment="Center"/>
                    </StackPanel>
                    <DropDownButton.Flyout>
                        <Flyout Placement="BottomEdgeAlignedRight">
                            <Border Background="#1E1E2A" BorderBrush="#2E3040" BorderThickness="1" CornerRadius="8" Padding="14,12">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="SHOW COLUMNS" FontSize="9" FontWeight="Bold" Foreground="#555" LetterSpacing="1"/>
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <ToggleButton Content="Format" IsChecked="{Binding IsFormatColumnVisible, Mode=TwoWay}" Classes="chip" Padding="10,5" FontSize="11" ToolTip.Tip="Toggle Format column"/>
                                        <ToggleButton Content="Forensics" IsChecked="{Binding IsForensicsColumnVisible, Mode=TwoWay}" Classes="chip" Padding="10,5" FontSize="11" ToolTip.Tip="Toggle Forensics column"/>
                                        <ToggleButton Content="Duration" IsChecked="{Binding IsDurationColumnVisible, Mode=TwoWay}" Classes="chip" Padding="10,5" FontSize="11" ToolTip.Tip="Toggle Duration column"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Flyout>
                    </DropDownButton.Flyout>
                </DropDownButton>
            </Grid>
        </Border>

        <!-- Inline Column Filters (Task 10.4) -->
        <Border Grid.Row="3"
                Background="#1A1A1E"
                BorderBrush="#3E3E3E"
                BorderThickness="0,0,0,1"
                Padding="16,8"
                IsVisible="{Binding IsColumnFilterStripVisible}">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock Text="Artist:" VerticalAlignment="Center" FontSize="11" Foreground="#888"/>
                <Border Background="#252526" BorderBrush="#3E3E3E" BorderThickness="1" CornerRadius="4" Padding="8,4" MinWidth="160">
                    <TextBox Text="{Binding FilterArtist, Mode=TwoWay}"
                             Watermark="Filter by artist..."
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="0"
                             FontSize="11"
                             Foreground="White"/>
                </Border>
                <TextBlock Text="Title:" VerticalAlignment="Center" FontSize="11" Foreground="#888"/>
                <Border Background="#252526" BorderBrush="#3E3E3E" BorderThickness="1" CornerRadius="4" Padding="8,4" MinWidth="200">
                    <TextBox Text="{Binding FilterTitle, Mode=TwoWay}"
                             Watermark="Filter by title..."
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="0"
                             FontSize="11"
                             Foreground="White"/>
                </Border>
                <Button Command="{Binding ToggleColumnFilterStripCommand}"
                        Padding="8,4" FontSize="10" Background="Transparent"
                        Foreground="#666" BorderThickness="0"
                        ToolTip.Tip="Close filter strip">✕</Button>
            </StackPanel>
        </Border>
        <!-- Column Header -->
        <controls:VirtualGridHeader Grid.Row="4">
            <controls:VirtualGridHeader.HeaderContent>
                <Grid ColumnDefinitions="60,44,124,180,*,90,110,100,120,80,84">
                    <!-- Column 0: Artwork/Status (Empty) -->
                    <!-- Column 1: Q -->
                    <TextBlock Grid.Column="1" Text="Q" FontSize="10" FontWeight="Bold" Foreground="#555" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="8,0,0,0"/>
                    <!-- Column 2: INSERT -->
                    <TextBlock Grid.Column="2" Text="INSERT" FontSize="10" FontWeight="Bold" Foreground="#555" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="2,0,0,0"/>
                    <!-- Column 3: Artist -->
                    <Button Grid.Column="3" Classes="sortableHeader" Margin="12,0"
                            Command="{Binding SortByColumnCommand}" CommandParameter="{x:Static models:TrackSortColumn.Artist}">
                        <StackPanel Orientation="Horizontal" Spacing="3">
                            <TextBlock Classes="label" Text="ARTIST"/>
                            <TextBlock Classes="label" Text="▲" Foreground="#4EC9B0" IsVisible="{Binding IsSortedByArtistAscending}"/>
                            <TextBlock Classes="label" Text="▼" Foreground="#4EC9B0" IsVisible="{Binding IsSortedByArtistDescending}"/>
                        </StackPanel>
                    </Button>
                    <!-- Column 4: Title -->
                    <Button Grid.Column="4" Classes="sortableHeader" Margin="12,0"
                            Command="{Binding SortByColumnCommand}" CommandParameter="{x:Static models:TrackSortColumn.Title}">
                        <StackPanel Orientation="Horizontal" Spacing="3">
                            <TextBlock Classes="label" Text="TITLE"/>
                            <TextBlock Classes="label" Text="▲" Foreground="#4EC9B0" IsVisible="{Binding IsSortedByTitleAscending}"/>
                            <TextBlock Classes="label" Text="▼" Foreground="#4EC9B0" IsVisible="{Binding IsSortedByTitleDescending}"/>
                        </StackPanel>
                    </Button>
                    <!-- Column 5: Energy -->
                    <TextBlock Grid.Column="5" Text="ENERGY" FontSize="10" FontWeight="Bold" Foreground="#555" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="8,0"/>
                    <!-- Column 6: BPM / Key -->
                    <Button Grid.Column="6" Classes="sortableHeader" Margin="8,0"
                            Command="{Binding SortByColumnCommand}" CommandParameter="{x:Static models:TrackSortColumn.Bpm}"
                            ToolTip.Tip="Sort by BPM. Click a track to highlight harmonically compatible keys">
                        <StackPanel Orientation="Horizontal" Spacing="3">
                            <TextBlock Classes="label" Text="BPM / KEY"/>
                            <TextBlock Classes="label" Text="▲" Foreground="#4EC9B0" IsVisible="{Binding IsSortedByBpmAscending}"/>
                            <TextBlock Classes="label" Text="▼" Foreground="#4EC9B0" IsVisible="{Binding IsSortedByBpmDescending}"/>
                        </StackPanel>
                    </Button>
                    <!-- Column 7: Format -->
                    <TextBlock Grid.Column="7" Text="FORMAT" FontSize="10" FontWeight="Bold" Foreground="#555" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="12,0"
                               IsVisible="{Binding IsFormatColumnVisible}"/>
                    <!-- Column 8: Forensics -->
                    <TextBlock Grid.Column="8" Text="FORENSICS" FontSize="10" FontWeight="Bold" Foreground="#555" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="12,0"
                               IsVisible="{Binding IsForensicsColumnVisible}"/>
                    <!-- Column 9: Duration -->
                    <Button Grid.Column="9" Classes="sortableHeader" Margin="12,0" HorizontalAlignment="Right"
                            Command="{Binding SortByColumnCommand}" CommandParameter="{x:Static models:TrackSortColumn.Duration}"
                            IsVisible="{Binding IsDurationColumnVisible}">
                        <StackPanel Orientation="Horizontal" Spacing="3">
                            <TextBlock Classes="label" Text="▲" Foreground="#4EC9B0" IsVisible="{Binding IsSortedByDurationAscending}"/>
                            <TextBlock Classes="label" Text="▼" Foreground="#4EC9B0" IsVisible="{Binding IsSortedByDurationDescending}"/>
                            <TextBlock Classes="label" Text="DURATION"/>
                        </StackPanel>
                    </Button>
                    <!-- Column 10: Rating -->
                    <TextBlock Grid.Column="10" Text="RATING" FontSize="10" FontWeight="Bold" Foreground="#555" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="12,0"/>
                </Grid>
            </controls:VirtualGridHeader.HeaderContent>
        </controls:VirtualGridHeader>

        <controls:VirtualGrid Grid.Row="5" Name="TrackGrid" 
                              ItemsSource="{Binding FilteredTracks}"
                              SelectionMode="Multiple"
                              SelectionChanged="OnTrackGridSelectionChanged">
            <controls:VirtualGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Play Track" Command="{Binding Operations.PlayTrackCommand}">
                        <MenuItem.Icon><TextBlock Text="▶️" FontSize="12"/></MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Queue Track" Command="{Binding Operations.AddToQueueCommand}">
                        <MenuItem.Icon><TextBlock Text="➕" FontSize="12"/></MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Queue Selected Tracks" Command="{Binding Operations.AddSelectedToQueueCommand}">
                        <MenuItem.Icon><TextBlock Text="📋" FontSize="12"/></MenuItem.Icon>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="Analyse Track" Command="{Binding Operations.AnalyseTrackCommand}" IsEnabled="{Binding Operations.AreDependenciesHealthy}">
                         <MenuItem.Icon><TextBlock Text="🔬" FontSize="12"/></MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Hard Retry" Command="{Binding Operations.HardRetryCommand}" IsEnabled="{Binding Operations.AreDependenciesHealthy}">
                         <MenuItem.Icon><TextBlock Text="🔄" FontSize="12"/></MenuItem.Icon>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="Terminal: View Search Audit" Command="{Binding Operations.OpenAuditLogCommand}">
                         <MenuItem.Icon><TextBlock Text="📝" FontSize="12"/></MenuItem.Icon>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="Open Folder" Command="{Binding Operations.OpenFolderCommand}">
                         <MenuItem.Icon><TextBlock Text="📂" FontSize="12"/></MenuItem.Icon>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="Export to CSV" Command="{Binding BulkExportCsvCommand}">
                         <MenuItem.Icon><TextBlock Text="📊" FontSize="12"/></MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Edit Cues in Cue Forge" Command="{Binding Operations.OpenInCueForgeCommand}">
                         <MenuItem.Icon><TextBlock Text="🎯" FontSize="12"/></MenuItem.Icon>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="Remove Track" Command="{Binding Operations.RemoveTrackCommand}" InputGesture="Delete">
                         <MenuItem.Icon><TextBlock Text="🗑️" FontSize="12" Foreground="#FF5252"/></MenuItem.Icon>
                    </MenuItem>
                </ContextMenu>
            </controls:VirtualGrid.ContextMenu>

            <controls:VirtualGrid.ItemTemplate>
                <DataTemplate DataType="vm:PlaylistTrackViewModel">
                    <Border Classes="track-row"
                            Classes.harmonic-match="{Binding IsHarmonicMatch}"
                            Height="48"
                            Focusable="True">
                        <Grid ColumnDefinitions="60,44,124,180,*,90,110,100,120,80,84">
                            <!-- Column 0: Artwork/Status -->
                            <Panel Grid.Column="0" Margin="12,0,0,0">
                                <Border Width="32" Height="32" CornerRadius="4" Background="#2A2A2E" ClipToBounds="True">
                                    <Panel>
                                        <Image Source="{Binding Artwork.Image}" Stretch="UniformToFill" IsVisible="{Binding Artwork.Image, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                                        <TextBlock Text="🎵" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.3" IsVisible="{Binding Artwork.Image, Converter={x:Static ObjectConverters.IsNull}}"/>
                                        
                                        <!-- Status Overlay -->
                                        <Border VerticalAlignment="Bottom" HorizontalAlignment="Right" Width="8" Height="8" Margin="0,0,2,2" CornerRadius="4" 
                                                Background="{Binding State, Converter={StaticResource TrackStateToColorConverter}}"
                                                BorderBrush="#1E1E1E" BorderThickness="1"/>
                                    </Panel>
                                </Border>
                            </Panel>

                            <!-- Column 1: Q Button -->
                            <Button Grid.Column="1"
                                    Command="{Binding $parent[UserControl].DataContext.Operations.AddToQueueCommand}"
                                    CommandParameter="{Binding}"
                                    Width="22"
                                    Height="22"
                                    Padding="0"
                                    Margin="8,0,0,0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Opacity="0.55"
                                    ToolTip.Tip="Queue track (or selected tracks)">
                                <TextBlock Text="＋" FontSize="11" Foreground="#6F8192" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Button>

                            <!-- Column 2: INSERT Button -->
                            <Button Grid.Column="2"
                                    Command="{Binding $parent[views:LibraryPage].DataContext.PrepareSmartInsertAfterTrackCommand}"
                                    CommandParameter="{Binding}"
                                    Classes="insert-affordance"
                                    Padding="8,4"
                                    Margin="2,0,0,0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Background="#143A4A"
                                    BorderBrush="#2D7D93"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    ToolTip.Tip="Add track that fits between this row and the next row">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="+" FontSize="11" FontWeight="SemiBold" Foreground="#9ED9C8"/>
                                    <TextBlock Text="Add here" FontSize="10" Foreground="#9ED9C8"/>
                                </StackPanel>
                            </Button>

                            <!-- Column 3: Artist -->
                            <TextBlock Grid.Column="3" Text="{Binding Artist}" VerticalAlignment="Center" Margin="12,0" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" TextTrimming="CharacterEllipsis"/>

                            <!-- Column 4: Title -->
                            <TextBlock Grid.Column="4" Text="{Binding Title}" VerticalAlignment="Center" Margin="12,0" Foreground="White" FontWeight="SemiBold" FontSize="12" TextTrimming="CharacterEllipsis"/>

                            <!-- Column 5: Energy Sparkline -->
                            <controls:SparklineControl Grid.Column="5"
                                Points="{Binding EnergyCurvePoints}"
                                LineBrush="#4EC9B0"
                                FillBrush="#224EC9B0"
                                LineThickness="1.2"
                                Height="22"
                                Margin="8,0"
                                VerticalAlignment="Center"
                                IsVisible="{Binding HasAnalysisData}"
                                ToolTip.Tip="Energy contour — analysed audio"/>

                            <!-- Column 6: BPM / Key (harmonic mixing) -->
                            <StackPanel Grid.Column="6" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" Margin="8,0" IsVisible="{Binding HasBpm}">
                                <TextBlock Text="{Binding BpmDisplay}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Width="26" TextAlignment="Right" VerticalAlignment="Center"/>
                                <Border Classes="key-badge"
                                        Classes.harmonic-match="{Binding IsHarmonicMatch}"
                                        Classes.exact-match="{Binding IsExactKeyMatch}"
                                        Background="{Binding ColorBrush}"
                                        CornerRadius="4"
                                        Padding="5,2"
                                        MinWidth="30"
                                        VerticalAlignment="Center"
                                        ToolTip.Tip="{Binding KeyDisplay}">
                                    <TextBlock Text="{Binding CamelotDisplay}" Foreground="White" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center"/>
                                </Border>
                            </StackPanel>

                            <!-- Column 7: Format -->
                            <Border Grid.Column="7" Background="#1A1F2C" BorderBrush="#3300BFFF" BorderThickness="1" CornerRadius="4" Padding="6,2" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="12,0"
                                    IsVisible="{Binding $parent[UserControl].DataContext.IsFormatColumnVisible}">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="{Binding Format}" FontSize="9" FontWeight="Bold" Foreground="#00BFFF" Opacity="0.8"/>
                                    <TextBlock Text="{Binding Bitrate, StringFormat='{}{0}k'}" FontSize="9" Foreground="#00BFFF"/>
                                </StackPanel>
                            </Border>

                            <!-- Column 8: Forensics -->
                            <Border Grid.Column="8" Background="{Binding IntegrityColor}"
                                    CornerRadius="10"
                                    Padding="8,3"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Margin="12,0"
                                    IsVisible="{Binding $parent[UserControl].DataContext.IsForensicsColumnVisible}"
                                    ToolTip.Tip="{Binding ForensicHudText}">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="{Binding IntegrityBadge}" FontSize="10"/>
                                    <TextBlock Text="{Binding ForensicVerdictText}"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Foreground="Black"/>
                                </StackPanel>
                            </Border>

                            <!-- Column 9: Duration -->
                            <TextBlock Grid.Column="9" Text="{Binding DurationDisplay}" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="12,0" Opacity="0.5"
                                       IsVisible="{Binding $parent[UserControl].DataContext.IsDurationColumnVisible}"/>

                            <!-- Column 10: Rating -->
                            <StackPanel Grid.Column="10" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center" Margin="12,0">
                                <controls:StarRatingControl Rating="{Binding Rating, Mode=TwoWay}" StarSize="11"/>
                                <ToggleButton IsChecked="{Binding IsLiked, Mode=TwoWay}"
                                              Background="Transparent" BorderThickness="0" Padding="0"
                                              Cursor="Hand" ToolTip.Tip="Like">
                                    <Panel>
                                        <TextBlock Text="🤍" FontSize="11" Opacity="0.5" IsVisible="{Binding !IsLiked}"/>
                                        <TextBlock Text="❤️" FontSize="11" IsVisible="{Binding IsLiked}"/>
                                    </Panel>
                                </ToggleButton>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </controls:VirtualGrid.ItemTemplate>
        </controls:VirtualGrid>

        <!-- Empty state — shown when the selected playlist has no tracks -->
        <StackPanel Grid.Row="5"
                    IsVisible="{Binding IsLibraryEmpty}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="12">
            <TextBlock Text="📚" FontSize="40" HorizontalAlignment="Center" Opacity="0.25"/>
            <TextBlock Text="No tracks here yet"
                       FontSize="15"
                       FontWeight="SemiBold"
                       Foreground="#555"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Search and download tracks, or import a folder from Settings → Library Sources."
                       FontSize="12"
                       Foreground="#444"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       MaxWidth="280"
                       TextWrapping="Wrap"/>
        </StackPanel>
    </Grid>
</UserControl>